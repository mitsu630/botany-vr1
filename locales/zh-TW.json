    "tabbed_faq": {
      "qa": {
        "workshop": {
          "title": "ワークショップ",
          "items": {
            "item_1": {
              "question": "初めてでも参加できますか？",
              "answer": "はい、初めての方でもご参加いただけます。ボタニーペインティングは、天然の蓮の葉や植物の葉を木製パネルに貼り、色を重ねて作品を仕上げていくアートです。絵を描くのが苦手な方や、普段あまり制作をされない方でも、講師が手順に沿ってサポートいたしますのでご安心ください。"
            },
            "item_2": {
              "question": "絵が苦手ですが大丈夫ですか？",
              "answer": "はい、大丈夫です。ボタニーペインティングは、下絵を描いたり、難しいデッサンをしたりする必要はありません。天然の葉の形や葉脈そのものが作品の表情になりますので、絵の経験がない方でも楽しんでいただけます。"
            },
            "item_3": {
              "question": "どのような作品を作りますか？",
              "answer": "木製パネルに蓮の葉や植物の葉を貼り、アクリル絵の具などで着色して作品を制作します。会場や講師によって制作するサイズや内容が異なる場合がありますので、各ワークショップページの内容をご確認ください。"
            },
            "item_4": {
              "question": "作品は当日持ち帰れますか？",
              "answer": "はい、当日お持ち帰りいただけます。制作後、乾燥や仕上がりの状態を確認したうえでお持ち帰りいただきます。"
            },
            "item_5": {
              "question": "所要時間はどのくらいですか？",
              "answer": "ワークショップの内容にもよりますが、目安は約3時間程度です。制作スピードや作品内容によって前後する場合がありますので、お時間には余裕をもってご参加ください。"
            },
            "item_6": {
              "question": "持ち物はありますか？",
              "answer": "基本的な画材や制作に必要な材料はご用意しております。汚れが気になる方は、エプロンをご持参いただくと安心です。"
            },
            "item_7": {
              "question": "服装に決まりはありますか？",
              "answer": "特に決まりはありませんが、絵の具や接着剤を使用するため、汚れてもよい服装でのご参加をおすすめいたします。気になる方はエプロンをご持参ください。"
            },
            "item_8": {
              "question": "子どもも参加できますか？",
              "answer": "ワークショップによって参加可能年齢が異なります。小学生以上を対象としている場合や、保護者同伴で参加できる場合など、会場・講師・内容により条件が異なります。お子さまの参加をご希望の場合は、事前にお問い合わせください。"
            },
            "item_9": {
              "question": "親子で参加できますか？",
              "answer": "はい、親子でご参加いただけるワークショップもございます。ただし、制作内容や会場の席数により参加条件が異なる場合がありますので、お申込み前にご確認ください。"
            },
            "item_10": {
              "question": "友人と一緒に参加できますか？",
              "answer": "はい、ご友人同士でのご参加も歓迎しております。同じ日程・会場で参加を希望される場合は、それぞれお申込みをお願いいたします。席数に限りがあるため、お早めのお申込みをおすすめいたします。"
            },
            "item_11": {
              "question": "1人で参加しても大丈夫ですか？",
              "answer": "はい、大丈夫です。ほとんどの方がお一人で参加されています。制作中はご自身のペースで集中して取り組んでいただけますので、初めての方やお一人でのご参加も安心してお越しください。"
            },
            "item_12": {
              "question": "色は自由に選べますか？",
              "answer": "はい、基本的にはお好きな色を選んで制作していただけます。色の組み合わせに迷った場合は、講師が作品の雰囲気に合わせてアドバイスいたします。"
            },
            "item_13": {
              "question": "不器用でも完成できますか？",
              "answer": "はい、完成を目指して講師がサポートいたします。制作の途中で迷ったり不安になったりした場合も、講師が工程ごとにお声がけいたしますのでご安心ください。"
            },
