{{ 'video-section.css' | asset_url | stylesheet_tag }}
<script src="{{ 'autoplay-loop-video.js' | asset_url }}" defer="defer"></script>

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  autoplay-loop-video {
    display: block;
    width: 100%;
  }
{%- endstyle -%}

{%- liquid
  assign video_id = section.settings.video.id | default: section.settings.video_url.id
  assign poster = section.settings.video.preview_image | default: section.settings.cover_image | default: section.settings.video_url.preview_image

  if poster != null
    assign ratio_percent = 1 | divided_by: poster.aspect_ratio | times: 100
  elsif section.settings.video != null
    assign ratio_percent = 1 | divided_by: section.settings.video.aspect_ratio | times: 100
  else
    assign ratio_percent = 56.25
  endif

  if section.settings.video != null and poster != null
    assign ratio_diff = section.settings.video.aspect_ratio | minus: poster.aspect_ratio | abs
    if ratio_diff < 0.01 and ratio_diff > 0
      assign fix_ratio = true
    endif
  endif
-%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="video-section isolate{% unless section.settings.full_width %} page-width{% endunless %} section-{{ section.id }}-padding">
    <div
      {% if section.settings.full_width %}
        class="page-width"
      {% endif %}
    >
      {%- unless section.settings.heading == blank -%}
        <div class="title-wrapper title-wrapper--no-top-margin{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
          <h2 class="title inline-richtext {{ section.settings.heading_size }}">{{ section.settings.heading }}</h2>
        </div>
      {%- endunless -%}
    </div>

    {%- if video_id != blank -%}
      <autoplay-loop-video data-threshold="0.12">
        <div
          class="video-section__media gradient global-media-settings{% if section.settings.full_width %} global-media-settings--full-width{% endif %}{% if fix_ratio %} media-fit-cover{% endif %}"
          style="--ratio-percent: {{ ratio_percent }}%;"
        >
          {%- if section.settings.video == null and section.settings.video_url != null -%}
            {%- liquid
              assign loop_yt = '&loop=1&playlist=' | append: video_id
            -%}
            {%- if section.settings.video_url.type == 'youtube' -%}
              <iframe
                class="js-youtube"
                data-src="https://www.youtube.com/embed/{{ video_id }}?enablejsapi=1&autoplay=1&mute=1&playsinline=1{{ loop_yt }}"
                allow="autoplay; encrypted-media; fullscreen"
                allowfullscreen
                title="{{ section.settings.description | escape }}"
                style="border: 0"
              ></iframe>
            {%- else -%}
              <iframe
                class="js-vimeo"
                data-src="https://player.vimeo.com/video/{{ video_id }}?autoplay=1&muted=1&loop=1&playsinline=1"
                allow="autoplay; encrypted-media; fullscreen"
                allowfullscreen
                title="{{ section.settings.description | escape }}"
                style="border: 0"
              ></iframe>
            {%- endif -%}
          {%- else -%}
            {{
              section.settings.video
              | video_tag:
                image_size: '1920x',
                autoplay: false,
                loop: true,
                muted: true,
                controls: section.settings.show_controls,
                playsinline: true
            }}
          {%- endif -%}
        </div>
      </autoplay-loop-video>
    {%- else -%}
      <div
        class="video-section__media gradient global-media-settings{% if section.settings.full_width %} global-media-settings--full-width{% endif %}"
        style="--ratio-percent: 56.25%;"
      >
        {{ 'hero-apparel-3' | placeholder_svg_tag: 'placeholder-svg placeholder' }}
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "t:sections.autoplay-loop-video.name",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "paragraph",
      "content": "t:sections.autoplay-loop-video.settings.paragraph_info.content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "t:sections.autoplay-loop-video.settings.heading.label",
      "default": "t:sections.autoplay-loop-video.settings.heading.default"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__1.label"
        },
        {
          "value": "h1",
          "label": "t:sections.all.heading_size.options__2.label"
        },
        {
          "value": "h0",
          "label": "t:sections.all.heading_size.options__3.label"
        },
        {
          "value": "hxl",
          "label": "t:sections.all.heading_size.options__4.label"
        },
        {
          "value": "hxxl",
          "label": "t:sections.all.heading_size.options__5.label"
        }
      ],
      "default": "h1",
      "label": "t:sections.all.heading_size.label"
    },
    {
      "type": "header",
      "content": "t:sections.autoplay-loop-video.settings.header_video.content"
    },
    {
      "type": "video",
      "id": "video",
      "label": "t:sections.autoplay-loop-video.settings.video.label"
    },
    {
      "type": "paragraph",
      "content": "t:sections.autoplay-loop-video.settings.paragraph_url.content"
    },
    {
      "type": "video_url",
      "id": "video_url",
      "accept": ["youtube", "vimeo"],
      "label": "t:sections.autoplay-loop-video.settings.video_url.label",
      "info": "t:sections.autoplay-loop-video.settings.video_url.info"
    },
    {
      "type": "image_picker",
      "id": "cover_image",
      "label": "t:sections.autoplay-loop-video.settings.cover_image.label",
      "info": "t:sections.autoplay-loop-video.settings.cover_image.info"
    },
    {
      "type": "checkbox",
      "id": "show_controls",
      "label": "t:sections.autoplay-loop-video.settings.show_controls.label",
      "info": "t:sections.autoplay-loop-video.settings.show_controls.info",
      "default": false
    },
    {
      "type": "text",
      "id": "description",
      "label": "t:sections.autoplay-loop-video.settings.description.label",
      "info": "t:sections.autoplay-loop-video.settings.description.info"
    },
    {
      "type": "header",
      "content": "t:sections.autoplay-loop-video.settings.header_layout.content"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "t:sections.autoplay-loop-video.settings.full_width.label",
      "default": false
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "t:sections.autoplay-loop-video.presets.name"
    }
  ]
}
{% endschema %}
