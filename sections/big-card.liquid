{%- style -%}
  {%- for block in section.blocks -%}
    {%- if block.settings.font != blank -%}
      {{ block.settings.font | font_face: font_display: 'swap' }}
    {%- endif -%}
  {%- endfor -%}

  #shopify-section-{{ section.id }} {
    --big-card-background: {{ section.settings.background_color }};
    --big-card-text-color: {{ section.settings.text_color }};
    --big-card-max-width: {{ section.settings.max_width }}px;
    --big-card-radius: {{ section.settings.border_radius }}px;
    --big-card-block-gap: {{ section.settings.block_gap }}px;
    --big-card-padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --big-card-padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
    --big-card-padding-top-desktop: {{ section.settings.padding_top_desktop }}px;
    --big-card-padding-bottom-desktop: {{ section.settings.padding_bottom_desktop }}px;
  }

  #shopify-section-{{ section.id }} .big-card {
    background: var(--big-card-background);
    color: var(--big-card-text-color);
    padding-top: var(--big-card-padding-top-mobile);
    padding-bottom: var(--big-card-padding-bottom-mobile);
  }

  #shopify-section-{{ section.id }} .big-card__inner {
    width: min(100% - 32px, var(--big-card-max-width));
    margin-right: auto;
    margin-left: auto;
  }

  #shopify-section-{{ section.id }} .big-card__blocks {
    display: flex;
    flex-direction: column;
    gap: var(--big-card-block-gap);
  }

  #shopify-section-{{ section.id }} .big-card__block {
    margin-top: var(--big-card-block-margin-top);
    margin-bottom: var(--big-card-block-margin-bottom);
    padding-top: var(--big-card-block-padding-top);
    padding-bottom: var(--big-card-block-padding-bottom);
  }

  #shopify-section-{{ section.id }} .big-card__title,
  #shopify-section-{{ section.id }} .big-card__text,
  #shopify-section-{{ section.id }} .big-card__text-column,
  #shopify-section-{{ section.id }} .big-card__text-cell {
    color: var(--big-card-block-color);
    font-family: var(--big-card-block-font-family, inherit);
    font-size: var(--big-card-block-font-size);
    font-style: var(--big-card-block-font-style, inherit);
    font-weight: var(--big-card-block-font-weight, inherit);
    line-height: 1.7;
    text-align: var(--big-card-block-text-align, inherit);
  }

  #shopify-section-{{ section.id }} .big-card__title {
    line-height: 1.25;
  }

  #shopify-section-{{ section.id }} .big-card__title *,
  #shopify-section-{{ section.id }} .big-card__text *,
  #shopify-section-{{ section.id }} .big-card__text-column *,
  #shopify-section-{{ section.id }} .big-card__text-cell * {
    font-family: inherit;
  }

  #shopify-section-{{ section.id }} .big-card__title > *:first-child,
  #shopify-section-{{ section.id }} .big-card__text > *:first-child,
  #shopify-section-{{ section.id }} .big-card__text-column > *:first-child,
  #shopify-section-{{ section.id }} .big-card__text-cell > *:first-child {
    margin-top: 0;
  }

  #shopify-section-{{ section.id }} .big-card__title > *:last-child,
  #shopify-section-{{ section.id }} .big-card__text > *:last-child,
  #shopify-section-{{ section.id }} .big-card__text-column > *:last-child,
  #shopify-section-{{ section.id }} .big-card__text-cell > *:last-child {
    margin-bottom: 0;
  }

  #shopify-section-{{ section.id }} .big-card__media,
  #shopify-section-{{ section.id }} .big-card__image,
  #shopify-section-{{ section.id }} .big-card__video,
  #shopify-section-{{ section.id }} .big-card__placeholder {
    overflow: hidden;
    border-radius: var(--big-card-radius);
  }

  #shopify-section-{{ section.id }} .big-card__image,
  #shopify-section-{{ section.id }} .big-card__video,
  #shopify-section-{{ section.id }} .big-card__placeholder {
    background: rgba(0, 0, 0, 0.04);
  }

  #shopify-section-{{ section.id }} .big-card__image {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #shopify-section-{{ section.id }} .big-card__image--boxed {
    width: min(100%, var(--big-card-image-box-width));
    height: var(--big-card-image-box-height);
  }

  #shopify-section-{{ section.id }} .big-card__media--content .big-card__image--boxed,
  #shopify-section-{{ section.id }} .big-card__media--full .big-card__image--boxed {
    width: 100%;
  }

  #shopify-section-{{ section.id }} .big-card__media--full {
    width: 100vw;
    margin-right: calc(50% - 50vw);
    margin-left: calc(50% - 50vw);
  }

  #shopify-section-{{ section.id }} .big-card__image--crop {
    width: 100%;
    height: auto;
    aspect-ratio: var(--big-card-media-ratio);
  }

  #shopify-section-{{ section.id }} .big-card__image--left {
    margin-right: auto;
    margin-left: 0;
  }

  #shopify-section-{{ section.id }} .big-card__image--center {
    margin-right: auto;
    margin-left: auto;
  }

  #shopify-section-{{ section.id }} .big-card__image--right {
    margin-right: 0;
    margin-left: auto;
  }

  #shopify-section-{{ section.id }} .big-card__image img,
  #shopify-section-{{ section.id }} .big-card__placeholder svg {
    display: block;
    width: auto;
    height: auto;
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  #shopify-section-{{ section.id }} .big-card__image--cover img,
  #shopify-section-{{ section.id }} .big-card__image--cover .big-card__placeholder svg,
  #shopify-section-{{ section.id }} .big-card__image--crop img,
  #shopify-section-{{ section.id }} .big-card__image--crop .big-card__placeholder svg {
    width: 100%;
    height: 100%;
    max-width: none;
    max-height: none;
    object-fit: cover;
  }

  #shopify-section-{{ section.id }} .big-card__placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
  }

  #shopify-section-{{ section.id }} .big-card__video .big-card__placeholder {
    height: auto;
    aspect-ratio: 16 / 9;
  }

  #shopify-section-{{ section.id }} .big-card__video .big-card__placeholder svg {
    width: 100%;
    height: 100%;
  }

  #shopify-section-{{ section.id }} .big-card__image .big-card__placeholder svg {
    width: 100%;
    height: 100%;
  }

  #shopify-section-{{ section.id }} .big-card__video video,
  #shopify-section-{{ section.id }} .big-card__video iframe {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    height: auto;
    border: 0;
  }

  #shopify-section-{{ section.id }} .big-card__video--contained {
    max-width: 880px;
    margin-right: auto;
    margin-left: auto;
  }

  #shopify-section-{{ section.id }} .big-card__image-grid,
  #shopify-section-{{ section.id }} .big-card__text-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--big-card-grid-gap);
  }

  #shopify-section-{{ section.id }} .big-card__button-wrap {
    text-align: var(--big-card-button-align);
  }

  #shopify-section-{{ section.id }} .big-card__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 12px 24px;
    border: 1px solid var(--big-card-button-background);
    border-radius: var(--big-card-radius);
    font: inherit;
    line-height: 1.3;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  #shopify-section-{{ section.id }} .big-card__button:hover {
    opacity: 0.82;
  }

  #shopify-section-{{ section.id }} .big-card__button--primary {
    background: var(--big-card-button-background);
    color: var(--big-card-button-color);
  }

  #shopify-section-{{ section.id }} .big-card__button--secondary {
    background: transparent;
    color: var(--big-card-button-background);
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .big-card {
      padding-top: var(--big-card-padding-top-desktop);
      padding-bottom: var(--big-card-padding-bottom-desktop);
    }

    #shopify-section-{{ section.id }} .big-card__inner {
      width: min(100% - 64px, var(--big-card-max-width));
    }

    #shopify-section-{{ section.id }} .big-card__image-grid--two,
    #shopify-section-{{ section.id }} .big-card__text-grid--two,
    #shopify-section-{{ section.id }} .big-card__image-grid--four,
    #shopify-section-{{ section.id }} .big-card__text-grid--four {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
{%- endstyle -%}

<section class="big-card" {{ section.shopify_attributes }}>
  <div class="big-card__inner">
    <div class="big-card__blocks">
      {%- for block in section.blocks -%}
        {%- liquid
          assign block_color = block.settings.color | default: section.settings.text_color
          assign block_font_size = block.settings.font_size | default: 16
          assign block_padding_top = block.settings.padding_top | default: 0
          assign block_padding_bottom = block.settings.padding_bottom | default: 0
          assign block_margin_top = block.settings.margin_top | default: 0
          assign block_margin_bottom = block.settings.margin_bottom | default: 0
          assign block_text_align = block.settings.text_align | default: 'left'
          assign media_ratio = block.settings.aspect_ratio | default: '16 / 9'
          assign grid_gap = block.settings.grid_gap | default: 16
          assign image_box_width = block.settings.image_box_width | default: 1200
          assign image_box_height = block.settings.image_box_height | default: 720
          assign image_align = block.settings.image_align | default: 'center'
          assign image_fit = block.settings.image_fit | default: 'cover'
          assign image_width_mode = block.settings.image_width_mode | default: 'box'
        -%}

        <div
          class="big-card__block big-card__block--{{ block.type }}"
          style="
            --big-card-block-color: {{ block_color }};
            --big-card-block-font-size: {{ block_font_size }}px;
            --big-card-block-padding-top: {{ block_padding_top }}px;
            --big-card-block-padding-bottom: {{ block_padding_bottom }}px;
            --big-card-block-margin-top: {{ block_margin_top }}px;
            --big-card-block-margin-bottom: {{ block_margin_bottom }}px;
            --big-card-block-text-align: {{ block_text_align }};
            {%- if block.settings.font != blank -%}
              --big-card-block-font-family: {{ block.settings.font.family }}, {{ block.settings.font.fallback_families }};
              --big-card-block-font-style: {{ block.settings.font.style }};
              --big-card-block-font-weight: {{ block.settings.font.weight }};
            {%- endif -%}
            --big-card-media-ratio: {{ media_ratio }};
            --big-card-grid-gap: {{ grid_gap }}px;
            --big-card-image-box-width: {{ image_box_width }}px;
            --big-card-image-box-height: {{ image_box_height }}px;
          "
          {{ block.shopify_attributes }}
        >
          {%- case block.type -%}
            {%- when 'title' -%}
              {%- if block.settings.title != blank -%}
                <div class="big-card__title rte">
                  {{ block.settings.title }}
                </div>
              {%- endif -%}

            {%- when 'text' -%}
              {%- if block.settings.text != blank -%}
                <div class="big-card__text rte">
                  {{ block.settings.text }}
                </div>
              {%- endif -%}

            {%- when 'video' -%}
              <div class="big-card__media">
                <div class="big-card__video">
                  {%- if block.settings.video != blank -%}
                    {{ block.settings.video | video_tag: controls: true, image_size: '1600x' }}
                  {%- elsif block.settings.video_url != blank -%}
                    {{ block.settings.video_url | external_video_tag }}
                  {%- elsif request.design_mode -%}
                    <div class="big-card__placeholder">
                      {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                    </div>
                  {%- endif -%}
                </div>
              </div>

            {%- when 'image' -%}
              <div class="big-card__media big-card__media--{{ image_width_mode }}">
                <div class="big-card__image big-card__image--boxed big-card__image--{{ image_fit }} big-card__image--{{ image_align }}">
                  {%- if block.settings.image != blank -%}
                    {{
                      block.settings.image
                      | image_url: width: 2000
                      | image_tag:
                        loading: 'lazy',
                        widths: '360, 540, 720, 900, 1200, 1600, 2000',
                        sizes: '(min-width: 750px) 100vw, 100vw'
                    }}
                  {%- elsif request.design_mode -%}
                    <div class="big-card__placeholder">
                      {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                    </div>
                  {%- endif -%}
                </div>
              </div>

            {%- when 'images_2' -%}
              <div class="big-card__image-grid big-card__image-grid--two">
                <div class="big-card__image big-card__image--crop">
                  {%- if block.settings.image_1 != blank -%}
                    {{
                      block.settings.image_1
                      | image_url: width: 1200
                      | image_tag:
                        loading: 'lazy',
                        widths: '360, 540, 720, 900, 1200',
                        sizes: '(min-width: 750px) 50vw, 100vw'
                    }}
                  {%- elsif request.design_mode -%}
                    <div class="big-card__placeholder">
                      {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                    </div>
                  {%- endif -%}
                </div>

                <div class="big-card__image big-card__image--crop">
                  {%- if block.settings.image_2 != blank -%}
                    {{
                      block.settings.image_2
                      | image_url: width: 1200
                      | image_tag:
                        loading: 'lazy',
                        widths: '360, 540, 720, 900, 1200',
                        sizes: '(min-width: 750px) 50vw, 100vw'
                    }}
                  {%- elsif request.design_mode -%}
                    <div class="big-card__placeholder">
                      {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                    </div>
                  {%- endif -%}
                </div>
              </div>

            {%- when 'images_4' -%}
              <div class="big-card__image-grid big-card__image-grid--four">
                <div class="big-card__image big-card__image--crop">
                  {%- if block.settings.image_1 != blank -%}
                    {{
                      block.settings.image_1
                      | image_url: width: 1000
                      | image_tag:
                        loading: 'lazy',
                        widths: '360, 540, 720, 900, 1000',
                        sizes: '(min-width: 750px) 50vw, 100vw'
                    }}
                  {%- elsif request.design_mode -%}
                    <div class="big-card__placeholder">
                      {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                    </div>
                  {%- endif -%}
                </div>

                <div class="big-card__image big-card__image--crop">
                  {%- if block.settings.image_2 != blank -%}
                    {{
                      block.settings.image_2
                      | image_url: width: 1000
                      | image_tag:
                        loading: 'lazy',
                        widths: '360, 540, 720, 900, 1000',
                        sizes: '(min-width: 750px) 50vw, 100vw'
                    }}
                  {%- elsif request.design_mode -%}
                    <div class="big-card__placeholder">
                      {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                    </div>
                  {%- endif -%}
                </div>

                <div class="big-card__image big-card__image--crop">
                  {%- if block.settings.image_3 != blank -%}
                    {{
                      block.settings.image_3
                      | image_url: width: 1000
                      | image_tag:
                        loading: 'lazy',
                        widths: '360, 540, 720, 900, 1000',
                        sizes: '(min-width: 750px) 50vw, 100vw'
                    }}
                  {%- elsif request.design_mode -%}
                    <div class="big-card__placeholder">
                      {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                    </div>
                  {%- endif -%}
                </div>

                <div class="big-card__image big-card__image--crop">
                  {%- if block.settings.image_4 != blank -%}
                    {{
                      block.settings.image_4
                      | image_url: width: 1000
                      | image_tag:
                        loading: 'lazy',
                        widths: '360, 540, 720, 900, 1000',
                        sizes: '(min-width: 750px) 50vw, 100vw'
                    }}
                  {%- elsif request.design_mode -%}
                    <div class="big-card__placeholder">
                      {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                    </div>
                  {%- endif -%}
                </div>
              </div>

            {%- when 'text_2' -%}
              <div class="big-card__text-grid big-card__text-grid--two">
                {%- if block.settings.left_text != blank -%}
                  <div class="big-card__text-column rte">
                    {{ block.settings.left_text }}
                  </div>
                {%- endif -%}

                {%- if block.settings.right_text != blank -%}
                  <div class="big-card__text-column rte">
                    {{ block.settings.right_text }}
                  </div>
                {%- endif -%}
              </div>

            {%- when 'text_4' -%}
              <div class="big-card__text-grid big-card__text-grid--four">
                {%- if block.settings.text_1 != blank -%}
                  <div class="big-card__text-cell rte">
                    {{ block.settings.text_1 }}
                  </div>
                {%- endif -%}

                {%- if block.settings.text_2 != blank -%}
                  <div class="big-card__text-cell rte">
                    {{ block.settings.text_2 }}
                  </div>
                {%- endif -%}

                {%- if block.settings.text_3 != blank -%}
                  <div class="big-card__text-cell rte">
                    {{ block.settings.text_3 }}
                  </div>
                {%- endif -%}

                {%- if block.settings.text_4 != blank -%}
                  <div class="big-card__text-cell rte">
                    {{ block.settings.text_4 }}
                  </div>
                {%- endif -%}
              </div>

            {%- when 'single_video' -%}
              <div class="big-card__media">
                <div class="big-card__video big-card__video--{{ block.settings.video_width }}">
                  {%- if block.settings.video != blank -%}
                    {{ block.settings.video | video_tag: controls: true, image_size: '1600x' }}
                  {%- elsif block.settings.video_url != blank -%}
                    {{ block.settings.video_url | external_video_tag }}
                  {%- elsif request.design_mode -%}
                    <div class="big-card__placeholder">
                      {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                    </div>
                  {%- endif -%}
                </div>
              </div>

            {%- when 'button' -%}
              {%- if block.settings.label != blank -%}
                <div
                  class="big-card__button-wrap"
                  style="
                    --big-card-button-align: {{ block.settings.align }};
                    --big-card-button-background: {{ block.settings.button_background }};
                    --big-card-button-color: {{ block.settings.button_color }};
                  "
                >
                  <a
                    class="big-card__button big-card__button--{{ block.settings.style }}"
                    {% if block.settings.link != blank %}
                      href="{{ block.settings.link }}"
                    {% else %}
                      role="link"
                      aria-disabled="true"
                    {% endif %}
                  >
                    {{ block.settings.label | escape }}
                  </a>
                </div>
              {%- endif -%}
          {%- endcase -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "ビックカード",
  "tag": "section",
  "class": "section big-card-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "全体の背景色",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "全体の文字色",
      "default": "#111111"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "コンテンツの最大幅",
      "min": 720,
      "max": 1600,
      "step": 20,
      "unit": "px",
      "default": 1200
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "角丸",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "block_gap",
      "label": "ブロック間の余白",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "header",
      "content": "セクション余白 Desktop"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "上余白 Desktop",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "下余白 Desktop",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "header",
      "content": "セクション余白 Mobile"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "上余白 Mobile",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "下余白 Mobile",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "title",
      "name": "タイトル",
      "settings": [
        {
          "type": "richtext",
          "id": "title",
          "label": "タイトル",
          "default": "<p>タイトルを入力してください</p>"
        },
        {
          "type": "font_picker",
          "id": "font",
          "label": "フォント",
          "default": "assistant_n4"
        },
        {
          "type": "range",
          "id": "font_size",
          "label": "フォントサイズ",
          "min": 18,
          "max": 72,
          "step": 1,
          "unit": "px",
          "default": 40
        },
        {
          "type": "color",
          "id": "color",
          "label": "フォントカラー",
          "default": "#111111"
        },
        {
          "type": "select",
          "id": "text_align",
          "label": "文字位置",
          "options": [
            {
              "value": "left",
              "label": "左"
            },
            {
              "value": "center",
              "label": "中央"
            },
            {
              "value": "right",
              "label": "右"
            }
          ],
          "default": "left"
        },
        {
          "type": "range",
          "id": "padding_top",
          "label": "上パディング",
          "min": 0,
          "max": 80,
          "step": 4,
          "unit": "px",
          "default": 0
        },
        {
          "type": "range",
