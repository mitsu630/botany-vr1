{{ 'section-custom-standalone-image.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign img = section.settings.image
  assign img_link = section.settings.image_link
  assign full_bleed = section.settings.full_viewport_width

  assign alt_override = section.settings.image_alt | strip
  assign alt_text = alt_override
  if alt_text == blank and img != blank
    assign alt_text = img.alt | default: shop.name
  elsif alt_text == blank
    assign alt_text = shop.name
  endif

  assign mt = section.settings.margin_top | default: 0
  assign mr = section.settings.margin_right | default: 0
  assign mb = section.settings.margin_bottom | default: 0
  assign ml = section.settings.margin_left | default: 0

  assign pt = section.settings.padding_top | default: 0
  assign pr = section.settings.padding_right | default: 0
  assign pb = section.settings.padding_bottom | default: 0
  assign pl = section.settings.padding_left | default: 0

  assign pad_style = 'padding-top: ' | append: pt | append: 'px; padding-right: ' | append: pr | append: 'px; padding-bottom: ' | append: pb | append: 'px; padding-left: ' | append: pl | append: 'px;'

  assign sizes_bleed = '100vw'
  assign sizes_contained = '(min-width: ' | append: settings.page_width | append: 'px) min(' | append: settings.page_width | append: 'px, 100vw), calc(100vw - 3rem)'

  assign loading_mode = 'lazy'
  if section.index == 1
    assign loading_mode = 'eager'
  endif

  assign fetch_priority = 'auto'
  if section.index == 1
    assign fetch_priority = 'high'
  endif
-%}

<div
  id="CustomStandaloneImage-{{ section.id }}"
  class="custom-standalone-image isolate color-{{ section.settings.color_scheme }} gradient{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}"
  style="margin-top: {{ mt }}px; margin-right: {{ mr }}px; margin-bottom: {{ mb }}px; margin-left: {{ ml }}px;"
>
  {%- if img != blank -%}
    {%- liquid
      assign img_height = img.width | divided_by: img.aspect_ratio | round
      assign img_sizes = sizes_contained
      if full_bleed
        assign img_sizes = sizes_bleed
      endif
    -%}
    {%- capture img_core -%}
      {{
        img
        | image_url: width: 3840
        | image_tag:
          width: img.width,
          height: img_height,
          alt: alt_text,
          sizes: img_sizes,
          widths: '165, 360, 535, 750, 940, 1100, 1500, 1780, 2000, 3000, 3840',
          fetchpriority: fetch_priority,
          loading: loading_mode
      }}
    {%- endcapture -%}

    {%- if full_bleed -%}
      <div class="custom-standalone-image__media custom-standalone-image__media--bleed" style="{{ pad_style }}">
        {%- if img_link != blank -%}
          <a
            class="custom-standalone-image__link"
            href="{{ img_link }}"
            {% if section.settings.link_new_tab %}
              target="_blank" rel="noopener noreferrer"
            {% endif %}
          >
            {{ img_core }}
          </a>
        {%- else -%}
          {{ img_core }}
        {%- endif -%}
      </div>
    {%- else -%}
      <div class="page-width">
        <div class="custom-standalone-image__media" style="{{ pad_style }}">
          {%- if img_link != blank -%}
            <a
              class="custom-standalone-image__link"
              href="{{ img_link }}"
              {% if section.settings.link_new_tab %}
                target="_blank" rel="noopener noreferrer"
              {% endif %}
            >
              {{ img_core }}
            </a>
          {%- else -%}
            {{ img_core }}
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}
  {%- else -%}
    {%- if full_bleed -%}
      <div class="custom-standalone-image__media custom-standalone-image__media--bleed placeholder" style="{{ pad_style }}">
        {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
      </div>
    {%- else -%}
      <div class="page-width">
        <div class="custom-standalone-image__media placeholder" style="{{ pad_style }}">
          {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
        </div>
      </div>
    {%- endif -%}
  {%- endif -%}
</div>

{% schema %}
{
  "name": "t:sections.custom-standalone-image.name",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.custom-standalone-image.settings.image.label"
    },
    {
      "type": "url",
      "id": "image_link",
      "label": "t:sections.custom-standalone-image.settings.image_link.label"
    },
    {
      "type": "checkbox",
      "id": "link_new_tab",
      "label": "t:sections.custom-standalone-image.settings.link_new_tab.label",
      "default": false
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "t:sections.custom-standalone-image.settings.image_alt.label",
      "info": "t:sections.custom-standalone-image.settings.image_alt.info"
    },
    {
      "type": "checkbox",
      "id": "full_viewport_width",
      "label": "t:sections.custom-standalone-image.settings.full_viewport_width.label",
      "info": "t:sections.custom-standalone-image.settings.full_viewport_width.info",
      "default": false
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.custom-standalone-image.settings.header_margin.content"
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "t:sections.custom-standalone-image.settings.margin_top.label",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_right",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "t:sections.custom-standalone-image.settings.margin_right.label",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "t:sections.custom-standalone-image.settings.margin_bottom.label",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_left",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "t:sections.custom-standalone-image.settings.margin_left.label",
      "default": 0
    },
    {
      "type": "header",
      "content": "t:sections.custom-standalone-image.settings.header_padding.content"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "t:sections.custom-standalone-image.settings.padding_top.label",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_right",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "t:sections.custom-standalone-image.settings.padding_right.label",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "t:sections.custom-standalone-image.settings.padding_bottom.label",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_left",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "t:sections.custom-standalone-image.settings.padding_left.label",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "t:sections.custom-standalone-image.presets.name"
    }
  ]
}
{% endschema %}
