{{ 'section-footer.css' | asset_url | stylesheet_tag }}

{% render 'footer-custom-content-markup',
  cfg: section.settings,
  use_page_width: false,
  mode: 'section',
  parent_section: section
%}

{% schema %}
{
  "name": "フッター汎用コンテンツ",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "richtext",
      "id": "text",
      "label": "テキスト（リッチテキスト）",
      "default": "<p>ここに説明文を入力します。画像を設定すると、テキストの代わりに画像が表示されます。</p>",
      "info": "画像を設定した場合はテキストは表示されません。"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "画像",
      "info": "画像がある場合はテキストより画像を優先して表示します。"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "配置",
      "options": [
        { "value": "left", "label": "左寄せ" },
        { "value": "center", "label": "中央" },
        { "value": "right", "label": "右寄せ" }
      ],
      "default": "center"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "カラーセット（背景色）",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "上部余白",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "label": "下部余白",
      "default": 24
    }
  ],
  "blocks": [
    {
      "type": "link_button",
      "name": "リンクボタン",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "ラベル",
          "default": "リンク",
          "info": "画像を設定した場合はラベルより画像が表示されます（代替テキスト用にも使えます）。"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "画像"
        },
        {
          "type": "range",
          "id": "image_width",
          "min": 50,
          "max": 800,
          "step": 10,
          "unit": "px",
          "label": "画像の表示幅",
          "default": 300,
          "info": "画面幅が狭いときは自動で縮小されます。"
        },
        {
          "type": "url",
          "id": "link",
          "label": "URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "フッター汎用コンテンツ"
    }
  ]
}
{% endschema %}
