    "custom_liquid_PWmTEj": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<style>\n  .bp-faq {\n    background: #fbf9f4;\n    padding: 88px 20px;\n    color: #2d2a25;\n    font-family: \"Noto Sans TC\", \"Hiragino Sans\", \"Helvetica Neue\", Arial, \"Microsoft JhengHei\", sans-serif;\n    -webkit-font-smoothing: antialiased;\n  }\n  .bp-faq__inner {\n    max-width: 880px;\n    margin: 0 auto;\n  }\n\n  /* ===== ヘッダー ===== */\n  .bp-faq__head {\n    text-align: center;\n    margin-bottom: 56px;\n  }\n  .bp-faq__eyebrow {\n    display: inline-block;\n    letter-spacing: .45em;\n    font-size: 11px;\n    color: #9c7a52;\n    margin-bottom: 16px;\n    text-transform: uppercase;\n    font-weight: 500;\n    font-family: \"Helvetica Neue\", \"Hiragino Sans\", sans-serif;\n  }\n  .bp-faq__title {\n    font-family: \"Noto Serif TC\", \"Source Han Serif TC\", \"Yu Mincho\", \"Hiragino Mincho ProN\", \"MS Mincho\", serif;\n    font-size: clamp(26px, 3.4vw, 34px);\n    font-weight: 400;\n    letter-spacing: .35em;\n    margin: 0;\n    color: #2d2a25;\n    padding-left: .35em;\n  }\n  .bp-faq__rule {\n    display: block;\n    width: 36px;\n    height: 1px;\n    background: #a8957a;\n    margin: 22px auto 0;\n    border: none;\n  }\n\n  /* ===== リスト ===== */\n  .bp-faq__list {\n    border-top: 1px solid #d8d2c2;\n  }\n  .bp-faq__item {\n    border-bottom: 1px solid #d8d2c2;\n  }\n\n  /* 質問ボタン */\n  .bp-faq__q {\n    width: 100%;\n    display: flex;\n    align-items: flex-start;\n    gap: 18px;\n    padding: 26px 4px;\n    background: transparent;\n    border: none;\n    cursor: pointer;\n    text-align: left;\n    color: #2d2a25;\n    font: inherit;\n    transition: color .2s ease;\n  }\n  .bp-faq__q:hover { color: #6b5a3d; }\n\n  .bp-faq__q-mark {\n    font-family: \"Noto Serif TC\", \"Yu Mincho\", \"Hiragino Mincho ProN\", serif;\n    font-size: 19px;\n    color: #b08d5a;\n    letter-spacing: .04em;\n    flex-shrink: 0;\n    line-height: 1.5;\n  }\n  .bp-faq__q-text {\n    flex: 1;\n    font-size: 16px;\n    line-height: 1.6;\n    font-weight: 500;\n    letter-spacing: .03em;\n    padding-right: 8px;\n    padding-top: 1px;\n  }\n\n  /* 開閉アイコン（＋／−） */\n  .bp-faq__icon {\n    position: relative;\n    flex-shrink: 0;\n    width: 18px;\n    height: 18px;\n    margin-top: 4px;\n  }\n  .bp-faq__icon::before,\n  .bp-faq__icon::after {\n    content: \"\";\n    position: absolute;\n    background: #8a8270;\n    transition: transform .3s ease, opacity .3s ease;\n  }\n  .bp-faq__icon::before {\n    top: 50%; left: 0;\n    width: 100%; height: 1px;\n    transform: translateY(-50%);\n  }\n  .bp-faq__icon::after {\n    top: 0; left: 50%;\n    width: 1px; height: 100%;\n    transform: translateX(-50%);\n  }\n  .bp-faq__item.is-open .bp-faq__icon::after {\n    transform: translateX(-50%) scaleY(0);\n    opacity: 0;\n  }\n\n  /* 回答パネル（grid-template-rowsで滑らかに展開） */\n  .bp-faq__a {\n    display: grid;\n    grid-template-rows: 0fr;\n    transition: grid-template-rows .4s ease;\n  }\n  .bp-faq__a-inner {\n    overflow: hidden;\n  }\n  .bp-faq__a-content {\n    display: flex;\n    align-items: flex-start;\n    gap: 18px;\n    padding: 0 4px 28px;\n  }\n  .bp-faq__a-mark {\n    font-family: \"Noto Serif TC\", \"Yu Mincho\", \"Hiragino Mincho ProN\", serif;\n    font-size: 19px;\n    color: #8a8270;\n    flex-shrink: 0;\n    line-height: 1.7;\n  }\n  .bp-faq__a-text {\n    flex: 1;\n    font-size: 14.5px;\n    line-height: 2;\n    color: #5e5b53;\n    margin: 0;\n    letter-spacing: .04em;\n  }\n\n  /* 開いた状態 */\n  .bp-faq__item.is-open .bp-faq__a {\n    grid-template-rows: 1fr;\n  }\n\n  /* スマホ */\n  @media (max-width: 720px) {\n    .bp-faq { padding: 60px 16px; }\n    .bp-faq__head { margin-bottom: 36px; }\n    .bp-faq__title { letter-spacing: .2em; padding-left: .2em; }\n    .bp-faq__q { padding: 20px 2px; gap: 12px; }\n    .bp-faq__q-mark { font-size: 16px; }\n    .bp-faq__q-text { font-size: 14px; line-height: 1.65; padding-right: 4px; }\n    .bp-faq__icon { width: 14px; height: 14px; margin-top: 3px; }\n    .bp-faq__a-content { gap: 12px; padding: 0 2px 24px; }\n    .bp-faq__a-mark { font-size: 16px; }\n    .bp-faq__a-text { font-size: 13.5px; line-height: 1.9; letter-spacing: .02em; }\n  }\n</style>\n\n<section class=\"bp-faq\" aria-label=\"常見問題\">\n  <div class=\"bp-faq__inner\">\n\n    <div class=\"bp-faq__list\">\n\n      <!-- Q1 -->\n      <div class=\"bp-faq__item is-open\">\n        <button type=\"button\" class=\"bp-faq__q\" aria-expanded=\"true\">\n          <span class=\"bp-faq__q-mark\">Q.</span>\n          <span class=\"bp-faq__q-text\">我沒有美感，對繪畫也沒自信，也可以參加課程嗎？</span>\n          <span class=\"bp-faq__icon\" aria-hidden=\"true\"></span>\n        </button>\n        <div class=\"bp-faq__a\">\n          <div class=\"bp-faq__a-inner\">\n            <div class=\"bp-faq__a-content\">\n              <span class=\"bp-faq__a-mark\">A.</span>\n              <p class=\"bp-faq__a-text\">多數參加者都是繪畫初學者。植物彩繪的特點是葉脈自然突顯了色彩的美感，只要學習基本技術並反覆練習，就能逐漸提升技能。90% 的講師都是從初學者開始的，您可以安心參加課程。</p>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      <!-- Q2 -->\n      <div class=\"bp-faq__item\">\n        <button type=\"button\" class=\"bp-faq__q\" aria-expanded=\"false\">\n          <span class=\"bp-faq__q-mark\">Q.</span>\n          <span class=\"bp-faq__q-text\">如果未通過考試會怎麼處理？另外，有多少人未通過考試？</span>\n          <span class=\"bp-faq__icon\" aria-hidden=\"true\"></span>\n        </button>\n        <div class=\"bp-faq__a\">\n          <div class=\"bp-faq__a-inner\">\n            <div class=\"bp-faq__a-content\">\n              <span class=\"bp-faq__a-mark\">A.</span>\n              <p class=\"bp-faq__a-text\">技術測驗主要提供一個場地讓大家確認、詢問不清楚的地方，最重要的目的是解決有關植物彩繪的所有疑惑。在測驗中發現不明白的地方，請大膽詢問並確認。目前在台灣舉行的測驗中，所有參加者皆順利通過。</p>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      <!-- Q3 -->\n      <div class=\"bp-faq__item\">\n        <button type=\"button\" class=\"bp-faq__q\" aria-expanded=\"false\">\n          <span class=\"bp-faq__q-mark\">Q.</span>\n          <span class=\"bp-faq__q-text\">通過考試後，畫材要如何購買？</span>\n          <span class=\"bp-faq__icon\" aria-hidden=\"true\"></span>\n        </button>\n        <div class=\"bp-faq__a\">\n          <div class=\"bp-faq__a-inner\">\n            <div class=\"bp-faq__a-content\">\n              <span class=\"bp-faq__a-mark\">A.</span>\n              <p class=\"bp-faq__a-text\">總部有提供講師專用的畫材購買網站。除了蓮葉等天然植物之外，還備有畫筆、定著劑、顏料等各類畫材供您選購。不過，天然植物以外的畫材（如顏料、工具等）也可在台灣的畫材店購買，因此您不必完全依賴總部供應，請放心選擇最適合您的方式。</p>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      <!-- Q4 -->\n      <div class=\"bp-faq__item\">\n        <button type=\"button\" class=\"bp-faq__q\" aria-expanded=\"false\">\n          <span class=\"bp-faq__q-mark\">Q.</span>\n          <span class=\"bp-faq__q-text\">如果講座當天因故無法參加該怎麼辦？</span>\n          <span class=\"bp-faq__icon\" aria-hidden=\"true\"></span>\n        </button>\n        <div class=\"bp-faq__a\">\n          <div class=\"bp-faq__a-inner\">\n            <div class=\"bp-faq__a-content\">\n              <span class=\"bp-faq__a-mark\">A.</span>\n              <p class=\"bp-faq__a-text\">如果您臨時無法參加講座當天的課程，請提前與我們的營運事務局聯繫。我們將與您個別討論改期或其他應對方式。</p>\n            </div>\n          </div>\n        </div>\n      </div>\n\n    </div>\n  </div>\n</section>\n\n<script>\n  (function() {\n    var btns = document.querySelectorAll('.bp-faq__q');\n    btns.forEach(function(btn) {\n      btn.addEventListener('click', function() {\n        var item = btn.closest('.bp-faq__item');\n        var isOpen = item.classList.toggle('is-open');\n        btn.setAttribute('aria-expanded', isOpen ? 'true' : 'false');\n      });\n    });\n  })();\n</script>",
        "color_scheme": "",
        "padding_top": 40,
        "padding_bottom": 52
      }
    },
