<div class="footer-trademark-section color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width">
    <div class="footer-trademark__content">
      {%- comment -%}
        管理画面の見出し（heading）が空じゃない時だけ表示。
        「レイヤーには名前を出したいが画面には出したくない」場合は、設定パネルの見出しを空にするか、
        以下のロジックで制御します。
      {%- endcomment -%}

      {%- if section.settings.show_heading and section.settings.heading != blank -%}
        <h2 class="footer-trademark__heading inline-richtext {{ section.settings.heading_size }}">
          {{ section.settings.heading }}
        </h2>
      {%- endif -%}

      <div class="footer-trademark__text rte">
        {{ section.settings.text }}
      </div>

      <div class="footer-trademark__links">
        {%- if section.settings.link_label_1 != blank -%}
          <a href="{{ section.settings.link_1 }}" class="footer-trademark__link" target="_blank">
            {{- section.settings.link_label_1 -}}
          </a>
        {%- endif -%}
        {%- if section.settings.link_label_2 != blank -%}
          <span class="footer-trademark__separator">|</span>
          <a href="{{ section.settings.link_2 }}" class="footer-trademark__link" target="_blank">
            {{- section.settings.link_label_2 -}}
          </a>
        {%- endif -%}
        {%- if section.settings.link_label_3 != blank -%}
          <span class="footer-trademark__separator">|</span>
          <a href="{{ section.settings.link_3 }}" class="footer-trademark__link" target="_blank">
            {{- section.settings.link_label_3 -}}
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

<style>
  .footer-trademark-section {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    text-align: center;
  }
  .footer-trademark__content { max-width: 80rem; margin: 0 auto; }
  .footer-trademark__text { margin-bottom: 1.5rem; line-height: 1.6; font-size: 1.2rem; }
  .footer-trademark__links { display: flex; flex-wrap: wrap; justify-content: center; gap: 1rem; align-items: center; }
  .footer-trademark__link { color: inherit; text-underline-offset: 0.3rem; }
  .footer-trademark__separator { opacity: 0.5; }
</style>

{% schema %}
{
  "name": "商標権表示",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "商標権表示",
      "label": "管理用名称（レイヤーに表示されます）"
    },
    {
      "type": "checkbox",
      "id": "show_heading",
      "default": false,
      "label": "実際の画面に見出しを表示する"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "小" },
        { "value": "h1", "label": "中" }
      ],
      "default": "h2",
      "label": "見出しサイズ"
    },
    {
      "type": "richtext",
      "id": "text",
      "default": "<p>ボタニ―、ロータスリーフペイントは、株式会社アントレ・サン・フラッペの登録商標です。</p>",
      "label": "説明文"
    },
    {
      "type": "header",
      "content": "登録証書へのリンク"
    },
    {
      "type": "text",
      "id": "link_label_1",
      "label": "ラベル1",
      "default": "ボタニー（第6026741号）"
    },
    {
      "type": "url",
      "id": "link_1",
      "label": "リンク先1"
    },
    {
      "type": "text",
      "id": "link_label_2",
      "label": "ラベル2",
      "default": "ロータスリーフ＆リンデン（第6304653号）"
    },
    {
      "type": "url",
      "id": "link_2",
      "label": "リンク先2"
    },
    {
      "type": "text",
      "id": "link_label_3",
      "label": "ラベル3",
      "default": "ロータスリーフペイント（第6147070号）"
    },
    {
      "type": "url",
      "id": "link_3",
      "label": "リンク先3"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "カラーセット",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "上部余白",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "下部余白",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "商標権表示"
    }
  ]
}
{% endschema %}
