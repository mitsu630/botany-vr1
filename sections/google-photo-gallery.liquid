{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  #GooglePhotoGallery-{{ section.id }} {
    --gpg-radius: {{ section.settings.corner_radius }}px;
    --gpg-gap: {{ section.settings.grid_gap }}px;
    --gpg-card-background: rgba(var(--color-foreground), 0.03);
    --gpg-border: rgba(var(--color-foreground), 0.08);
    --gpg-muted: rgba(var(--color-foreground), 0.68);
    --gpg-skeleton: rgba(var(--color-foreground), 0.08);
    --gpg-skeleton-highlight: rgba(var(--color-foreground), 0.16);
  }
{%- endstyle -%}

{%- liquid
  assign loading_text = section.settings.loading_text | default: 'Loading...'
-%}

<google-photo-gallery
  id="GooglePhotoGallery-{{ section.id }}"
  class="google-photo-gallery color-{{ section.settings.color_scheme }} gradient"
  data-section-id="{{ section.id }}"
>
  <div class="page-width section-{{ section.id }}-padding">
    {%- if section.settings.heading != blank or section.settings.description != blank -%}
      <div class="google-photo-gallery__header {{ section.settings.heading_alignment }}">
        {%- if section.settings.heading != blank -%}
          <h2 class="google-photo-gallery__heading inline-richtext {{ section.settings.heading_size }}">
            {{ section.settings.heading }}
          </h2>
        {%- endif -%}

        {%- if section.settings.description != blank -%}
          <div class="google-photo-gallery__description rte">
            {{ section.settings.description }}
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="google-photo-gallery__albums">
      {%- for block in section.blocks -%}
        <article
          class="google-photo-gallery__album"
          data-google-photo-album
          data-album-title="{{ block.settings.album_title | escape }}"
          data-endpoint="{{ block.settings.gas_web_app_url | escape }}"
          {{ block.shopify_attributes }}
        >
          <div class="google-photo-gallery__album-header">
            {%- if block.settings.album_title != blank -%}
              <h3 class="google-photo-gallery__album-title inline-richtext">
                {{ block.settings.album_title }}
              </h3>
            {%- endif -%}

            {%- if block.settings.album_description != blank -%}
              <div class="google-photo-gallery__album-description rte">
                {{ block.settings.album_description }}
              </div>
            {%- endif -%}
          </div>

          {%- if block.settings.gas_web_app_url != blank -%}
            <div
              class="google-photo-gallery__grid google-photo-gallery__grid--{{ section.settings.image_ratio }}"
              data-album-grid
              aria-busy="true"
              aria-live="polite"
            >
              <div class="google-photo-gallery__loading" role="status">
                <span class="google-photo-gallery__spinner" aria-hidden="true">
                  {{ 'loading-spinner.svg' | inline_asset_content }}
                </span>
                <span>{{ loading_text }}</span>
              </div>
              {%- for i in (1..section.settings.skeleton_count) -%}
                <div class="google-photo-gallery__skeleton" aria-hidden="true"></div>
              {%- endfor -%}
            </div>
          {%- else -%}
            <div class="google-photo-gallery__empty">
              GAS WebアプリURLを設定してください。
            </div>
          {%- endif -%}
        </article>
      {%- else -%}
        <div class="google-photo-gallery__empty">
          テーマエディタでアルバムブロックを追加してください。
        </div>
      {%- endfor -%}
    </div>
  </div>

  <div class="google-photo-gallery__lightbox" data-lightbox aria-hidden="true">
    <button class="google-photo-gallery__lightbox-close" type="button" data-lightbox-close aria-label="閉じる">
      <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
        <path d="M5 5L19 19M19 5L5 19" />
      </svg>
    </button>
    <div class="google-photo-gallery__lightbox-frame">
      <img alt="" data-lightbox-image loading="eager" width="2048" height="2048">
      <p class="google-photo-gallery__lightbox-caption" data-lightbox-caption></p>
    </div>
  </div>
</google-photo-gallery>

<style>
  .google-photo-gallery {
    display: block;
  }

  .google-photo-gallery__header {
    max-width: 78rem;
    margin: 0 auto 4rem;
  }

  .google-photo-gallery__header.left {
    margin-left: 0;
    text-align: left;
  }

  .google-photo-gallery__header.center {
    text-align: center;
  }

  .google-photo-gallery__header.right {
    margin-right: 0;
    text-align: right;
  }

  .google-photo-gallery__heading {
    margin: 0;
  }

  .google-photo-gallery__description {
    margin-top: 1.2rem;
    color: var(--gpg-muted);
  }

  .google-photo-gallery__albums {
    display: grid;
    gap: clamp(3.2rem, 5vw, 6.4rem);
  }

  .google-photo-gallery__album {
    display: grid;
    gap: 2rem;
  }

  .google-photo-gallery__album-header {
    max-width: 72rem;
  }

  .google-photo-gallery__album-title {
    margin: 0;
    font-size: clamp(2rem, 2vw, 2.8rem);
  }

  .google-photo-gallery__album-description {
    margin-top: 0.8rem;
    color: var(--gpg-muted);
  }

  .google-photo-gallery__grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns_mobile }}, minmax(0, 1fr));
    gap: var(--gpg-gap);
  }

  @media screen and (min-width: 750px) {
    .google-photo-gallery__grid {
      grid-template-columns: repeat({{ section.settings.columns_desktop }}, minmax(0, 1fr));
    }
  }

  .google-photo-gallery__tile,
  .google-photo-gallery__skeleton {
    position: relative;
    width: 100%;
    overflow: hidden;
    border: 0;
    border-radius: var(--gpg-radius);
    background: var(--gpg-card-background);
    aspect-ratio: 1 / 1;
  }

  .google-photo-gallery__grid--portrait .google-photo-gallery__tile,
  .google-photo-gallery__grid--portrait .google-photo-gallery__skeleton {
    aspect-ratio: 4 / 5;
  }

  .google-photo-gallery__tile {
    display: block;
    padding: 0;
    cursor: zoom-in;
    box-shadow: inset 0 0 0 0.1rem var(--gpg-border);
  }

  .google-photo-gallery__tile img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    transition: transform 360ms ease, opacity 220ms ease;
  }

  .google-photo-gallery__tile.is-loading {
    cursor: progress;
  }

  .google-photo-gallery__tile.is-loading img {
    opacity: 0;
  }

  .google-photo-gallery__tile.is-loading::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        90deg,
        var(--gpg-skeleton) 0%,
        var(--gpg-skeleton-highlight) 45%,
        var(--gpg-skeleton) 90%
      );
    background-size: 220% 100%;
    animation: google-photo-gallery-skeleton 1.4s ease-in-out infinite;
  }

  .google-photo-gallery__tile.is-loading::after {
    content: "";
    position: absolute;
    top: 50%;
    left: 50%;
    width: 2.8rem;
    height: 2.8rem;
    margin: -1.4rem 0 0 -1.4rem;
    border: 0.2rem solid rgba(var(--color-foreground), 0.18);
    border-top-color: rgba(var(--color-foreground), 0.72);
    border-radius: 50%;
    animation: google-photo-gallery-spin 800ms linear infinite;
  }

  .google-photo-gallery__tile:hover img {
    transform: scale(1.045);
  }

  .google-photo-gallery__loading {
    grid-column: 1 / -1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    min-height: 5.6rem;
    padding: 1.6rem;
    border: 0.1rem solid var(--gpg-border);
    border-radius: var(--gpg-radius);
    color: var(--gpg-muted);
    background: var(--gpg-card-background);
    font-size: 1.4rem;
  }

  .google-photo-gallery__spinner {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
    width: 2.2rem;
    height: 2.2rem;
  }

  .google-photo-gallery__spinner svg {
    width: 100%;
    height: 100%;
    animation: google-photo-gallery-spin 1.4s linear infinite !important;
  }

  .google-photo-gallery__spinner .path {
    stroke: rgba(var(--color-foreground), 0.68);
    stroke-dasharray: 280;
    stroke-dashoffset: 0;
    transform-origin: center;
    animation: google-photo-gallery-dash 1.4s ease-in-out infinite !important;
  }

  .google-photo-gallery__tile:focus-visible {
    outline: 0.2rem solid rgba(var(--color-foreground), 0.75);
    outline-offset: 0.3rem;
  }

  .google-photo-gallery__skeleton {
    background:
      linear-gradient(
        90deg,
        var(--gpg-skeleton) 0%,
        var(--gpg-skeleton-highlight) 45%,
        var(--gpg-skeleton) 90%
      );
    background-size: 220% 100%;
    animation: google-photo-gallery-skeleton 1.4s ease-in-out infinite;
  }

  .google-photo-gallery__empty,
  .google-photo-gallery__error {
    padding: 2.4rem;
    border: 0.1rem solid var(--gpg-border);
    border-radius: var(--gpg-radius);
    color: var(--gpg-muted);
    background: var(--gpg-card-background);
  }

  .google-photo-gallery__error {
    color: rgb(var(--color-foreground));
  }

  .google-photo-gallery__lightbox {
    position: fixed;
    inset: 0;
    z-index: 999;
    display: grid;
    place-items: center;
    padding: 6.4rem 2rem 2rem;
    background: rgba(0, 0, 0, 0);
    opacity: 0;
    visibility: hidden;
    transition: opacity 260ms ease, visibility 260ms ease, background-color 260ms ease;
  }

  .google-photo-gallery__lightbox.is-open {
    opacity: 1;
    visibility: visible;
    background: rgba(0, 0, 0, 0.82);
  }

  .google-photo-gallery__lightbox-frame {
    max-width: min(108rem, 100%);
    max-height: 100%;
    display: grid;
    gap: 1.2rem;
    justify-items: center;
    transform: translateY(1.2rem) scale(0.98);
    transition: transform 260ms ease;
  }

  .google-photo-gallery__lightbox.is-open .google-photo-gallery__lightbox-frame {
    transform: translateY(0) scale(1);
  }

  .google-photo-gallery__lightbox img {
    max-width: 100%;
    max-height: calc(100vh - 12rem);
    display: block;
    border-radius: calc(var(--gpg-radius) * 0.75);
    object-fit: contain;
    box-shadow: 0 2.4rem 7rem rgba(0, 0, 0, 0.28);
  }

  .google-photo-gallery__lightbox-caption {
    max-width: 72rem;
    margin: 0;
    color: rgba(255, 255, 255, 0.82);
    text-align: center;
    font-size: 1.3rem;
    line-height: 1.5;
  }

  .google-photo-gallery__lightbox-caption:empty {
    display: none;
  }

  .google-photo-gallery__lightbox-close {
    position: absolute;
    top: 1.8rem;
    right: 1.8rem;
    width: 4.4rem;
    height: 4.4rem;
    display: grid;
    place-items: center;
    padding: 0;
    border: 0.1rem solid rgba(255, 255, 255, 0.22);
    border-radius: 999rem;
    color: #fff;
    background: rgba(255, 255, 255, 0.08);
    cursor: pointer;
    transition: background-color 180ms ease, border-color 180ms ease, transform 180ms ease;
  }

  .google-photo-gallery__lightbox-close:hover {
    border-color: rgba(255, 255, 255, 0.42);
    background: rgba(255, 255, 255, 0.14);
    transform: scale(1.04);
  }

  .google-photo-gallery__lightbox-close svg {
    width: 2rem;
    height: 2rem;
  }

  .google-photo-gallery__lightbox-close path {
    fill: none;
    stroke: currentColor;
    stroke-width: 1.4;
    stroke-linecap: round;
  }

  body.google-photo-gallery-lock {
    overflow: hidden;
  }

  @keyframes google-photo-gallery-skeleton {
    0% {
      background-position: 120% 0;
    }
    100% {
      background-position: -120% 0;
    }
  }

  @keyframes google-photo-gallery-spin {
    to {
      transform: rotate(360deg);
    }
  }

  @keyframes google-photo-gallery-dash {
    0% {
      stroke-dashoffset: 280;
    }
    50% {
      stroke-dashoffset: 75;
      transform: rotate(135deg);
    }
    100% {
      stroke-dashoffset: 280;
      transform: rotate(450deg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .google-photo-gallery__tile img,
    .google-photo-gallery__lightbox,
    .google-photo-gallery__lightbox-frame,
    .google-photo-gallery__lightbox-close {
      transition: none;
    }

    .google-photo-gallery__skeleton {
      animation: none;
    }

    .google-photo-gallery__tile.is-loading::before,
    .google-photo-gallery__tile.is-loading::after {
      animation: none;
    }
  }
</style>

<script>
  (() => {
    if (customElements.get('google-photo-gallery')) {
      return;
    }

    class GooglePhotoGallery extends HTMLElement {
      connectedCallback() {
        this.albums = Array.from(this.querySelectorAll('[data-google-photo-album]'));
        this.lightbox = this.querySelector('[data-lightbox]');
        this.lightboxImage = this.querySelector('[data-lightbox-image]');
        this.lightboxCaption = this.querySelector('[data-lightbox-caption]');
        this.closeButton = this.querySelector('[data-lightbox-close]');
        this.previousBodyPaddingRight = '';
        this.boundHandleKeydown = this.handleKeydown.bind(this);

        this.closeButton?.addEventListener('click', () => this.closeLightbox());
        this.lightbox?.addEventListener('click', (event) => {
          if (event.target === this.lightbox) {
            this.closeLightbox();
          }
        });

        this.loadAlbums();
      }

      async loadAlbums() {
        await Promise.all(this.albums.map((album) => this.loadAlbum(album)));
      }

      async loadAlbum(album) {
        const endpoint = album.dataset.endpoint;
        const grid = album.querySelector('[data-album-grid]');

        if (!endpoint || !grid) {
          return;
        }

        try {
          const response = await fetch(endpoint, { method: 'GET', credentials: 'omit' });

          if (!response.ok) {
            throw new Error(`HTTP ${response.status}`);
          }

          const payload = await response.json();
          const photos = this.normalizePhotos(payload);
          this.renderPhotos(grid, photos, album.dataset.albumTitle || '');
        } catch (error) {
          this.renderError(grid, '写真を読み込めませんでした。GAS URL、公開設定、CORS設定を確認してください。');
          console.error('[GooglePhotoGallery] Album fetch failed:', error);
        }
      }

      normalizePhotos(payload) {
        const items = Array.isArray(payload) ? payload : payload.photos || payload.mediaItems || payload.items || [];

        return items
          .map((item) => {
            const baseUrl = item.baseUrl || item.base_url || '';
            const thumbnail = item.thumbnailUrl || item.thumbnail_url || item.src || item.url || baseUrl;
            const full = item.fullUrl || item.full_url || item.lightboxUrl || item.lightbox_url || item.url || baseUrl;
            const alt = item.alt || item.description || item.filename || item.title || '';

            return {
              thumbnail: this.withGooglePhotoSize(thumbnail, 'w900-h900-c'),
              full: this.withGooglePhotoSize(full, 'w2048-h2048'),
              alt,
              caption: item.caption || item.description || item.filename || ''
            };
          })
          .filter((item) => item.thumbnail);
      }

      withGooglePhotoSize(url, size) {
        if (!url || !url.includes('googleusercontent.com') || url.includes('=')) {
          return url;
        }

        return `${url}=${size}`;
      }

      renderPhotos(grid, photos, albumTitle) {
        grid.innerHTML = '';
        grid.setAttribute('aria-busy', 'false');

        if (!photos.length) {
          this.renderError(grid, 'このアルバムには表示できる写真がありません。');
          return;
        }

        photos.forEach((photo, index) => {
          const button = document.createElement('button');
          button.type = 'button';
          button.className = 'google-photo-gallery__tile is-loading';
          button.setAttribute('aria-label', `${albumTitle || 'アルバム'}の写真 ${index + 1} を拡大表示`);

          const image = document.createElement('img');
          image.alt = photo.alt || '';
          image.loading = index < 4 ? 'eager' : 'lazy';
          image.decoding = 'async';
          image.addEventListener('load', () => button.classList.remove('is-loading'), { once: true });
          image.addEventListener('error', () => button.classList.remove('is-loading'), { once: true });
          image.src = photo.thumbnail;

          button.append(image);
          button.addEventListener('click', () => this.openLightbox(photo));
          grid.append(button);
        });
      }

      renderError(grid, message) {
        grid.innerHTML = '';
        grid.setAttribute('aria-busy', 'false');
        const error = document.createElement('div');
        error.className = 'google-photo-gallery__error';
        error.textContent = message;
        grid.append(error);
      }

      openLightbox(photo) {
        if (!this.lightbox || !this.lightboxImage) {
          return;
        }

        this.lightboxImage.src = photo.full || photo.thumbnail;
        this.lightboxImage.alt = photo.alt || '';
        this.lightboxCaption.textContent = photo.caption || '';
        this.lightbox.classList.add('is-open');
        this.lightbox.setAttribute('aria-hidden', 'false');
        this.lockScroll();
        document.addEventListener('keydown', this.boundHandleKeydown);
        this.closeButton?.focus();
      }

      closeLightbox() {
        if (!this.lightbox || !this.lightboxImage) {
          return;
        }

        this.lightbox.classList.remove('is-open');
        this.lightbox.setAttribute('aria-hidden', 'true');
        this.lightboxImage.src = '';
        this.unlockScroll();
        document.removeEventListener('keydown', this.boundHandleKeydown);
      }

      handleKeydown(event) {
        if (event.key === 'Escape') {
          this.closeLightbox();
        }
      }

      lockScroll() {
        const scrollbarWidth = window.innerWidth - document.documentElement.clientWidth;
        this.previousBodyPaddingRight = document.body.style.paddingRight;

        if (scrollbarWidth > 0) {
          document.body.style.paddingRight = `${scrollbarWidth}px`;
        }

        document.body.classList.add('google-photo-gallery-lock');
      }

      unlockScroll() {
        document.body.classList.remove('google-photo-gallery-lock');
        document.body.style.paddingRight = this.previousBodyPaddingRight;
      }
    }

    customElements.define('google-photo-gallery', GooglePhotoGallery);
  })();
</script>

{% schema %}
{
  "name": "googleDrivephoto",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "見出し",
      "default": "Googleフォトギャラリー"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "説明文"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h2",
          "label": "小"
        },
        {
          "value": "h1",
          "label": "中"
        },
        {
          "value": "h0",
          "label": "大"
        },
        {
          "value": "hxl",
          "label": "特大"
        }
      ],
      "default": "h1",
      "label": "見出しサイズ"
    },
    {
      "type": "text_alignment",
      "id": "heading_alignment",
      "label": "見出し配置",
      "default": "center"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "カラー",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "画像比率",
      "options": [
        {
          "value": "square",
          "label": "1:1"
        },
        {
          "value": "portrait",
          "label": "4:5"
        }
      ],
      "default": "square"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 6,
      "step": 1,
      "label": "PCの列数",
      "default": 4
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "モバイルの列数",
      "options": [
        {
          "value": "1",
          "label": "1列"
        },
        {
          "value": "2",
          "label": "2列"
        }
      ],
      "default": "2"
    },
    {
      "type": "range",
      "id": "grid_gap",
      "min": 4,
      "max": 32,
      "step": 2,
      "unit": "px",
      "label": "画像間の余白",
      "default": 12
    },
    {
      "type": "range",
      "id": "corner_radius",
      "min": 0,
      "max": 28,
      "step": 2,
      "unit": "px",
      "label": "角丸",
      "default": 12
    },
    {
      "type": "range",
      "id": "skeleton_count",
      "min": 2,
      "max": 12,
      "step": 1,
      "label": "読み込み中のプレースホルダー数",
      "default": 8
    },
    {
      "type": "text",
      "id": "loading_text",
      "label": "読み込み中テキスト",
      "default": "Loading..."
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "上の余白",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "下の余白",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "album",
      "name": "Group",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "album_title",
          "label": "アルバム名称",
          "default": "アルバム名称"
        },
        {
          "type": "richtext",
          "id": "album_description",
          "label": "アルバムの説明文"
        },
        {
          "type": "url",
          "id": "gas_web_app_url",
          "label": "GAS WebアプリURL",
          "info": "設定例: https://script.google.com/macros/s/AKfycbxwPuxPdHsU7v6ahYlfg0xmxoDPiG7XdJi3O0oZFTWDApkah7AZVlmVA2GnQHXp6zA6/exec?folderId=ここにフォルダIDを入れる。"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "googleDrivephoto",
      "blocks": [
        {
          "type": "album"
        }
      ]
    }
  ]
}
{% endschema %}
