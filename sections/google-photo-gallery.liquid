{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  #GooglePhotoGallery-{{ section.id }} {
    --gpg-radius: {{ section.settings.corner_radius }}px;
    --gpg-gap: {{ section.settings.grid_gap }}px;
    --gpg-card-background: rgba(var(--color-foreground), 0.03);
    --gpg-border: rgba(var(--color-foreground), 0.08);
    --gpg-muted: rgba(var(--color-foreground), 0.68);
    --gpg-skeleton: rgba(var(--color-foreground), 0.08);
    --gpg-skeleton-highlight: rgba(var(--color-foreground), 0.16);
  }
{%- endstyle -%}

{%- liquid
  assign loading_text = section.settings.loading_text | default: 'Loading...'
-%}

<google-photo-gallery
  id="GooglePhotoGallery-{{ section.id }}"
  class="google-photo-gallery color-{{ section.settings.color_scheme }} gradient"
  data-section-id="{{ section.id }}"
>
  <div class="page-width section-{{ section.id }}-padding">
    {%- if section.settings.heading != blank or section.settings.description != blank -%}
      <div class="google-photo-gallery__header {{ section.settings.heading_alignment }}">
        {%- if section.settings.heading != blank -%}
          <h2 class="google-photo-gallery__heading inline-richtext {{ section.settings.heading_size }}">
            {{ section.settings.heading }}
          </h2>
        {%- endif -%}

        {%- if section.settings.description != blank -%}
          <div class="google-photo-gallery__description rte">
            {{ section.settings.description }}
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="google-photo-gallery__albums">
      {%- for block in section.blocks -%}
        <article
          class="google-photo-gallery__album"
          data-google-photo-album
          data-album-title="{{ block.settings.album_title | escape }}"
          data-endpoint="{{ block.settings.gas_web_app_url | escape }}"
          {{ block.shopify_attributes }}
        >
          <div class="google-photo-gallery__album-header">
            {%- if block.settings.album_title != blank -%}
              <h3 class="google-photo-gallery__album-title inline-richtext">
                {{ block.settings.album_title }}
              </h3>
            {%- endif -%}

            {%- if block.settings.album_description != blank -%}
              <div class="google-photo-gallery__album-description rte">
                {{ block.settings.album_description }}
              </div>
            {%- endif -%}
          </div>

          {%- if block.settings.gas_web_app_url != blank -%}
            <div
              class="google-photo-gallery__grid google-photo-gallery__grid--{{ section.settings.image_ratio }}"
              data-album-grid
              aria-busy="true"
              aria-live="polite"
            >
              <div class="google-photo-gallery__loading" role="status">
                <span class="google-photo-gallery__spinner" aria-hidden="true">
                  {{ 'loading-spinner.svg' | inline_asset_content }}
                </span>
                <span>{{ loading_text }}</span>
              </div>
              {%- for i in (1..section.settings.skeleton_count) -%}
                <div class="google-photo-gallery__skeleton" aria-hidden="true"></div>
              {%- endfor -%}
            </div>
          {%- else -%}
            <div class="google-photo-gallery__empty">
              GAS WebアプリURLを設定してください。
            </div>
          {%- endif -%}
        </article>
      {%- else -%}
        <div class="google-photo-gallery__empty">
          テーマエディタでアルバムブロックを追加してください。
        </div>
      {%- endfor -%}
    </div>
  </div>

</google-photo-gallery>

<style>
  .google-photo-gallery {
    display: block;
  }

  .google-photo-gallery__header {
    max-width: 78rem;
    margin: 0 auto 4rem;
  }

  .google-photo-gallery__header.left {
    margin-left: 0;
    text-align: left;
  }

  .google-photo-gallery__header.center {
    text-align: center;
  }

  .google-photo-gallery__header.right {
    margin-right: 0;
    text-align: right;
  }

  .google-photo-gallery__heading {
    margin: 0;
  }

  .google-photo-gallery__description {
    margin-top: 1.2rem;
    color: var(--gpg-muted);
  }

  .google-photo-gallery__albums {
    display: grid;
    gap: clamp(3.2rem, 5vw, 6.4rem);
  }

  .google-photo-gallery__album {
    display: grid;
    gap: 2rem;
  }

  .google-photo-gallery__album-header {
    max-width: 72rem;
  }

  .google-photo-gallery__album-title {
    margin: 0;
    font-size: clamp(2rem, 2vw, 2.8rem);
  }

  .google-photo-gallery__album-description {
    margin-top: 0.8rem;
    color: var(--gpg-muted);
  }

  .google-photo-gallery__grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns_mobile }}, minmax(0, 1fr));
    gap: var(--gpg-gap);
  }

  @media screen and (min-width: 750px) {
    .google-photo-gallery__grid {
      grid-template-columns: repeat({{ section.settings.columns_desktop }}, minmax(0, 1fr));
    }
  }

  .google-photo-gallery__tile,
  .google-photo-gallery__skeleton {
    position: relative;
    width: 100%;
    overflow: hidden;
    border: 0;
    border-radius: var(--gpg-radius);
    background: var(--gpg-card-background);
    aspect-ratio: 1 / 1;
  }

  .google-photo-gallery__grid--portrait .google-photo-gallery__tile,
  .google-photo-gallery__grid--portrait .google-photo-gallery__skeleton {
    aspect-ratio: 4 / 5;
  }

  .google-photo-gallery__tile {
    display: block;
    padding: 0;
    cursor: zoom-in;
    box-shadow: inset 0 0 0 0.1rem var(--gpg-border);
  }

  .google-photo-gallery__tile img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    transition: transform 360ms ease, opacity 220ms ease;
  }

  .google-photo-gallery__tile.is-loading {
    cursor: progress;
  }

  .google-photo-gallery__tile.is-loading img {
    opacity: 0;
  }

  .google-photo-gallery__tile.is-loading::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        90deg,
        var(--gpg-skeleton) 0%,
        var(--gpg-skeleton-highlight) 45%,
        var(--gpg-skeleton) 90%
      );
    background-size: 220% 100%;
    animation: google-photo-gallery-skeleton 1.4s ease-in-out infinite;
  }

  .google-photo-gallery__tile.is-loading::after {
    content: "";
    position: absolute;
    top: 50%;
    left: 50%;
    width: 2.8rem;
    height: 2.8rem;
    margin: -1.4rem 0 0 -1.4rem;
    border: 0.2rem solid rgba(var(--color-foreground), 0.18);
    border-top-color: rgba(var(--color-foreground), 0.72);
    border-radius: 50%;
    animation: google-photo-gallery-spin 800ms linear infinite;
  }

  .google-photo-gallery__tile:hover img {
    transform: scale(1.045);
  }

  .google-photo-gallery__loading {
    grid-column: 1 / -1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    min-height: 5.6rem;
    padding: 1.6rem;
    border: 0.1rem solid var(--gpg-border);
    border-radius: var(--gpg-radius);
    color: var(--gpg-muted);
    background: var(--gpg-card-background);
    font-size: 1.4rem;
  }

  .google-photo-gallery__spinner {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
    width: 2.2rem;
    height: 2.2rem;
  }

  .google-photo-gallery__spinner svg {
    width: 100%;
    height: 100%;
    animation: google-photo-gallery-spin 1.4s linear infinite !important;
  }

  .google-photo-gallery__spinner .path {
    stroke: rgba(var(--color-foreground), 0.68);
    stroke-dasharray: 280;
    stroke-dashoffset: 0;
    transform-origin: center;
    animation: google-photo-gallery-dash 1.4s ease-in-out infinite !important;
  }

  .google-photo-gallery__tile:focus-visible {
    outline: 0.2rem solid rgba(var(--color-foreground), 0.75);
    outline-offset: 0.3rem;
  }

  .google-photo-gallery__skeleton {
    background:
      linear-gradient(
        90deg,
        var(--gpg-skeleton) 0%,
        var(--gpg-skeleton-highlight) 45%,
        var(--gpg-skeleton) 90%
      );
    background-size: 220% 100%;
    animation: google-photo-gallery-skeleton 1.4s ease-in-out infinite;
  }

  .google-photo-gallery__empty,
  .google-photo-gallery__error {
    padding: 2.4rem;
    border: 0.1rem solid var(--gpg-border);
    border-radius: var(--gpg-radius);
    color: var(--gpg-muted);
    background: var(--gpg-card-background);
  }

  .google-photo-gallery__error {
    color: rgb(var(--color-foreground));
  }

  .pswp {
    --pswp-bg: rgba(0, 0, 0, 0.86) !important;
  }

  .pswp__button--arrow {
    width: clamp(4.4rem, 8vw, 7.2rem) !important;
    height: clamp(7rem, 18vw, 12rem) !important;
    display: grid !important;
    place-items: center !important;
    margin-top: calc(clamp(7rem, 18vw, 12rem) / -2) !important;
    color: rgba(255, 255, 255, 0.82) !important;
    opacity: 1 !important;
  }

  .pswp__button--arrow:hover {
    color: #fff !important;
  }

  .pswp__button--arrow .pswp__icn {
    display: none !important;
  }

  .pswp__button--arrow::before {
    content: "\2039" !important;
    position: static !important;
    width: auto !important;
    height: auto !important;
    margin: 0 !important;
    background: transparent !important;
    font-family: Georgia, 'Times New Roman', serif !important;
    font-size: clamp(5.2rem, 11vw, 8.8rem) !important;
    font-weight: 200 !important;
    line-height: 1 !important;
  }

  .pswp__button--arrow--next::before {
    content: "\203A" !important;
  }

  .pswp__button--close {
    top: 1.6rem !important;
    right: 1.6rem !important;
    width: 4.8rem !important;
    height: 4.8rem !important;
    border: 0.1rem solid rgba(255, 255, 255, 0.26) !important;
    border-radius: 999rem !important;
    background-color: rgba(0, 0, 0, 0.46) !important;
    color: #fff !important;
    opacity: 1 !important;
  }

  .pswp__button--close:hover {
    border-color: rgba(255, 255, 255, 0.5) !important;
    background-color: rgba(0, 0, 0, 0.68) !important;
  }

  .pswp__button--close .pswp__icn {
    width: 2.8rem !important;
    height: 2.8rem !important;
  }

  .pswp__img {
    object-fit: contain !important;
  }

  .google-photo-gallery__pswp-watermark {
    position: fixed;
    top: 50%;
    left: 50%;
    z-index: 100002;
    width: min(42rem, 58vw);
    max-width: 72%;
    height: auto;
    opacity: 0.42;
    pointer-events: none;
    transform: translate(-50%, -50%);
    user-select: none;
  }

  @keyframes google-photo-gallery-skeleton {
    0% {
      background-position: 120% 0;
    }
    100% {
      background-position: -120% 0;
    }
  }

  @keyframes google-photo-gallery-spin {
    to {
      transform: rotate(360deg);
    }
  }

  @keyframes google-photo-gallery-dash {
    0% {
      stroke-dashoffset: 280;
    }
    50% {
      stroke-dashoffset: 75;
      transform: rotate(135deg);
    }
    100% {
      stroke-dashoffset: 280;
      transform: rotate(450deg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .google-photo-gallery__tile img {
      transition: none;
    }

    .google-photo-gallery__skeleton {
      animation: none;
    }

    .google-photo-gallery__tile.is-loading::before,
    .google-photo-gallery__tile.is-loading::after {
      animation: none;
    }
  }
</style>

<script>
  (() => {
    if (customElements.get('google-photo-gallery')) {
      return;
    }

    class GooglePhotoGallery extends HTMLElement {
      connectedCallback() {
        this.albums = Array.from(this.querySelectorAll('[data-google-photo-album]'));
        this.photoSwipeLightbox = null;
        this.photoSwipeInitPromise = null;
        this.dimensionPromises = new Map();

        this.loadAlbums();
        this.ensurePhotoSwipeStyles();
        this.initializePhotoSwipe();
      }

      disconnectedCallback() {
        this.photoSwipeLightbox?.destroy();
        this.photoSwipeLightbox = null;
        this.photoSwipeInitPromise = null;
      }

      async loadAlbums() {
        await Promise.all(this.albums.map((album) => this.loadAlbum(album)));
      }

      async loadAlbum(album) {
        const endpoint = album.dataset.endpoint;
        const grid = album.querySelector('[data-album-grid]');

        if (!endpoint || !grid) {
          return;
        }

        try {
          const response = await fetch(endpoint, { method: 'GET', credentials: 'omit' });

          if (!response.ok) {
            throw new Error(`HTTP ${response.status}`);
          }

          const payload = await response.json();
          const photos = this.normalizePhotos(payload);
          this.renderPhotos(grid, photos, album.dataset.albumTitle || '');
        } catch (error) {
          this.renderError(grid, '写真を読み込めませんでした。GAS URL、公開設定、CORS設定を確認してください。');
          console.error('[GooglePhotoGallery] Album fetch failed:', error);
        }
      }

      normalizePhotos(payload) {
        const items = Array.isArray(payload) ? payload : payload.photos || payload.mediaItems || payload.items || [];

        return items
          .map((item) => {
            const baseUrl = item.baseUrl || item.base_url || '';
            const thumbnail = item.thumbnailUrl || item.thumbnail_url || item.src || item.url || baseUrl;
            const full = item.fullUrl || item.full_url || item.lightboxUrl || item.lightbox_url || item.url || baseUrl;
            const alt = item.alt || item.description || item.filename || item.title || '';
            const width = Number(item.width || item.w || item.mediaMetadata?.width || item.media_metadata?.width || 0);
            const height = Number(item.height || item.h || item.mediaMetadata?.height || item.media_metadata?.height || 0);

            return {
              thumbnail: this.withGooglePhotoSize(thumbnail, 'w900-h900-c'),
              full: this.withGooglePhotoSize(full, 'w2048-h2048'),
              alt,
              caption: item.caption || item.description || item.filename || '',
              width: width > 0 ? width : 2048,
              height: height > 0 ? height : 2048,
              hasDimensions: width > 0 && height > 0
            };
          })
          .filter((item) => item.thumbnail);
      }

      withGooglePhotoSize(url, size) {
        if (!url || !url.includes('googleusercontent.com') || url.includes('=')) {
          return url;
        }

        return `${url}=${size}`;
      }

      renderPhotos(grid, photos, albumTitle) {
        grid.innerHTML = '';
        grid.setAttribute('aria-busy', 'false');

        if (!photos.length) {
          this.renderError(grid, 'このアルバムには表示できる写真がありません。');
          return;
        }

        photos.forEach((photo, index) => {
          const link = document.createElement('a');
          link.className = 'google-photo-gallery__tile is-loading';
          link.href = photo.full || photo.thumbnail;
          link.dataset.pswpWidth = String(photo.width);
          link.dataset.pswpHeight = String(photo.height);
          link.dataset.pswpCaption = photo.caption || '';
          link.setAttribute('aria-label', `${albumTitle || 'アルバム'}の写真 ${index + 1} を拡大表示`);

          if (!photo.hasDimensions) {
            link.dataset.needsImageDimensions = 'true';
            link.addEventListener('click', (event) => this.handlePhotoClick(event, link));
          }

          const image = document.createElement('img');
          image.alt = photo.alt || '';
          image.loading = index < 4 ? 'eager' : 'lazy';
          image.decoding = 'async';
          image.addEventListener('load', () => link.classList.remove('is-loading'), { once: true });
          image.addEventListener('error', () => link.classList.remove('is-loading'), { once: true });
          image.src = photo.thumbnail;

          link.append(image);
          grid.append(link);
        });
      }

      renderError(grid, message) {
        grid.innerHTML = '';
        grid.setAttribute('aria-busy', 'false');
        const error = document.createElement('div');
        error.className = 'google-photo-gallery__error';
        error.textContent = message;
        grid.append(error);
      }

      ensurePhotoSwipeStyles() {
        if (document.querySelector('link[data-google-photo-gallery-photoswipe]')) {
          return;
        }

        const link = document.createElement('link');
        link.rel = 'stylesheet';
        link.href = 'https://cdn.jsdelivr.net/npm/photoswipe@5/dist/photoswipe.css';
        link.dataset.googlePhotoGalleryPhotoswipe = 'true';
        document.head.append(link);
      }

      async handlePhotoClick(event, link) {
        if (link.dataset.needsImageDimensions !== 'true') {
          return;
        }

        event.preventDefault();
        event.stopPropagation();

        await this.initializePhotoSwipe();
        await this.updateLinkImageDimensions(link);

        const links = Array.from(this.querySelectorAll('.google-photo-gallery__tile'));
        const index = links.indexOf(link);

        if (index >= 0) {
          this.photoSwipeLightbox?.loadAndOpen(index);
        }
      }

      updateLinkImageDimensions(link) {
        const src = link.href;

        if (!src) {
          return Promise.resolve();
        }

        if (!this.dimensionPromises.has(src)) {
          this.dimensionPromises.set(
            src,
            new Promise((resolve) => {
              const image = new Image();

              image.onload = () => {
                if (image.naturalWidth > 0 && image.naturalHeight > 0) {
                  resolve({
                    width: image.naturalWidth,
                    height: image.naturalHeight
                  });
                  return;
                }

                resolve(null);
              };

              image.onerror = () => resolve(null);
              image.src = src;
            })
          );
        }

        return this.dimensionPromises.get(src).then((dimensions) => {
          if (dimensions) {
            link.dataset.pswpWidth = String(dimensions.width);
            link.dataset.pswpHeight = String(dimensions.height);
            link.dataset.needsImageDimensions = 'false';
          }
        });
      }

      async initializePhotoSwipe() {
        if (this.photoSwipeLightbox || this.photoSwipeInitPromise) {
          return this.photoSwipeInitPromise;
        }

        this.photoSwipeInitPromise = import('https://cdn.jsdelivr.net/npm/photoswipe@5/dist/photoswipe-lightbox.esm.js')
          .then(({ default: PhotoSwipeLightbox }) => {
            const lightbox = new PhotoSwipeLightbox({
              gallery: this,
              children: '.google-photo-gallery__tile',
              loop: true,
              showHideAnimationType: 'fade',
              pswpModule: () => import('https://cdn.jsdelivr.net/npm/photoswipe@5/dist/photoswipe.esm.js')
            });

            lightbox.on('uiRegister', () => {
              lightbox.pswp.ui.registerElement({
                name: 'google-photo-gallery-watermark',
                order: 9,
                isButton: false,
                appendTo: 'root',
                html: '<img class="google-photo-gallery__pswp-watermark" src="https://cdn.shopify.com/s/files/1/0402/9110/6972/files/sukashi.png?v=1777424554" alt="" aria-hidden="true">'
              });
            });

            lightbox.init();
            this.photoSwipeLightbox = lightbox;
          })
          .catch((error) => {
            this.photoSwipeInitPromise = null;
            console.error('[GooglePhotoGallery] PhotoSwipe failed to load:', error);
          });

        return this.photoSwipeInitPromise;
      }
    }

    customElements.define('google-photo-gallery', GooglePhotoGallery);
  })();
</script>

{% schema %}
{
  "name": "googleDrivephoto",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "見出し",
      "default": "Googleフォトギャラリー"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "説明文"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h2",
          "label": "小"
        },
        {
          "value": "h1",
          "label": "中"
        },
        {
          "value": "h0",
          "label": "大"
        },
        {
          "value": "hxl",
          "label": "特大"
        }
      ],
      "default": "h1",
      "label": "見出しサイズ"
    },
    {
      "type": "text_alignment",
      "id": "heading_alignment",
      "label": "見出し配置",
      "default": "center"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "カラー",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "画像比率",
      "options": [
        {
          "value": "square",
          "label": "1:1"
        },
        {
          "value": "portrait",
          "label": "4:5"
        }
      ],
      "default": "square"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 6,
      "step": 1,
      "label": "PCの列数",
      "default": 4
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "モバイルの列数",
      "options": [
        {
          "value": "1",
          "label": "1列"
        },
        {
          "value": "2",
          "label": "2列"
        }
      ],
      "default": "2"
    },
    {
      "type": "range",
      "id": "grid_gap",
      "min": 4,
      "max": 32,
      "step": 2,
      "unit": "px",
      "label": "画像間の余白",
      "default": 12
    },
    {
      "type": "range",
      "id": "corner_radius",
      "min": 0,
      "max": 28,
      "step": 2,
      "unit": "px",
      "label": "角丸",
      "default": 12
    },
    {
      "type": "range",
      "id": "skeleton_count",
      "min": 2,
      "max": 12,
      "step": 1,
      "label": "読み込み中のプレースホルダー数",
      "default": 8
    },
    {
      "type": "text",
      "id": "loading_text",
      "label": "読み込み中テキスト",
      "default": "Loading..."
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "上の余白",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "下の余白",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "album",
      "name": "Group",
      "settings": [
        {
          "type": "inline_richtext",
