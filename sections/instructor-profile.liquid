                      {%- if prof_license != blank -%}
                        <p class="instructor-profile__meta-item">ライセンス番号：{{ prof_license | escape }}</p>
                      {%- endif -%}
                      {%- if prof_status != blank -%}
                        <p class="instructor-profile__meta-item">{{ prof_status | escape }}</p>
                      {%- endif -%}
                    {%- endif -%}
                  </div>
