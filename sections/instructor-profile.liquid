{%- liquid
  assign ip_param = ''
  if request.url contains '?'
    assign ip_qs = request.url | split: '?' | last
    assign ip_pairs = ip_qs | split: '&'
    for ip_pair in ip_pairs
      assign ip_kv = ip_pair | split: '='
      if ip_kv[0] == 'id'
        assign ip_param = ip_kv[1] | url_decode
        break
      endif
    endfor
  endif

  assign instructor = nil
  if ip_param != ''
    assign _try = shop.metaobjects.instructors[ip_param]
    if _try.system.handle != blank
      assign instructor = _try
    endif
  endif
  if instructor == nil and ip_param != ''
    for m in shop.metaobjects.instructors.values
      if m.bp_id.value == ip_param
        assign instructor = m
        break
      endif
    endfor
  endif
  if instructor == nil and request.design_mode
    for m in shop.metaobjects.instructors.values
      assign instructor = m
      break
    endfor
  endif

  assign is_active = false
  if instructor != nil and instructor.bp_is_active.value
    assign is_active = true
  endif
-%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .instructor-profile__block + .instructor-profile__block { margin-top: 5.6rem; }

  /* Header */
  .instructor-profile__header {
    display: flex;
    flex-direction: column;
    gap: 2.4rem;
    align-items: center;
  }
  @media screen and (min-width: 750px) {
    .instructor-profile__header { flex-direction: row; align-items: flex-start; gap: 4rem; }
  }
  .instructor-profile__photo {
    flex: 0 0 auto;
    width: 18rem;
    height: 18rem;
    border-radius: 50%;
    overflow: hidden;
    background: rgba(var(--color-foreground), 0.06);
  }
  @media screen and (min-width: 750px) { .instructor-profile__photo { width: 22rem; height: 22rem; } }
  .instructor-profile__photo img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .instructor-profile__photo-placeholder {
    width: 100%; height: 100%;
    display: flex; align-items: center; justify-content: center;
    color: rgba(var(--color-foreground), 0.3);
  }
  .instructor-profile__photo-placeholder svg { width: 5rem; height: 5rem; }
  .instructor-profile__info { flex: 1 1 0; min-width: 0; }
  .instructor-profile__name {
    font-size: 2.4rem; font-weight: 700; margin: 0 0 0.4rem; line-height: 1.2;
  }
  @media screen and (min-width: 750px) { .instructor-profile__name { font-size: 3rem; } }
  .instructor-profile__name-kana {
    font-size: 1.3rem; color: rgba(var(--color-foreground), 0.6);
    margin: 0 0 1.2rem; letter-spacing: 0.06em;
  }
  .instructor-profile__rank {
    display: inline-block;
    padding: 0.3rem 1rem;
    border: 1px solid rgba(var(--color-foreground), 0.3);
    border-radius: 2rem;
    font-size: 1.2rem; font-weight: 600; letter-spacing: 0.05em;
    margin: 0 0 1.2rem;
  }
  .instructor-profile__meta { display: flex; flex-direction: column; gap: 0.4rem; margin-bottom: 1.6rem; }
  .instructor-profile__meta-item { font-size: 1.4rem; color: rgba(var(--color-foreground), 0.7); margin: 0; }
  .instructor-profile__sns { display: flex; gap: 1.2rem; flex-wrap: wrap; }
  .instructor-profile__sns-link {
    display: inline-flex; align-items: center; gap: 0.5rem;
    font-size: 1.3rem; color: rgb(var(--color-link));
    text-decoration: none; transition: opacity 0.2s;
  }
  .instructor-profile__sns-link:hover { opacity: 0.7; }
  .instructor-profile__sns-link svg { width: 1.8rem; height: 1.8rem; flex: 0 0 auto; }

  /* Section heading */
  .instructor-profile__section-heading {
    font-size: 1.8rem; font-weight: 700;
    margin: 0 0 2rem;
    padding-bottom: 0.8rem;
    border-bottom: 2px solid rgba(var(--color-foreground), 0.12);
  }

  /* Bio */
  .instructor-profile__bio {
    font-size: 1.5rem; line-height: 1.85;
    white-space: pre-wrap;
    color: rgba(var(--color-foreground), 0.85);
    margin: 0;
  }

  /* Gallery */
  .instructor-profile__gallery-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.8rem;
  }
  {%- for block in section.blocks -%}
    {%- if block.type == 'gallery' -%}
      @media screen and (min-width: 750px) {
        .instructor-profile__gallery-grid {
          grid-template-columns: repeat({{ block.settings.columns | default: 3 }}, 1fr);
        }
      }
    {%- endif -%}
  {%- endfor -%}
  .instructor-profile__gallery-item {
    position: relative; aspect-ratio: 1; overflow: hidden;
    border-radius: 0.4rem; cursor: pointer;
    background: rgba(var(--color-foreground), 0.06);
    border: none; padding: 0; display: block; width: 100%;
    transition: transform 0.2s, opacity 0.2s;
  }
  .instructor-profile__gallery-item:hover { opacity: 0.85; transform: scale(1.02); }
  .instructor-profile__gallery-item img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .instructor-profile__gallery-overlay {
    position: absolute; inset: 0; pointer-events: none;
    background: rgba(0,0,0,0); transition: background 0.2s;
  }
  .instructor-profile__gallery-item:hover .instructor-profile__gallery-overlay { background: rgba(0,0,0,0.12); }

  /* Lightbox */
  .instructor-lightbox {
    display: none; position: fixed; inset: 0; z-index: 9999;
    background: rgba(0,0,0,0.88);
    align-items: center; justify-content: center;
  }
  .instructor-lightbox.is-open { display: flex; }
  .instructor-lightbox__img-wrap {
    position: relative;
    max-width: min(90vw, 120rem); max-height: 90vh;
    display: flex; align-items: center; justify-content: center;
  }
  .instructor-lightbox__img {
    max-width: 100%; max-height: 90vh; object-fit: contain;
    display: block; border-radius: 0.4rem;
  }
  .instructor-lightbox__btn {
    position: absolute;
    background: rgba(255,255,255,0.15); border: none; color: #fff;
    cursor: pointer; padding: 0;
    display: flex; align-items: center; justify-content: center;
    border-radius: 50%; width: 4.4rem; height: 4.4rem;
    font-size: 2.4rem; line-height: 1;
    transition: background 0.2s; z-index: 1;
  }
  .instructor-lightbox__btn:hover { background: rgba(255,255,255,0.28); }
  .instructor-lightbox__close { position: fixed; top: 1.6rem; right: 1.6rem; }
  .instructor-lightbox__prev { left: -5.5rem; }
  .instructor-lightbox__next { right: -5.5rem; }
  @media screen and (max-width: 749px) {
    .instructor-lightbox__prev { left: 0.5rem; }
    .instructor-lightbox__next { right: 0.5rem; }
  }

  /* Workshops */
  .instructor-profile__workshop-item + .instructor-profile__workshop-item {
    margin-top: 3.2rem; padding-top: 3.2rem;
    border-top: 1px solid rgba(var(--color-foreground), 0.1);
  }
  .instructor-profile__workshop-title { font-size: 1.7rem; font-weight: 700; margin: 0 0 1.6rem; }
  .instructor-profile__workshop-title a { color: inherit; text-decoration: none; }
  .instructor-profile__workshop-title a:hover { text-decoration: underline; }
  .instructor-profile__workshop-thumb {
    width: 100%; max-width: 36rem; aspect-ratio: 16/9;
    object-fit: cover; border-radius: 0.4rem; margin-bottom: 1.2rem; display: block;
  }
  .instructor-profile__variants { display: flex; flex-direction: column; gap: 0.8rem; }
  .instructor-profile__variant-btn {
    display: flex; justify-content: space-between; align-items: center; gap: 1rem;
    text-align: left; padding: 1rem 1.6rem; border-radius: 0.6rem;
    font-size: 1.4rem; text-decoration: none; transition: opacity 0.15s;
  }
  .instructor-profile__variant-btn:hover { opacity: 0.82; }
  .instructor-profile__variant-btn--available {
    background: rgb(var(--color-button)); color: rgb(var(--color-button-text));
  }
  .instructor-profile__variant-btn--soldout {
    background: transparent; color: rgba(var(--color-foreground), 0.45);
    border: 1px solid rgba(var(--color-foreground), 0.2); pointer-events: none;
  }
  .instructor-profile__variant-badge {
    font-size: 1.1rem; font-weight: 600; flex: 0 0 auto;
    padding: 0.2rem 0.7rem; border-radius: 0.3rem;
    background: rgba(255,255,255,0.18); white-space: nowrap;
  }
  .instructor-profile__variant-btn--soldout .instructor-profile__variant-badge {
    background: rgba(var(--color-foreground), 0.08);
  }

  /* Artworks */
  .instructor-profile__artworks-grid {
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.6rem;
  }
  @media screen and (min-width: 750px) {
    .instructor-profile__artworks-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media screen and (min-width: 990px) {
    .instructor-profile__artworks-grid { grid-template-columns: repeat(4, 1fr); }
  }
  .instructor-profile__artwork-card { display: block; text-decoration: none; color: inherit; transition: opacity 0.2s; }
  .instructor-profile__artwork-card:hover { opacity: 0.8; }
  .instructor-profile__artwork-img-wrap {
    aspect-ratio: 1; overflow: hidden; border-radius: 0.4rem;
    background: rgba(var(--color-foreground), 0.06); margin-bottom: 0.8rem;
  }
  .instructor-profile__artwork-img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .instructor-profile__artwork-title { font-size: 1.3rem; font-weight: 600; margin: 0 0 0.2rem; line-height: 1.3; }
  .instructor-profile__artwork-price { font-size: 1.2rem; color: rgba(var(--color-foreground), 0.65); margin: 0; }

  /* Instagram embed */
  .instructor-profile__ig-embed { overflow: hidden; }

  /* Not found */
  .instructor-profile__not-found {
    text-align: center; padding: 8rem 2rem;
    color: rgba(var(--color-foreground), 0.45); font-size: 1.5rem;
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width section-{{ section.id }}-padding">

    {%- if instructor == nil or is_active == false -%}

      {%- unless request.design_mode -%}
        <div class="instructor-profile__not-found">
          <p>{{ section.settings.not_found_message | escape }}</p>
        </div>
      {%- else -%}
        <div class="instructor-profile__not-found">
          <p>テーマエディター表示中：メタオブジェクト「instructors」にデータを登録すると、ここにプロフィールが表示されます。</p>
        </div>
      {%- endunless -%}

    {%- else -%}

      {%- liquid
        assign prof_name = instructor.name.value
        if prof_name == blank
          assign _last  = instructor.bp_last_name.value  | default: ''
          assign _first = instructor.bp_first_name.value | default: ''
          assign prof_name = _last | append: ' ' | append: _first | strip
        endif
        if prof_name == blank
          assign prof_name = instructor.system.handle
        endif
        assign prof_kana_last  = instructor.bp_last_name_kana.value  | default: ''
        assign prof_kana_first = instructor.bp_first_name_kana.value | default: ''
        assign prof_kana = prof_kana_last | append: ' ' | append: prof_kana_first | strip
        assign prof_photo    = instructor.bp_photo_profile.value
        assign prof_rank     = instructor.bp_rank.value
        assign prof_nickname = instructor.bp_nickname.value
        assign prof_license  = instructor.bp_license_no.value
        assign prof_status   = instructor.bp_status.value
        assign prof_bio      = instructor.bp_bio.value
        assign prof_ig_url   = instructor.bp_sns_ig.value
        assign prof_fb_url   = instructor.bp_sns_fb.value
        assign prof_ig_embed = instructor.bp_sns_ig_embed.value
        assign prof_works    = instructor.bp_photo_work001.value
        assign prof_artworks = instructor.bp_related_artworks.value
        assign prof_workshops = instructor.bp_related_workshops.value
      -%}

      {%- for block in section.blocks -%}

        {%- case block.type -%}

          {%- when 'profile_header' -%}
            <div class="instructor-profile__block instructor-profile__header" {{ block.shopify_attributes }}>
              <div class="instructor-profile__photo">
                {%- if prof_photo != blank -%}
                  <img
                    src="{{ prof_photo | image_url: width: 440 }}"
                    alt="{{ prof_name | escape }}"
                    width="440"
                    height="440"
                    loading="eager"
                  >
                {%- else -%}
                  <div class="instructor-profile__photo-placeholder" aria-hidden="true">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                      <path d="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z"/>
                    </svg>
                  </div>
                {%- endif -%}
              </div>
              <div class="instructor-profile__info">
                <h1 class="instructor-profile__name">{{ prof_name | escape }}</h1>
                {%- if prof_kana != blank and prof_kana != ' ' -%}
                  <p class="instructor-profile__name-kana">{{ prof_kana | escape }}</p>
                {%- endif -%}
                {%- if block.settings.show_rank and prof_rank != blank -%}
                  <div><span class="instructor-profile__rank">{{ prof_rank | escape }}</span></div>
                {%- endif -%}
                <div class="instructor-profile__meta">
                  {%- if prof_nickname != blank -%}
                    <p class="instructor-profile__meta-item">{{ prof_nickname | escape }}</p>
                  {%- endif -%}
                  {%- if block.settings.show_license -%}
                    {%- if prof_license != blank -%}
                      <p class="instructor-profile__meta-item">ライセンス番号：{{ prof_license | escape }}</p>
                    {%- endif -%}
                    {%- if prof_status != blank -%}
                      <p class="instructor-profile__meta-item">{{ prof_status | escape }}</p>
                    {%- endif -%}
                  {%- endif -%}
                </div>
                {%- if block.settings.show_sns and (prof_ig_url != blank or prof_fb_url != blank) -%}
                  <div class="instructor-profile__sns">
                    {%- if prof_ig_url != blank -%}
                      <a
                        href="{{ prof_ig_url | escape }}"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="instructor-profile__sns-link"
                      >
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                          <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                        </svg>
                        Instagram
                      </a>
                    {%- endif -%}
                    {%- if prof_fb_url != blank -%}
                      <a
                        href="{{ prof_fb_url | escape }}"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="instructor-profile__sns-link"
                      >
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                          <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                        </svg>
                        Facebook
                      </a>
                    {%- endif -%}
                  </div>
                {%- endif -%}
              </div>
            </div>

          {%- when 'bio' -%}
            {%- if prof_bio != blank -%}
              <div class="instructor-profile__block" {{ block.shopify_attributes }}>
                {%- if block.settings.heading != blank -%}
                  <h2 class="instructor-profile__section-heading">{{ block.settings.heading | escape }}</h2>
                {%- endif -%}
                <p class="instructor-profile__bio">{{ prof_bio | escape }}</p>
              </div>
            {%- endif -%}

          {%- when 'gallery' -%}
            {%- if prof_works != blank and prof_works.size > 0 -%}
              <div class="instructor-profile__block" {{ block.shopify_attributes }}>
                {%- if block.settings.heading != blank -%}
                  <h2 class="instructor-profile__section-heading">{{ block.settings.heading | escape }}</h2>
                {%- endif -%}
                <div data-instructor-gallery>
                  <div class="instructor-profile__gallery-grid">
                    {%- for img in prof_works -%}
                      <button
                        class="instructor-profile__gallery-item"
                        type="button"
                        data-lightbox-trigger
                        data-lightbox-src="{{ img | image_url: width: 1600 }}"
                        aria-label="{{ prof_name | escape }} 作品 {{ forloop.index }}"
                      >
                        <img
                          src="{{ img | image_url: width: 600, height: 600, crop: 'center' }}"
                          alt=""
                          width="600"
                          height="600"
                          loading="lazy"
                        >
                        <span class="instructor-profile__gallery-overlay" aria-hidden="true"></span>
                      </button>
                    {%- endfor -%}
                  </div>
                  <div
                    class="instructor-lightbox"
                    role="dialog"
                    aria-modal="true"
                    aria-label="作品ギャラリー"
                    data-lightbox-modal
                    tabindex="-1"
                  >
                    <button class="instructor-lightbox__btn instructor-lightbox__close" type="button" data-lightbox-close aria-label="閉じる">&#215;</button>
                    <div class="instructor-lightbox__img-wrap">
                      <button class="instructor-lightbox__btn instructor-lightbox__prev" type="button" data-lightbox-prev aria-label="前の画像">&#8249;</button>
                      <img class="instructor-lightbox__img" src="" alt="" data-lightbox-img>
                      <button class="instructor-lightbox__btn instructor-lightbox__next" type="button" data-lightbox-next aria-label="次の画像">&#8250;</button>
                    </div>
                  </div>
                </div>
              </div>
            {%- endif -%}

          {%- when 'workshops' -%}
            {%- if prof_workshops != blank and prof_workshops.size > 0 -%}
              <div class="instructor-profile__block" {{ block.shopify_attributes }}>
                {%- if block.settings.heading != blank -%}
                  <h2 class="instructor-profile__section-heading">{{ block.settings.heading | escape }}</h2>
                {%- endif -%}
                <div class="instructor-profile__workshops">
                  {%- for ws in prof_workshops -%}
                    <div class="instructor-profile__workshop-item">
                      {%- if block.settings.show_product_image and ws.featured_image != blank -%}
                        <img
                          class="instructor-profile__workshop-thumb"
                          src="{{ ws.featured_image | image_url: width: 720 }}"
                          alt="{{ ws.title | escape }}"
                          width="720"
                          height="405"
                          loading="lazy"
                        >
                      {%- endif -%}
                      <h3 class="instructor-profile__workshop-title">
                        <a href="{{ ws.url }}">{{ ws.title | escape }}</a>
                      </h3>
                      <div class="instructor-profile__variants">
                        {%- if ws.has_only_default_variant -%}
                          <a
                            href="{{ ws.url }}"
                            class="instructor-profile__variant-btn {% if ws.available %}instructor-profile__variant-btn--available{% else %}instructor-profile__variant-btn--soldout{% endif %}"
                          >
                            <span>詳細・お申込み</span>
                            {%- if ws.available -%}
                              <span class="instructor-profile__variant-badge">申込む</span>
                            {%- else -%}
                              <span class="instructor-profile__variant-badge">満席</span>
                            {%- endif -%}
                          </a>
                        {%- else -%}
                          {%- for variant in ws.variants -%}
                            <a
                              href="{{ variant.url }}"
                              class="instructor-profile__variant-btn {% if variant.available %}instructor-profile__variant-btn--available{% else %}instructor-profile__variant-btn--soldout{% endif %}"
                              {%- unless variant.available %} aria-disabled="true"{% endunless %}
                            >
                              <span>{{ variant.title | escape }}</span>
                              {%- if variant.available -%}
                                <span class="instructor-profile__variant-badge">申込む</span>
                              {%- else -%}
                                <span class="instructor-profile__variant-badge">満席</span>
                              {%- endif -%}
                            </a>
                          {%- endfor -%}
                        {%- endif -%}
                      </div>
                    </div>
                  {%- endfor -%}
                </div>
              </div>
            {%- endif -%}

          {%- when 'artworks' -%}
            {%- if prof_artworks != blank and prof_artworks.size > 0 -%}
              <div class="instructor-profile__block" {{ block.shopify_attributes }}>
                {%- if block.settings.heading != blank -%}
                  <h2 class="instructor-profile__section-heading">{{ block.settings.heading | escape }}</h2>
                {%- endif -%}
                <div class="instructor-profile__artworks-grid">
                  {%- for artwork in prof_artworks -%}
                    <a href="{{ artwork.url }}" class="instructor-profile__artwork-card">
                      <div class="instructor-profile__artwork-img-wrap">
                        {%- if artwork.featured_image != blank -%}
                          <img
                            class="instructor-profile__artwork-img"
                            src="{{ artwork.featured_image | image_url: width: 400, height: 400, crop: 'center' }}"
                            alt="{{ artwork.title | escape }}"
                            width="400"
                            height="400"
                            loading="lazy"
                          >
                        {%- endif -%}
                      </div>
                      <p class="instructor-profile__artwork-title">{{ artwork.title | escape }}</p>
                      <p class="instructor-profile__artwork-price">
                        {%- if artwork.price_varies -%}
                          {{ artwork.price_min | money }} 〜
                        {%- else -%}
                          {{ artwork.price | money }}
                        {%- endif -%}
                      </p>
                    </a>
                  {%- endfor -%}
                </div>
              </div>
            {%- endif -%}

          {%- when 'ig_embed' -%}
            {%- if prof_ig_embed != blank -%}
              <div class="instructor-profile__block" {{ block.shopify_attributes }}>
                {%- if block.settings.heading != blank -%}
                  <h2 class="instructor-profile__section-heading">{{ block.settings.heading | escape }}</h2>
                {%- endif -%}
                <div class="instructor-profile__ig-embed">{{ prof_ig_embed }}</div>
              </div>
            {%- endif -%}

        {%- endcase -%}

      {%- endfor -%}

    {%- endif -%}

  </div>
</div>

<script>
(function () {
  function initGallery(el) {
    var triggers = Array.from(el.querySelectorAll('[data-lightbox-trigger]'));
    var modal    = el.querySelector('[data-lightbox-modal]');
    var img      = el.querySelector('[data-lightbox-img]');
    if (!triggers.length || !modal) return;
    var current = 0;

    function update() {
      var src = triggers[current] && triggers[current].dataset.lightboxSrc;
      if (img && src) img.src = src;
    }
    function open(i) {
      current = i; update();
      modal.classList.add('is-open');
      document.body.style.overflow = 'hidden';
      modal.focus();
    }
    function close() {
      modal.classList.remove('is-open');
      document.body.style.overflow = '';
    }
    function nav(dir) {
      current = (current + dir + triggers.length) % triggers.length;
      update();
    }

    triggers.forEach(function (t, i) { t.addEventListener('click', function () { open(i); }); });
    var closeBtn = el.querySelector('[data-lightbox-close]');
    var prevBtn  = el.querySelector('[data-lightbox-prev]');
    var nextBtn  = el.querySelector('[data-lightbox-next]');
    if (closeBtn) closeBtn.addEventListener('click', close);
    if (prevBtn)  prevBtn.addEventListener('click',  function () { nav(-1); });
    if (nextBtn)  nextBtn.addEventListener('click',  function () { nav(1); });
    modal.addEventListener('click', function (e) { if (e.target === modal) close(); });
    document.addEventListener('keydown', function (e) {
      if (!modal.classList.contains('is-open')) return;
      if (e.key === 'Escape')     close();
      if (e.key === 'ArrowLeft')  nav(-1);
      if (e.key === 'ArrowRight') nav(1);
    });
  }

  document
    .querySelectorAll('#shopify-section-{{ section.id }} [data-instructor-gallery]')
    .forEach(initGallery);
})();
</script>

