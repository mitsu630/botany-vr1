  "disabled_on": { "groups": ["header", "footer"] },
  "blocks": [
    {
      "type": "profile_header",
      "name": "プロフィールヘッダー",
      "limit": 1,
      "settings": [
        { "type": "checkbox", "id": "show_rank",    "label": "ランクを表示",                   "default": true  },
        { "type": "checkbox", "id": "show_license", "label": "ライセンス番号・ステータスを表示", "default": false },
        { "type": "checkbox", "id": "show_sns",     "label": "SNSリンクを表示",                "default": true  }
      ]
    },
    {
      "type": "bio",
      "name": "プロフィール文",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "heading", "label": "見出し", "default": "プロフィール" }
      ]
    },
    {
      "type": "gallery",
      "name": "作品ギャラリー",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "heading", "label": "見出し", "default": "作品ギャラリー" },
