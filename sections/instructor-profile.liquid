                    {%- endif -%}
                  {%- endif -%}
                </div>
              </div>
            </div>
            <hr class="instructor-profile__divider">

          {%- when 'bio' -%}
            <div class="instructor-profile__block instructor-profile__card instructor-profile__card--bio" {{ block.shopify_attributes }}>
              {%- if block.settings.heading != blank -%}
                <div class="instructor-profile__section-label">{{ block.settings.heading | escape }}</div>
              {%- endif -%}
              {%- if prof_bio != blank -%}
                <p class="instructor-profile__bio">{{ prof_bio | escape }}</p>
              {%- elsif request.design_mode -%}
                <p class="instructor-profile__bio" style="opacity:0.4;">（プロフィール文が未設定です）</p>
              {%- endif -%}
            </div>
            <hr class="instructor-profile__divider">

          {%- when 'gallery' -%}
            <div class="instructor-profile__block" {{ block.shopify_attributes }}>
              {%- if block.settings.heading != blank -%}
                <div class="instructor-profile__section-label">{{ block.settings.heading | escape }}</div>
              {%- endif -%}
              {%- if prof_works != blank and prof_works.size > 0 -%}
                <div data-instructor-gallery>
                  <div class="instructor-profile__gallery-grid">
                    {%- for img in prof_works -%}
                      <button
                        class="instructor-profile__gallery-item"
                        type="button"
                        data-lightbox-trigger
                        data-lightbox-src="{{ img | image_url: width: 1600 }}"
                        aria-label="{{ prof_name | escape }} 作品 {{ forloop.index }}"
                      >
                        <img
                          src="{{ img | image_url: width: 600, height: 600, crop: 'center' }}"
                          alt=""
                          width="600"
                          height="600"
                          loading="lazy"
                        >
                        <span class="instructor-profile__gallery-overlay" aria-hidden="true"></span>
                      </button>
                    {%- endfor -%}
                  </div>
                  <div
                    class="instructor-lightbox"
                    role="dialog"
                    aria-modal="true"
                    aria-label="作品ギャラリー"
                    data-lightbox-modal
                    tabindex="-1"
                  >
                    <button class="instructor-lightbox__btn instructor-lightbox__close" type="button" data-lightbox-close aria-label="閉じる">&#215;</button>
                    <div class="instructor-lightbox__img-wrap">
                      <button class="instructor-lightbox__btn instructor-lightbox__prev" type="button" data-lightbox-prev aria-label="前の画像">&#8249;</button>
                      <img class="instructor-lightbox__img" src="" alt="" width="1600" height="1600" data-lightbox-img>
                      <button class="instructor-lightbox__btn instructor-lightbox__next" type="button" data-lightbox-next aria-label="次の画像">&#8250;</button>
                    </div>
                  </div>
                </div>
              {%- elsif request.design_mode -%}
                <p style="opacity:0.4;">（作品写真が未設定です）</p>
              {%- endif -%}
            </div>
            <hr class="instructor-profile__divider">

          {%- when 'workshops' -%}
            <div class="instructor-profile__block" {{ block.shopify_attributes }}>
              {%- if block.settings.heading != blank -%}
                <div class="instructor-profile__section-label">{{ block.settings.heading | escape }}</div>
              {%- endif -%}
              {%- if prof_workshops != blank and prof_workshops.size > 0 -%}
                <div class="instructor-profile__workshops">
                  {%- for ws in prof_workshops -%}
                    <div class="instructor-profile__workshop-item">
                      <div class="instructor-profile__workshop-card">
                        <div class="instructor-profile__workshop-row">
                          {%- if block.settings.show_product_image and ws.featured_image != blank -%}
                            <div class="instructor-profile__workshop-thumb-wrap">
                              <img
                                src="{{ ws.featured_image | image_url: width: 360, height: 360, crop: 'center' }}"
                                alt="{{ ws.title | escape }}"
                                width="360"
                                height="360"
                                loading="lazy"
                              >
                            </div>
                          {%- endif -%}
                          <div class="instructor-profile__workshop-body">
                            <h3 class="instructor-profile__workshop-title">
                              <a href="{{ ws.url }}">{{ ws.title | escape }}</a>
                            </h3>
                            <p class="instructor-profile__workshop-price">
                              {%- if ws.price_varies -%}
                                {{ ws.price_min | money }}〜
                              {%- else -%}
                                {{ ws.price | money }}
                              {%- endif -%}
                            </p>
                            <div class="instructor-profile__workshop-dates">
                              {%- if ws.has_only_default_variant -%}
                                <a
                                  href="{{ ws.url }}"
                                  class="instructor-profile__ws-date {% if ws.available %}instructor-profile__ws-date--available{% else %}instructor-profile__ws-date--soldout{% endif %}"
                                >
                                  {%- if ws.available -%}詳細・お申込み{%- else -%}満席{%- endif -%}
                                </a>
                              {%- else -%}
                                {%- for variant in ws.variants -%}
                                  <a
                                    href="{{ variant.url }}"
                                    class="instructor-profile__ws-date {% if variant.available %}instructor-profile__ws-date--available{% else %}instructor-profile__ws-date--soldout{% endif %}"
                                    {%- unless variant.available %} aria-disabled="true"{% endunless %}
                                  >
                                    {{ variant.title | escape }}
                                  </a>
                                {%- endfor -%}
                              {%- endif -%}
                            </div>
                          </div>
                        </div>
                      </div>
                    </div>
                  {%- endfor -%}
                </div>
              {%- elsif request.design_mode -%}
                <p style="opacity:0.4;">（担当ワークショップが未設定です）</p>
              {%- endif -%}
            </div>
            <hr class="instructor-profile__divider">

          {%- when 'artworks' -%}
            <div class="instructor-profile__block" {{ block.shopify_attributes }}>
              {%- if block.settings.heading != blank -%}
                <h2 class="instructor-profile__section-heading">{{ block.settings.heading | escape }}</h2>
              {%- endif -%}
              {%- if prof_artworks != blank and prof_artworks.size > 0 -%}
                <div class="instructor-profile__artworks-grid">
                  {%- for artwork in prof_artworks -%}
                    <a href="{{ artwork.url }}" class="instructor-profile__artwork-card">
                      <div class="instructor-profile__artwork-img-wrap">
                        {%- if artwork.featured_image != blank -%}
                          <img
                            class="instructor-profile__artwork-img"
                            src="{{ artwork.featured_image | image_url: width: 400, height: 400, crop: 'center' }}"
                            alt="{{ artwork.title | escape }}"
                            width="400"
                            height="400"
                            loading="lazy"
                          >
                        {%- endif -%}
                      </div>
                      <p class="instructor-profile__artwork-title">{{ artwork.title | escape }}</p>
                      <p class="instructor-profile__artwork-price">
                        {%- if artwork.price_varies -%}
                          {{ artwork.price_min | money }} 〜
                        {%- else -%}
                          {{ artwork.price | money }}
                        {%- endif -%}
                      </p>
                    </a>
                  {%- endfor -%}
                </div>
              {%- elsif request.design_mode -%}
                <p style="opacity:0.4;">（関連作品が未設定です）</p>
              {%- endif -%}
            </div>

          {%- when 'ig_embed' -%}
            <div class="instructor-profile__block" {{ block.shopify_attributes }}>
              {%- if block.settings.heading != blank -%}
                <h2 class="instructor-profile__section-heading">{{ block.settings.heading | escape }}</h2>
              {%- endif -%}
              {%- if prof_ig_embed != blank -%}
                <div class="instructor-profile__ig-embed">{{ prof_ig_embed }}</div>
              {%- elsif request.design_mode -%}
                <p style="opacity:0.4;">（Instagram埋め込みコードが未設定です）</p>
              {%- endif -%}
            </div>

        {%- endcase -%}

      {%- endfor -%}

    {%- endif -%}

    </div>
  </div>
</div>

<script>
(function () {
  function initGallery(el) {
    var triggers = Array.from(el.querySelectorAll('[data-lightbox-trigger]'));
    var modal    = el.querySelector('[data-lightbox-modal]');
    var img      = el.querySelector('[data-lightbox-img]');
    if (!triggers.length || !modal) return;
    var current = 0;

    function update() {
      var src = triggers[current] && triggers[current].dataset.lightboxSrc;
      if (img && src) img.src = src;
    }
    function open(i) {
      current = i; update();
      modal.classList.add('is-open');
      document.body.style.overflow = 'hidden';
      modal.focus();
    }
    function close() {
      modal.classList.remove('is-open');
      document.body.style.overflow = '';
    }
    function nav(dir) {
      current = (current + dir + triggers.length) % triggers.length;
      update();
    }

    triggers.forEach(function (t, i) { t.addEventListener('click', function () { open(i); }); });
    var closeBtn = el.querySelector('[data-lightbox-close]');
    var prevBtn  = el.querySelector('[data-lightbox-prev]');
    var nextBtn  = el.querySelector('[data-lightbox-next]');
    if (closeBtn) closeBtn.addEventListener('click', close);
    if (prevBtn)  prevBtn.addEventListener('click',  function () { nav(-1); });
    if (nextBtn)  nextBtn.addEventListener('click',  function () { nav(1); });
    modal.addEventListener('click', function (e) { if (e.target === modal) close(); });
    document.addEventListener('keydown', function (e) {
      if (!modal.classList.contains('is-open')) return;
      if (e.key === 'Escape')     close();
      if (e.key === 'ArrowLeft')  nav(-1);
      if (e.key === 'ArrowRight') nav(1);
    });
  }

  document
    .querySelectorAll('#shopify-section-{{ section.id }} [data-instructor-gallery]')
    .forEach(initGallery);
})();
</script>

{% schema %}
{
