{%- liquid
  assign ip_param = ''

  if request.query_parameters and request.query_parameters.id != blank
    assign ip_param = request.query_parameters.id | url_decode
  endif

  if ip_param == blank and request.params
    if request.params['id'] != blank
      assign ip_param = request.params['id'] | url_decode
    endif
  endif

  if ip_param == blank and request.query_string != blank
    assign ip_pairs = request.query_string | split: '&'
    for ip_pair in ip_pairs
      assign ip_kv = ip_pair | split: '='
      if ip_kv[0] == 'id'
        assign ip_param = ip_kv[1] | url_decode
        break
      endif
    endfor
  endif

  if ip_param == blank and request.url contains '?'
    assign ip_qs = request.url | split: '?' | last
    assign ip_pairs_2 = ip_qs | split: '&'
    for ip_pair in ip_pairs_2
      assign ip_kv = ip_pair | split: '='
      if ip_kv[0] == 'id'
        assign ip_param = ip_kv[1] | url_decode
        break
      endif
    endfor
  endif

  assign instructor = nil
  if ip_param != ''
    if shop.metaobjects.instructors
      assign _try = shop.metaobjects.instructors[ip_param]
      if _try and _try.system and _try.system.handle != blank
        assign instructor = _try
      endif
    endif
  endif
  if instructor == nil and ip_param != ''
    if shop.metaobjects.instructors
      for m in shop.metaobjects.instructors.values
        if m and m.bp_id and m.bp_id.value == ip_param
          assign instructor = m
          break
        endif
      endfor
    endif
  endif
  if instructor == nil and request.design_mode
    if shop.metaobjects.instructors
      for m in shop.metaobjects.instructors.values
        if m
          assign instructor = m
          break
        endif
      endfor
    endif
  endif

  assign is_active = false
  if instructor and instructor.bp_is_active and instructor.bp_is_active.value
    assign is_active = true
  endif
-%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .instructor-profile__block + .instructor-profile__block { margin-top: 5.6rem; }

  .instructor-profile {
    position: relative;
    background-color: {{ section.settings.background_color }};
  }

  .instructor-profile__bg {
    position: absolute;
    inset: 0;
    background-image: {% if section.settings.background_image != blank %}url({{ section.settings.background_image | image_url: width: 2400 }}){% else %}none{% endif %};
    background-size: cover;
    background-repeat: no-repeat;
    background-position: center;
    opacity: {{ section.settings.background_image_opacity | divided_by: 100.0 }};
    pointer-events: none;
  }

  .instructor-profile__bg-overlay {
    position: absolute;
    inset: 0;
    background: {{ section.settings.background_overlay_color }};
    opacity: {{ section.settings.background_overlay_opacity | divided_by: 100.0 }};
    pointer-events: none;
  }

  .instructor-profile__inner {
    position: relative;
    max-width: {{ section.settings.content_max_width }}px;
    margin: 0 auto;
  }

  .instructor-profile__card {
    background: {{ section.settings.card_background_color | color_modify: 'alpha', section.settings.card_background_opacity | divided_by: 100.0 }};
    border-radius: {{ section.settings.card_radius }}px;
    border: 1px solid rgba(var(--color-foreground), 0.08);
    box-shadow: 0 10px 28px rgba(0,0,0,0.10);
    overflow: hidden;
    backdrop-filter: blur({{ section.settings.card_blur }}px);
    -webkit-backdrop-filter: blur({{ section.settings.card_blur }}px);
  }

  .instructor-profile__card--hero {
    padding: 3rem 3rem 2.4rem;
  }

  .instructor-profile__card--bio {
    padding: 2.6rem 3rem 3rem;
  }

  @media screen and (max-width: 749px) {
    .instructor-profile__card--hero { padding: 2.2rem 2rem 1.8rem; }
    .instructor-profile__card--bio  { padding: 2.2rem 2rem 2.4rem; }
  }

  .instructor-profile__hero-label {
    font-size: 1.2rem;
    letter-spacing: 0.08em;
    color: rgba(var(--color-foreground), 0.7);
    margin: 0 0 1.8rem;
  }

  .instructor-profile__divider {
    border: none;
    border-top: 1px solid rgba(var(--color-foreground), 0.10);
    margin: 0;
  }

  .instructor-profile__section-label {
    font-size: 1rem;
    letter-spacing: 0.12em;
    color: rgba(var(--color-foreground), 0.55);
    text-transform: uppercase;
    margin: 0 0 1.2rem;
    padding-bottom: 0.6rem;
    border-bottom: 1px solid rgba(var(--color-foreground), 0.12);
  }

  .instructor-profile__tagrow {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    flex-wrap: wrap;
    margin: 0 0 0.8rem;
  }

  .instructor-profile__tag {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
    padding: 0.3rem 1rem;
    border-radius: 2rem;
    letter-spacing: 0.08em;
    background: {{ section.settings.tag_bg_color }};
    color: {{ section.settings.tag_text_color }};
    border: 1px solid rgba(var(--color-foreground), 0.10);
    white-space: nowrap;
  }

  .instructor-profile__tagmeta {
    font-size: 1.2rem;
    color: rgba(var(--color-foreground), 0.55);
  }

  /* Header */
  .instructor-profile__header {
    display: flex;
    flex-direction: column;
    gap: 2.4rem;
    align-items: center;
  }
  @media screen and (min-width: 750px) {
    .instructor-profile__header { flex-direction: row; align-items: center; gap: 4rem; }
  }
  .instructor-profile__photo {
    flex: 0 0 auto;
    width: 18rem;
    height: 18rem;
    border-radius: 50%;
    overflow: hidden;
    background: rgba(var(--color-foreground), 0.06);
  }
  @media screen and (min-width: 750px) { .instructor-profile__photo { width: 22rem; height: 22rem; } }
  .instructor-profile__photo img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .instructor-profile__photo-placeholder {
    width: 100%; height: 100%;
    display: flex; align-items: center; justify-content: center;
    color: rgba(var(--color-foreground), 0.3);
  }
  .instructor-profile__photo-placeholder svg { width: 5rem; height: 5rem; }
  .instructor-profile__info { flex: 1 1 0; min-width: 0; }
  .instructor-profile__kicker {
    font-size: 1.6rem;
    font-style: italic;
    letter-spacing: 0.05em;
    color: rgba(var(--color-foreground), 0.35);
    margin: 0 0 0.6rem;
    text-align: center;
  }
  @media screen and (min-width: 750px) { .instructor-profile__kicker { text-align: left; } }

  .instructor-profile__name {
    font-size: 3.6rem;
    font-weight: 700;
    margin: 0 0 1.6rem;
    line-height: 1.1;
    font-family: var(--font-heading-family);
    font-style: italic;
    text-shadow: 0 3px 10px rgba(0,0,0,0.18);
    color: rgba(var(--color-foreground), 0.85);
    text-align: center;
  }
  @media screen and (max-width: 749px) { .instructor-profile__name { font-size: 3rem; } }
  @media screen and (min-width: 750px) { .instructor-profile__name { text-align: left; } }

  .instructor-profile__name-kana {
    font-size: 1.3rem;
    color: rgba(var(--color-foreground), 0.55);
    margin: -1.2rem 0 1.2rem;
    letter-spacing: 0.06em;
    text-align: center;
  }
  @media screen and (min-width: 750px) { .instructor-profile__name-kana { text-align: left; } }

  .instructor-profile__meta {
    display: grid;
    gap: 0;
    margin-bottom: 1.2rem;
  }
  .instructor-profile__meta-item {
    font-size: 1.35rem;
    padding: 0.8rem 0;
    color: rgba(var(--color-foreground), 0.75);
    margin: 0;
    border-top: 1px solid rgba(var(--color-foreground), 0.18);
  }
  .instructor-profile__meta-item:first-child { border-top: 0; }

  .instructor-profile__rank {
    display: inline-block;
    padding: 0.3rem 1rem;
    border: 1px solid rgba(var(--color-foreground), 0.3);
    border-radius: 2rem;
    font-size: 1.2rem; font-weight: 600; letter-spacing: 0.05em;
    margin: 0 0 1.2rem;
  }
  .instructor-profile__sns { display: flex; gap: 1.2rem; flex-wrap: wrap; }
  .instructor-profile__sns-link {
    display: inline-flex; align-items: center; gap: 0.5rem;
    font-size: 1.3rem; color: rgb(var(--color-link));
    text-decoration: none; transition: opacity 0.2s;
  }
  .instructor-profile__sns-link:hover { opacity: 0.7; }
  .instructor-profile__sns-link svg { width: 1.8rem; height: 1.8rem; flex: 0 0 auto; }

  /* Section heading */
  .instructor-profile__section-heading {
    font-size: 1.8rem; font-weight: 700;
    margin: 0 0 1.6rem;
    padding-bottom: 0.8rem;
    border-bottom: 2px solid rgba(var(--color-foreground), 0.12);
  }

  /* Bio */
  .instructor-profile__bio {
    font-size: 1.5rem; line-height: 1.85;
    white-space: pre-wrap;
    color: rgba(var(--color-foreground), 0.85);
    margin: 0;
  }

  /* Workshops card layout (mockup-like) */
  .instructor-profile__workshop-card {
    background: rgba(255,255,255,0.55);
    border: 1px solid rgba(var(--color-foreground), 0.10);
    border-radius: 1.2rem;
    overflow: hidden;
  }
  .instructor-profile__workshop-row { display: flex; gap: 0; }
  .instructor-profile__workshop-thumb-wrap {
    width: 9rem;
    min-width: 9rem;
    height: 9rem;
    background: rgba(var(--color-foreground), 0.06);
    overflow: hidden;
  }
  .instructor-profile__workshop-thumb-wrap img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .instructor-profile__workshop-body { padding: 1.2rem; flex: 1; min-width: 0; }
  .instructor-profile__workshop-title { font-size: 1.35rem; font-weight: 600; margin: 0 0 0.4rem; }
  .instructor-profile__workshop-title a { color: inherit; text-decoration: none; }
  .instructor-profile__workshop-title a:hover { text-decoration: underline; }
  .instructor-profile__workshop-price { font-size: 1.15rem; color: rgba(var(--color-foreground), 0.55); margin: 0 0 0.8rem; }
  .instructor-profile__workshop-dates { display: flex; gap: 0.6rem; flex-wrap: wrap; }
  .instructor-profile__ws-date {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.4rem 1.1rem;
    border-radius: 0.6rem;
    font-size: 1.1rem;
    border: 1px solid rgba(var(--color-foreground), 0.18);
    color: rgba(var(--color-foreground), 0.75);
    background: rgba(255,255,255,0.5);
    text-decoration: none;
  }
  .instructor-profile__ws-date--available {
    background: {{ section.settings.tag_bg_color }};
    border-color: {{ section.settings.tag_text_color }};
    color: {{ section.settings.tag_text_color }};
  }
  .instructor-profile__ws-date--soldout {
    background: rgba(var(--color-foreground), 0.04);
    color: rgba(var(--color-foreground), 0.45);
    border-color: rgba(var(--color-foreground), 0.10);
    text-decoration: line-through;
    pointer-events: none;
  }

  /* Gallery */
  .instructor-profile__gallery-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.8rem;
  }
  {%- for block in section.blocks -%}
    {%- if block.type == 'gallery' -%}
      @media screen and (min-width: 750px) {
        .instructor-profile__gallery-grid {
          grid-template-columns: repeat({{ block.settings.columns | default: 3 }}, 1fr);
        }
      }
    {%- endif -%}
  {%- endfor -%}
  .instructor-profile__gallery-item {
    position: relative; aspect-ratio: 1; overflow: hidden;
    border-radius: 0.4rem; cursor: pointer;
    background: rgba(var(--color-foreground), 0.06);
    border: none; padding: 0; display: block; width: 100%;
    transition: transform 0.2s, opacity 0.2s;
  }
  .instructor-profile__gallery-item:hover { opacity: 0.85; transform: scale(1.02); }
  .instructor-profile__gallery-item img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .instructor-profile__gallery-overlay {
    position: absolute; inset: 0; pointer-events: none;
    background: rgba(0,0,0,0); transition: background 0.2s;
  }
  .instructor-profile__gallery-item:hover .instructor-profile__gallery-overlay { background: rgba(0,0,0,0.12); }

  /* Lightbox */
  .instructor-lightbox {
    display: none; position: fixed; inset: 0; z-index: 9999;
    background: rgba(0,0,0,0.88);
    align-items: center; justify-content: center;
  }
  .instructor-lightbox.is-open { display: flex; }
  .instructor-lightbox__img-wrap {
    position: relative;
    max-width: min(90vw, 120rem); max-height: 90vh;
    display: flex; align-items: center; justify-content: center;
  }
  .instructor-lightbox__img {
    max-width: 100%; max-height: 90vh; object-fit: contain;
    display: block; border-radius: 0.4rem;
  }
  .instructor-lightbox__btn {
    position: absolute;
    background: rgba(255,255,255,0.15); border: none; color: #fff;
    cursor: pointer; padding: 0;
    display: flex; align-items: center; justify-content: center;
    border-radius: 50%; width: 4.4rem; height: 4.4rem;
    font-size: 2.4rem; line-height: 1;
    transition: background 0.2s; z-index: 1;
  }
  .instructor-lightbox__btn:hover { background: rgba(255,255,255,0.28); }
  .instructor-lightbox__close { position: fixed; top: 1.6rem; right: 1.6rem; }
  .instructor-lightbox__prev { left: -5.5rem; }
  .instructor-lightbox__next { right: -5.5rem; }
  @media screen and (max-width: 749px) {
    .instructor-lightbox__prev { left: 0.5rem; }
    .instructor-lightbox__next { right: 0.5rem; }
  }

  /* Workshops */
  .instructor-profile__workshop-item + .instructor-profile__workshop-item {
    margin-top: 3.2rem; padding-top: 3.2rem;
    border-top: 1px solid rgba(var(--color-foreground), 0.1);
  }
  .instructor-profile__workshop-title { font-size: 1.7rem; font-weight: 700; margin: 0 0 1.6rem; }
  .instructor-profile__workshop-title a { color: inherit; text-decoration: none; }
  .instructor-profile__workshop-title a:hover { text-decoration: underline; }
  .instructor-profile__workshop-thumb {
    width: 100%; max-width: 36rem; aspect-ratio: 16/9;
    object-fit: cover; border-radius: 0.4rem; margin-bottom: 1.2rem; display: block;
  }
  .instructor-profile__variants { display: flex; flex-direction: column; gap: 0.8rem; }
  .instructor-profile__variant-btn {
    display: flex; justify-content: space-between; align-items: center; gap: 1rem;
    text-align: left; padding: 1rem 1.6rem; border-radius: 0.6rem;
    font-size: 1.4rem; text-decoration: none; transition: opacity 0.15s;
  }
  .instructor-profile__variant-btn:hover { opacity: 0.82; }
  .instructor-profile__variant-btn--available {
    background: rgb(var(--color-button)); color: rgb(var(--color-button-text));
  }
  .instructor-profile__variant-btn--soldout {
    background: transparent; color: rgba(var(--color-foreground), 0.45);
    border: 1px solid rgba(var(--color-foreground), 0.2); pointer-events: none;
  }
  .instructor-profile__variant-badge {
    font-size: 1.1rem; font-weight: 600; flex: 0 0 auto;
    padding: 0.2rem 0.7rem; border-radius: 0.3rem;
    background: rgba(255,255,255,0.18); white-space: nowrap;
  }
  .instructor-profile__variant-btn--soldout .instructor-profile__variant-badge {
    background: rgba(var(--color-foreground), 0.08);
  }

  /* Artworks */
  .instructor-profile__artworks-grid {
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.6rem;
  }
  @media screen and (min-width: 750px) {
    .instructor-profile__artworks-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media screen and (min-width: 990px) {
    .instructor-profile__artworks-grid { grid-template-columns: repeat(4, 1fr); }
  }
  .instructor-profile__artwork-card { display: block; text-decoration: none; color: inherit; transition: opacity 0.2s; }
  .instructor-profile__artwork-card:hover { opacity: 0.8; }
  .instructor-profile__artwork-img-wrap {
    aspect-ratio: 1; overflow: hidden; border-radius: 0.4rem;
    background: rgba(var(--color-foreground), 0.06); margin-bottom: 0.8rem;
  }
  .instructor-profile__artwork-img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .instructor-profile__artwork-title { font-size: 1.3rem; font-weight: 600; margin: 0 0 0.2rem; line-height: 1.3; }
  .instructor-profile__artwork-price { font-size: 1.2rem; color: rgba(var(--color-foreground), 0.65); margin: 0; }

  /* Instagram embed */
  .instructor-profile__ig-embed { overflow: hidden; }

  /* Not found */
  .instructor-profile__not-found {
    text-align: center; padding: 8rem 2rem;
    color: rgba(var(--color-foreground), 0.45); font-size: 1.5rem;
  }
{%- endstyle -%}

<div class="instructor-profile color-{{ section.settings.color_scheme }} gradient">
  <div class="instructor-profile__bg" aria-hidden="true"></div>
  <div class="instructor-profile__bg-overlay" aria-hidden="true"></div>
  <div class="page-width section-{{ section.id }}-padding">
    <div class="instructor-profile__inner">

    {%- if section.settings.debug -%}
      <div style="margin: 0 0 1.2rem; padding: 1.2rem 1.4rem; border: 1px dashed rgba(var(--color-foreground), 0.25); border-radius: 0.8rem; font-size: 12px; background: rgba(255,255,255,0.6);">
        <div><strong>debug</strong></div>
        <div>id(param): <code>{{ ip_param | escape }}</code></div>
        <div>found: <code>{% if instructor %}true{% else %}false{% endif %}</code></div>
        <div>handle: <code>{% if instructor %}{{ instructor.system.handle | escape }}{% else %}-{% endif %}</code></div>
        <div>bp_is_active: <code>{% if instructor and instructor.bp_is_active %}{{ instructor.bp_is_active.value | json }}{% else %}-{% endif %}</code></div>
      </div>
    {%- endif -%}

    {%- if instructor == nil or is_active == false -%}

      {%- unless request.design_mode -%}
        <div class="instructor-profile__not-found">
          <p>{{ section.settings.not_found_message | escape }}</p>
        </div>
      {%- else -%}
        <div class="instructor-profile__not-found">
          <p>テーマエディター表示中：メタオブジェクト「instructors」にデータを登録すると、ここにプロフィールが表示されます。</p>
        </div>
      {%- endunless -%}

    {%- else -%}

      {%- liquid
        assign prof_name = instructor.name.value
        if prof_name == blank
          assign _last  = instructor.bp_last_name.value  | default: ''
          assign _first = instructor.bp_first_name.value | default: ''
          assign prof_name = _last | append: ' ' | append: _first | strip
        endif
        if prof_name == blank
          assign prof_name = instructor.system.handle
        endif
        assign prof_kana_last  = instructor.bp_last_name_kana.value  | default: ''
        assign prof_kana_first = instructor.bp_first_name_kana.value | default: ''
        assign prof_kana = prof_kana_last | append: ' ' | append: prof_kana_first | strip
        assign prof_photo    = instructor.bp_photo_profile.value
        assign prof_rank     = instructor.bp_rank.value
        assign prof_nickname = instructor.bp_nickname.value
        assign prof_license  = instructor.bp_license_no.value
        assign prof_status   = instructor.bp_status.value
        assign prof_bio      = instructor.bp_bio.value
        assign prof_ig_url   = instructor.bp_sns_ig.value
        assign prof_fb_url   = instructor.bp_sns_fb.value
        assign prof_ig_embed = instructor.bp_sns_ig_embed.value
        assign prof_works    = instructor.bp_photo_work001.value
        assign prof_artworks = instructor.bp_related_artworks.value
        assign prof_workshops = instructor.bp_related_workshops.value

        assign prof_location = ''
        if instructor.bp_location and instructor.bp_location.value != blank
          assign prof_location = instructor.bp_location.value
        endif
        assign prof_country = ''
        if instructor.bp_country and instructor.bp_country.value != blank
          assign prof_country = instructor.bp_country.value
        endif

        assign prof_fact_1 = ''
        if instructor.bp_fact_1 and instructor.bp_fact_1.value != blank
          assign prof_fact_1 = instructor.bp_fact_1.value
        endif
        assign prof_fact_2 = ''
        if instructor.bp_fact_2 and instructor.bp_fact_2.value != blank
          assign prof_fact_2 = instructor.bp_fact_2.value
        endif
        assign prof_fact_3 = ''
        if instructor.bp_fact_3 and instructor.bp_fact_3.value != blank
          assign prof_fact_3 = instructor.bp_fact_3.value
        endif
        assign prof_fact_4 = ''
        if instructor.bp_fact_4 and instructor.bp_fact_4.value != blank
          assign prof_fact_4 = instructor.bp_fact_4.value
        endif
      -%}

      {%- for block in section.blocks -%}

        {%- case block.type -%}

          {%- when 'profile_header' -%}
            {%- liquid
              assign hero_label = prof_nickname | default: prof_name
              if hero_label == blank
                assign hero_label = prof_name
              endif
            -%}
            <div class="instructor-profile__block instructor-profile__card instructor-profile__card--hero" {{ block.shopify_attributes }}>
              <p class="instructor-profile__hero-label">{{ hero_label | escape }} 先生</p>
              <div class="instructor-profile__header">
                <div class="instructor-profile__photo">
                  {%- if prof_photo != blank -%}
                    <img
                      src="{{ prof_photo | image_url: width: 440 }}"
                      alt="{{ prof_name | escape }}"
                      width="440"
                      height="440"
                      loading="eager"
                    >
                  {%- else -%}
                    <div class="instructor-profile__photo-placeholder" aria-hidden="true">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12 12c2.7 0 4.8-2.1 4.8-4.8S14.7 2.4 12 2.4 7.2 4.5 7.2 7.2 9.3 12 12 12zm0 2.4c-3.2 0-9.6 1.6-9.6 4.8v2.4h19.2v-2.4c0-3.2-6.4-4.8-9.6-4.8z"/>
                      </svg>
                    </div>
                  {%- endif -%}
                </div>
                <div class="instructor-profile__info">
                <div class="instructor-profile__tagrow">
                  {%- if prof_rank != blank -%}
                    <span class="instructor-profile__tag">{{ prof_rank | escape }}</span>
                  {%- endif -%}
                  {%- if prof_location != blank or prof_country != blank -%}
                    <span class="instructor-profile__tagmeta">
                      {%- if prof_location != blank -%}{{ prof_location | escape }}{%- endif -%}
                      {%- if prof_location != blank and prof_country != blank -%} / {%- endif -%}
                      {%- if prof_country != blank -%}{{ prof_country | escape }}{%- endif -%}
                    </span>
                  {%- endif -%}
                </div>
                {%- if section.settings.hero_kicker != blank -%}
                  <p class="instructor-profile__kicker">{{ section.settings.hero_kicker | escape }}</p>
                {%- endif -%}
                  <h1 class="instructor-profile__name">{{ prof_name | escape }}</h1>
                  {%- if prof_kana != blank and prof_kana != ' ' -%}
                    <p class="instructor-profile__name-kana">{{ prof_kana | escape }}</p>
                  {%- endif -%}
                  <div class="instructor-profile__meta">
                  {%- if prof_fact_1 != blank -%}<p class="instructor-profile__meta-item">{{ prof_fact_1 | escape }}</p>{%- endif -%}
                  {%- if prof_fact_2 != blank -%}<p class="instructor-profile__meta-item">{{ prof_fact_2 | escape }}</p>{%- endif -%}
                  {%- if prof_fact_3 != blank -%}<p class="instructor-profile__meta-item">{{ prof_fact_3 | escape }}</p>{%- endif -%}
                  {%- if prof_fact_4 != blank -%}<p class="instructor-profile__meta-item">{{ prof_fact_4 | escape }}</p>{%- endif -%}
