        { "type": "text",     "id": "heading",            "label": "見出し",          "default": "担当ワークショップ" },
        { "type": "checkbox", "id": "show_product_image", "label": "商品画像を表示", "default": true }
      ]
    },
    {
      "type": "artworks",
      "name": "関連作品",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "heading", "label": "見出し", "default": "関連作品" }
