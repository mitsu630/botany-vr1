{%- paginate metaobjects.instructors.values by 250 -%}
{%- liquid
  assign instructors = metaobjects.instructors.values
  assign workshop_product = section.settings.workshop_product
  if workshop_product == blank
    assign workshop_product = all_products['workshop']
  endif
  assign artworks_collection = section.settings.artworks_collection
  assign workshop_heading = '担当ワークショップ'
  assign show_workshop_product_image = true
  assign artworks_heading = '販売中の作品'
  for block in section.blocks
    case block.type
      when 'workshops'
        assign workshop_heading = block.settings.heading | default: workshop_heading
        assign show_workshop_product_image = block.settings.show_product_image
      when 'artworks'
        assign artworks_heading = block.settings.heading | default: artworks_heading
    endcase
  endfor
-%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .instructor-profile__block + .instructor-profile__block { margin-top: 5.6rem; }

  .instructor-profile {
    position: relative;
    background-color: {{ section.settings.background_color }};
  }

  .instructor-profile__bg {
    position: absolute;
    inset: 0;
    background-image: {% if section.settings.background_image != blank %}url({{ section.settings.background_image | image_url: width: 2400 }}){% else %}none{% endif %};
    background-size: cover;
    background-repeat: no-repeat;
    background-position: center;
    opacity: {{ section.settings.background_image_opacity | divided_by: 100.0 }};
    pointer-events: none;
  }

  .instructor-profile__bg-overlay {
    position: absolute;
    inset: 0;
    background: {{ section.settings.background_overlay_color }};
    opacity: {{ section.settings.background_overlay_opacity | divided_by: 100.0 }};
    pointer-events: none;
  }

  .instructor-profile__inner {
    position: relative;
    max-width: {{ section.settings.content_max_width }}px;
    margin: 0 auto;
  }

  .instructor-profile__card {
    background: {{ section.settings.card_background_color | color_modify: 'alpha', section.settings.card_background_opacity | divided_by: 100.0 }};
    border-radius: {{ section.settings.card_radius }}px;
    border: 1px solid rgba(var(--color-foreground), 0.08);
    box-shadow: 0 10px 28px rgba(0,0,0,0.10);
    overflow: hidden;
    backdrop-filter: blur({{ section.settings.card_blur }}px);
    -webkit-backdrop-filter: blur({{ section.settings.card_blur }}px);
  }

  .instructor-profile__card--hero {
    padding: 3rem 3rem 2.4rem;
  }

  .instructor-profile__card--bio {
    padding: 2.6rem 3rem 3rem;
  }

  @media screen and (max-width: 749px) {
    .instructor-profile__card--hero { padding: 2.2rem 2rem 1.8rem; }
    .instructor-profile__card--bio  { padding: 2.2rem 2rem 2.4rem; }
  }

  .instructor-profile__hero-label {
    font-size: 1.2rem;
    letter-spacing: 0.08em;
    color: rgba(var(--color-foreground), 0.7);
    margin: 0 0 1.8rem;
  }

  .instructor-profile__divider {
    border: none;
    border-top: 1px solid rgba(var(--color-foreground), 0.10);
    margin: 3.6rem 0;
  }

  @media screen and (max-width: 749px) {
    .instructor-profile__divider { margin: 2.8rem 0; }
  }

  .instructor-profile__section-label {
    font-size: 1rem;
    letter-spacing: 0.12em;
    color: rgba(var(--color-foreground), 0.55);
    text-transform: uppercase;
    margin: 0 0 1.2rem;
    padding-bottom: 0.6rem;
    border-bottom: 1px solid rgba(var(--color-foreground), 0.12);
  }

  .instructor-profile__tagrow {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    flex-wrap: wrap;
    margin: 0 0 0.8rem;
  }

  .instructor-profile__tag {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
    padding: 0.3rem 1rem;
    border-radius: 2rem;
    letter-spacing: 0.08em;
    background: {{ section.settings.tag_bg_color }};
    color: {{ section.settings.tag_text_color }};
    border: 1px solid rgba(var(--color-foreground), 0.10);
    white-space: nowrap;
  }

  .instructor-profile__tagmeta {
    font-size: 1.2rem;
    color: rgba(var(--color-foreground), 0.55);
  }

  /* Header */
  .instructor-profile__header {
    display: flex;
    flex-direction: column;
    gap: 2.4rem;
    align-items: center;
  }
  @media screen and (min-width: 750px) {
    .instructor-profile__header { flex-direction: row; align-items: center; gap: 4rem; }
  }
  .instructor-profile__photo {
    flex: 0 0 auto;
    width: 18rem;
    height: 18rem;
    border-radius: 50%;
    overflow: hidden;
    background: rgba(var(--color-foreground), 0.06);
  }
  @media screen and (min-width: 750px) { .instructor-profile__photo { width: 22rem; height: 22rem; } }
  .instructor-profile__photo img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .instructor-profile__photo-placeholder {
    width: 100%; height: 100%;
    display: flex; align-items: center; justify-content: center;
    color: rgba(var(--color-foreground), 0.3);
  }
  .instructor-profile__photo-placeholder svg { width: 5rem; height: 5rem; }
  .instructor-profile__info { flex: 1 1 0; min-width: 0; }
  .instructor-profile__kicker {
    font-size: 1.6rem;
    font-style: italic;
    letter-spacing: 0.05em;
    color: rgba(var(--color-foreground), 0.35);
    margin: 0 0 0.6rem;
    text-align: center;
  }
  @media screen and (min-width: 750px) { .instructor-profile__kicker { text-align: left; } }

  .instructor-profile__name {
    font-size: 3.6rem;
    font-weight: 700;
    margin: 0 0 1.6rem;
    line-height: 1.1;
    font-family: var(--font-heading-family);
    font-style: italic;
    text-shadow: 0 3px 10px rgba(0,0,0,0.18);
    color: rgba(var(--color-foreground), 0.85);
    text-align: center;
  }
  @media screen and (max-width: 749px) { .instructor-profile__name { font-size: 3rem; } }
  @media screen and (min-width: 750px) { .instructor-profile__name { text-align: left; } }

  .instructor-profile__meta {
    display: grid;
    gap: 0;
    margin-bottom: 1.2rem;
  }
  .instructor-profile__meta-item {
    font-size: 1.35rem;
    padding: 0.8rem 0;
    color: rgba(var(--color-foreground), 0.75);
    margin: 0;
    border-top: 1px solid rgba(var(--color-foreground), 0.18);
  }
  .instructor-profile__meta-item:first-child { border-top: 0; }

  .instructor-profile__rank {
    display: inline-block;
    padding: 0.3rem 1rem;
    border: 1px solid rgba(var(--color-foreground), 0.3);
    border-radius: 2rem;
    font-size: 1.2rem; font-weight: 600; letter-spacing: 0.05em;
    margin: 0 0 1.2rem;
  }
  .instructor-profile__sns { display: flex; gap: 1.2rem; flex-wrap: wrap; }
  .instructor-profile__sns-link {
    display: inline-flex; align-items: center; gap: 0.5rem;
    font-size: 1.3rem; color: rgb(var(--color-link));
    text-decoration: none; transition: opacity 0.2s;
  }
  .instructor-profile__sns-link:hover { opacity: 0.7; }
  .instructor-profile__sns-link svg { width: 1.8rem; height: 1.8rem; flex: 0 0 auto; }

  /* Section heading */
  .instructor-profile__section-heading {
    font-size: 1.8rem; font-weight: 700;
    margin: 0 0 1.6rem;
    padding-bottom: 0.8rem;
    border-bottom: 2px solid rgba(var(--color-foreground), 0.12);
  }

  /* Bio */
  .instructor-profile__bio {
    font-size: 1.5rem; line-height: 1.85;
    white-space: pre-wrap;
    color: rgba(var(--color-foreground), 0.85);
    margin: 0;
  }

  /* Workshops */
  .instructor-profile__workshop-list {
    display: grid;
    gap: 1.2rem;
  }
  .instructor-profile__workshop-card {
    background-color: #ffffff;
    border-radius: var(--border-radius, 0.8rem);
    padding: 1.8rem;
    box-shadow: 0 0.1rem 0.4rem rgba(var(--color-foreground), 0.08);
  }
  .instructor-profile__workshop-meta {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin: 0 0 1.2rem;
  }
  .instructor-profile__workshop-venue {
    display: block;
    width: 100%;
    margin: 0;
    font-size: 1.5rem;
    line-height: calc(1 + 0.35 / var(--font-heading-scale));
    font-weight: 600;
    color: rgb(var(--color-foreground));
  }
  .instructor-profile__workshop-datetime {
    display: block;
    width: 100%;
    margin: 0;
    font-size: 1.5rem;
    line-height: calc(1 + 0.5 / var(--font-body-scale));
    color: rgba(var(--color-foreground), 0.7);
  }
  .instructor-profile__workshop-actions {
    margin-top: auto;
  }
  .instructor-profile__workshop-action {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 4.7rem;
    padding: 1rem 1.6rem;
    border: 0.1rem solid transparent;
    font-size: 1.4rem;
    font-weight: 600;
    text-decoration: none;
    text-align: center;
  }
  .instructor-profile__workshop-action--available {
    background: rgb(var(--color-button));
    color: rgb(var(--color-button-text));
  }
  .instructor-profile__workshop-action--soldout {
    background: transparent;
    color: rgba(var(--color-foreground), 0.55);
    border-color: rgba(var(--color-foreground), 0.45);
  }

  /* Gallery */
  .instructor-profile__gallery-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.8rem;
  }
  {%- for block in section.blocks -%}
    {%- if block.type == 'gallery' -%}
      @media screen and (min-width: 750px) {
        .instructor-profile__gallery-grid {
          grid-template-columns: repeat({{ block.settings.columns | default: 3 }}, 1fr);
        }
      }
    {%- endif -%}
  {%- endfor -%}
  .instructor-profile__gallery-item {
    position: relative; aspect-ratio: 1; overflow: hidden;
    border-radius: 0.4rem; cursor: pointer;
    background: rgba(var(--color-foreground), 0.06);
    border: none; padding: 0; display: block; width: 100%;
    transition: transform 0.2s, opacity 0.2s;
  }
  .instructor-profile__gallery-item:hover { opacity: 0.85; transform: scale(1.02); }
  .instructor-profile__gallery-item img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .instructor-profile__gallery-overlay {
    position: absolute; inset: 0; pointer-events: none;
    background: rgba(0,0,0,0); transition: background 0.2s;
  }
  .instructor-profile__gallery-item:hover .instructor-profile__gallery-overlay { background: rgba(0,0,0,0.12); }

  /* Lightbox */
  .instructor-lightbox {
    display: none; position: fixed; inset: 0; z-index: 9999;
    background: rgba(0,0,0,0.88);
    align-items: center; justify-content: center;
  }
  .instructor-lightbox.is-open { display: flex; }
  .instructor-lightbox__img-wrap {
    position: relative;
    max-width: min(90vw, 120rem); max-height: 90vh;
    display: flex; align-items: center; justify-content: center;
  }
  .instructor-lightbox__img {
    max-width: 100%; max-height: 90vh; object-fit: contain;
    display: block; border-radius: 0.4rem;
  }
  .instructor-lightbox__btn {
    position: absolute;
    background: rgba(255,255,255,0.15); border: none; color: #fff;
    cursor: pointer; padding: 0;
    display: flex; align-items: center; justify-content: center;
    border-radius: 50%; width: 4.4rem; height: 4.4rem;
    font-size: 2.4rem; line-height: 1;
    transition: background 0.2s; z-index: 1;
  }
  .instructor-lightbox__btn:hover { background: rgba(255,255,255,0.28); }
  .instructor-lightbox__close { position: fixed; top: 1.6rem; right: 1.6rem; }
  .instructor-lightbox__prev { left: -5.5rem; }
  .instructor-lightbox__next { right: -5.5rem; }
  @media screen and (max-width: 749px) {
    .instructor-lightbox__prev { left: 0.5rem; }
    .instructor-lightbox__next { right: 0.5rem; }
  }

  /* Artworks */
  .instructor-profile__artworks-grid {
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.6rem;
  }
  @media screen and (min-width: 750px) {
    .instructor-profile__artworks-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media screen and (min-width: 990px) {
    .instructor-profile__artworks-grid { grid-template-columns: repeat(4, 1fr); }
  }
  .instructor-profile__artwork-card {
    display: block;
    text-decoration: none;
    color: inherit;
    transition: opacity 0.2s;
    background: rgba(255,255,255,0.55);
    border: 1px solid rgba(var(--color-foreground), 0.10);
    border-radius: 1.2rem;
    overflow: hidden;
    padding: 1rem;
  }
  .instructor-profile__artwork-card:hover { opacity: 0.8; }
  .instructor-profile__artwork-img-wrap {
    aspect-ratio: 1; overflow: hidden; border-radius: 0.4rem;
    background: rgba(var(--color-foreground), 0.06); margin-bottom: 0.8rem;
  }
  .instructor-profile__artwork-img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .instructor-profile__artwork-title { font-size: 1.3rem; font-weight: 600; margin: 0 0 0.2rem; line-height: 1.3; }
  .instructor-profile__artwork-price { font-size: 1.2rem; color: rgba(var(--color-foreground), 0.65); margin: 0; }

  /* Instagram embed */
  .instructor-profile__ig-embed { overflow: hidden; }

  /* Not found */
  .instructor-profile__not-found {
    text-align: center; padding: 8rem 2rem;
    color: rgba(var(--color-foreground), 0.45); font-size: 1.5rem;
  }

{%- endstyle -%}

<div class="instructor-profile color-{{ section.settings.color_scheme }} gradient">
  <div class="instructor-profile__bg" aria-hidden="true"></div>
  <div class="instructor-profile__bg-overlay" aria-hidden="true"></div>
  <div class="page-width section-{{ section.id }}-padding">
    <div class="instructor-profile__inner">

      <div class="instructor-profile__not-found" id="InstructorProfileNotFound-{{ section.id }}" hidden>
        <p>{{ section.settings.not_found_message | escape }}</p>
      </div>
      <div id="InstructorProfileMount-{{ section.id }}"></div>

    </div>
  </div>
</div>

<script>
(function () {
  var blockOrder = [
    {%- for block in section.blocks -%}
      {{ block.type | json }}{% unless forloop.last %},{% endunless %}
    {%- endfor -%}
  ];

  function initGallery(el) {
    var triggers = Array.from(el.querySelectorAll('[data-lightbox-trigger]'));
    var modal    = el.querySelector('[data-lightbox-modal]');
    var img      = el.querySelector('[data-lightbox-img]');
    if (!triggers.length || !modal) return;
    var current = 0;

    function update() {
      var src = triggers[current] && triggers[current].dataset.lightboxSrc;
      if (img && src) img.src = src;
    }
    function open(i) {
      current = i; update();
      modal.classList.add('is-open');
      document.body.style.overflow = 'hidden';
      modal.focus();
    }
    function close() {
      modal.classList.remove('is-open');
      document.body.style.overflow = '';
    }
    function nav(dir) {
      current = (current + dir + triggers.length) % triggers.length;
      update();
    }

    triggers.forEach(function (t, i) { t.addEventListener('click', function () { open(i); }); });
    var closeBtn = el.querySelector('[data-lightbox-close]');
    var prevBtn  = el.querySelector('[data-lightbox-prev]');
    var nextBtn  = el.querySelector('[data-lightbox-next]');
    if (closeBtn) closeBtn.addEventListener('click', close);
    if (prevBtn)  prevBtn.addEventListener('click',  function () { nav(-1); });
    if (nextBtn)  nextBtn.addEventListener('click',  function () { nav(1); });
    modal.addEventListener('click', function (e) { if (e.target === modal) close(); });
    document.addEventListener('keydown', function (e) {
      if (!modal.classList.contains('is-open')) return;
      if (e.key === 'Escape')     close();
      if (e.key === 'ArrowLeft')  nav(-1);
      if (e.key === 'ArrowRight') nav(1);
    });
  }

  function escapeHtml(s) {
    return String(s || '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function getParam(name) {
    try {
      return new URLSearchParams(window.location.search).get(name) || '';
    } catch (e) {
      return '';
    }
  }

  function getInstructorId() {
    var id = (getParam('id') || '').trim();
    if (id) return id;

    if (window.Shopify && window.Shopify.designMode) {
      return {{ section.settings.preview_instructor_id | json }} || '';
    }

    return '';
  }

  function renderWorkshops(instructor) {
    var workshops = instructor.workshops || [];
    if (!workshops.length) return '';

    var html = '';
    html += '<div class="instructor-profile__block">';
    html += '<div class="instructor-profile__section-label">' + escapeHtml(instructor.workshop_heading || '担当ワークショップ') + '</div>';
    html += '<div class="instructor-profile__workshop-list">';

    workshops.forEach(function (workshop) {
      html += '<article class="instructor-profile__workshop-card">';
      html += '<div class="instructor-profile__workshop-meta">';
      if (workshop.venue) html += '<p class="instructor-profile__workshop-venue">' + escapeHtml(workshop.venue) + '</p>';
      if (workshop.datetime) html += '<p class="instructor-profile__workshop-datetime">' + escapeHtml(workshop.datetime) + '</p>';
      if (!workshop.venue && !workshop.datetime && workshop.title) html += '<p class="instructor-profile__workshop-datetime">' + escapeHtml(workshop.title) + '</p>';
      html += '</div>';
      html += '<div class="instructor-profile__workshop-actions">';
      if (workshop.available) {
        html += '<a class="instructor-profile__workshop-action instructor-profile__workshop-action--available" href="' + escapeHtml(workshop.url) + '">講座詳細はこちら</a>';
      } else {
        html += '<a class="instructor-profile__workshop-action instructor-profile__workshop-action--soldout" href="' + escapeHtml(workshop.url) + '">満席（会場詳細はこちら）</a>';
      }
      html += '</div></article>';
    });

    html += '</div></div><hr class="instructor-profile__divider">';
    return html;
  }

  function renderArtworks(instructor) {
    var artworks = instructor.artworks || [];
    if (!artworks.length) return '';

    var html = '';
    html += '<div class="instructor-profile__block">';
    html += '<div class="instructor-profile__section-label">' + escapeHtml(instructor.artworks_heading || '販売中の作品') + '</div>';
    html += '<div class="instructor-profile__artworks-grid">';

    artworks.forEach(function (artwork) {
      html += '<a class="instructor-profile__artwork-card" href="' + escapeHtml(artwork.url) + '">';
      html += '<div class="instructor-profile__artwork-img-wrap">';
      if (artwork.image) {
        html += '<img class="instructor-profile__artwork-img" src="' + escapeHtml(artwork.image) + '" alt="' + escapeHtml(artwork.title) + '" width="600" height="600" loading="lazy">';
      }
      html += '</div>';
      html += '<p class="instructor-profile__artwork-title">' + escapeHtml(artwork.title) + '</p>';
      if (artwork.price) html += '<p class="instructor-profile__artwork-price">' + escapeHtml(artwork.price) + '</p>';
      html += '</a>';
    });

    html += '</div></div><hr class="instructor-profile__divider">';
    return html;
  }

  function render() {
    var mount = document.getElementById('InstructorProfileMount-{{ section.id }}');
    var nf = document.getElementById('InstructorProfileNotFound-{{ section.id }}');
    if (!mount || !nf) return;

    var id = getInstructorId();
    var dataEl = document.getElementById('InstructorProfileData-{{ section.id }}');
    var instructors = [];
    var raw = (dataEl && dataEl.textContent) ? dataEl.textContent : '';
    try { instructors = JSON.parse(raw || '[]'); } catch (e) { instructors = []; }

    var instructor = instructors.find(function (x) {
      if (!x) return false;
      return (x.handle && x.handle === id) || (x.bp_id && x.bp_id === id);
    }) || null;
    var isActive = instructor && instructor.bp_is_active === true;

    if (!instructor || !isActive) {
      nf.hidden = false;
      mount.innerHTML = '';
      return;
    }

    nf.hidden = true;

    var hero = '';
    hero += '<div class="instructor-profile__block instructor-profile__card instructor-profile__card--hero">';
    hero += '<p class="instructor-profile__hero-label">' + escapeHtml(instructor.hero_label || instructor.name) + ' 先生</p>';
    hero += '<div class="instructor-profile__header">';
    hero += '<div class="instructor-profile__photo">';
    if (instructor.photo) {
      hero += '<img src="' + escapeHtml(instructor.photo) + '" alt="' + escapeHtml(instructor.name) + '" width="440" height="440" loading="eager">';
    } else {
      hero += '<div class="instructor-profile__photo-placeholder" aria-hidden="true"></div>';
    }
    hero += '</div>';
    hero += '<div class="instructor-profile__info">';
    hero += '<div class="instructor-profile__tagrow">';
    if (instructor.rank) hero += '<span class="instructor-profile__tag">' + escapeHtml(instructor.rank) + '</span>';
    if (instructor.location || instructor.country) {
      hero += '<span class="instructor-profile__tagmeta">' + escapeHtml(instructor.location || '') +
        ((instructor.location && instructor.country) ? ' / ' : '') + escapeHtml(instructor.country || '') + '</span>';
    }
    hero += '</div>';
    if (instructor.kicker) hero += '<p class="instructor-profile__kicker">' + escapeHtml(instructor.kicker) + '</p>';
    hero += '<h1 class="instructor-profile__name">' + escapeHtml(instructor.name) + '</h1>';
    hero += '<div class="instructor-profile__meta">';
    (instructor.facts || []).forEach(function (f) {
      if (!f) return;
      hero += '<p class="instructor-profile__meta-item">' + escapeHtml(f) + '</p>';
    });
    hero += '</div>';
    if (instructor.sns_ig || instructor.sns_fb) {
      hero += '<div class="instructor-profile__sns">';
      if (instructor.sns_ig) hero += '<a class="instructor-profile__sns-link" href="' + escapeHtml(instructor.sns_ig) + '" target="_blank" rel="noopener noreferrer">Instagram</a>';
      if (instructor.sns_fb) hero += '<a class="instructor-profile__sns-link" href="' + escapeHtml(instructor.sns_fb) + '" target="_blank" rel="noopener noreferrer">Facebook</a>';
      hero += '</div>';
    }
    hero += '</div></div></div><hr class="instructor-profile__divider">';

    var bio = '';
    if (instructor.bio) {
      bio += '<div class="instructor-profile__block instructor-profile__card instructor-profile__card--bio">';
      bio += '<div class="instructor-profile__section-label">プロフィール</div>';
      bio += '<p class="instructor-profile__bio">' + escapeHtml(instructor.bio) + '</p>';
      bio += '</div><hr class="instructor-profile__divider">';
    }

    var gallery = '';
    if (instructor.works && instructor.works.length) {
      gallery += '<div class="instructor-profile__block">';
      gallery += '<div class="instructor-profile__section-label">作品</div>';
      gallery += '<div data-instructor-gallery>';
      gallery += '<div class="instructor-profile__gallery-grid">';
      instructor.works.forEach(function (u, idx) {
        if (!u) return;
        gallery += '<button class="instructor-profile__gallery-item" type="button" data-lightbox-trigger data-lightbox-src="' + escapeHtml(u) + '" aria-label="作品 ' + (idx+1) + '">';
        gallery += '<img src="' + escapeHtml(u) + '" alt="" width="600" height="600" loading="lazy">';
        gallery += '<span class="instructor-profile__gallery-overlay" aria-hidden="true"></span></button>';
      });
      gallery += '</div>';
      gallery += '<div class="instructor-lightbox" role="dialog" aria-modal="true" aria-label="作品ギャラリー" data-lightbox-modal tabindex="-1">';
      gallery += '<button class="instructor-lightbox__btn instructor-lightbox__close" type="button" data-lightbox-close aria-label="閉じる">&#215;</button>';
      gallery += '<div class="instructor-lightbox__img-wrap">';
      gallery += '<button class="instructor-lightbox__btn instructor-lightbox__prev" type="button" data-lightbox-prev aria-label="前の画像">&#8249;</button>';
      gallery += '<img class="instructor-lightbox__img" src="" alt="" width="1600" height="1600" data-lightbox-img>';
      gallery += '<button class="instructor-lightbox__btn instructor-lightbox__next" type="button" data-lightbox-next aria-label="次の画像">&#8250;</button>';
      gallery += '</div></div></div></div><hr class="instructor-profile__divider">';
    }

    var workshops = renderWorkshops(instructor);
    var artworks = renderArtworks(instructor);

    var ig = '';
    if (instructor.ig_embed) {
      ig += '<div class="instructor-profile__block">';
      ig += '<div class="instructor-profile__section-label">Instagram</div>';
      ig += '<div class="instructor-profile__ig-embed">' + instructor.ig_embed + '</div>';
      ig += '</div>';
    }

    var parts = {
      profile_header: hero,
      bio: bio,
      gallery: gallery,
      workshops: workshops,
      artworks: artworks,
      ig_embed: ig
    };
    var orderedHtml = blockOrder.map(function (type) {
      return parts[type] || '';
    }).join('');

    mount.innerHTML = orderedHtml || (hero + bio + gallery + workshops + artworks + ig);

    // init lightbox galleries after render
    mount.querySelectorAll('[data-instructor-gallery]').forEach(initGallery);
  }

  // JSONデータ用scriptがこのscriptの後ろにあるため、DOM構築後に実行する
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', render);
  } else {
    render();
  }
})();
</script>

<script type="application/json" id="InstructorProfileData-{{ section.id }}">
[
{%- if instructors != blank -%}
  {%- for m in instructors -%}
    {%- liquid
      if m == blank
        continue
      endif

      assign is_active = false
      if m.bp_is_active and m.bp_is_active.value
        assign is_active = true
      endif

      assign name = m.name.value
      if name == blank
        assign name = m.system.handle
      endif

      assign display_name = name
      if m.bp_nickname and m.bp_nickname.value != blank
        assign display_name = m.bp_nickname.value
      endif

      assign photo_url = ''
      if m.bp_photo_profile and m.bp_photo_profile.value != blank
        assign photo_url = m.bp_photo_profile.value | image_url: width: 440, height: 440, crop: 'center'
      endif

      assign rank = m.bp_rank.value | default: ''
      assign location = m.bp_location.value | default: ''
      assign country = m.bp_country.value | default: ''

      assign bp_id = ''
      if m.bp_id and m.bp_id.value != blank
        assign bp_id = m.bp_id.value
      endif

      assign fact_1 = m.bp_fact_1.value | default: ''
      assign fact_2 = m.bp_fact_2.value | default: ''
      assign fact_3 = m.bp_fact_3.value | default: ''
      assign fact_4 = m.bp_fact_4.value | default: ''

      assign sns_ig = m.bp_sns_ig.value | default: ''
      assign sns_fb = m.bp_sns_fb.value | default: ''

      assign bio = m.bp_bio.value | default: ''
      assign ig_embed = m.bp_sns_ig_embed.value | default: ''

      assign works = m.bp_photo_work001.value
      assign instructor_handle = m.system.handle
      assign instructor_bp_id = bp_id
      assign instructor_system_id = ''
      if m.system and m.system.id != blank
        assign instructor_system_id = m.system.id
      endif
    -%}
    {
      "handle": {{ m.system.handle | json }},
      "bp_id": {{ bp_id | json }},
      "system_id": {{ instructor_system_id | json }},
      "bp_is_active": {{ is_active | json }},
      "name": {{ display_name | json }},
      "photo": {{ photo_url | json }},
      "rank": {{ rank | json }},
      "location": {{ location | json }},
      "country": {{ country | json }},
      "facts": [{{ fact_1 | json }}, {{ fact_2 | json }}, {{ fact_3 | json }}, {{ fact_4 | json }}],
      "sns_ig": {{ sns_ig | json }},
      "sns_fb": {{ sns_fb | json }},
      "bio": {{ bio | json }},
      "ig_embed": {{ ig_embed | json }},
      "kicker": {{ section.settings.hero_kicker | json }},
      "hero_label": {{ display_name | json }},
      "works": [
        {%- if works != blank and works.size > 0 -%}
          {%- for img in works -%}
            {{ img | image_url: width: 1600 | json }}{% unless forloop.last %},{% endunless %}
          {%- endfor -%}
        {%- endif -%}
      ],
      "workshop_heading": {{ workshop_heading | json }},
      "artworks_heading": {{ artworks_heading | json }},
      "workshops": [
        {%- liquid
          assign has_workshop = false
        -%}
        {%- if workshop_product != blank and workshop_product.variants.size > 0 -%}
          {%- for variant in workshop_product.variants -%}
            {%- liquid
              assign linked_instructor_metafield = variant.metafields.custom['koushi-item-link']
              if linked_instructor_metafield == blank
                assign linked_instructor_metafield = variant.metafields.custom['koushi_item_link']
              endif
              assign linked_instructor = linked_instructor_metafield.value
              if linked_instructor == blank and linked_instructor_metafield.reference != blank
                assign linked_instructor = linked_instructor_metafield.reference
              endif
              assign linked_instructor_references = linked_instructor_metafield.references
              assign linked_handle = ''
              assign linked_bp_id = ''
              assign linked_system_id = ''
              assign instructor_matched = false
              capture linked_reference_text
                echo linked_instructor_metafield.value | json
                echo ' '
                echo linked_instructor_metafield.reference | json
                echo ' '
                echo linked_instructor_metafield.references | json
                echo ' '
                echo linked_instructor_metafield | json
              endcapture
              if linked_instructor and linked_instructor.system and linked_instructor.system.handle != blank
                assign linked_handle = linked_instructor.system.handle
              elsif linked_instructor and linked_instructor.handle != blank
                assign linked_handle = linked_instructor.handle
              endif
              if linked_instructor and linked_instructor.bp_id and linked_instructor.bp_id.value != blank
                assign linked_bp_id = linked_instructor.bp_id.value
              endif
              if linked_instructor and linked_instructor.system and linked_instructor.system.id != blank
                assign linked_system_id = linked_instructor.system.id
              endif

              if linked_handle != blank and linked_handle == instructor_handle
                assign instructor_matched = true
              endif
              if linked_bp_id != blank and linked_bp_id == instructor_bp_id
                assign instructor_matched = true
              endif
              if linked_system_id != blank and linked_system_id == instructor_system_id
                assign instructor_matched = true
              endif
              if linked_reference_text contains instructor_handle
                assign instructor_matched = true
              endif
              if instructor_bp_id != blank and linked_reference_text contains instructor_bp_id
                assign instructor_matched = true
              endif
              if instructor_system_id != blank and linked_reference_text contains instructor_system_id
                assign instructor_matched = true
              endif

              unless instructor_matched
                for linked_item in linked_instructor
                  assign linked_item_handle = ''
                  assign linked_item_bp_id = ''
                  assign linked_item_system_id = ''
                  if linked_item.system and linked_item.system.handle != blank
                    assign linked_item_handle = linked_item.system.handle
                  elsif linked_item.handle != blank
                    assign linked_item_handle = linked_item.handle
                  endif
                  if linked_item.bp_id and linked_item.bp_id.value != blank
                    assign linked_item_bp_id = linked_item.bp_id.value
                  endif
                  if linked_item.system and linked_item.system.id != blank
                    assign linked_item_system_id = linked_item.system.id
                  endif
                  if linked_item_handle != blank and linked_item_handle == instructor_handle
                    assign instructor_matched = true
                  endif
                  if linked_item_bp_id != blank and linked_item_bp_id == instructor_bp_id
                    assign instructor_matched = true
                  endif
                  if linked_item_system_id != blank and linked_item_system_id == instructor_system_id
                    assign instructor_matched = true
                  endif
                endfor
              endunless

              unless instructor_matched
                for linked_item in linked_instructor_references
                  assign linked_item_handle = ''
                  assign linked_item_bp_id = ''
                  assign linked_item_system_id = ''
                  if linked_item.system and linked_item.system.handle != blank
                    assign linked_item_handle = linked_item.system.handle
                  elsif linked_item.handle != blank
                    assign linked_item_handle = linked_item.handle
                  endif
                  if linked_item.bp_id and linked_item.bp_id.value != blank
                    assign linked_item_bp_id = linked_item.bp_id.value
                  endif
                  if linked_item.system and linked_item.system.id != blank
                    assign linked_item_system_id = linked_item.system.id
                  endif
                  if linked_item_handle != blank and linked_item_handle == instructor_handle
                    assign instructor_matched = true
                  endif
                  if linked_item_bp_id != blank and linked_item_bp_id == instructor_bp_id
                    assign instructor_matched = true
                  endif
                  if linked_item_system_id != blank and linked_item_system_id == instructor_system_id
                    assign instructor_matched = true
                  endif
                endfor
              endunless

              unless instructor_matched
                continue
              endunless

              assign venue_m = variant.metafields.custom.workshop_venue.value
              assign datetime_m = variant.metafields.custom.workshop_datetime.value
              assign venue = ''
              assign datetime_line = ''

              if venue_m != blank or datetime_m != blank
                assign venue = venue_m | default: ''
                assign datetime_line = datetime_m | default: ''
              else
                assign split_title = variant.title | split: ' || '
                if split_title.size >= 2
                  assign venue = split_title[0] | strip
                  assign datetime_line = split_title[1] | strip
                else
                  assign split_title_secondary = variant.title | split: '||'
                  if split_title_secondary.size >= 2
                    assign venue = split_title_secondary[0] | strip
                    assign datetime_line = split_title_secondary[1] | strip
                  endif
                endif
              endif

              assign workshop_image = ''
              if show_workshop_product_image and workshop_product.featured_media != blank
                assign workshop_image = workshop_product.featured_media.preview_image | image_url: width: 360, height: 360, crop: 'center'
              endif
            -%}
            {%- if has_workshop -%},{%- endif -%}
            {
              "product_title": {{ workshop_product.title | json }},
              "title": {{ variant.title | json }},
              "venue": {{ venue | json }},
              "datetime": {{ datetime_line | json }},
              "price": {{ variant.price | money | json }},
              "url": {{ variant.url | json }},
              "image": {{ workshop_image | json }},
              "available": {{ variant.available | json }}
            }
            {%- liquid
              assign has_workshop = true
            -%}
          {%- endfor -%}
        {%- endif -%}
      ],
      "artworks": [
        {%- liquid
          assign has_artwork = false
          assign artwork_limit = section.settings.artworks_limit | default: 8
          assign artwork_count = 0
        -%}
        {%- if artworks_collection != blank and artworks_collection.products.size > 0 -%}
          {%- for product in artworks_collection.products -%}
            {%- liquid
              assign linked_instructor_metafield = product.metafields.custom['koushi-item-link']
              if linked_instructor_metafield == blank
                assign linked_instructor_metafield = product.metafields.custom['koushi_item_link']
              endif
              assign linked_instructor = linked_instructor_metafield.value
              if linked_instructor == blank and linked_instructor_metafield.reference != blank
                assign linked_instructor = linked_instructor_metafield.reference
              endif
              assign linked_instructor_references = linked_instructor_metafield.references
              assign linked_handle = ''
              assign linked_bp_id = ''
              assign linked_system_id = ''
              assign instructor_matched = false
              capture linked_reference_text
                echo linked_instructor_metafield.value | json
                echo ' '
                echo linked_instructor_metafield.reference | json
                echo ' '
                echo linked_instructor_metafield.references | json
                echo ' '
                echo linked_instructor_metafield | json
              endcapture
              if linked_instructor and linked_instructor.system and linked_instructor.system.handle != blank
                assign linked_handle = linked_instructor.system.handle
              elsif linked_instructor and linked_instructor.handle != blank
                assign linked_handle = linked_instructor.handle
              endif
              if linked_instructor and linked_instructor.bp_id and linked_instructor.bp_id.value != blank
                assign linked_bp_id = linked_instructor.bp_id.value
              endif
              if linked_instructor and linked_instructor.system and linked_instructor.system.id != blank
                assign linked_system_id = linked_instructor.system.id
              endif

              if linked_handle != blank and linked_handle == instructor_handle
                assign instructor_matched = true
              endif
              if linked_bp_id != blank and linked_bp_id == instructor_bp_id
                assign instructor_matched = true
              endif
              if linked_system_id != blank and linked_system_id == instructor_system_id
                assign instructor_matched = true
              endif
              if linked_reference_text contains instructor_handle
                assign instructor_matched = true
              endif
              if instructor_bp_id != blank and linked_reference_text contains instructor_bp_id
                assign instructor_matched = true
              endif
              if instructor_system_id != blank and linked_reference_text contains instructor_system_id
                assign instructor_matched = true
              endif

              unless instructor_matched
                for linked_item in linked_instructor
                  assign linked_item_handle = ''
                  assign linked_item_bp_id = ''
                  assign linked_item_system_id = ''
                  if linked_item.system and linked_item.system.handle != blank
                    assign linked_item_handle = linked_item.system.handle
                  elsif linked_item.handle != blank
                    assign linked_item_handle = linked_item.handle
                  endif
                  if linked_item.bp_id and linked_item.bp_id.value != blank
                    assign linked_item_bp_id = linked_item.bp_id.value
                  endif
                  if linked_item.system and linked_item.system.id != blank
                    assign linked_item_system_id = linked_item.system.id
                  endif
                  if linked_item_handle != blank and linked_item_handle == instructor_handle
                    assign instructor_matched = true
                  endif
                  if linked_item_bp_id != blank and linked_item_bp_id == instructor_bp_id
                    assign instructor_matched = true
                  endif
                  if linked_item_system_id != blank and linked_item_system_id == instructor_system_id
                    assign instructor_matched = true
                  endif
                endfor
              endunless

              unless instructor_matched
                for linked_item in linked_instructor_references
                  assign linked_item_handle = ''
                  assign linked_item_bp_id = ''
                  assign linked_item_system_id = ''
                  if linked_item.system and linked_item.system.handle != blank
                    assign linked_item_handle = linked_item.system.handle
                  elsif linked_item.handle != blank
                    assign linked_item_handle = linked_item.handle
                  endif
                  if linked_item.bp_id and linked_item.bp_id.value != blank
                    assign linked_item_bp_id = linked_item.bp_id.value
                  endif
                  if linked_item.system and linked_item.system.id != blank
                    assign linked_item_system_id = linked_item.system.id
                  endif
                  if linked_item_handle != blank and linked_item_handle == instructor_handle
                    assign instructor_matched = true
                  endif
                  if linked_item_bp_id != blank and linked_item_bp_id == instructor_bp_id
                    assign instructor_matched = true
                  endif
                  if linked_item_system_id != blank and linked_item_system_id == instructor_system_id
                    assign instructor_matched = true
                  endif
                endfor
              endunless

              unless instructor_matched
                continue
              endunless

              if artwork_count >= artwork_limit
                break
              endif

              assign artwork_image = ''
              if product.featured_media != blank
                assign artwork_image = product.featured_media.preview_image | image_url: width: 600, height: 600, crop: 'center'
              endif
            -%}
            {%- if has_artwork -%},{%- endif -%}
            {
              "title": {{ product.title | json }},
              "price": {{ product.price | money | json }},
              "url": {{ product.url | json }},
              "image": {{ artwork_image | json }},
              "available": {{ product.available | json }}
            }
            {%- liquid
              assign has_artwork = true
              assign artwork_count = artwork_count | plus: 1
            -%}
          {%- endfor -%}
        {%- endif -%}
      ]
    }{% unless forloop.last %},{% endunless %}
  {%- endfor -%}
{%- endif -%}
]
</script>
{%- endpaginate -%}

