{%- comment -%}
  japan-workshop-buytool

  目的:
  - pro-workshop など「このセクションを入れた商品テンプレート」だけで、
    OPTIS（BSS）+ 数量 + Buy it now を画面最下部に固定表示する（iPhone safe-area 考慮）
  - DOMは移動しない（CSSのみでレイアウトを変更）
  - 「カートに追加する」(po-atc-btn) は display:none にせず、DOM上に残したまま画面外退避

  前提:
  - OPTIS ブロックが main-product 内で出力され、id に "__optis_product_options_" を含む
  - このセクションは該当テンプレートにだけ配置する（他商品へ影響させない）
{%- endcomment -%}

<div class="jwb-marker" aria-hidden="true"></div>

{% comment %}
  ProductInfo（.product__info-container）のスタイルは assets/japan-workshop-buytool.css に集約。
  テーマ設定の色だけここで :root に注入（このブロックが後勝ちになるよう stylesheet の直後に置く）。
{% endcomment %}
{{ 'japan-workshop-buytool.css' | asset_url | stylesheet_tag }}

{%- style -%}
  :root {
    --jwb-bg: {{ section.settings.bg_color | default: '#fafff0' }};
    --jwb-accent: {{ section.settings.accent_color | default: '#d31d84' }};
  }
{%- endstyle -%}

{% schema %}
{
  "name": "japan-workshop-buytool",
  "tag": "section",
  "class": "section",
  "enabled_on": { "templates": ["product"] },
  "settings": [
    { "type": "color", "id": "bg_color", "label": "背景色", "default": "#eef2e6" },
    { "type": "color", "id": "accent_color", "label": "ボタン強調色", "default": "#d31d84" },
    {
      "type": "number",
      "id": "z_index",
      "label": "z-index",
      "default": 9999,
      "info": "1〜9999 推奨。大きいほど前面に表示されます。"
    },
    {
      "type": "range",
      "id": "footer_height_px",
      "min": 80,
      "max": 360,
      "step": 4,
      "unit": "px",
      "label": "下部余白（固定バー分）",
      "default": 200
    }
  ],
  "presets": [{ "name": "japan-workshop-buytool" }]
}
{% endschema %}
