{%- comment -%}
  japan-workshop-buytool

  目的:
  - pro-workshop など「このセクションを入れた商品テンプレート」だけで、
    OPTIS（BSS）+ 数量 + Buy it now を画面最下部に固定表示する（iPhone safe-area 考慮）
  - DOMは移動しない（CSSのみでレイアウトを変更）
  - 「カートに追加する」(po-atc-btn) は display:none にせず、DOM上に残したまま画面外退避

  前提:
  - OPTIS ブロックが main-product 内で出力され、id に "__optis_product_options_" を含む
  - このセクションは該当テンプレートにだけ配置する（他商品へ影響させない）
{%- endcomment -%}

<div class="jwb-marker" aria-hidden="true"></div>

{%- style -%}
  :root {
    --jwb-bg: {{ section.settings.bg_color | default: '#eef2e6' }};
    --jwb-accent: {{ section.settings.accent_color | default: '#d31d84' }};
    --jwb-z: {{ section.settings.z_index | default: 9999 }};
    --jwb-pad: 12px;
    --jwb-gap: 10px;
    --jwb-btn-w: 220px;
    --jwb-qty-w: 120px;
    --jwb-row-h: 48px;
    --jwb-row-gap: 8px;
    --jwb-variant-h: 56px; /* 会場開催日の1行想定（ラベル含む） */

    /* iPhone home indicator safe area */
    --jwb-safe: env(safe-area-inset-bottom, 0px);

    /* Reserve space so content doesn't hide under the fixed bar */
    --jwb-reserve: calc({{ section.settings.footer_height_px | default: 200 }}px + var(--jwb-safe));

    /* Space on the right for qty + CTA button (desktop/tablet) */
    --jwb-right-space: calc(var(--jwb-btn-w) + var(--jwb-qty-w) + (var(--jwb-gap) * 2));
    --jwb-right-pad: calc(var(--jwb-pad) + var(--jwb-right-space));

    /* 会場開催日(variant) + OPTIS 2段 を想定した総段数 */
    --jwb-optis-rows: 2;
    --jwb-variant-offset: calc(
      (var(--jwb-optis-rows) * var(--jwb-row-h)) + (var(--jwb-optis-rows) * var(--jwb-row-gap))
    );
  }

  /* 1) Reserve space at page bottom */
  main {
    padding-bottom: var(--jwb-reserve) !important;
  }

  /* Workshopテンプレートでは商品サムネ（メディア列）を非表示 */
  .product__media-wrapper {
    display: none !important;
  }

  /* 2) Fixed bar base: OPTIS app block (Shopify app block)
        DOM例:
        <div class="shopify-block shopify-app-block" id="...__optis_product_options_...">...</div>
  */
  .product__info-container > .shopify-app-block[id*="__optis_product_options_"] {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;

    z-index: var(--jwb-z);
    background: var(--jwb-bg);
    border: 1px solid rgba(0, 0, 0, 0.12);
    border-top: 0;
    border-radius: 0 0 12px 12px;

    padding: var(--jwb-pad);
    padding-bottom: calc(var(--jwb-pad) + var(--jwb-safe));
    /* keep selects from going under qty/button overlays */
    padding-right: var(--jwb-right-pad);
    box-sizing: border-box;
  }

  /* 2.5) Variant picker（会場開催日）を下部バー先頭に固定配置 */
  .product__info-container > variant-selects[id^="variant-selects-"] {
    position: fixed;
    left: 0;
    right: 0;
    /* OPTIS 2段分だけ上に持ち上げて、希望レイアウト（上：会場開催日）にする */
    bottom: calc(var(--jwb-pad) + var(--jwb-safe) + var(--jwb-variant-offset));
    z-index: calc(var(--jwb-z) + 3);

    max-width: var(--page-width);
    margin: 0 auto;
    padding-left: var(--jwb-pad);
    padding-right: var(--jwb-right-pad);
    box-sizing: border-box;

    background: var(--jwb-bg);
    border: 1px solid rgba(0, 0, 0, 0.12);
    border-bottom: 0;
    border-radius: 12px 12px 0 0;
  }

  .product__info-container > variant-selects .product-form__input--dropdown .select {
    width: 100%;
  }
  .product__info-container > variant-selects .product-form__input--dropdown .select__select {
    min-height: var(--jwb-row-h);
  }

  /* Center align inner content to page width */
  .product__info-container > .shopify-app-block[id*="__optis_product_options_"] {
    max-width: var(--page-width);
    margin-left: auto;
    margin-right: auto;
  }

  /* 3) OPTIS dropdown layout: 2 columns on desktop/tablet */
  .product__info-container > .shopify-app-block[id*="__optis_product_options_"] .bss-po-product-page {
    display: grid !important;
    grid-template-columns: 1fr; /* 希望レイアウト：縦積み */
    gap: var(--jwb-row-gap);
    align-items: end;
  }

  .product__info-container > .shopify-app-block[id*="__optis_product_options_"] .po-select-dropdown-thumbnail {
    min-height: var(--jwb-row-h);
  }

  /* 4) Quantity: fixed overlay aligned with bar */
  .product__info-container > [id^="Quantity-Form-"].product-form__quantity {
    position: fixed;
    left: 0;
    right: 0;
    bottom: calc(var(--jwb-pad) + var(--jwb-safe));
    z-index: calc(var(--jwb-z) + 1);

    max-width: var(--page-width);
    margin: 0 auto;

    display: flex;
    justify-content: flex-end;
    /* 右端のボタン幅分だけ左に寄せて、ボタンと被らないように */
    padding-right: calc(var(--jwb-pad) + var(--jwb-btn-w) + var(--jwb-gap));
    padding-left: var(--jwb-pad);
    box-sizing: border-box;
    pointer-events: none; /* don't block underlying interactions except the controls themselves */
  }

  .product__info-container > [id^="Quantity-Form-"].product-form__quantity .quantity,
  .product__info-container > [id^="Quantity-Form-"].product-form__quantity .quantity__input,
  .product__info-container > [id^="Quantity-Form-"].product-form__quantity .quantity__button {
    pointer-events: auto;
  }

  /* make quantity compact (like "1 人") */
  .product__info-container > [id^="Quantity-Form-"].product-form__quantity .quantity__input {
    width: 72px;
  }

  /* 5) Buy area: fixed overlay right aligned */
  .product__info-container > div > product-form {
    position: fixed;
    left: 0;
    right: 0;
    bottom: calc(var(--jwb-pad) + var(--jwb-safe));
    z-index: calc(var(--jwb-z) + 2);

    max-width: var(--page-width);
    margin: 0 auto;

    display: flex;
    justify-content: flex-end;
    padding-right: var(--jwb-pad);
    padding-left: var(--jwb-pad);
    box-sizing: border-box;
    pointer-events: none;
  }

  .product__info-container > div > product-form .product-form__buttons {
    pointer-events: auto;
    width: var(--jwb-btn-w); /* 予約するボタン幅 */
  }

  /* Emphasize Buy it now button (as "予約する") */
  .product__info-container .shopify-payment-button__button--unbranded {
    background: var(--jwb-accent);
    border-color: var(--jwb-accent);
    color: #fff;
    font-weight: 700;
    border-radius: 8px;
    min-height: 48px;
    width: 100%;
  }

  /* Keep Add to cart in DOM, but hide offscreen safely */
  .product__info-container .po-atc-btn {
    position: fixed !important;
    left: -9999px !important;
    top: auto !important;
    bottom: 0 !important;

    width: 1px !important;
    height: 1px !important;
    padding: 0 !important;
    margin: 0 !important;
    opacity: 0 !important;
    overflow: hidden !important;
    pointer-events: none !important;
  }

  /* 6) Mobile (iPhone): stack inside the fixed bar to reduce overlap risk */
  @media (max-width: 749px) {
    :root {
      --jwb-pad: 10px;
      --jwb-gap: 8px;
      --jwb-reserve: calc({{ section.settings.footer_height_px | default: 240 }}px + var(--jwb-safe));
    }

    .product__info-container > .shopify-app-block[id*="__optis_product_options_"] .bss-po-product-page {
      grid-template-columns: 1fr;
    }

    /* on mobile, allow full width content and don't lift variant-selects */
    .product__info-container > .shopify-app-block[id*="__optis_product_options_"] {
      padding-right: var(--jwb-pad);
      border-radius: 12px;
      border-top: 1px solid rgba(0, 0, 0, 0.12);
    }

    .product__info-container > variant-selects[id^="variant-selects-"] {
      position: static;
      max-width: var(--page-width);
      margin: 0 auto 8px auto;
      padding-right: var(--jwb-pad);
      border-radius: 12px;
      border-bottom: 1px solid rgba(0, 0, 0, 0.12);
    }

    /* On iPhone, stop extra fixed overlays; let them appear in the bar flow */
    .product__info-container > [id^="Quantity-Form-"].product-form__quantity,
    .product__info-container > div > product-form {
      position: static;
      max-width: var(--page-width);
      pointer-events: auto;
      margin: 8px auto 0 auto;
      padding-left: 0;
      padding-right: 0;
    }

    .product__info-container > div > product-form .product-form__buttons {
      width: 100%;
    }
  }
{%- endstyle -%}

{% schema %}
{
  "name": "japan-workshop-buytool",
  "tag": "section",
  "class": "section",
  "enabled_on": { "templates": ["product"] },
  "settings": [
    { "type": "color", "id": "bg_color", "label": "背景色", "default": "#eef2e6" },
    { "type": "color", "id": "accent_color", "label": "ボタン強調色", "default": "#d31d84" },
    { "type": "number", "id": "z_index", "label": "z-index", "default": 9999, "info": "1〜9999 推奨。大きいほど前面に表示されます。" },
    { "type": "range", "id": "footer_height_px", "min": 80, "max": 360, "step": 4, "unit": "px", "label": "下部余白（固定バー分）", "default": 200 }
  ],
  "presets": [
    { "name": "japan-workshop-buytool" }
  ]
}
{% endschema %}
