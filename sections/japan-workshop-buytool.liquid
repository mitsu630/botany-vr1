{%- comment -%}
  japan-workshop-buytool

  目的:
  - pro-workshop など「このセクションを入れた商品テンプレート」だけで、
    OPTIS（BSS）+ 数量 + Buy it now を画面最下部に固定表示する（iPhone safe-area 考慮）
  - DOMは移動しない（CSSのみでレイアウトを変更）
  - 「カートに追加する」(po-atc-btn) は display:none にせず、DOM上に残したまま画面外退避

  前提:
  - OPTIS ブロックが main-product 内で出力され、id に "__optis_product_options_" を含む
  - このセクションは該当テンプレートにだけ配置する（他商品へ影響させない）
{%- endcomment -%}

<div class="jwb-marker" aria-hidden="true"></div>

{%- style -%}
  :root {
    --jwb-bg: {{ section.settings.bg_color | default: '#fafff0' }};
    --jwb-accent: {{ section.settings.accent_color | default: '#d31d84' }};
    --jwb-pad: 16px;
    --jwb-gap: 12px;
    --jwb-row-h: 48px;
    --jwb-radius: 10px;
    --jwb-btn-w: 160px;
    --jwb-qty-w: 92px;
    --jwb-help-text: 'ご予約はサイズと植物を\n選んだ後に行ってください';
  }

  /* 注意: このCSSは「このセクションを入れたテンプレート」だけに適用する運用前提 */
  .product__media-wrapper {
    display: none !important;
  }

  .product__info-wrapper,
  .product__info-container {
    width: 100% !important;
    max-width: 100% !important;
  }

  .product__info-container {
    background: var(--jwb-bg);
    border-radius: var(--jwb-radius);
    padding: var(--jwb-pad);
    display: grid;
    gap: var(--jwb-gap);
    grid-template-columns: minmax(96px, 128px) 1fr var(--jwb-btn-w);
    grid-template-areas:
      'variant variant variant'
      'optis   optis   optis'
      'qty     help    cta';
    align-items: start;
  }

  /* 中央の案内文（DOM追加せずCSSだけで表示） */
  .product__info-container::after {
    content: var(--jwb-help-text);
    grid-area: help;
    align-self: center;
    justify-self: center;
    text-align: center;
    white-space: pre-line;
    font-size: 12px;
    line-height: 1.3;
    color: rgba(var(--color-foreground), 0.85);
    padding: 0 6px;
  }

  /* 不要なラベル類（見た目のため） */
  .product__info-container .form__label,
  .product__info-container .po-label,
  .product__info-container .quantity__label,
  .product__info-container .product__view-details {
    display: none !important;
  }

  /* 1段目：会場開催日 */
  .product__info-container > variant-selects[id^='variant-selects-'] {
    grid-area: variant;
  }
  .product__info-container > variant-selects .select,
  .product__info-container > variant-selects .select__select {
    width: 100%;
    min-height: var(--jwb-row-h);
  }

  /* 2-3段目：OPTIS（サイズ/植物） */
  .product__info-container > .shopify-app-block[id*='__optis_product_options_'] {
    grid-area: optis;
  }
  .product__info-container .bss-po-product-page {
    display: flex !important;
    flex-direction: column !important;
    gap: var(--jwb-gap) !important;
  }
  .product__info-container .po-select-dropdown-thumbnail {
    min-height: var(--jwb-row-h) !important;
  }

  /* OPTIS: 上に出る表示は非表示 */
  .product__info-container .po-selected-swatch,
  .product__info-container .po-extra-price {
    display: none !important;
  }

  /* 4段目：数量 */
  .product__info-container > [id^='Quantity-Form-'].product-form__quantity {
    grid-area: qty;
    display: flex;
    align-items: center;
    gap: 8px;
    margin: 0 !important;
  }
  .product__info-container > [id^='Quantity-Form-'] .quantity {
    width: var(--jwb-qty-w);
    min-height: var(--jwb-row-h);
    background: #fff;
    border-radius: var(--jwb-radius);
  }
  .product__info-container > [id^='Quantity-Form-'].product-form__quantity::after {
    content: '人';
    font-size: 14px;
    color: rgba(var(--color-foreground), 0.9);
  }

  /* 4段目：CTA（Quantity-Form の次のDIVが product-form を内包） */
  .product__info-container > [id^='Quantity-Form-'] + div {
    grid-area: cta;
    display: flex;
    justify-content: flex-end;
    align-items: center;
  }
  .product__info-container > [id^='Quantity-Form-'] + div .product-form__buttons {
    width: var(--jwb-btn-w);
  }

  /* Buy it now ボタン強調（予約する想定） */
  .product__info-container .shopify-payment-button__button--unbranded {
    background: var(--jwb-accent) !important;
    border-color: var(--jwb-accent) !important;
    color: #fff !important;
    font-weight: 700 !important;
    border-radius: var(--jwb-radius) !important;
    min-height: 56px !important;
    width: 100% !important;
    font-size: 16px !important;
  }

  /* Add to cart はDOMに残して退避 */
  .product__info-container .po-atc-btn {
    position: fixed !important;
    left: -9999px !important;
    width: 1px !important;
    height: 1px !important;
    opacity: 0 !important;
    pointer-events: none !important;
  }

  /* iPhoneでも同じ構造で崩れにくい列幅へ */
  @media (max-width: 749px) {
    :root {
      --jwb-pad: 14px;
      --jwb-gap: 12px;
      --jwb-btn-w: 150px;
      --jwb-qty-w: 84px;
    }

    .product__info-container {
      grid-template-columns: minmax(86px, 110px) 1fr var(--jwb-btn-w);
    }

    .product__info-container::after {
      font-size: 11px;
    }
  }
{%- endstyle -%}

{% schema %}
{
  "name": "japan-workshop-buytool",
  "tag": "section",
  "class": "section",
  "enabled_on": { "templates": ["product"] },
  "settings": [
    { "type": "color", "id": "bg_color", "label": "背景色", "default": "#eef2e6" },
    { "type": "color", "id": "accent_color", "label": "ボタン強調色", "default": "#d31d84" },
    { "type": "number", "id": "z_index", "label": "z-index", "default": 9999, "info": "1〜9999 推奨。大きいほど前面に表示されます。" },
    { "type": "range", "id": "footer_height_px", "min": 80, "max": 360, "step": 4, "unit": "px", "label": "下部余白（固定バー分）", "default": 200 }
  ],
  "presets": [
    { "name": "japan-workshop-buytool" }
  ]
}
{% endschema %}
