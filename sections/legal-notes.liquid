{%- style -%}
  #shopify-section-{{ section.id }} {
    --legal-notes-section-bg: {{ section.settings.section_background_color }};
    --legal-notes-card-bg: {{ section.settings.card_background_color }};
    --legal-notes-border-color: {{ section.settings.card_border_color }};
    --legal-notes-title-color: {{ section.settings.title_color }};
    --legal-notes-text-color: {{ section.settings.text_color }};
    --legal-notes-card-radius: {{ section.settings.card_border_radius }}px;
    --legal-notes-card-padding-top: {{ section.settings.card_padding_top }}px;
    --legal-notes-card-padding-right: {{ section.settings.card_padding_right }}px;
    --legal-notes-card-padding-bottom: {{ section.settings.card_padding_bottom }}px;
    --legal-notes-card-padding-left: {{ section.settings.card_padding_left }}px;
    --legal-notes-section-margin-top: {{ section.settings.margin_top }}px;
    --legal-notes-section-margin-bottom: {{ section.settings.margin_bottom }}px;
    --legal-notes-title-size: {{ section.settings.title_font_size }}px;
    --legal-notes-title-weight: {{ section.settings.title_font_weight }};
    --legal-notes-text-size: {{ section.settings.text_font_size }}px;
    --legal-notes-line-height: {{ section.settings.text_line_height | divided_by: 100.0 }};
    --legal-notes-item-gap: {{ section.settings.item_gap }}px;
    --legal-notes-mobile-card-padding-top: {{ section.settings.mobile_card_padding_top }}px;
    --legal-notes-mobile-card-padding-right: {{ section.settings.mobile_card_padding_right }}px;
    --legal-notes-mobile-card-padding-bottom: {{ section.settings.mobile_card_padding_bottom }}px;
    --legal-notes-mobile-card-padding-left: {{ section.settings.mobile_card_padding_left }}px;
    --legal-notes-mobile-title-size: {{ section.settings.mobile_title_font_size }}px;
    --legal-notes-mobile-text-size: {{ section.settings.mobile_text_font_size }}px;
  }

  #shopify-section-{{ section.id }} .legal-notes {
    margin-top: var(--legal-notes-section-margin-top);
    margin-bottom: var(--legal-notes-section-margin-bottom);
    background: var(--legal-notes-section-bg);
  }

  #shopify-section-{{ section.id }} .legal-notes__inner {
    width: min(100% - 32px, {{ section.settings.max_width }}px);
    margin-right: auto;
    margin-left: auto;
  }

  #shopify-section-{{ section.id }} .legal-notes__card {
    background: var(--legal-notes-card-bg);
    border: 1px solid var(--legal-notes-border-color);
    border-radius: var(--legal-notes-card-radius);
    padding: var(--legal-notes-card-padding-top) var(--legal-notes-card-padding-right) var(--legal-notes-card-padding-bottom) var(--legal-notes-card-padding-left);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
  }

  #shopify-section-{{ section.id }} .legal-notes__title {
    margin: 0 0 28px;
    color: var(--legal-notes-title-color);
    font-size: var(--legal-notes-title-size);
    font-weight: var(--legal-notes-title-weight);
    line-height: 1.35;
  }

  #shopify-section-{{ section.id }} .legal-notes__list {
    display: flex;
    flex-direction: column;
    gap: var(--legal-notes-item-gap);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  #shopify-section-{{ section.id }} .legal-notes__item {
    display: flex;
    align-items: flex-start;
    gap: 0.35em;
    color: var(--legal-notes-text-color);
    font-size: var(--legal-notes-text-size);
    line-height: var(--legal-notes-line-height);
  }

  #shopify-section-{{ section.id }} .legal-notes__marker {
    flex: 0 0 auto;
    white-space: nowrap;
  }

  #shopify-section-{{ section.id }} .legal-notes__content {
    min-width: 0;
    flex: 1 1 auto;
  }

  #shopify-section-{{ section.id }} .legal-notes__content > * {
    margin-top: 0;
  }

  #shopify-section-{{ section.id }} .legal-notes__content > *:last-child {
    margin-bottom: 0;
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .legal-notes__inner {
      width: min(100% - 24px, {{ section.settings.max_width }}px);
    }

    #shopify-section-{{ section.id }} .legal-notes__card {
      padding: var(--legal-notes-mobile-card-padding-top) var(--legal-notes-mobile-card-padding-right) var(--legal-notes-mobile-card-padding-bottom) var(--legal-notes-mobile-card-padding-left);
    }

    #shopify-section-{{ section.id }} .legal-notes__title {
      margin-bottom: 20px;
      font-size: var(--legal-notes-mobile-title-size);
    }

    #shopify-section-{{ section.id }} .legal-notes__item {
      font-size: var(--legal-notes-mobile-text-size);
    }
  }
{%- endstyle -%}

<section class="legal-notes">
  <div class="legal-notes__inner">
    <div class="legal-notes__card">
      {%- if section.settings.title != blank -%}
        <h2 class="legal-notes__title">{{ section.settings.title | escape }}</h2>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <ol class="legal-notes__list" role="list">
          {%- for block in section.blocks -%}
            {%- liquid
              assign marker = ''
              if section.settings.marker_mode == 'auto'
                assign marker = '※' | append: forloop.index
              elsif block.settings.marker_text != blank
                assign marker = block.settings.marker_text
              endif
            -%}

            <li class="legal-notes__item" {{ block.shopify_attributes }}>
              {%- if marker != blank -%}
                <span class="legal-notes__marker" aria-hidden="true">{{ marker | escape }}</span>
              {%- endif -%}
              <div class="legal-notes__content">
                {{ block.settings.text }}
              </div>
            </li>
          {%- endfor -%}
        </ol>
      {%- endif -%}
    </div>
  </div>
</section>

