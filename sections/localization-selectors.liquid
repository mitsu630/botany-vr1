{%- liquid
  assign show_country_selector = false
  assign show_language_selector = false

  if section.settings.enable_country_selector and localization.available_countries.size > 1
    assign show_country_selector = true
  endif

  if section.settings.enable_language_selector and localization.available_languages.size > 1
    assign show_language_selector = true
  endif

  assign country_form_id = 'SectionCountryForm-' | append: section.id
  assign language_form_id = 'SectionLanguageForm-' | append: section.id
-%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  .localization-selectors-{{ section.id }} {
    display: flex;
    justify-content: {{ section.settings.content_alignment }};
    position: relative;
    z-index: 2;
  }

  .localization-selectors-{{ section.id }} .localization-selectors__forms {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-start;
    justify-content: {{ section.settings.content_alignment }};
    gap: 1.2rem;
    width: 100%;
  }

  .localization-selectors-{{ section.id }} .localization-selectors__form {
    flex: 0 1 24rem;
    margin: 0;
  }

  .localization-selectors-{{ section.id }} .localization-selectors__select {
    width: 100%;
    min-height: 4.4rem;
    padding: 1rem 3.6rem 1rem 1.4rem;
    border: var(--inputs-border-width) solid rgba(var(--color-foreground), var(--inputs-border-opacity));
    border-radius: var(--inputs-radius-outset);
    background-color: rgb(var(--color-background));
    color: rgb(var(--color-foreground));
    font-family: var(--font-body-family);
    font-size: 1.4rem;
    line-height: calc(1 + 0.5 / var(--font-body-scale));
  }

  .localization-selectors-{{ section.id }} .localization-selectors__empty {
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .localization-selectors-{{ section.id }} .localization-selectors__forms {
      flex-direction: {{ section.settings.mobile_layout }};
      align-items: stretch;
    }

    .localization-selectors-{{ section.id }} .localization-selectors__form {
      flex: 1 1 {% if section.settings.mobile_layout == 'row' %}0{% else %}100%{% endif %};
      width: 100%;
    }
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }

    .localization-selectors-{{ section.id }} .localization-selectors__forms {
      width: auto;
    }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="section-{{ section.id }}-padding">
    <div class="{% unless section.settings.full_width %}page-width{% endunless %}">
      <div class="localization-selectors localization-selectors-{{ section.id }} isolate">
        {%- if show_country_selector or show_language_selector -%}
          <div class="localization-selectors__forms">
            {%- if show_country_selector -%}
              {%- form 'localization', id: country_form_id, class: 'localization-selectors__form' -%}
                <label class="visually-hidden" for="{{ country_form_id }}-country">
                  {{ 'localization.country_label' | t }}
                </label>
                <select
                  id="{{ country_form_id }}-country"
                  class="localization-selectors__select"
                  name="country_code"
                  aria-label="{{ 'localization.country_label' | t }}"
                  onchange="this.form.requestSubmit ? this.form.requestSubmit() : this.form.submit()"
                >
                  {%- for country in localization.available_countries -%}
                    <option
                      value="{{ country.iso_code | escape }}"
                      {% if country.iso_code == localization.country.iso_code %}
                        selected
                      {% endif %}
                    >
                      {{ country.name }} | {{ country.currency.iso_code }}
                      {{ country.currency.symbol }}
                    </option>
                  {%- endfor -%}
                </select>
              {%- endform -%}
            {%- endif -%}

            {%- if show_language_selector -%}
              {%- form 'localization', id: language_form_id, class: 'localization-selectors__form' -%}
                <label class="visually-hidden" for="{{ language_form_id }}-language">
                  {{ 'localization.language_label' | t }}
                </label>
                <select
                  id="{{ language_form_id }}-language"
                  class="localization-selectors__select"
                  name="locale_code"
                  aria-label="{{ 'localization.language_label' | t }}"
                  onchange="this.form.requestSubmit ? this.form.requestSubmit() : this.form.submit()"
                >
                  {%- for language in localization.available_languages -%}
                    <option
                      value="{{ language.iso_code | escape }}"
                      {% if language.iso_code == localization.language.iso_code %}
                        selected
                      {% endif %}
                    >
                      {{ language.endonym_name | capitalize }}
                    </option>
                  {%- endfor -%}
                </select>
              {%- endform -%}
            {%- endif -%}
          </div>
        {%- elsif request.design_mode -%}
          <p class="localization-selectors__empty caption-large">
            Shopify adminで複数のマーケットまたは言語を有効にすると、セレクターが表示されます。
          </p>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "言語・通貨表示",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "checkbox",
      "id": "enable_country_selector",
      "default": true,
      "label": "国/地域・通貨セレクターを表示"
    },
    {
      "type": "checkbox",
      "id": "enable_language_selector",
      "default": true,
      "label": "言語セレクターを表示"
    },
    {
      "type": "select",
      "id": "content_alignment",
      "options": [
        {
          "value": "flex-start",
          "label": "左"
        },
        {
          "value": "center",
          "label": "中央"
        },
        {
          "value": "flex-end",
          "label": "右"
        }
      ],
      "default": "center",
      "label": "配置"
    },
    {
      "type": "select",
      "id": "mobile_layout",
      "options": [
        {
          "value": "column",
          "label": "縦並び"
        },
        {
          "value": "row",
          "label": "横並び"
        }
      ],
      "default": "column",
      "label": "スマホ表示"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "default": false,
      "label": "全幅表示"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "カラースキーム",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "余白"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "上の余白",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "下の余白",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "言語・通貨表示"
    }
  ]
}
{% endschema %}
