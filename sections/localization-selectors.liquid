{%- liquid
  assign show_country_selector = false
  assign show_language_selector = false

  if section.settings.enable_country_selector and localization.available_countries.size > 1
    assign show_country_selector = true
  endif

  if section.settings.enable_language_selector and localization.available_languages.size > 1
    assign show_language_selector = true
  endif

  assign country_form_id = 'SectionCountryForm-' | append: section.id
  assign country_position = 'SectionCountry-' | append: section.id
  assign language_form_id = 'SectionLanguageForm-' | append: section.id
  assign language_position = 'SectionLanguage-' | append: section.id
-%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  .localization-selectors-{{ section.id }} {
    display: flex;
    justify-content: {{ section.settings.content_alignment }};
    position: relative;
    z-index: 50;
  }

  .localization-selectors-{{ section.id }} .localization-selectors__forms {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-start;
    justify-content: {{ section.settings.content_alignment }};
    gap: 1.2rem;
    width: 100%;
  }

  .localization-selectors-{{ section.id }} localization-form {
    display: block;
  }

  .localization-selectors-{{ section.id }} .localization-form {
    padding: 0;
    margin: 0;
  }

  .localization-selectors-{{ section.id }} .localization-form__select {
    margin: 0;
  }

  .localization-selectors-{{ section.id }} .disclosure {
    z-index: 10000;
  }

  .localization-selectors-{{ section.id }} .disclosure__list-wrapper {
    z-index: 10000;
  }

  .localization-selectors-{{ section.id }} .country-selector__overlay {
    z-index: 9999;
  }

  .localization-selectors-{{ section.id }} .disclosure__list-wrapper:not(.country-selector) {
    bottom: auto;
    top: 100%;
    transform: translateY(0.6rem);
  }

  .localization-selectors-{{ section.id }} .localization-selectors__empty {
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .localization-selectors-{{ section.id }} .localization-selectors__forms {
      flex-direction: {{ section.settings.mobile_layout }};
      align-items: stretch;
    }

    .localization-selectors-{{ section.id }} localization-form,
    .localization-selectors-{{ section.id }} .localization-form,
    .localization-selectors-{{ section.id }} .localization-form__select {
      width: 100%;
    }

    .localization-selectors-{{ section.id }} .disclosure__list-wrapper.country-selector {
      position: absolute;
      top: 100%;
      bottom: auto;
      left: 0;
      width: 100%;
      height: auto;
      max-height: 32rem;
      border-width: var(--popup-border-width);
      border-style: solid;
      border-color: rgba(var(--color-foreground), var(--popup-border-opacity));
      border-radius: var(--popup-corner-radius);
      box-shadow: var(--popup-shadow-horizontal-offset) var(--popup-shadow-vertical-offset) var(--popup-shadow-blur-radius)
        rgba(var(--color-shadow), var(--popup-shadow-opacity));
      transform: translateY(0.6rem);
    }

    .localization-selectors-{{ section.id }} .disclosure__list.country-selector__list {
      min-width: 100%;
      max-height: 24rem;
    }

    .localization-selectors-{{ section.id }} .country-selector__close-button,
    .localization-selectors-{{ section.id }} .country-selector__overlay {
      display: none;
    }
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }

    .localization-selectors-{{ section.id }} .localization-selectors__forms {
      width: auto;
    }

    .localization-selectors-{{ section.id }} .disclosure__list-wrapper {
      bottom: auto;
      top: 100%;
      transform: translateY(0.6rem);
    }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="section-{{ section.id }}-padding">
    <div class="{% unless section.settings.full_width %}page-width{% endunless %}">
      <div class="localization-selectors localization-selectors-{{ section.id }} isolate">
        {%- if show_country_selector or show_language_selector -%}
          <div class="localization-selectors__forms">
            {%- if show_country_selector -%}
              <localization-form>
                {%- form 'localization', id: country_form_id, class: 'localization-form' -%}
                  <div>
                    <h2 class="visually-hidden" id="{{ country_position }}Label">
                      {{ 'localization.country_label' | t }}
                    </h2>
                    {%- render 'country-localization', localPosition: country_position -%}
                  </div>
                {%- endform -%}
              </localization-form>
            {%- endif -%}

            {%- if show_language_selector -%}
              <localization-form>
                {%- form 'localization', id: language_form_id, class: 'localization-form' -%}
                  <div>
                    <h2 class="visually-hidden" id="{{ language_position }}Label">
                      {{ 'localization.language_label' | t }}
                    </h2>
                    {%- render 'language-localization', localPosition: language_position -%}
                  </div>
                {%- endform -%}
              </localization-form>
            {%- endif -%}
          </div>
        {%- elsif request.design_mode -%}
          <p class="localization-selectors__empty caption-large">
            Shopify adminで複数のマーケットまたは言語を有効にすると、セレクターが表示されます。
          </p>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "言語・通貨表示",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "checkbox",
      "id": "enable_country_selector",
      "default": true,
      "label": "国/地域・通貨セレクターを表示"
    },
    {
      "type": "checkbox",
      "id": "enable_language_selector",
      "default": true,
      "label": "言語セレクターを表示"
    },
    {
      "type": "select",
      "id": "content_alignment",
      "options": [
        {
          "value": "flex-start",
          "label": "左"
        },
        {
          "value": "center",
          "label": "中央"
        },
        {
          "value": "flex-end",
          "label": "右"
        }
      ],
      "default": "center",
      "label": "配置"
    },
    {
      "type": "select",
      "id": "mobile_layout",
      "options": [
        {
          "value": "column",
          "label": "縦並び"
        },
        {
          "value": "row",
          "label": "横並び"
        }
      ],
      "default": "column",
      "label": "スマホ表示"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "default": false,
      "label": "全幅表示"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "カラースキーム",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "余白"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "上の余白",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "下の余白",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "言語・通貨表示"
    }
  ]
}
{% endschema %}
