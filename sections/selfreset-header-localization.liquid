{%- liquid
  assign show_lang = section.settings.show_language
  assign show_curr = section.settings.show_currency
  assign locales_count = shop.published_locales.size
  assign currencies_count = shop.enabled_currencies.size
  assign show_lang_ui = false
  assign show_curr_ui = false
  if show_lang and locales_count > 1
    assign show_lang_ui = true
  endif
  if show_curr and currencies_count > 1
    assign show_curr_ui = true
  endif
  assign show_bar = false
  if section.settings.show_section
    if show_lang_ui or show_curr_ui
      assign show_bar = true
    endif
  endif
-%}

{%- if show_bar -%}
  <div
    class="selfreset-mobile-localization-bar md:hidden fixed top-10 left-0 right-0 z-[55] bg-white/95 backdrop-blur-sm border-b border-gray-100"
    {{ section.shopify_attributes }}
  >
    <div class="max-w-7xl mx-auto px-4 py-1 flex items-center justify-center gap-2">
      {%- form 'localization', id: 'SelfresetHeaderLocalization', class: 'flex items-center justify-center gap-2 flex-wrap' -%}
        {%- unless show_lang_ui -%}
          <input type="hidden" name="locale_code" value="{{ request.locale.iso_code }}">
        {%- endunless -%}
        {%- unless show_curr_ui -%}
          <input type="hidden" name="currency_code" value="{{ cart.currency.iso_code }}">
        {%- endunless -%}
        {%- if show_lang_ui -%}
          <label class="sr-only" for="SelfresetHeaderLocale">{{ 'localization.language_label' | t }}</label>
          <div class="relative">
            <select
              id="SelfresetHeaderLocale"
              name="locale_code"
              class="appearance-none bg-white border border-gray-300 rounded-full py-0.5 pl-2 pr-6 text-[10px] leading-tight text-gray-600 focus:outline-none focus:ring-1 focus:ring-gray-400 max-w-[42vw]"
              aria-label="{{ 'localization.language_label' | t }}"
              onchange="this.form.requestSubmit ? this.form.requestSubmit() : this.form.submit()"
            >
              {%- for locale in shop.published_locales -%}
                <option value="{{ locale.iso_code }}" {% if locale.iso_code == request.locale.iso_code %}selected{% endif %}>
                  {{ locale.endonym_name }}
                </option>
              {%- endfor -%}
            </select>
            <span class="pointer-events-none absolute right-1.5 top-1/2 -translate-y-1/2 text-[8px] text-gray-400" aria-hidden="true">▾</span>
          </div>
        {%- endif -%}

        {%- if show_curr_ui -%}
          {%- assign currency_aria = 'Currency' -%}
          {%- if request.locale.iso_code == 'ja' -%}
            {%- assign currency_aria = '通貨' -%}
          {%- endif -%}
          <label class="sr-only" for="SelfresetHeaderCurrency">{{ currency_aria }}</label>
          <div class="relative">
            <select
              id="SelfresetHeaderCurrency"
              name="currency_code"
              class="appearance-none bg-white border border-gray-300 rounded-full py-0.5 pl-2 pr-6 text-[10px] leading-tight text-gray-600 focus:outline-none focus:ring-1 focus:ring-gray-400 max-w-[42vw]"
              aria-label="{{ currency_aria }}"
              onchange="this.form.requestSubmit ? this.form.requestSubmit() : this.form.submit()"
            >
              {%- for currency in shop.enabled_currencies -%}
                <option value="{{ currency.iso_code }}" {% if currency.iso_code == cart.currency.iso_code %}selected{% endif %}>
                  {{ currency.iso_code }}{% if currency.symbol %} {{ currency.symbol }}{% endif %}
                </option>
              {%- endfor -%}
            </select>
            <span class="pointer-events-none absolute right-1.5 top-1/2 -translate-y-1/2 text-[8px] text-gray-400" aria-hidden="true">▾</span>
          </div>
        {%- endif -%}
      {%- endform -%}
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Self Reset ヘッダー（言語・通貨）",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_section",
      "label": "セクションを有効にする",
      "default": true,
      "info": "768px未満の画面でのみ表示します。オフにすると言語・通貨バーを非表示にします。"
    },
    {
      "type": "checkbox",
      "id": "show_language",
      "label": "言語プルダウンを表示",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_currency",
      "label": "通貨プルダウンを表示",
      "default": true
    }
  ]
}
{% endschema %}
