<script>
document.addEventListener('DOMContentLoaded', function() {
  const dots = document.querySelectorAll('.dot');
  const conceptItems = document.querySelectorAll('.concept-item');

  function updateScroll() {
    const windowHeight = window.innerHeight;
    const scrolled = window.pageYOffset || document.documentElement.scrollTop;

    // ドットの更新
    const viewportMiddle = scrolled + (windowHeight / 2);
    conceptItems.forEach((item, index) => {
      const rect = item.getBoundingClientRect();
      const itemTop = scrolled + rect.top;
      const itemBottom = itemTop + rect.height;
      
      if (viewportMiddle >= itemTop && viewportMiddle <= itemBottom) {
        dots[index].classList.add('active');
      } else {
        dots[index].classList.remove('active');
      }
    });

    // スクロールアニメーション
    conceptItems.forEach((item, index) => {
      const rect = item.getBoundingClientRect();
      const triggerBottom = window.innerHeight * 0.8;
      
      if (rect.top < triggerBottom) {
        setTimeout(() => {
          item.classList.add('visible');
        }, index * 100);
      }
    });
  }

  // スクロールイベントの設定（throttleを追加）
  let ticking = false;
  window.addEventListener('scroll', function() {
    if (!ticking) {
      window.requestAnimationFrame(function() {
        updateScroll();
        ticking = false;
      });
      ticking = true;
    }
  });
  
  // ドットクリックイベントの設定
  dots.forEach((dot, index) => {
    dot.addEventListener('click', () => {
      const targetItem = conceptItems[index];
      const targetPosition = targetItem.offsetTop - (window.innerHeight / 2) + (targetItem.offsetHeight / 2);
      
      window.scrollTo({
        top: targetPosition,
        behavior: 'smooth'
      });
    });
  });

  // 初期状態の設定
  updateScroll();

  // AOSの初期化
  AOS.init({
    duration: 800,
    once: true,
    offset: 100
  });

  // ライトボックスの実装
  const lightbox = document.createElement('div');
  lightbox.className = 'lightbox';
  lightbox.innerHTML = `
    <div class="lightbox-content">
      <img src="" alt="Lightbox image">
      <p class="lightbox-caption"></p>
      <button class="lightbox-close">Close</button>
    </div>
  `;
  document.body.appendChild(lightbox);

  const galleryItems = document.querySelectorAll('.gallery-item');
  
  galleryItems.forEach(item => {
    item.addEventListener('click', function() {
      const img = this.querySelector('img');
      const caption = this.getAttribute('x-data').match(/caption: '([^']+)'/)[1];
      lightbox.querySelector('img').src = img.src;
      lightbox.querySelector('img').alt = img.alt;
      lightbox.querySelector('.lightbox-caption').textContent = caption;
      requestAnimationFrame(() => {
        lightbox.classList.add('active');
      });
    });
  });

  lightbox.querySelector('.lightbox-close').addEventListener('click', function() {
    lightbox.classList.remove('active');
  });

  lightbox.addEventListener('click', function(e) {
    if (e.target === lightbox) {
      lightbox.classList.remove('active');
    }
  });

  // ESCキーでライトボックスを閉じる
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && lightbox.classList.contains('active')) {
      lightbox.classList.remove('active');
    }
  });
});
</script>

