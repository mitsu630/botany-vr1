{
  "name": "Self Reset Intro",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "タイトル",
      "default": "Self Reset Intro"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "サブタイトル",
      "default": "Self Reset Art"
    }
  ],
  "presets": [
    {
      "name": "Self Reset Intro",
      "category": "Self Reset"
    }
  ]
