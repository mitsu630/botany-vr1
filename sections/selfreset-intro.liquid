      </div>
      <div class="gallery-item" x-data="{ open: false, caption: '黄と緑の2色で着色。ゴールドも加えました' }">
        <img src="https://botanypainting.com/00_sra_img/sra303_IMG_9036.webp" alt="黄と緑の2色で着色。ゴールドも加えました" loading="lazy" @click="open = true" width="1080" height="1080">
      </div>
      <div class="gallery-item" x-data="{ open: false, caption: '白とエメラルドグリーンで着色' }">
