      </div>
      <div class="gallery-item" x-data="{ open: false, caption: '青と白の2色で着色。ゴールドも加えました' }">
        <img src="https://botanypainting.com/00_sra_img/sra305_P1060284.webp" alt="青と白の2色で着色。ゴールドも加えました" loading="lazy" @click="open = true" width="1080" height="1080">
      </div>
      <div class="gallery-item" x-data="{ open: false, caption: 'グレーと白の着色。ゴールドも加えました' }">
        <img src="https://botanypainting.com/00_sra_img/sra306_P1090297.webp" alt="グレーと白の着色。ゴールドも加えました" loading="lazy" @click="open = true" width="1080" height="1080">
      </div>
      <div class="gallery-item" x-data="{ open: false, caption: 'グレーと白の着色。ゴールドも加えました' }">
        <img src="https://botanypainting.com/00_sra_img/sra307_IMG_3493.webp" alt="グレーと白の着色。ゴールドも加えました" loading="lazy" @click="open = true" width="1080" height="1080">
      </div>
      <div class="gallery-item" x-data="{ open: false, caption: 'ベージュ１色で塗りました' }">
        <img src="https://botanypainting.com/00_sra_img/sra308_P1060438.webp" alt="ベージュで塗りました" loading="lazy" @click="open = true" width="1080" height="1080">
      </div>
      <div class="gallery-item" x-data="{ open: false, caption: '薄くグリーンを塗りました' }">
        <img src="https://botanypainting.com/00_sra_img/sra309_P1090400.webp" alt="薄くグリーンを塗りました" loading="lazy" @click="open = true" width="1080" height="1080">
      </div>
