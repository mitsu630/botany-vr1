{% schema %}
{
  "name": "Self Reset Intro 2",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "タイトル",
      "default": "Self Reset Art"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "ボタンテキスト",
      "default": "購入する"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "ボタンリンク"
    }
  ],
  "presets": [
    {
      "name": "Self Reset Intro 2"
    }
  ]
}
{% endschema %}

{% if template contains 'product.selfreset' %}
{{ 'selfreset-common.css' | asset_url | stylesheet_tag }}



