  height: 2px;
  background-color: #b4a7a7;
  transition: transform 0.3s ease;
}

.arrow::before {
  transform: translate(-50%, -50%);
}

.arrow::after {
  transform: translate(-50%, -50%) rotate(90deg);
}

.arrow.open::after {
  transform: translate(-50%, -50%) rotate(0deg);
}

