{% schema %}
{
  "name": "商品カスタマイズ",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "タイトル",
      "default": "あなたの Self Reset <br>をカスタマイズ"
    }
  ],
  "presets": [
    {
      "name": "商品カスタマイズ"
    }
  ]
}
{% endschema %}

{% if template contains 'product.selfreset' %}
<div class="product-customizer" x-data="productCustomizer">
  <h2 class="customizer-title">
    <div class="logo-container">
      <img src="https://botanypainting.com/00_sra_img/sr_rogo.svg" alt="Self Reset Art" class="logo" width="240" height="60">
    </div>
    {{ section.settings.title }}
  </h2>
  
  <p class="intro-text">あなたにぴったりのサイズ、<br>見つけませんか？<br>選んでみるだけでも、<br>ちょっと楽しい。</p>
  <div class="customizer-container">
    <!-- サイズ選択 -->
    <div class="option-group" data-aos="fade-up">
      <h3 class="option-title">「まずはサイズを選ぶ」</h3>
      <p class="size-description">
        あなたの気持ちに寄り添う、<br>ぴったりのサイズを見つけてください。
      </p>
      <p class="size-subtext">下のお好みのボタンを押してください</p>
      <div class="option-buttons">
        <button 
          class="option-button" 
          :class="{ 'selected': selectedSize === '24cm正方形' }"
          @click="selectSize('24cm正方形')">
          <span class="option-label">24cm正方形</span>
          <span class="option-price">¥8,000〜</span>
          <span class="option-desc">両手におさまる、ちょっとした「気持ちの切り替え」にぴったり</span>
        </button>
        <button 
          class="option-button" 
          :class="{ 'selected': selectedSize === '30cm円形' }"
          @click="selectSize('30cm円形')">
          <span class="option-label">30cm円形</span>
          <span class="option-price">¥10,000〜</span>
          <span class="option-desc">丸い形で気持ちもやわらぐ。はじめてでも塗りやすい定番サイズ</span>
        </button>
        <button 
          class="option-button" 
          :class="{ 'selected': selectedSize === '41cm正方形' }"
          @click="selectSize('41cm正方形')">
          <span class="option-label">41cm正方形</span>
          <span class="option-price">¥12,000〜</span>
          <span class="option-desc">思いきり感情を出したいときに。広い面がじぶんを受けとめてくれる</span>
        </button>
      </div>
    </div>

    <!-- 絵の具セット選択 -->
    <div class="option-group" data-aos="fade-up" data-aos-delay="100">
      <h3 class="option-title">「絵の具はどうしますか？」</h3>
      <div class="paint-info-container">
        <div class="paint-info-button" @click="togglePaintInfo">
          <span class="info-icon">i</span>
          <span class="info-text">絵の具について</span>
        </div>
      </div>
      <div class="paint-description" x-show="showPaintInfo" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 transform -translate-y-2" x-transition:enter-end="opacity-100 transform translate-y-0" x-transition:leave="transition ease-in duration-200" x-transition:leave-start="opacity-100 transform translate-y-0" x-transition:leave-end="opacity-0 transform -translate-y-2">
        <div class="speech-bubble">
          <div class="speech-bubble-content">
            <p>
              セルフリセットでは、<br>「アクリル絵の具12色セット」をご用意しています。<br>
              はじめての方や、道具をそろえるのが面倒な方には、届いてすぐ始められるこのセットがおすすめです。<br><br>
              すでにアクリル絵の具をお持ちの方や、色選びを楽しみたい方は、お近くの画材店で単色絵の具を選んでいただくこともできます。<br><br>
              使用するのは、水を使わずそのまま塗れるアクリル絵の具です。<br>
              ※水彩や油絵の具も使えますが、初心者の方にはアクリル絵の具が扱いやすくおすすめです。
            </p>
          </div>
          <div class="speech-bubble-arrow"></div>
        </div>
      </div>
      <div class="option-buttons">
        <button 
          class="option-button" 
          :class="{ 'selected': paintSet === '必要' }"
          @click="selectPaintSet('必要')">
          <span class="option-label">セットで購入</span>
          <span class="option-desc">すぐに始められます</span>
        </button>
        <button 
          class="option-button" 
          :class="{ 'selected': paintSet === '不要' }"
          @click="selectPaintSet('不要')">
          <span class="option-label">画材店で購入</span>
          <span class="option-desc">お手持ちを使用</span>
        </button>
      </div>

    </div>

    <!-- カラー選択 -->
    <div class="option-group" data-aos="fade-up" data-aos-delay="200">
      <h3 class="option-title">「メタルカラーはどうしますか？」</h3>
      <div class="paint-info-container">
        <div class="paint-info-button" @click="toggleMetalInfo">
          <span class="info-icon">i</span>
          <span class="info-text">メタルカラーについて</span>
        </div>
      </div>
      <div class="paint-description" x-show="showMetalInfo" x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0 transform -translate-y-2" x-transition:enter-end="opacity-100 transform translate-y-0" x-transition:leave="transition ease-in duration-200" x-transition:leave-start="opacity-100 transform translate-y-0" x-transition:leave-end="opacity-0 transform -translate-y-2">
        <div class="speech-bubble">
          <div class="speech-bubble-content">
            <p>
              通常の絵の具に加えて、「ゴールド」や「シルバー」のメタルカラーもご用意しています。<br><br>
              いつもの色に少しだけ混ぜてみたり、乾いた作品の上から軽く重ねてみたり。<br>
              光を受けてさりげなく輝く、あなただけの表現が生まれます。
            </p>
          </div>
          <div class="speech-bubble-arrow"></div>
        </div>
      </div>
      <div class="option-buttons">
        <button 
          class="option-button" 
          :class="{ 'selected': selectedColor === 'ゴールド' }"
          @click="selectColor('ゴールド')">
          <span class="option-label">ゴールド</span>
        </button>
        <button 
          class="option-button" 
          :class="{ 'selected': selectedColor === 'シルバー' }"
          @click="selectColor('シルバー')">
          <span class="option-label">シルバー</span>
        </button>
        <button 
          class="option-button" 
          :class="{ 'selected': selectedColor === 'ゴールドとシルバー' }"
          @click="selectColor('ゴールドとシルバー')">
          <span class="option-label">両方使う</span>
        </button>
        <button 
          class="option-button" 
          :class="{ 'selected': selectedColor === '不要' }"
          @click="selectColor('不要')">
          <span class="option-label">不要</span>
        </button>
      </div>
    </div>

    <!-- 選択内容とカートボタン -->
    <div class="selection-summary" x-show="selectedSize" x-transition>
      <div class="summary-content">
        <div class="total-price">
          <span class="price-label">合計</span>
          <span class="price-value" x-text="formatPrice(getVariantPrice())"></span>
          <span class="price-note">税/送料込み（離島除く）</span>
        </div>
        <button 
          class="remember-selection"
          @click="saveSelections()"
          x-bind:disabled="!isComplete">
          <span x-text="isComplete ? '購入する' : '絵の具とメタルカラーを選んでください'"></span>
        </button>
      </div>
    </div>
  </div>
</div>

<div class="line-button-container">
  <a href="https://lin.ee/p6V05va" target="_blank" rel="noopener noreferrer" class="line-button">
    <span class="line-text">気になるご質問はLINEにて</span>
  </a>
</div>


