  font-size: 0.8rem;
  color: #999;
  text-align: center;
  margin-bottom: 1.5rem;
}
</style>

<script>
document.addEventListener('alpine:init', () => {
  Alpine.data('productCustomizer', () => ({
    selectedSize: '',
    paintSet: '',
    selectedColor: '',
    showPaintInfo: false,
    showMetalInfo: false,
    
    get isComplete() {
      return this.selectedSize && this.paintSet && this.selectedColor;
    },
    
    selectSize(size) {
      this.selectedSize = size;
    },
    
    selectPaintSet(set) {
      this.paintSet = set;
    },
    
    selectColor(color) {
      this.selectedColor = color;
    },
    
    togglePaintInfo() {
      this.showPaintInfo = !this.showPaintInfo;
    },
    
    toggleMetalInfo() {
      this.showMetalInfo = !this.showMetalInfo;
    },
    
    getVariantPrice() {
      let basePrice = 0;
      
      // サイズによる基本価格
      switch(this.selectedSize) {
        case '24cm正方形':
          basePrice = 8000;
          break;
        case '30cm円形':
          basePrice = 10000;
          break;
        case '41cm正方形':
          basePrice = 12000;
          break;
      }
      
      // 絵の具セット追加（画材店で購入の場合は加算なし）
      if (this.paintSet === '必要') {
        basePrice += 1000;
      }
      
      // メタルカラー追加（「不要」以外の場合に加算）
      if (this.selectedColor && this.selectedColor !== '不要') {
        if (this.selectedColor === 'ゴールドとシルバー') {
          basePrice += 800;
        } else if (this.selectedColor === 'ゴールド' || this.selectedColor === 'シルバー') {
          basePrice += 400;
        }
      }
      
      return basePrice;
    },
    
    formatPrice(price) {
      return `¥${price.toLocaleString()}`;
    },
    
    saveSelections() {
      // 選択内容をローカルストレージに保存
      localStorage.setItem('selfResetSelections', JSON.stringify({
        size: this.selectedSize,
        paintSet: this.paintSet,
        color: this.selectedColor,
        price: this.getVariantPrice()
      }));

      // 商品のバリアントIDを取得
      let variantId;
      
      // 24cm正方形の場合
      if (this.selectedSize === '24cm正方形') {
        if (this.paintSet === '必要') {
          if (this.selectedColor === 'ゴールド') {
            variantId = 44873466380444;
          } else if (this.selectedColor === 'シルバー') {
            variantId = 44873466413212;
          } else if (this.selectedColor === 'ゴールドとシルバー') {
            variantId = 44873466445980;
          } else {
            variantId = 44873487646876;
          }
        } else {
          if (this.selectedColor === 'ゴールド') {
            variantId = 44873466478748;
          } else if (this.selectedColor === 'シルバー') {
            variantId = 44873466511516;
          } else if (this.selectedColor === 'ゴールドとシルバー') {
            variantId = 44873466544284;
          } else {
            variantId = 44873487679644;
          }
        }
      }
      
      // 30cm円形の場合
      else if (this.selectedSize === '30cm円形') {
        if (this.paintSet === '必要') {
          if (this.selectedColor === 'ゴールド') {
            variantId = 44873466577052;
          } else if (this.selectedColor === 'シルバー') {
            variantId = 44873466609820;
          } else if (this.selectedColor === 'ゴールドとシルバー') {
            variantId = 44873466642588;
          } else {
            variantId = 44873487712412;
          }
        } else {
          if (this.selectedColor === 'ゴールド') {
            variantId = 44873466675356;
          } else if (this.selectedColor === 'シルバー') {
            variantId = 44873466708124;
          } else if (this.selectedColor === 'ゴールドとシルバー') {
            variantId = 44873466740892;
          } else {
            variantId = 44873487745180;
          }
        }
      }
      
      // 41cm正方形の場合
      else if (this.selectedSize === '41cm正方形') {
        if (this.paintSet === '必要') {
          if (this.selectedColor === 'ゴールド') {
            variantId = 44873466773660;
          } else if (this.selectedColor === 'シルバー') {
            variantId = 44873466806428;
          } else if (this.selectedColor === 'ゴールドとシルバー') {
            variantId = 44873466839196;
          } else {
            variantId = 44873487777948;
          }
        } else {
          if (this.selectedColor === 'ゴールド') {
            variantId = 44873466871964;
          } else if (this.selectedColor === 'シルバー') {
            variantId = 44873466904732;
          } else if (this.selectedColor === 'ゴールドとシルバー') {
            variantId = 44873466937500;
          } else {
            variantId = 44873487810716;
          }
        }
      }

      // カートに商品を追加
      fetch('/cart/add.js', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          items: [{
            id: variantId,
            quantity: 1
          }]
        })
      })
      .then(response => response.json())
      .then(data => {
        // カートページにリダイレクト
        window.location.href = '/cart';
      })
      .catch(error => {
        console.error('Error:', error);
        alert('商品の追加に失敗しました。もう一度お試しください。');
      });
    }
  }));
});
</script>
