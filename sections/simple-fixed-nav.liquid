{%- liquid
  assign has_link = false
  if section.settings.button_1_label != blank and section.settings.button_1_link != blank
    assign has_link = true
  elsif section.settings.button_2_label != blank and section.settings.button_2_link != blank
    assign has_link = true
  elsif section.settings.button_3_label != blank and section.settings.button_3_link != blank
    assign has_link = true
  elsif section.settings.button_4_label != blank and section.settings.button_4_link != blank
    assign has_link = true
  elsif section.settings.button_5_label != blank and section.settings.button_5_link != blank
    assign has_link = true
  endif

  assign bg_alpha = section.settings.background_opacity | divided_by: 100.0
  assign bg_rendered = section.settings.background_color | color_modify: 'alpha', bg_alpha

  assign vis_class = ''
  if section.settings.visibility == 'mobile_only'
    assign vis_class = ' simple-fixed-nav--mobile-only'
  elsif section.settings.visibility == 'desktop_only'
    assign vis_class = ' simple-fixed-nav--desktop-only'
  endif

  assign layout_class = ''
  if section.settings.layout_direction == 'vertical'
    assign layout_class = ' simple-fixed-nav__inner--stack'
  endif

  assign nav_label = section.settings.aria_label | strip
  if nav_label == blank
    assign nav_label = 'sections.simple_fixed_nav.default_aria_label' | t
  endif
-%}

{%- if has_link or request.design_mode -%}
  {%- style -%}
    #shopify-section-{{ section.id }} {
      padding: 0 !important;
      margin: 0 !important;
    }

    .simple-fixed-nav--{{ section.id }} {
      position: fixed;
      z-index: {{ section.settings.z_index }};
      max-width: min({{ section.settings.max_width }}px, calc(100vw - {{ section.settings.offset }}px * 2));
      pointer-events: none;
    }

    .simple-fixed-nav--{{ section.id }} .simple-fixed-nav__inner {
      display: flex;
      flex-wrap: wrap;
      gap: {{ section.settings.gap }}px;
      pointer-events: auto;
      {%- if section.settings.layout_direction == 'vertical' -%}
        flex-direction: column;
        {%- if section.settings.position contains 'right' -%}
          align-items: flex-end;
        {%- else -%}
          align-items: flex-start;
        {%- endif -%}
      {%- else -%}
        flex-direction: row;
        align-items: center;
      {%- endif -%}
    }

    {%- if section.settings.position == 'bottom_left' -%}
      .simple-fixed-nav--{{ section.id }} {
        bottom: calc(env(safe-area-inset-bottom, 0px) + {{ section.settings.offset }}px);
        left: calc(env(safe-area-inset-left, 0px) + {{ section.settings.offset }}px);
        right: auto;
        top: auto;
      }
      .simple-fixed-nav--{{ section.id }} .simple-fixed-nav__inner {
        justify-content: flex-start;
      }
    {%- elsif section.settings.position == 'bottom_right' -%}
      .simple-fixed-nav--{{ section.id }} {
        bottom: calc(env(safe-area-inset-bottom, 0px) + {{ section.settings.offset }}px);
        right: calc(env(safe-area-inset-right, 0px) + {{ section.settings.offset }}px);
        left: auto;
        top: auto;
      }
      .simple-fixed-nav--{{ section.id }} .simple-fixed-nav__inner {
        justify-content: flex-end;
      }
    {%- elsif section.settings.position == 'top_left' -%}
      .simple-fixed-nav--{{ section.id }} {
        top: calc(env(safe-area-inset-top, 0px) + {{ section.settings.offset }}px);
        left: calc(env(safe-area-inset-left, 0px) + {{ section.settings.offset }}px);
        right: auto;
        bottom: auto;
      }
      .simple-fixed-nav--{{ section.id }} .simple-fixed-nav__inner {
        justify-content: flex-start;
      }
    {%- else -%}
      .simple-fixed-nav--{{ section.id }} {
        top: calc(env(safe-area-inset-top, 0px) + {{ section.settings.offset }}px);
        right: calc(env(safe-area-inset-right, 0px) + {{ section.settings.offset }}px);
        left: auto;
        bottom: auto;
      }
      .simple-fixed-nav--{{ section.id }} .simple-fixed-nav__inner {
        justify-content: flex-end;
      }
    {%- endif -%}

    @media screen and (max-width: 749px) {
      .simple-fixed-nav--{{ section.id }}.simple-fixed-nav--desktop-only {
        display: none !important;
      }
    }

    @media screen and (min-width: 750px) {
      .simple-fixed-nav--{{ section.id }}.simple-fixed-nav--mobile-only {
        display: none !important;
      }
    }

    .simple-fixed-nav--{{ section.id }} .simple-fixed-nav__link {
      display: inline-block;
      margin: 0;
      font-family: var(--font-body-family);
      font-style: var(--font-body-style);
      font-weight: {{ section.settings.font_weight }};
      font-size: {{ section.settings.font_size }}px;
      line-height: 1.3;
      letter-spacing: 0.02em;
      text-decoration: none;
      color: {{ section.settings.text_color }};
      background-color: {{ bg_rendered }};
      border: {{ section.settings.border_width }}px solid {{ section.settings.border_color }};
      border-radius: {{ section.settings.border_radius }}px;
      padding: {{ section.settings.padding_vertical }}px {{ section.settings.padding_horizontal }}px;
      box-shadow: {% if section.settings.enable_shadow %}0 1px 3px rgba(0, 0, 0, 0.12){% else %}none{% endif %};
      -webkit-tap-highlight-color: transparent;
      text-align: center;
      max-width: 100%;
    }

    .simple-fixed-nav--{{ section.id }} .simple-fixed-nav__link:focus-visible {
      outline: 2px solid {{ section.settings.text_color }};
      outline-offset: 2px;
    }

    @media (prefers-reduced-motion: reduce) {
      .simple-fixed-nav--{{ section.id }} .simple-fixed-nav__link {
        transition: none;
      }
    }
  {%- endstyle -%}

  <div
    class="simple-fixed-nav simple-fixed-nav--{{ section.id }}{{ vis_class }}"
    {{ section.shopify_attributes }}
  >
    <nav class="simple-fixed-nav__inner{{ layout_class }}" aria-label="{{ nav_label | escape }}">
      {%- if section.settings.button_1_label != blank and section.settings.button_1_link != blank -%}
        <a
          href="{{ section.settings.button_1_link }}"
          class="simple-fixed-nav__link"
          {% if section.settings.open_new_tab %}
            target="_blank" rel="noopener noreferrer"
          {% endif %}
        >
          {{- section.settings.button_1_label | escape -}}
        </a>
      {%- endif -%}
      {%- if section.settings.button_2_label != blank and section.settings.button_2_link != blank -%}
        <a
          href="{{ section.settings.button_2_link }}"
          class="simple-fixed-nav__link"
          {% if section.settings.open_new_tab %}
            target="_blank" rel="noopener noreferrer"
          {% endif %}
        >
          {{- section.settings.button_2_label | escape -}}
        </a>
      {%- endif -%}
      {%- if section.settings.button_3_label != blank and section.settings.button_3_link != blank -%}
        <a
          href="{{ section.settings.button_3_link }}"
          class="simple-fixed-nav__link"
          {% if section.settings.open_new_tab %}
            target="_blank" rel="noopener noreferrer"
          {% endif %}
        >
          {{- section.settings.button_3_label | escape -}}
        </a>
      {%- endif -%}
      {%- if section.settings.button_4_label != blank and section.settings.button_4_link != blank -%}
        <a
          href="{{ section.settings.button_4_link }}"
          class="simple-fixed-nav__link"
          {% if section.settings.open_new_tab %}
            target="_blank" rel="noopener noreferrer"
          {% endif %}
        >
          {{- section.settings.button_4_label | escape -}}
        </a>
      {%- endif -%}
      {%- if section.settings.button_5_label != blank and section.settings.button_5_link != blank -%}
        <a
          href="{{ section.settings.button_5_link }}"
          class="simple-fixed-nav__link"
          {% if section.settings.open_new_tab %}
            target="_blank" rel="noopener noreferrer"
          {% endif %}
        >
          {{- section.settings.button_5_label | escape -}}
        </a>
      {%- endif -%}
      {%- if request.design_mode and has_link == false -%}
        <span class="simple-fixed-nav__link" role="note">
          {{- 'sections.simple_fixed_nav.editor_hint' | t -}}
        </span>
      {%- endif -%}
    </nav>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "t:sections.simple-fixed-nav.name",
  "tag": "section",
  "class": "section-simple-fixed-nav",
  "enabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "paragraph",
      "content": "t:sections.simple-fixed-nav.settings.paragraph_intro.content"
    },
    {
      "type": "select",
      "id": "visibility",
      "label": "t:sections.simple-fixed-nav.settings.visibility.label",
      "options": [
        {
          "value": "all",
          "label": "t:sections.simple-fixed-nav.settings.visibility.options__1.label"
        },
        {
          "value": "mobile_only",
          "label": "t:sections.simple-fixed-nav.settings.visibility.options__2.label"
        },
        {
          "value": "desktop_only",
          "label": "t:sections.simple-fixed-nav.settings.visibility.options__3.label"
        }
      ],
      "default": "all"
    },
    {
      "type": "select",
      "id": "position",
      "label": "t:sections.simple-fixed-nav.settings.position.label",
      "options": [
        {
          "value": "bottom_right",
          "label": "t:sections.simple-fixed-nav.settings.position.options__1.label"
        },
        {
          "value": "bottom_left",
          "label": "t:sections.simple-fixed-nav.settings.position.options__2.label"
        },
        {
          "value": "top_right",
          "label": "t:sections.simple-fixed-nav.settings.position.options__3.label"
        },
        {
          "value": "top_left",
          "label": "t:sections.simple-fixed-nav.settings.position.options__4.label"
        }
      ],
      "default": "bottom_right"
    },
    {
      "type": "range",
      "id": "offset",
      "min": 4,
      "max": 32,
      "step": 2,
      "unit": "px",
      "label": "t:sections.simple-fixed-nav.settings.offset.label",
      "default": 8
    },
    {
      "type": "range",
      "id": "z_index",
      "min": 1,
      "max": 999,
      "step": 1,
      "label": "t:sections.simple-fixed-nav.settings.z_index.label",
      "default": 30
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 120,
      "max": 360,
      "step": 10,
      "unit": "px",
      "label": "t:sections.simple-fixed-nav.settings.max_width.label",
      "default": 280
    },
    {
      "type": "select",
      "id": "layout_direction",
      "label": "t:sections.simple-fixed-nav.settings.layout_direction.label",
      "options": [
        {
          "value": "horizontal",
          "label": "t:sections.simple-fixed-nav.settings.layout_direction.options__1.label"
        },
        {
          "value": "vertical",
          "label": "t:sections.simple-fixed-nav.settings.layout_direction.options__2.label"
        }
      ],
      "default": "horizontal"
    },
    {
      "type": "checkbox",
      "id": "open_new_tab",
      "default": false,
      "label": "t:sections.simple-fixed-nav.settings.open_new_tab.label"
    },
    {
      "type": "text",
      "id": "aria_label",
      "label": "t:sections.simple-fixed-nav.settings.aria_label.label",
      "info": "t:sections.simple-fixed-nav.settings.aria_label.info"
    },
    {
      "type": "header",
      "content": "t:sections.simple-fixed-nav.settings.header_buttons.content"
    },
    {
      "type": "text",
      "id": "button_1_label",
      "label": "t:sections.simple-fixed-nav.settings.button_1_label.label"
    },
    {
      "type": "url",
      "id": "button_1_link",
      "label": "t:sections.simple-fixed-nav.settings.button_1_link.label"
    },
    {
      "type": "text",
      "id": "button_2_label",
      "label": "t:sections.simple-fixed-nav.settings.button_2_label.label"
    },
    {
      "type": "url",
      "id": "button_2_link",
      "label": "t:sections.simple-fixed-nav.settings.button_2_link.label"
    },
    {
      "type": "text",
      "id": "button_3_label",
      "label": "t:sections.simple-fixed-nav.settings.button_3_label.label"
    },
    {
      "type": "url",
      "id": "button_3_link",
      "label": "t:sections.simple-fixed-nav.settings.button_3_link.label"
    },
    {
      "type": "text",
      "id": "button_4_label",
      "label": "t:sections.simple-fixed-nav.settings.button_4_label.label"
    },
    {
      "type": "url",
      "id": "button_4_link",
      "label": "t:sections.simple-fixed-nav.settings.button_4_link.label"
    },
    {
      "type": "text",
      "id": "button_5_label",
      "label": "t:sections.simple-fixed-nav.settings.button_5_label.label"
    },
    {
      "type": "url",
      "id": "button_5_link",
      "label": "t:sections.simple-fixed-nav.settings.button_5_link.label"
    },
    {
      "type": "header",
      "content": "t:sections.simple-fixed-nav.settings.header_style.content"
    },
    {
      "type": "range",
      "id": "font_size",
      "min": 10,
      "max": 16,
      "step": 1,
      "unit": "px",
      "label": "t:sections.simple-fixed-nav.settings.font_size.label",
      "default": 11
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "t:sections.simple-fixed-nav.settings.font_weight.label",
      "options": [
        {
          "value": "400",
          "label": "t:sections.simple-fixed-nav.settings.font_weight.options__1.label"
        },
        {
          "value": "500",
          "label": "t:sections.simple-fixed-nav.settings.font_weight.options__2.label"
        },
        {
          "value": "600",
          "label": "t:sections.simple-fixed-nav.settings.font_weight.options__3.label"
        }
      ],
      "default": "500"
    },
    {
      "type": "range",
      "id": "gap",
      "min": 2,
      "max": 12,
      "step": 1,
      "unit": "px",
      "label": "t:sections.simple-fixed-nav.settings.gap.label",
      "default": 4
    },
    {
      "type": "range",
      "id": "padding_vertical",
      "min": 2,
      "max": 16,
      "step": 1,
      "unit": "px",
      "label": "t:sections.simple-fixed-nav.settings.padding_vertical.label",
      "default": 6
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "min": 4,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "t:sections.simple-fixed-nav.settings.padding_horizontal.label",
      "default": 10
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "t:sections.simple-fixed-nav.settings.text_color.label",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:sections.simple-fixed-nav.settings.background_color.label",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "background_opacity",
      "min": 60,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "t:sections.simple-fixed-nav.settings.background_opacity.label",
      "default": 92
    },
    {
      "type": "range",
      "id": "border_width",
      "min": 0,
      "max": 2,
      "step": 1,
      "unit": "px",
      "label": "t:sections.simple-fixed-nav.settings.border_width.label",
      "default": 1
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "t:sections.simple-fixed-nav.settings.border_color.label",
      "default": "#cccccc"
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 8,
      "step": 1,
      "unit": "px",
      "label": "t:sections.simple-fixed-nav.settings.border_radius.label",
      "default": 2
    },
    {
      "type": "checkbox",
      "id": "enable_shadow",
      "default": false,
      "label": "t:sections.simple-fixed-nav.settings.enable_shadow.label"
    }
  ],
  "presets": [
    {
      "name": "t:sections.simple-fixed-nav.presets.name"
    }
  ]
}
{% endschema %}
