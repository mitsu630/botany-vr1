{%- comment -%}
  Tabbed FAQ — qfa metaobjects provide group/question/answer content.
{%- endcomment -%}

{%- liquid
  assign sid = section.id
  assign faqs = blank
  if shop.metaobjects.qfa
    assign faqs = shop.metaobjects.qfa.values
  elsif shop.metaobjects.qa
    assign faqs = shop.metaobjects.qa.values
  endif
-%}

{%- style -%}
  #shopify-section-{{ sid }} {
    --tabbed-faq-tab-active-bg: {{ section.settings.tab_active_bg }};
    --tabbed-faq-tab-active-color: {{ section.settings.tab_active_text }};
    --tabbed-faq-tab-inactive-bg: {{ section.settings.tab_inactive_bg }};
    --tabbed-faq-tab-inactive-color: {{ section.settings.tab_inactive_text }};
    --tabbed-faq-tab-border: {{ section.settings.tab_border_color }};
    --tabbed-faq-tab-border-width: {{ section.settings.tab_border_width }}px;
    --tabbed-faq-item-bg: {{ section.settings.item_bg }};
    --tabbed-faq-item-border: {{ section.settings.item_border_color }};
    --tabbed-faq-item-border-width: {{ section.settings.item_border_width }}px;
    --tabbed-faq-item-radius: {{ section.settings.item_radius }}px;
    --tabbed-faq-heading-box-bg: {{ section.settings.heading_box_bg }};
    --tabbed-faq-heading-box-color: {{ section.settings.heading_box_text }};
    --tabbed-faq-content-title-color: {{ section.settings.content_title_color }};
    --tabbed-faq-line-strong: {{ section.settings.divider_strong_color }};
    --tabbed-faq-line-muted: {{ section.settings.divider_muted_color }};
    --tabbed-faq-link-color: {{ section.settings.intro_link_color }};
    --tabbed-faq-q-color: {{ section.settings.q_label_color }};
    --tabbed-faq-a-color: {{ section.settings.a_label_color }};
    --tabbed-faq-icon-color: {{ section.settings.toggle_icon_color }};
    --tabbed-faq-font-heading: {{ section.settings.font_size_heading }}px;
    --tabbed-faq-font-sub: {{ section.settings.font_size_subheading }}px;
    --tabbed-faq-font-tab: {{ section.settings.font_size_tab }}px;
    --tabbed-faq-font-content-title: {{ section.settings.font_size_content_title }}px;
    --tabbed-faq-font-question: {{ section.settings.font_size_question }}px;
    --tabbed-faq-font-answer: {{ section.settings.font_size_answer }}px;
    --tabbed-faq-font-intro: {{ section.settings.font_size_intro }}px;
    --tabbed-faq-section-pad-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    --tabbed-faq-section-pad-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    #shopify-section-{{ sid }} {
      --tabbed-faq-section-pad-top: {{ section.settings.padding_top }}px;
      --tabbed-faq-section-pad-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="tabbed-faq page-width section-{{ sid }}-padding" id="tabbed-faq-{{ sid }}" data-tabbed-faq>
  {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
    <header class="tabbed-faq__masthead">
      {%- if section.settings.heading != blank -%}
        <div class="tabbed-faq__heading-box">
          <h2 class="tabbed-faq__heading">{{ section.settings.heading | escape }}</h2>
        </div>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="tabbed-faq__subheading">{{ section.settings.subheading | escape }}</p>
      {%- endif -%}
    </header>
  {%- endif -%}

  {%- if section.settings.intro != blank -%}
    <div class="tabbed-faq__intro rte">{{ section.settings.intro }}</div>
  {%- endif -%}

  {%- if section.blocks.size > 0 -%}
    <div class="tabbed-faq__tabs-wrap">
      <div
        class="tabbed-faq__tabs"
        role="tablist"
        aria-label="{{ section.settings.tabs_aria_label | escape }}"
      >
        {%- assign category_index = 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'category' -%}
            {%- assign category_index = category_index | plus: 1 -%}
            <button
              type="button"
              class="tabbed-faq__tab{% if category_index == 1 %} is-active{% endif %}"
              role="tab"
              id="tabbed-faq-tab-{{ sid }}-{{ block.id }}"
              aria-selected="{% if category_index == 1 %}true{% else %}false{% endif %}"
              aria-controls="tabbed-faq-panel-{{ sid }}-{{ block.id }}"
              tabindex="{% if category_index == 1 %}0{% else %}-1{% endif %}"
              data-tabbed-faq-tab
              data-panel-id="tabbed-faq-panel-{{ sid }}-{{ block.id }}"
            >
              {{ block.settings.tab_title | escape }}
            </button>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

    <div class="tabbed-faq__panels">
      {%- assign category_index = 0 -%}
      {%- for block in section.blocks -%}
        {%- unless block.type == 'category' -%}
          {%- continue -%}
        {%- endunless -%}
        {%- liquid
          assign category_index = category_index | plus: 1
          assign cat_first = false
          if category_index == 1
            assign cat_first = true
          endif
          assign group_key = block.settings.group_key | default: block.settings.qa_key | default: block.settings.tab_title | strip
        -%}
        <div
          class="tabbed-faq__panel{% if cat_first %} is-active{% endif %}"
          role="tabpanel"
          id="tabbed-faq-panel-{{ sid }}-{{ block.id }}"
          aria-labelledby="tabbed-faq-tab-{{ sid }}-{{ block.id }}"
          {% unless cat_first %}hidden{% endunless %}
          data-tabbed-faq-panel
          {{ block.shopify_attributes }}
        >
          {%- if block.settings.tab_title != blank -%}
            <div class="tabbed-faq__content-head">
              <h3 class="tabbed-faq__content-title">{{ block.settings.tab_title | escape }}</h3>
            </div>
          {%- endif -%}

          <div class="tabbed-faq__accordion" data-tabbed-faq-accordion>
            {%- assign pair_index = 0 -%}

            {%- if faqs != blank and group_key != blank -%}
              {%- assign faq_refs = '' -%}
              {%- for faq in faqs -%}
                {%- liquid
                  assign faq_group = ''
                  if faq.group and faq.group.value != blank
                    assign faq_group = faq.group.value | strip
                  elsif faq['group'] and faq['group'].value != blank
                    assign faq_group = faq['group'].value | strip
                  endif

                  assign faq_handle = ''
                  if faq.system and faq.system.handle != blank
                    assign faq_handle = faq.system.handle
                  elsif faq.handle != blank
                    assign faq_handle = faq.handle
                  endif

                  assign question = ''
                  if faq.question and faq.question.value != blank
                    assign question = faq.question.value | strip
                  elsif faq['question'] and faq['question'].value != blank
                    assign question = faq['question'].value | strip
                  endif

                  assign answer = ''
                  if faq.answer and faq.answer.value != blank
                    assign answer = faq.answer.value | strip
                  elsif faq['answer'] and faq['answer'].value != blank
                    assign answer = faq['answer'].value | strip
                  endif
                -%}

                {%- if faq_group == group_key and faq_handle != blank and question != blank and answer != blank -%}
                  {%- liquid
                    assign order_number = faq_handle | remove: 'qfa' | remove: '-' | plus: 0
                    assign sort_number = order_number | plus: 1000000000
                    assign faq_refs = faq_refs | append: sort_number | append: '::' | append: faq_handle | append: '||'
                  -%}
                {%- endif -%}
              {%- endfor -%}

              {%- assign faq_refs = faq_refs | split: '||' | sort | reverse -%}
              {%- for faq_ref in faq_refs -%}
                {%- if faq_ref == blank -%}
                  {%- continue -%}
                {%- endif -%}
                {%- assign sorted_handle = faq_ref | split: '::' | last -%}
                {%- for faq in faqs -%}
                  {%- liquid
                    assign faq_handle = ''
                    if faq.system and faq.system.handle != blank
                      assign faq_handle = faq.system.handle
                    elsif faq.handle != blank
                      assign faq_handle = faq.handle
                    endif
                  -%}
                  {%- if faq_handle == sorted_handle -%}
                    {%- liquid
                      assign question = ''
                      if faq.question and faq.question.value != blank
                        assign question = faq.question.value | strip
                      elsif faq['question'] and faq['question'].value != blank
                        assign question = faq['question'].value | strip
                      endif
                      assign answer = ''
                      if faq.answer and faq.answer.value != blank
                        assign answer = faq.answer.value | strip
                      elsif faq['answer'] and faq['answer'].value != blank
                        assign answer = faq['answer'].value | strip
                      endif
                    -%}
                    {%- if question != blank and answer != blank -%}
                      {%- assign pair_index = pair_index | plus: 1 -%}
                      <div
                        class="tabbed-faq__item{% if cat_first and pair_index == 1 %} is-open{% endif %}"
                        data-tabbed-faq-item
                      >
                        <button
                          type="button"
                          class="tabbed-faq__question"
                          aria-expanded="{% if cat_first and pair_index == 1 %}true{% else %}false{% endif %}"
                          data-tabbed-faq-trigger
                          id="tabbed-faq-q-{{ sid }}-{{ block.id }}-{{ pair_index }}"
                        >
                          <span class="tabbed-faq__q-label">Q.</span>
                          <span class="tabbed-faq__q-text">{{ question | escape }}</span>
                          <span class="tabbed-faq__icon" aria-hidden="true" data-tabbed-faq-icon></span>
                        </button>
                        <div
                          class="tabbed-faq__answer"
                          id="tabbed-faq-a-{{ sid }}-{{ block.id }}-{{ pair_index }}"
                          role="region"
                          aria-labelledby="tabbed-faq-q-{{ sid }}-{{ block.id }}-{{ pair_index }}"
                          {% unless cat_first and pair_index == 1 %}hidden{% endunless %}
                          data-tabbed-faq-answer
                        >
                          <span class="tabbed-faq__a-label">A.</span>
                          <div class="tabbed-faq__a-text">{{ answer | escape | newline_to_br }}</div>
                        </div>
                      </div>
                    {%- endif -%}
                    {%- break -%}
                  {%- endif -%}
                {%- endfor -%}
              {%- endfor -%}
            {%- endif -%}

            {%- if pair_index == 0 -%}
              <p class="tabbed-faq__empty">このカテゴリーのQ&Aはまだありません。</p>
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  {%- else -%}
    <p class="tabbed-faq__empty">テーマエディタでカテゴリー（タブ）ブロックを追加してください。</p>
  {%- endif -%}
</div>

<style>
  #shopify-section-{{ sid }} .tabbed-faq {
    padding-top: var(--tabbed-faq-section-pad-top);
    padding-bottom: var(--tabbed-faq-section-pad-bottom);
    max-width: 100%;
  }
  #shopify-section-{{ sid }} .tabbed-faq__masthead {
    text-align: center;
    margin-bottom: 1.25rem;
  }
  #shopify-section-{{ sid }} .tabbed-faq__heading-box {
    display: inline-block;
    background: var(--tabbed-faq-heading-box-bg);
    color: var(--tabbed-faq-heading-box-color);
    padding: 0.5rem 1.25rem;
    margin-bottom: 0.5rem;
  }
  #shopify-section-{{ sid }} .tabbed-faq__heading {
    margin: 0;
    font-size: var(--tabbed-faq-font-heading);
    line-height: 1.2;
    font-weight: 700;
    color: var(--tabbed-faq-heading-box-color);
  }
  #shopify-section-{{ sid }} .tabbed-faq__subheading {
    margin: 0;
    font-size: var(--tabbed-faq-font-sub);
    font-weight: 400;
  }
  #shopify-section-{{ sid }} .tabbed-faq__intro {
    text-align: center;
    font-size: var(--tabbed-faq-font-intro);
    margin-bottom: 1.5rem;
  }
  #shopify-section-{{ sid }} .tabbed-faq__intro a {
    color: var(--tabbed-faq-link-color);
    text-decoration: underline;
  }
  #shopify-section-{{ sid }} .tabbed-faq__tabs-wrap {
    overflow-x: auto;
    overflow-y: visible;
    -webkit-overflow-scrolling: touch;
    margin-bottom: 1.5rem;
    padding-bottom: 10px;
  }
  #shopify-section-{{ sid }} .tabbed-faq__tabs {
    display: flex;
    flex-wrap: nowrap;
    gap: 0.5rem;
    min-width: min-content;
    padding-bottom: 0.75rem;
  }
  #shopify-section-{{ sid }} .tabbed-faq__tab {
    flex: 1 1 auto;
    position: relative;
    margin: 0;
    padding: 0.75rem 1rem;
    font-size: var(--tabbed-faq-font-tab);
    font-family: inherit;
    cursor: pointer;
    text-align: center;
    white-space: nowrap;
    border: var(--tabbed-faq-tab-border-width) solid var(--tabbed-faq-tab-border);
    background: var(--tabbed-faq-tab-inactive-bg);
    color: var(--tabbed-faq-tab-inactive-color);
    transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
  }
  #shopify-section-{{ sid }} .tabbed-faq__tab.is-active {
    background: var(--tabbed-faq-tab-active-bg);
    color: var(--tabbed-faq-tab-active-color);
    border-color: var(--tabbed-faq-tab-active-bg);
    padding-bottom: calc(0.75rem + 8px);
  }
  #shopify-section-{{ sid }} .tabbed-faq__tab.is-active::after {
    content: '';
    position: absolute;
    left: 50%;
    bottom: 0;
    transform: translate(-50%, 100%);
    width: 0;
    height: 0;
    border-left: 8px solid transparent;
    border-right: 8px solid transparent;
    border-top: 8px solid var(--tabbed-faq-tab-active-bg);
  }
  #shopify-section-{{ sid }} .tabbed-faq__tab:focus-visible {
    outline: 2px solid var(--tabbed-faq-tab-active-bg);
    outline-offset: 2px;
  }
  #shopify-section-{{ sid }} .tabbed-faq__content-head {
    border-top: 3px solid var(--tabbed-faq-line-strong);
    border-bottom: 1px solid var(--tabbed-faq-line-muted);
    padding: 0.75rem 0;
    margin-bottom: 1rem;
  }
  #shopify-section-{{ sid }} .tabbed-faq__content-title {
    margin: 0;
    font-size: var(--tabbed-faq-font-content-title);
    font-weight: 700;
    color: var(--tabbed-faq-content-title-color);
  }
  #shopify-section-{{ sid }} .tabbed-faq__accordion {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  #shopify-section-{{ sid }} .tabbed-faq__item {
    background: var(--tabbed-faq-item-bg);
    border: var(--tabbed-faq-item-border-width) solid var(--tabbed-faq-item-border);
    border-radius: var(--tabbed-faq-item-radius);
    overflow: hidden;
  }
  #shopify-section-{{ sid }} .tabbed-faq__question {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    width: 100%;
    margin: 0;
    padding: 1rem 1.25rem;
    font: inherit;
    text-align: left;
    cursor: pointer;
    background: transparent;
    border: none;
    color: inherit;
  }
  #shopify-section-{{ sid }} .tabbed-faq__q-label {
    flex-shrink: 0;
    font-weight: 700;
    font-size: var(--tabbed-faq-font-question);
    color: var(--tabbed-faq-q-color);
  }
  #shopify-section-{{ sid }} .tabbed-faq__q-text {
    flex: 1;
    font-size: var(--tabbed-faq-font-question);
    line-height: 1.5;
  }
  #shopify-section-{{ sid }} .tabbed-faq__icon {
    flex-shrink: 0;
    width: 1.25rem;
    height: 1.25rem;
    position: relative;
    color: var(--tabbed-faq-icon-color);
    margin-top: 0.15em;
  }
  #shopify-section-{{ sid }} .tabbed-faq__icon::before,
  #shopify-section-{{ sid }} .tabbed-faq__icon::after {
    content: '';
    position: absolute;
    background: currentColor;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    transition: opacity 0.2s ease, transform 0.2s ease;
  }
  #shopify-section-{{ sid }} .tabbed-faq__icon::before {
    width: 12px;
    height: 2px;
  }
  #shopify-section-{{ sid }} .tabbed-faq__icon::after {
    width: 2px;
    height: 12px;
  }
  #shopify-section-{{ sid }} .tabbed-faq__item.is-open .tabbed-faq__icon::after {
    opacity: 0;
    transform: translate(-50%, -50%) scaleY(0);
  }
  #shopify-section-{{ sid }} .tabbed-faq__answer {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.5rem 0.5rem;
    padding: 0 1.25rem 1rem;
    align-items: start;
  }
  #shopify-section-{{ sid }} .tabbed-faq__answer[hidden] {
    display: none;
  }
  #shopify-section-{{ sid }} .tabbed-faq__a-label {
    font-weight: 600;
    font-size: var(--tabbed-faq-font-answer);
    color: var(--tabbed-faq-a-color);
  }
  #shopify-section-{{ sid }} .tabbed-faq__a-text {
    font-size: var(--tabbed-faq-font-answer);
    line-height: 1.6;
    margin: 0;
  }
  #shopify-section-{{ sid }} .tabbed-faq__empty {
    text-align: center;
    opacity: 0.7;
  }
</style>

<script>
  (function () {
    var root = document.getElementById('tabbed-faq-{{ sid }}');
    if (!root) return;

    function setTabActive(tab) {
      var tabs = root.querySelectorAll('[data-tabbed-faq-tab]');
      var panels = root.querySelectorAll('[data-tabbed-faq-panel]');
      var panelId = tab.getAttribute('aria-controls');
      tabs.forEach(function (t) {
        var on = t === tab;
        t.classList.toggle('is-active', on);
        t.setAttribute('aria-selected', on ? 'true' : 'false');
        t.setAttribute('tabindex', on ? '0' : '-1');
      });
      panels.forEach(function (p) {
        var show = p.id === panelId;
        p.classList.toggle('is-active', show);
        if (show) p.removeAttribute('hidden');
        else p.setAttribute('hidden', '');
      });
    }

    root.addEventListener('click', function (e) {
      var tab = e.target.closest('[data-tabbed-faq-tab]');
      if (tab && root.contains(tab)) {
        e.preventDefault();
        setTabActive(tab);
        return;
      }
      var trigger = e.target.closest('[data-tabbed-faq-trigger]');
      if (!trigger || !root.contains(trigger)) return;
      var item = trigger.closest('[data-tabbed-faq-item]');
      if (!item) return;
      var answer = item.querySelector('[data-tabbed-faq-answer]');
      var open = !item.classList.contains('is-open');
      item.classList.toggle('is-open', open);
      trigger.setAttribute('aria-expanded', open ? 'true' : 'false');
      if (answer) {
        if (open) answer.removeAttribute('hidden');
        else answer.setAttribute('hidden', '');
      }
    });

    root.addEventListener('keydown', function (e) {
      var tabs = Array.prototype.slice.call(root.querySelectorAll('[data-tabbed-faq-tab]'));
      var i = tabs.indexOf(document.activeElement);
      if (i < 0) return;
      var next = null;
      if (e.key === 'ArrowRight' || e.key === 'ArrowDown') {
        next = tabs[(i + 1) % tabs.length];
      } else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') {
        next = tabs[(i - 1 + tabs.length) % tabs.length];
      } else if (e.key === 'Home') {
        next = tabs[0];
      } else if (e.key === 'End') {
        next = tabs[tabs.length - 1];
      }
      if (next) {
        e.preventDefault();
        setTabActive(next);
        next.focus();
      }
    });
  })();
</script>

{% schema %}
{
  "name": "タブQ&A (tabbed-faq)",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "見出し（ボックス内）",
      "default": "FAQ"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "サブ見出し",
      "default": "よくある質問"
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "紹介文",
      "default": "<p>お問い合わせは<a href=\"/pages/contact\">お問い合わせフォーム</a>からどうぞ。</p>"
    },
    {
      "type": "text",
      "id": "tabs_aria_label",
      "label": "タブリストのラベル（アクセシビリティ）",
      "default": "質問カテゴリー"
    },
    {
      "type": "header",
      "content": "色"
    },
    {
      "type": "color",
      "id": "heading_box_bg",
      "label": "見出しボックス背景",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "heading_box_text",
      "label": "見出しボックス文字",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "intro_link_color",
      "label": "紹介文のリンク色",
      "default": "#2563eb"
    },
    {
      "type": "color",
      "id": "tab_active_bg",
      "label": "アクティブタブ背景",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "tab_active_text",
      "label": "アクティブタブ文字",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "tab_inactive_bg",
      "label": "非アクティブタブ背景",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "tab_inactive_text",
      "label": "非アクティブタブ文字",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "tab_border_color",
      "label": "タブ枠線",
      "default": "#1a1a1a"
    },
    {
      "type": "range",
      "id": "tab_border_width",
      "min": 0,
      "max": 4,
      "step": 1,
      "unit": "px",
      "label": "タブ枠線の太さ",
      "default": 1
    },
    {
      "type": "color",
      "id": "content_title_color",
      "label": "カテゴリー見出しの文字色",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "divider_strong_color",
      "label": "上線（太い）",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "divider_muted_color",
      "label": "下線（細い）",
      "default": "#cccccc"
    },
    {
      "type": "color",
      "id": "item_bg",
      "label": "Q&Aボックス背景",
      "default": "#f4f4f4"
    },
    {
