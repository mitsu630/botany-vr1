        {
          "type": "range",
          "id": "rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5,
          "label": "星の評価"
        },
        {
          "type": "text",
          "id": "name",
          "default": "山田 花子様",
          "label": "氏名"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "作品写真"
