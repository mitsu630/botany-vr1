    // variant id の value 変化を監視（installment は OPTIS 注入後に現れるため毎回再取得）
    (function esfsWatchVariantIdChanges() {
      if (typeof MutationObserver === 'undefined') return;
      var lastI = '';
      var lastM = '';
      var lastUrl = esfsGetVariantIdFromUrl();
      var observed = new WeakSet();
      function pickEls() {
        var inst = document.querySelector('form.installment input[name="id"]');
        var main =
          document.querySelector('form[action*="/cart/add"] input[name="id"].product-variant-id') ||
          document.querySelector('form[action*="/cart/add"] input[name="id"]');
        return { inst: inst, main: main };
      }
      function tick() {
        var els = pickEls();
        var ni = els.inst ? String(els.inst.value) : '';
        var nm = els.main ? String(els.main.value) : '';
        if (ni !== lastI || nm !== lastM) {
          lastI = ni;
          lastM = nm;
          esfsUpdateVariantBanner();
          esfsUpdateVariantInfo();
        }
        var nowUrl = esfsGetVariantIdFromUrl();
        if (nowUrl && nowUrl !== lastUrl) {
          lastUrl = nowUrl;
          esfsUpdateVariantBanner();
          esfsUpdateVariantInfo();
        }
      }
      var mo = new MutationObserver(tick);
      function observeNew() {
        var els = pickEls();
        [els.inst, els.main].forEach(function (el) {
          if (el && !observed.has(el)) {
            try {
              mo.observe(el, { attributes: true, attributeFilter: ['value'] });
              observed.add(el);
            } catch (e) {}
          }
        });
      }
      observeNew();
      setInterval(function () {
        observeNew();
        tick();
      }, 400);
    })();

