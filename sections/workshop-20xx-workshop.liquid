          <td id="esfs-variant-info-kaijyo">{% if esfs_liq_kaijyo != blank %}{{ esfs_liq_kaijyo | newline_to_br }}{% else %}—{% endif %}</td>
        </tr>
        <tr>
          <th scope="row">住所</th>
