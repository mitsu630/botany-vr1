          var returnTo = srcForm.querySelector('input[name="return_to"]');
          if (!returnTo) {
            returnTo = document.createElement('input');
            returnTo.type = 'hidden';
            returnTo.name = 'return_to';
            srcForm.appendChild(returnTo);
          }
          returnTo.value = esfsCheckoutStepUrl;

          esfsReserveDebug('fallback:submit-existing-cart-form', {
            reason: reason,
            formClass: srcForm.className || '',
            returnTo: returnTo.value
          });

          // OPTIS/BSS側が change/input 後に hidden/properties を再計算するため、
          // 反映待ちを入れてから送信する
          setTimeout(function () {
            var submitBtn = srcForm.querySelector(
              'button[type="submit"]:not([disabled]), input[type="submit"]:not([disabled])'
            );
            if (submitBtn && typeof submitBtn.click === 'function') {
              submitBtn.click();
              return;
            }
            if (typeof srcForm.requestSubmit === 'function') {
              srcForm.requestSubmit();
              return;
            }
            srcForm.submit();
          }, 250);
        } catch (e) {
          esfsReserveDebug('fallback:post-formdata-failed', {
            reason: reason,
            message: String(e && e.message ? e.message : e)
          });
          setReserveBtnWaiting(false);
          window.location.href = '/cart';
        }
      }

      function esfsSubmitNativeCheckoutFallback(reason) {
        var form = getBestCartAddForm();
        if (!form) {
          esfsReserveDebug('forceReserve:no-form-for-fallback', { reason: reason });
          setReserveBtnWaiting(false);
          window.location.href = '/cart';
          return;
        }
        esfsPostCartAddFormDataToCheckout(form, reason);
      }
      var payBtn =
        document.querySelector('button.shopify-payment-button__button--unbranded.bss-po-btn-buyitnow[po-btn-buy-it-now="true"]') ||
        document.querySelector('button.shopify-payment-button__button--unbranded.bss-po-btn-buyitnow') ||
        document.querySelector('button.shopify-payment-button__button--unbranded[po-btn-buy-it-now="true"]') ||
        document.querySelector('button.shopify-payment-button__button--unbranded');
      if (payBtn && !payBtn.disabled && payBtn.getAttribute('aria-disabled') !== 'true') {
        esfsReserveDebug('forceReserve:click-payBtn', { disabled: false });
        payBtn.click();
        // payBtn（Shopify Accelerated Checkout）は遷移開始までタイムラグがあるため、
        // URL に checkout が出るまで長めにポーリングしてからフォールバックする
        var fallbackMaxMs = 25000;
        var tickMs = 250;
        var elapsed = 0;
        var iv = setInterval(function () {
          elapsed += tickMs;
          var href = String(window.location.href || '');
          var path = String(window.location.pathname || '');
          var hasNavigatedToCheckout =
            href !== startHref &&
            (path.indexOf('/checkouts') !== -1 || path.indexOf('/checkout') !== -1 || href.indexOf('/checkouts') !== -1);

          if (hasNavigatedToCheckout) {
            clearInterval(iv);
