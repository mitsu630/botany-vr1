<script type="application/json" id="esfs-variant-photo-map">
  {
  {%- assign first_written = false -%}
  {%- for v in product.variants -%}
    {%- assign photo_mf = v.metafields.custom.custom_photo -%}
    {%- if photo_mf == blank -%}{%- assign photo_mf = v.metafields.custom.photo -%}{%- endif -%}
    {%- assign photo_obj = photo_mf.value -%}
    {%- assign photo_url = '' -%}

    {%- if photo_mf != blank -%}
      {%- comment -%} media_image / image 参照 {%- endcomment -%}
      {%- if photo_obj != blank -%}
        {%- assign photo_url = photo_obj | image_url: width: 1600 -%}
      {%- endif -%}
      {%- if photo_url == blank and photo_obj.preview_image != blank -%}
        {%- assign photo_url = photo_obj.preview_image | image_url: width: 1600 -%}
      {%- endif -%}

      {%- comment -%} file 参照 {%- endcomment -%}
      {%- if photo_url == blank and photo_obj != blank -%}
        {%- assign photo_url = photo_obj | file_url -%}
      {%- endif -%}
      {%- if photo_url == blank -%}
        {%- assign photo_url = photo_mf | file_url -%}
      {%- endif -%}

      {%- comment -%} 最後の保険: URL文字列が取れる場合 {%- endcomment -%}
      {%- if photo_url == blank and photo_obj.url != blank -%}
        {%- assign photo_url = photo_obj.url -%}
      {%- endif -%}
      {%- if photo_url == blank -%}
        {%- assign photo_url = photo_mf | metafield_text -%}
      {%- endif -%}
    {%- endif -%}

    {%- comment -%}
      追加フォールバック: custom.photo_url（単一行テキスト）
      Google Drive URL の場合は埋め込み表示しやすい uc 形式へ正規化
    {%- endcomment -%}
    {%- if photo_url == blank -%}
      {%- assign photo_url_text_mf = v.metafields.custom.photo_url -%}
