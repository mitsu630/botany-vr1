        nativeReserveBtn.id = 'esfs-fw-reserve-btn';

        nativeSize.classList.add('esfs-fw-select');
        nativePlant.classList.add('esfs-fw-select');
        nativeReserveBtn.classList.add('esfs-fw-reserve-btn');

        // DOM移動（イベントハンドラを維持したまま表示だけをフッターへ寄せる）
        sizeHolder.replaceWith(nativeSize);
        plantHolder.replaceWith(nativePlant);
        var reserveRoot =
          nativeReserveBtn.closest('shopify-buy-it-now-button') ||
          nativeReserveBtn.closest('[data-shopify="payment-button"]') ||
          nativeReserveBtn.parentElement;
        reserveHolder.replaceWith(reserveRoot);

        // id 変更後に参照を更新
        selSize = document.getElementById('esfs-fw-select-size');
        selPlant = document.getElementById('esfs-fw-select-plant');

        nativeOptisMoved = true;
        updateEsfsReserveBtnState();
        scheduleUpdateFooterTotal();
        return true;
      }

      // ネイティブの「予約する」ボタンのみをフッター内へ移植（サイズ/植物 select は移植しない）
      function moveNativeReserveButtonOnly() {
        // DOM移動すると Accelerated Checkout が文脈を失い失敗するため、
        // ここでは移植しない（CSSで可視化する）
        return false;

        var reserveHolder = document.getElementById('esfs-fw-reserve-btn');
        if (!reserveHolder) return false;

        if (reserveHolder.dataset && reserveHolder.dataset.esfsNativeReserveMoved === '1') return true;

        // 「ネイティブの予約する（予約する）」を含む候補を探して移植する
        // ※ Accelerated Checkout は custom element で後から描画されるため、複数候補を広く探す
        function containsReserveLabel(el) {
          try {
            var btn = el && el.querySelector ? el.querySelector('button') : null;
            var t = btn && btn.textContent ? btn.textContent : el && el.textContent ? el.textContent : '';
            return String(t).indexOf('予約') !== -1 || String(t).indexOf('Reserve') !== -1;
          } catch (e) {
            return false;
          }
        }

        var nativeBuyItNow = null;
        var mainForm = document.querySelector('form[action*="/cart/add"]');
        var candidates = [];
        if (mainForm) {
          candidates = candidates.concat(
            Array.prototype.slice.call(mainForm.querySelectorAll('shopify-buy-it-now-button'))
          );
        }
        candidates = candidates.concat(
          Array.prototype.slice.call(document.querySelectorAll('shopify-buy-it-now-button'))
        );

        for (var i = 0; i < candidates.length; i++) {
          if (containsReserveLabel(candidates[i])) {
            nativeBuyItNow = candidates[i];
            break;
          }
        }
        if (!nativeBuyItNow && candidates.length) nativeBuyItNow = candidates[0];

        if (!nativeBuyItNow) return false;

        // フッター内のカスタム枠ごと置換し、残りボタンが発生しないようにする
        nativeBuyItNow.setAttribute('data-esfs-native-reserve', '1');
        reserveHolder.replaceWith(nativeBuyItNow);
        return true;
      }

      function getQuantityInputs() {
        var list = Array.prototype.slice.call(
          document.querySelectorAll('form[action*="/cart/add"] input[name="quantity"]')
        );
        if (list.length) return list;
        var qi =
          document.querySelector('quantity-input input[name="quantity"]') ||
          document.querySelector('quantity-input input[type="number"]') ||
          document.querySelector('.product-form input[name="quantity"]');
        return qi ? [qi] : [];
      }

      function cloneOptionsInto(targetSelect, sourceSelect) {
        if (!targetSelect || !sourceSelect) return;
        var prev = targetSelect.value;
        targetSelect.innerHTML = '';
        for (var i = 0; i < sourceSelect.options.length; i++) {
          var o = sourceSelect.options[i];
          var opt = document.createElement('option');
          opt.value = o.value;
          opt.textContent = o.textContent || o.value || o.innerText;
          targetSelect.appendChild(opt);
        }
        if (prev && Array.prototype.some.call(targetSelect.options, function (x) { return x.value === prev; })) {
          targetSelect.value = prev;
        } else {
          targetSelect.value = sourceSelect.value;
        }
      }

      function dispatchChange(el) {
        if (!el) return;
        el.dispatchEvent(new Event('change', { bubbles: true }));
      }

      function readQuantity() {
        var inputs = getQuantityInputs();
        if (!inputs.length) return qtyMin;
        var v = parseInt(String(inputs[0].value), 10);
        if (isNaN(v) || v < qtyMin) return qtyMin;
        return v;
      }

      /**
       * 1人あたり：作品サイズに「○○yen」が含まれるときのみ（未選択・他形式は null → 合計¥0）
       * リロード直後や比較価格の誤取得を避けるため、バリアント/DOMからは取らない。
       */
      function perPersonYenFromSizeOnly() {
        var sz = getMainSizeSelect();
        if (!sz || !sz.value) return null;
        var sv = String(sz.value).trim();
        if (sv.indexOf('Please select') !== -1) return null;
        if (sv === 'サイズを選ぶ') return null;
        var m = sv.match(/(\d{3,7})\s*yen\b/i);
        if (m) return parseInt(m[1], 10);
        return null;
      }

      var updateTotalTimer;
      function scheduleUpdateFooterTotal() {
        clearTimeout(updateTotalTimer);
        updateTotalTimer = setTimeout(function () {
          updateFooterTotalDisplay();
        }, 100);
      }

      function updateFooterTotalDisplay() {
        if (!totalAmountEl) return;
        var unit = perPersonYenFromSizeOnly();
        var q = readQuantity();
        var mult =
          unit != null && !isNaN(unit) && unit > 0
            ? Math.round(unit * q)
            : 0;
        totalAmountEl.textContent = '合計 ¥' + mult.toLocaleString('ja-JP');
      }

      /**
       * OPTIS 未選択：英語プレースホルダー or 日本語初期文言（サイズを選ぶ / 植物を選ぶ）
       */
      function isOptisPoUnset(sel, jaPlaceholder) {
        if (sel == null) return true;
        var raw = typeof sel === 'string' ? sel : sel.value;
        var v = String(raw || '').trim();
        if (!v) return true;
        if (v.indexOf('Please select') !== -1) return true;
        if (jaPlaceholder && v === jaPlaceholder) return true;
        return false;
      }
      function pickReserveValue(mainSel, footerSel, jaPlaceholder) {
        var mv = mainSel && mainSel.value ? String(mainSel.value).trim() : '';
        var fv = footerSel && footerSel.value ? String(footerSel.value).trim() : '';
        if (!isOptisPoUnset(mv, jaPlaceholder)) return mv;
        if (!isOptisPoUnset(fv, jaPlaceholder)) return fv;
        return mv || fv;
      }

      function updateEsfsReserveBtnState() {
        var btn = document.getElementById('esfs-fw-reserve-btn');
        if (!btn) return;

        // ネイティブ予約ボタンを移植できている場合、muted制御はやめて
        // ネイティブ側（disabled / aria-disabled）に任せる
        if (btn.dataset && btn.dataset.esfsNativeReserveMoved === '1') {
          btn.classList.remove('esfs-fw-reserve-btn--muted');
          btn.removeAttribute('aria-disabled');
          btn.removeAttribute('title');
          return;
        }

        if (window.esfsSetReserveBtnWaiting) window.esfsSetReserveBtnWaiting(false);
        var sz = pickReserveValue(getMainSizeSelect(), selSize, 'サイズを選ぶ');
        var pl = pickReserveValue(getMainPlantSelect(), selPlant, '植物を選ぶ');
        var muted =
          isOptisPoUnset(sz, 'サイズを選ぶ') ||
          isOptisPoUnset(pl, '植物を選ぶ');
        if (muted) {
          btn.classList.add('esfs-fw-reserve-btn--muted');
          btn.setAttribute('aria-disabled', 'true');
          btn.setAttribute(
            'title',
            '作品のサイズと希望する植物を選んでからお進みください'
          );
        } else {
          btn.classList.remove('esfs-fw-reserve-btn--muted');
          btn.removeAttribute('aria-disabled');
          btn.removeAttribute('title');
        }
      }

      function ensureQtyOptionInFooter(n) {
        if (!qtySelect) return;
        n = Math.max(qtyMin, Math.min(qtyMax, parseInt(String(n), 10) || qtyMin));
        qtySelect.value = String(n);
      }

      function syncQtyFooterWithInputs() {
        var q = readQuantity();
        if (q > qtyMax) {
          setQuantityAll(qtyMax);
        } else {
          ensureQtyOptionInFooter(q);
        }
      }

      function setQuantityAll(n) {
        n = Math.max(qtyMin, Math.min(qtyMax, parseInt(String(n), 10) || qtyMin));
        getQuantityInputs().forEach(function (inp) {
          inp.value = String(n);
          inp.dispatchEvent(new Event('input', { bubbles: true }));
          inp.dispatchEvent(new Event('change', { bubbles: true }));
        });
        var qtySelectReserve = document.querySelector('#esfs-workshop-reserve-form .esfs-quantity-select');
        if (qtySelectReserve) qtySelectReserve.value = String(n);
        ensureQtyOptionInFooter(n);
        scheduleUpdateFooterTotal();
        return n;
      }

      function syncFooterFromMains() {
        if (syncLock) return;
        syncLock = true;
        try {
          if (mainDate && selDate) {
            cloneOptionsInto(selDate, mainDate);
            selDate.value = mainDate.value;
            esfsUpdateDateTrigger();
          }
          if (mainSize && selSize) {
            if (!nativeOptisMoved) {
              cloneOptionsInto(selSize, mainSize);
              selSize.value = mainSize.value;
            }
          }
          if (mainPlant && selPlant) {
            if (!nativeOptisMoved) {
              cloneOptionsInto(selPlant, mainPlant);
              selPlant.value = mainPlant.value;
            }
          }
          syncQtyFooterWithInputs();
        } finally {
          syncLock = false;
        }
        scheduleUpdateFooterTotal();
        updateEsfsReserveBtnState();
      }

      function applyFooterDate() {
        if (!mainDate || !selDate) return;
        mainDate.value = selDate.value;
        dispatchChange(mainDate);
        scheduleUpdateFooterTotal();
        setTimeout(scheduleUpdateFooterTotal, 280);
        setTimeout(scheduleUpdateFooterTotal, 650);
      }

      function applyFooterSize() {
        if (!mainSize || !selSize) return;
        mainSize.value = selSize.value;
        dispatchChange(mainSize);
        scheduleUpdateFooterTotal();
        setTimeout(scheduleUpdateFooterTotal, 280);
        setTimeout(scheduleUpdateFooterTotal, 650);
        updateEsfsReserveBtnState();
        setTimeout(updateEsfsReserveBtnState, 350);
        setTimeout(updateEsfsReserveBtnState, 700);
      }

      function applyFooterPlant() {
        if (!mainPlant || !selPlant) return;
        mainPlant.value = selPlant.value;
        dispatchChange(mainPlant);
        scheduleUpdateFooterTotal();
        updateEsfsReserveBtnState();
        setTimeout(updateEsfsReserveBtnState, 350);
        setTimeout(updateEsfsReserveBtnState, 700);
      }

      function esfsEscapeHtml(str) {
        var d = document.createElement('div');
        d.textContent = str == null ? '' : String(str);
        return d.innerHTML;
      }

      /**
       * 会場住所と日程のあいだ（全角スペース or 連続スペース）で2行に分ける
       */
      function esfsSplitKaijoLines(text) {
        var t = String(text || '').trim();
        if (!t) return { l1: '', l2: '' };
        var u3000 = '\u3000';
        var i = t.indexOf(u3000);
        if (i > 0) {
          var a = t.slice(0, i).trim();
          var b = t.slice(i + 1).replace(/^[\s\u3000]+/, '').trim();
          if (b.length) return { l1: a, l2: b };
        }
        var m = t.match(/^(.+?)(\s{2,}|\s\u3000|\u3000\s)(.+)$/);
        if (m && m[3].length) {
          return { l1: m[1].trim(), l2: m[3].trim() };
        }
        return { l1: t, l2: '' };
      }

      function esfsUpdateDateTrigger() {
        var sel = document.getElementById('esfs-fw-select-date');
        var el = document.getElementById('esfs-fw-date-trigger-lines');
        if (!sel || !el) return;
        var parts = esfsSplitKaijoLines(sel.value);
        if (parts.l2) {
          el.innerHTML =
            '<span class="esfs-fw-date-line1">' +
            esfsEscapeHtml(parts.l1) +
            '</span><span class="esfs-fw-date-line2">' +
            esfsEscapeHtml(parts.l2) +
            '</span>';
        } else {
          el.innerHTML =
            '<span class="esfs-fw-date-line1">' +
            esfsEscapeHtml(parts.l1 || '—') +
            '</span>';
        }
      }

      function esfsCloseDatePanel() {
        var bd = document.getElementById('esfs-fw-date-backdrop');
        var wrap = document.getElementById('esfs-fw-date-panel-wrap');
        var tr = document.getElementById('esfs-fw-date-trigger');
        if (bd) bd.setAttribute('hidden', '');
        if (wrap) wrap.setAttribute('hidden', '');
        if (tr) tr.setAttribute('aria-expanded', 'false');
      }

      function esfsOpenDatePanel() {
        var footer = document.getElementById('esfs-floating-workshop-footer');
        var wrap = document.getElementById('esfs-fw-date-panel-wrap');
        var bd = document.getElementById('esfs-fw-date-backdrop');
        var tr = document.getElementById('esfs-fw-date-trigger');
        if (!wrap || !bd || !tr) return;
        esfsRenderDatePanel();
        var topSpace = 72;
        if (footer) {
          var r = footer.getBoundingClientRect();
          var avail = Math.max(160, r.top - topSpace);
          wrap.style.maxHeight = avail + 'px';
          wrap.style.bottom = Math.round(window.innerHeight - r.top + 10) + 'px';
          wrap.style.top = 'auto';
        } else {
          wrap.style.maxHeight = '42vh';
          wrap.style.bottom = '32%';
          wrap.style.top = 'auto';
        }
        bd.removeAttribute('hidden');
        wrap.removeAttribute('hidden');
        tr.setAttribute('aria-expanded', 'true');
      }

      function esfsRenderDatePanel() {
        var sel = document.getElementById('esfs-fw-select-date');
        var panel = document.getElementById('esfs-fw-date-panel');
        if (!sel || !panel) return;
        panel.innerHTML = '';
        var cur = sel.value;
        for (var i = 0; i < sel.options.length; i++) {
          var o = sel.options[i];
          var v = o.value;
          var parts = esfsSplitKaijoLines(v);
          var li = document.createElement('li');
          li.className = 'esfs-fw-date-item';
          li.setAttribute('role', 'option');
          if (v === cur) li.classList.add('esfs-fw-date-item--current');
          var h =
            '<span class="esfs-fw-date-item-l1">' +
            esfsEscapeHtml(parts.l1) +
            '</span>';
          if (parts.l2) {
            h +=
              '<span class="esfs-fw-date-item-l2">' +
              esfsEscapeHtml(parts.l2) +
              '</span>';
          }
          li.innerHTML = h;
          (function (val) {
            li.addEventListener('click', function () {
              esfsChooseKaijoDate(val);
            });
          })(v);
          panel.appendChild(li);
        }
      }

      function esfsChooseKaijoDate(val) {
        var sel = document.getElementById('esfs-fw-select-date');
        if (!sel) return;
        sel.value = val;
        applyFooterDate();
        if (window.esfsUpdateVariantBanner) {
          setTimeout(window.esfsUpdateVariantBanner, 80);
          setTimeout(window.esfsUpdateVariantBanner, 320);
        }
        if (window.esfsUpdateVariantInfo) {
          setTimeout(window.esfsUpdateVariantInfo, 80);
          setTimeout(window.esfsUpdateVariantInfo, 320);
        }
        esfsUpdateDateTrigger();
        esfsCloseDatePanel();
        if (typeof window.esfsScrollToTopSmooth === 'function') {
          window.esfsScrollToTopSmooth();
        }
      }

      var esfsKaijoPickerBound = false;
      function esfsBindKaijoDatePickerUi() {
        if (esfsKaijoPickerBound) return;
        esfsKaijoPickerBound = true;
        var tr = document.getElementById('esfs-fw-date-trigger');
        var bd = document.getElementById('esfs-fw-date-backdrop');
        if (!tr) return;
        tr.addEventListener('click', function (e) {
          e.stopPropagation();
          var wrap = document.getElementById('esfs-fw-date-panel-wrap');
          var open = wrap && !wrap.hasAttribute('hidden');
          if (open) esfsCloseDatePanel();
          else esfsOpenDatePanel();
        });
        if (bd) bd.addEventListener('click', esfsCloseDatePanel);
        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape') esfsCloseDatePanel();
        });
      }

      function bindOnce() {
        if (mainDate) {
          mainDate.addEventListener('change', function () {
            if (syncLock) return;
            cloneOptionsInto(selDate, mainDate);
            selDate.value = mainDate.value;
            esfsUpdateDateTrigger();
            scheduleUpdateFooterTotal();
            setTimeout(scheduleUpdateFooterTotal, 300);
          });
        }
        if (mainSize) {
          mainSize.addEventListener('change', function () {
            if (syncLock) return;
            if (!nativeOptisMoved) {
              cloneOptionsInto(selSize, mainSize);
              selSize.value = mainSize.value;
            }
            scheduleUpdateFooterTotal();
            setTimeout(scheduleUpdateFooterTotal, 350);
            updateEsfsReserveBtnState();
            setTimeout(updateEsfsReserveBtnState, 400);
          });
        }
        if (mainPlant) {
          mainPlant.addEventListener('change', function () {
            if (syncLock) return;
            if (!nativeOptisMoved) {
              cloneOptionsInto(selPlant, mainPlant);
              selPlant.value = mainPlant.value;
            }
            scheduleUpdateFooterTotal();
            updateEsfsReserveBtnState();
            setTimeout(updateEsfsReserveBtnState, 400);
          });
        }

        getQuantityInputs().forEach(function (inp) {
          inp.addEventListener('change', function () {
            syncQtyFooterWithInputs();
            scheduleUpdateFooterTotal();
          });
        });

        if (selSize) {
          if (!nativeOptisMoved) {
            selSize.addEventListener('change', applyFooterSize);
          } else {
            selSize.addEventListener('change', function () {
              scheduleUpdateFooterTotal();
              updateEsfsReserveBtnState();
            });
          }
        }
        if (selPlant) {
          if (!nativeOptisMoved) {
            selPlant.addEventListener('change', applyFooterPlant);
          } else {
            selPlant.addEventListener('change', function () {
              scheduleUpdateFooterTotal();
              updateEsfsReserveBtnState();
            });
          }
        }

        if (qtySelect) {
          qtySelect.addEventListener('change', function () {
            setQuantityAll(qtySelect.value);
          });
        }

        if (typeof MutationObserver !== 'undefined' && totalAmountEl) {
          var priceMoT;
          var priceMo = new MutationObserver(function () {
            clearTimeout(priceMoT);
            priceMoT = setTimeout(function () {
              updateFooterTotalDisplay();
            }, 450);
          });
          var priceRoot =
            document.querySelector('.product__info') ||
            document.querySelector('.product') ||
            document.body;
          priceMo.observe(priceRoot, { childList: true, subtree: true });
        }

        var reserveFooterBtn = document.getElementById('esfs-fw-reserve-btn');
        function getShopifyReserveButton() {
          return (
            document.querySelector(
              'button.shopify-payment-button__button--unbranded.bss-po-btn-buyitnow[po-btn-buy-it-now="true"]'
            ) ||
            document.querySelector('button.shopify-payment-button__button--unbranded.bss-po-btn-buyitnow') ||
            document.querySelector('button.shopify-payment-button__button--unbranded[po-btn-buy-it-now="true"]') ||
            document.querySelector('button.shopify-payment-button__button--unbranded')
          );
        }
        function getMainCartAddForm() {
          return (typeof getBestCartAddForm === 'function')
            ? getBestCartAddForm()
            : (
              document.querySelector('product-form form[action*="/cart/add"]') ||
              document.querySelector('form[action*="/cart/add"]')
            );
        }
        function fallbackAddToCartAndCheckout() {
          var form = getMainCartAddForm();
          if (!form) {
            if (window.esfsReserveDebug) window.esfsReserveDebug('fallback:no-form');
            return;
          }
          if (typeof submitExistingCartFormToCheckout === 'function') {
            if (!submitExistingCartFormToCheckout(form, 'bindOnce-fallback')) {
              if (window.esfsReserveDebug) window.esfsReserveDebug('fallback:no-variant-id');
              return;
            }
            return;
          }
          var fd = new FormData(form);
          if (!fd.get('id')) {
            if (window.esfsReserveDebug) window.esfsReserveDebug('fallback:no-variant-id');
            return;
          }
        }

        if (reserveFooterBtn) {
          function tryClickRealReserve() {
            var realBtn = getShopifyReserveButton();
            if (
              realBtn &&
              !realBtn.disabled &&
              realBtn.getAttribute('aria-disabled') !== 'true'
            ) {
              realBtn.click();
              return true;
            }
            if (
              realBtn &&
              (realBtn.disabled || realBtn.getAttribute('aria-disabled') === 'true')
            ) {
              /* 一時的に非活性のことがあるため、成功扱いせず再試行させる */
              return false;
            }
            return false;
          }
          reserveFooterBtn.addEventListener('click', function () {
            // フッター内にネイティブボタンを移植できている場合は、
            // ネイティブ側のクリックをそのまま任せる（二重処理を防ぐ）
            if (reserveFooterBtn.dataset && reserveFooterBtn.dataset.esfsNativeReserveMoved === '1') {
              return;
            }
            if (window.esfsReserveGlobalHandled) {
              if (window.esfsReserveDebug) window.esfsReserveDebug('bindOnce:skip-duplicate-handler');
              return;
            }
            /* 先に最新状態へ更新（誤判定で muted が残るケースを吸収） */
            updateEsfsReserveBtnState();
            if (reserveFooterBtn.classList.contains('esfs-fw-reserve-btn--muted')) {
              if (window.esfsReserveDebug) window.esfsReserveDebug('bindOnce:blocked-muted');
              return;
            }
            if (tryClickRealReserve()) {
              if (window.esfsReserveDebug) window.esfsReserveDebug('bindOnce:clicked-real-button');
              return;
            }
            if (window.esfsReserveDebug) window.esfsReserveDebug('bindOnce:start-retry-loop');
            var tries = 0;
            var iv = setInterval(function () {
              tries += 1;
              if (tryClickRealReserve() || tries >= 20) {
                clearInterval(iv);
                if (tries >= 20 && !getShopifyReserveButton()) {
                  var payWrap = document.querySelector('[data-shopify="payment-button"]');
                  if (payWrap) {
                    payWrap.scrollIntoView({ behavior: 'smooth', block: 'center' });
                  }
                  fallbackAddToCartAndCheckout();
                } else if (tries >= 20) {
                  fallbackAddToCartAndCheckout();
                }
              }
            }, 120);
          });
        }

        esfsBindKaijoDatePickerUi();
      }

      function updateFooterPadding() {
        var h = footer.offsetHeight || 0;
        scope.style.setProperty('--esfs-fw-pad', h + 'px');
        document.body.style.paddingBottom = h + 'px';
      }

      function tryActivate() {
        if (fwFooterReady) return true;

        mainDate = getMainDateSelect();
        mainSize = getMainSizeSelect();
        mainPlant = getMainPlantSelect();

        if (!mainDate || !mainSize || !mainPlant) return false;

        // サイズ/植物はフッター側の表示用 select を使う（表示崩れを防ぐ）
        // OPTIS の追加料金計算は、値をメインフォームへ反映して BSS/OPTIS の再計算に寄せる
        moveNativeOptisSelectsAndReserveBtn();

        cloneOptionsInto(selDate, mainDate);

        selDate.value = mainDate.value;
        if (!nativeOptisMoved) {
          cloneOptionsInto(selSize, mainSize);
          cloneOptionsInto(selPlant, mainPlant);
          selSize.value = mainSize.value;
          selPlant.value = mainPlant.value;
        }

        esfsUpdateDateTrigger();
        esfsBindKaijoDatePickerUi();

        syncQtyFooterWithInputs();
        scheduleUpdateFooterTotal();
        setTimeout(scheduleUpdateFooterTotal, 400);
        setTimeout(scheduleUpdateFooterTotal, 900);

        footer.removeAttribute('hidden');
        footer.classList.add('esfs-floating-workshop-footer--active');
        scope.classList.add('esfs-floating-workshop-footer--ready');
        document.body.classList.add('esfs-20xx-workshop-reserve-in-footer');

        bindOnce();
        updateEsfsReserveBtnState();
        setTimeout(updateEsfsReserveBtnState, 500);
        setTimeout(updateEsfsReserveBtnState, 1000);

        if (typeof ResizeObserver !== 'undefined') {
          var ro = new ResizeObserver(function () {
            updateFooterPadding();
          });
          ro.observe(footer);
        }
        if (String(window.location.search || '').indexOf('esfs_debug_show_native=1') !== -1) {
          document.body.classList.add('esfs-debug-show-native');
        }
        updateFooterPadding();
        window.addEventListener('resize', updateFooterPadding);

        if (window.esfsUpdateVariantBanner) {
          window.esfsUpdateVariantBanner();
          setTimeout(window.esfsUpdateVariantBanner, 120);
          setTimeout(window.esfsUpdateVariantBanner, 450);
        }
        if (window.esfsUpdateVariantInfo) {
          window.esfsUpdateVariantInfo();
          setTimeout(window.esfsUpdateVariantInfo, 120);
          setTimeout(window.esfsUpdateVariantInfo, 450);
          setTimeout(window.esfsUpdateVariantInfo, 900);
        }

        var mo = new MutationObserver(function () {
          var d = getMainDateSelect();
          var s = getMainSizeSelect();
          var p = getMainPlantSelect();
          if (d && s && p && (d !== mainDate || s !== mainSize || p !== mainPlant)) {
            mainDate = d;
            mainSize = s;
            mainPlant = p;
            syncFooterFromMains();
          }
        });
        mo.observe(document.body, { childList: true, subtree: true });

        fwFooterReady = true;

        var qTries = 0;
        var qTimer = setInterval(function () {
          qTries += 1;
          if (getQuantityInputs().length || qTries > 25) {
            clearInterval(qTimer);
            syncQtyFooterWithInputs();
          }
        }, 200);

        return true;
      }

      var attempts = 0;
      var timer = setInterval(function () {
        attempts += 1;
        if (tryActivate() || attempts > 80) {
          clearInterval(timer);
        }
      }, 200);
    })();
  });
</script>

