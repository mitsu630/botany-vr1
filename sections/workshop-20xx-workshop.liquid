      function esfsPostCartAddFormDataToCheckout(srcForm, reason) {
        try {
          syncOptisValuesToCartForms();
          // フォールバックは「既存の /cart/add フォーム送信」に寄せ、
          // 送信時JS（OPTIS/BSSの hidden properties 生成など）が確実に走るようにする
          var qtyEl = document.getElementById('esfs-fw-qty-select');
