<script>
  document.addEventListener('DOMContentLoaded', function () {
    var scope = document.querySelector('.esfs-20xx-workshop-scope');
    if (!scope) return;

    function esfsParseJsonScript(id) {
      try {
        var el = document.getElementById(id);
        if (!el || !el.textContent) return null;
        return JSON.parse(el.textContent.trim());
      } catch (e) {
        return null;
      }
    }

    /* esfsParseJsonScriptDebug: returns object with data, error, preview */
    function esfsParseJsonScriptDebug(id) {
      var out = { data: null, error: null, preview: '' };
      try {
        var el = document.getElementById(id);
        if (!el) {
          out.error = '要素なし id=' + id;
          return out;
        }
        var raw = (el.textContent || '').trim();
        out.preview = raw.length > 420 ? raw.slice(0, 420) + '…' : raw;
        if (!raw) {
          out.error = '中身が空 id=' + id;
          return out;
        }
        out.data = JSON.parse(raw);
        return out;
      } catch (e) {
        out.error = (e && e.message) ? e.message : String(e);
        return out;
      }
    }

    function esfsB64Utf8Decode(b64) {
      if (b64 == null || b64 === '') return '';
      var s = String(b64);
      try {
        var bin = atob(s);
        if (typeof TextDecoder !== 'undefined') {
          var u8 = new Uint8Array(bin.length);
          for (var i = 0; i < bin.length; i++) u8[i] = bin.charCodeAt(i);
          return new TextDecoder('utf-8').decode(u8);
        }
        return decodeURIComponent(escape(bin));
      } catch (e) {
        return '';
      }
    }

    function esfsBuildInfoMapsFromB64List(arr) {
      var byId = {};
      var byOpt = {};
      if (!Array.isArray(arr)) return { byId: byId, byOpt: byOpt };
      for (var i = 0; i < arr.length; i++) {
        var row = arr[i];
        if (!row) continue;
        var info = {
          day: esfsB64Utf8Decode(row.day_b64),
          time: esfsB64Utf8Decode(row.time_b64),
          mochimono: esfsB64Utf8Decode(row.mochi_b64),
          kaijyo: esfsB64Utf8Decode(row.kaijyo_b64),
          jyusho: esfsB64Utf8Decode(row.jyu_b64),
          hoka: esfsB64Utf8Decode(row.hoka_b64)
        };
