    function getBestCartAddForm() {
      var forms = Array.prototype.slice.call(document.querySelectorAll('form[action*="/cart/add"]'));
      if (!forms.length) return null;
      forms.sort(function (a, b) {
        var aHasId = a.querySelector('input[name="id"]') ? 1 : 0;
        var bHasId = b.querySelector('input[name="id"]') ? 1 : 0;
        var aPo = a.querySelectorAll('select[name^="po_dropdown"], input[name^="po_dropdown"]').length;
        var bPo = b.querySelectorAll('select[name^="po_dropdown"], input[name^="po_dropdown"]').length;
        var aDate = a.querySelectorAll('select[name="options[会場開催日]"], input[name="options[会場開催日]"]').length;
        var bDate = b.querySelectorAll('select[name="options[会場開催日]"], input[name="options[会場開催日]"]').length;
        var aProps = a.querySelectorAll('input[name^="properties["], select[name^="properties["], textarea[name^="properties["]').length;
        var bProps = b.querySelectorAll('input[name^="properties["], select[name^="properties["], textarea[name^="properties["]').length;
        // まず po_dropdown が2つ以上あるフォームを最優先
        var aBonus = aPo >= 2 ? 100000 : aPo * 1000;
        var bBonus = bPo >= 2 ? 100000 : bPo * 1000;

        var aScore = aBonus + aHasId * 100 + aDate * 20 + aProps;
        var bScore = bBonus + bHasId * 100 + bDate * 20 + bProps;
        return bScore - aScore;
      });
      return forms[0];
    }
    function submitExistingCartFormToCheckout(form, reason) {
