    function syncOptisValuesToCartForms() {
      var sv = getSelectedSizePlantValues();
      var dateSel = document.querySelector('select[name="options[会場開催日]"]');
      var dateVal = dateSel && dateSel.value ? String(dateSel.value) : '';

      function esfsNormPoText(s) {
        return String(s == null ? '' : s)
          .replace(/\u3000/g, ' ')
          .replace(/\s+/g, ' ')
          .trim();
      }

      function esfsResolvePoNameBySelectedValue(targetValue) {
        var tv = esfsNormPoText(targetValue);
        if (!tv) return null;
        var els = Array.prototype.slice.call(
          document.querySelectorAll('select[name^="po_dropdown"], input[name^="po_dropdown"]')
        );
        for (var i = 0; i < els.length; i++) {
          var el = els[i];
          var name = el && el.name ? el.name : '';
          if (!name) continue;
          if (el.tagName === 'SELECT' && el.options) {
            for (var j = 0; j < el.options.length; j++) {
              var opt = el.options[j];
              var optText = esfsNormPoText(opt && opt.textContent ? opt.textContent : '');
              var optVal = esfsNormPoText(opt && opt.value != null ? opt.value : '');
              if (optText === tv || optVal === tv) return name;
            }
          } else {
            var v = esfsNormPoText(el.value);
            if (v === tv) return name;
          }
        }
        return null;
      }

      var poSizeName = esfsResolvePoNameBySelectedValue(sv.size);
      var poPlantName = esfsResolvePoNameBySelectedValue(sv.plant);

      var forms = Array.prototype.slice.call(document.querySelectorAll('form[action*="/cart/add"]'));
      forms.forEach(function (form) {
        // サイズ/植物は po_dropdown の name がフォームによって異なるため、
        // ページ上に存在する po_dropdown から「選択値に対応する name」を解決して強制送信
        if (!esfsIsUnsetValue(sv.size, 'サイズを選ぶ') && poSizeName) {
          var sField =
            form.querySelector('select[name="' + poSizeName + '"], input[name="' + poSizeName + '"]');
          if (!sField) {
            sField = document.createElement('input');
            sField.type = 'hidden';
            sField.name = poSizeName;
            form.appendChild(sField);
          }
          setFormFieldValue(sField, sv.size);
        }
        if (!esfsIsUnsetValue(sv.plant, '植物を選ぶ') && poPlantName) {
          var pField =
            form.querySelector('select[name="' + poPlantName + '"], input[name="' + poPlantName + '"]');
          if (!pField) {
            pField = document.createElement('input');
            pField.type = 'hidden';
            pField.name = poPlantName;
            form.appendChild(pField);
          }
          setFormFieldValue(pField, sv.plant);
        }

        // フォーム内に po_dropdown が2つ存在する場合は従来の順序埋めも行う（補助）
        var poFields = Array.prototype.slice.call(
          form.querySelectorAll('select[name^="po_dropdown"], input[name^="po_dropdown"]')
        );
        if (poFields.length >= 1 && !esfsIsUnsetValue(sv.size, 'サイズを選ぶ') && !poSizeName) {
          setFormFieldValue(poFields[0], sv.size);
        }
        if (poFields.length >= 2 && !esfsIsUnsetValue(sv.plant, '植物を選ぶ') && !poPlantName) {
          setFormFieldValue(poFields[1], sv.plant);
        }

        if (dateVal) {
          var dateField = form.querySelector('select[name="options[会場開催日]"], input[name="options[会場開催日]"]');
          if (!dateField) {
            dateField = document.createElement('input');
            dateField.type = 'hidden';
            dateField.name = 'options[会場開催日]';
            form.appendChild(dateField);
          }
          setFormFieldValue(dateField, dateVal);
        }
      });
      esfsReserveDebug('forceReserve:sync-optis-to-forms', {
        size: sv.size,
        plant: sv.plant,
        poSizeName: poSizeName,
        poPlantName: poPlantName,
        kaijoDate: dateVal,
        formCount: forms.length
      });
