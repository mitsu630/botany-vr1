{%- liquid
  assign variant = product.selected_or_first_available_variant

  assign wdh_fb = ''
  if product.featured_image
    assign wdh_fb = product.featured_image | image_url: width: 2000
  elsif product.media.size > 0
    assign wdh_m0 = product.media.first
    if wdh_m0.media_type == 'image'
      assign wdh_fb = wdh_m0 | image_url: width: 2000
    elsif wdh_m0.preview_image
      assign wdh_fb = wdh_m0.preview_image | image_url: width: 2000
    endif
  endif
-%}
{%- capture wdh_img_src -%}
  {%- render 'wdh-resolve-image-url',
    photo_url_mf: variant.metafields.custom.photo_url,
    photo_file_mf: variant.metafields.custom.photo,
    variant_obj: variant,
    product_fallback: wdh_fb
  -%}
{%- endcapture -%}
{%- assign wdh_img_src = wdh_img_src | strip -%}

{%- liquid
  assign wdh_day = variant.metafields.custom.day.value | default: '' | strip
  if wdh_day == blank
    assign wdh_day = variant.title | strip
  endif

  assign wdh_time = variant.metafields.custom.time.value | default: '' | strip
  assign wdh_mochimono = variant.metafields.custom.mochimono.value | default: '' | strip
  assign wdh_kaijyo = variant.metafields.custom.kaijyo.value | default: '' | strip
  assign wdh_jyusho = variant.metafields.custom.jyusho.value | default: '' | strip
  assign wdh_biko = variant.metafields.custom.biko.value | default: '' | strip
-%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  #shopify-section-{{ section.id }} .wdh-card {
    background-color: #ffffff;
    border-radius: var(--border-radius, 0.8rem);
    padding: 2rem 1.5rem;
    box-shadow: 0 0.1rem 0.4rem rgba(var(--color-foreground), 0.08);
    max-width: 72rem;
    margin: 0 auto;
  }
  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .wdh-card {
      padding: 2.5rem 2rem;
    }
  }
  #shopify-section-{{ section.id }} .wdh__layout {
    display: grid;
    gap: 1.75rem;
    align-items: start;
  }
  @media screen and (min-width: 990px) {
    #shopify-section-{{ section.id }} .wdh__layout {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.1fr);
      gap: 2.5rem;
    }
  }
  #shopify-section-{{ section.id }} .wdh__media {
    margin: 0;
    border-radius: calc(var(--border-radius, 0.8rem) - 0.2rem);
    overflow: hidden;
    background: rgba(var(--color-foreground), 0.04);
  }
  #shopify-section-{{ section.id }} .wdh__image {
    display: block;
    width: 100%;
    height: auto;
    vertical-align: middle;
  }
  #shopify-section-{{ section.id }} .wdh-course-block {
    border-radius: calc(var(--border-radius, 0.8rem) - 0.2rem);
    overflow: hidden;
    border: 0.1rem solid rgba(var(--color-foreground), 0.12);
  }
  #shopify-section-{{ section.id }} .wdh-table {
    width: 100%;
    border-collapse: collapse;
    margin: 0;
    background-color: rgb(var(--color-background));
  }
  #shopify-section-{{ section.id }} .wdh-table__title {
    margin: 0;
    padding: 1rem 1.25rem;
    font-size: 1.4rem;
    font-weight: 600;
    text-align: center;
    letter-spacing: 0.06rem;
    background-color: rgb(var(--color-button));
    color: rgb(var(--color-button-text));
  }
  #shopify-section-{{ section.id }} .wdh-table__label {
    width: 28%;
    margin: 0;
    padding: 1rem 1.1rem;
    font-size: 1.3rem;
    font-weight: 600;
    text-align: left;
    vertical-align: top;
    background-color: rgba(var(--color-foreground), 0.06);
    color: rgb(var(--color-foreground));
    border-top: 0.1rem solid rgba(var(--color-foreground), 0.12);
    border-right: 0.1rem solid rgba(var(--color-foreground), 0.12);
  }
  #shopify-section-{{ section.id }} .wdh-table__value {
    margin: 0;
    padding: 1rem 1.1rem;
    font-size: 1.4rem;
    line-height: calc(1 + 0.5 / var(--font-body-scale));
    vertical-align: top;
    color: rgba(var(--color-foreground), 0.92);
    background-color: rgb(var(--color-background));
    border-top: 0.1rem solid rgba(var(--color-foreground), 0.12);
    word-break: break-word;
    white-space: pre-wrap;
  }
  #shopify-section-{{ section.id }} .wdh-table__value--muted {
    font-size: 1.3rem;
    color: rgba(var(--color-foreground), 0.75);
  }
  #shopify-section-{{ section.id }} .wdh-table tbody tr:first-child .wdh-table__label,
  #shopify-section-{{ section.id }} .wdh-table tbody tr:first-child .wdh-table__value {
    border-top: none;
  }
{%- endstyle -%}

{%- if product != blank -%}
  <script src="{{ 'workshop-dynamic-header.js' | asset_url }}" defer="defer"></script>

  <div
    class="workshop-dynamic-header"
    data-section-id="{{ section.id }}"
    data-initial-variant-id="{{ variant.id }}"
    data-initial-variant-title="{{ variant.title | escape }}"
    data-product-id="{{ product.id }}"
  >
    <script type="application/json" data-wdh-json>
      {
        "productId": {{ product.id | json }},
        "productTitle": {{ product.title | json }},
        "fallbackImage": {{ wdh_fb | json }},
        "variants": {
          {%- for v in product.variants -%}
            {%- capture v_img -%}
              {%- render 'wdh-resolve-image-url',
                photo_url_mf: v.metafields.custom.photo_url,
                photo_file_mf: v.metafields.custom.photo,
                variant_obj: v,
                product_fallback: wdh_fb
              -%}
            {%- endcapture -%}
            {%- assign v_img = v_img | strip -%}
            {%- assign v_day = v.metafields.custom.day.value | default: '' | strip -%}
            {%- if v_day == blank -%}
              {%- assign v_day = v.title | strip -%}
            {%- endif -%}
            "{{ v.id }}": {
              "imageUrl": {{ v_img | json }},
              "photoUrl": {% if v.metafields.custom.photo_url.value != blank %}{{ v.metafields.custom.photo_url.value | strip | json }}{% else %}""{% endif %},
              "photoFileUrl": {% if v.metafields.custom.photo.value != blank %}{{ v.metafields.custom.photo | image_url: width: 2000 | json }}{% else %}""{% endif %},
              "day": {{ v_day | json }},
              "time": {{ v.metafields.custom.time.value | default: '' | json }},
              "mochimono": {{ v.metafields.custom.mochimono.value | default: '' | json }},
              "kaijyo": {{ v.metafields.custom.kaijyo.value | default: '' | json }},
              "jyusho": {{ v.metafields.custom.jyusho.value | default: '' | json }},
              "biko": {{ v.metafields.custom.biko.value | default: '' | json }}
            }{%- unless forloop.last -%},{%- endunless -%}
          {%- endfor -%}
        }
      }
    </script>

    <div class="page-width section-{{ section.id }}-padding">
      <div class="wdh-card">
        <div class="wdh__layout">
          <figure class="wdh__media">
            <img
              class="wdh__image"
              {% if wdh_img_src != blank %}
                src="{{ wdh_img_src }}"
              {% elsif wdh_fb != blank %}
                src="{{ wdh_fb }}"
              {% endif %}
              alt="{{ product.title | escape }} — {{ variant.title | escape }}"
              width="1200"
              height="800"
              loading="lazy"
              decoding="async"
            >
          </figure>

          <div class="wdh-course-block color-{{ section.settings.color_scheme }} gradient isolate">
            <table class="wdh-table" role="table">
              <thead>
                <tr>
                  <th class="wdh-table__title" scope="colgroup" colspan="2">講座詳細</th>
                </tr>
              </thead>
              <tbody>
                <tr data-wdh-row="day" {% if wdh_day == blank %}hidden{% endif %}>
                  <th class="wdh-table__label" scope="row">日程</th>
                  <td class="wdh-table__value"><span data-wdh-field="day">{{ wdh_day }}</span></td>
                </tr>
                <tr data-wdh-row="time" {% if wdh_time == blank %}hidden{% endif %}>
                  <th class="wdh-table__label" scope="row">時間</th>
                  <td class="wdh-table__value"><span data-wdh-field="time">{{ wdh_time }}</span></td>
                </tr>
                <tr data-wdh-row="mochimono" {% if wdh_mochimono == blank %}hidden{% endif %}>
                  <th class="wdh-table__label" scope="row">持ち物</th>
                  <td class="wdh-table__value"><span data-wdh-field="mochimono">{{ wdh_mochimono }}</span></td>
                </tr>
                <tr data-wdh-row="kaijyo" {% if wdh_kaijyo == blank %}hidden{% endif %}>
                  <th class="wdh-table__label" scope="row">会場</th>
                  <td class="wdh-table__value"><span data-wdh-field="kaijyo">{{ wdh_kaijyo }}</span></td>
                </tr>
                <tr data-wdh-row="jyusho" {% if wdh_jyusho == blank %}hidden{% endif %}>
                  <th class="wdh-table__label" scope="row">住所</th>
                  <td class="wdh-table__value"><span data-wdh-field="jyusho">{{ wdh_jyusho }}</span></td>
                </tr>
                <tr data-wdh-row="biko" {% if wdh_biko == blank %}hidden{% endif %}>
                  <th class="wdh-table__label" scope="row">備考</th>
                  <td class="wdh-table__value wdh-table__value--muted"><span data-wdh-field="biko">{{ wdh_biko }}</span></td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
{%- else -%}
  <div class="color-{{ section.settings.color_scheme }} gradient">
    <div class="page-width section-{{ section.id }}-padding">
      <div class="wdh-card">
        <p class="center">商品データがある商品ページテンプレートで表示されます。</p>
      </div>
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "ワークショップ動的ヘッダー",
  "tag": "section",
  "class": "section",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1",
      "info": "講座詳細テーブル（ヘッダー・罫線・背景）に反映されます。"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "ワークショップ動的ヘッダー"
    }
  ]
}
{% endschema %}
