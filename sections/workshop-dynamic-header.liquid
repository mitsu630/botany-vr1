{%- liquid
  assign variant = product.selected_or_first_available_variant

  assign wdh_fb = ''
  if product.featured_image
    assign wdh_fb = product.featured_image | image_url: width: 2000
  elsif product.media.size > 0
    assign wdh_m0 = product.media.first
    if wdh_m0.media_type == 'image'
      assign wdh_fb = wdh_m0 | image_url: width: 2000
    elsif wdh_m0.preview_image
      assign wdh_fb = wdh_m0.preview_image | image_url: width: 2000
    endif
  endif

  assign wdh_photo_mf = variant.metafields.custom.custom_photo
  if wdh_photo_mf == blank
    assign wdh_photo_mf = variant.metafields.custom.photo
  endif
  assign wdh_photo_obj = wdh_photo_mf.value

  assign wdh_photo_file_url = ''
  if wdh_photo_mf != blank
    if wdh_photo_obj != blank
      assign wdh_photo_file_url = wdh_photo_obj | image_url: width: 2000
    endif
    if wdh_photo_file_url == blank and wdh_photo_obj.preview_image != blank
      assign wdh_photo_file_url = wdh_photo_obj.preview_image | image_url: width: 2000
    endif
    if wdh_photo_file_url == blank and wdh_photo_obj != blank
      assign wdh_photo_file_url = wdh_photo_obj | file_url
    endif
    if wdh_photo_file_url == blank
      assign wdh_photo_file_url = wdh_photo_mf | file_url
    endif
    if wdh_photo_file_url == blank and wdh_photo_obj.url != blank
      assign wdh_photo_file_url = wdh_photo_obj.url
    endif
    if wdh_photo_file_url == blank
      assign wdh_photo_file_url = wdh_photo_mf | metafield_text | strip
    endif
  endif

  assign wdh_photo_url = ''
  if variant.metafields.custom.photo_url.value != blank
    assign pu_val = variant.metafields.custom.photo_url.value
    assign wdh_photo_url = ''
    if pu_val.url != blank
      assign wdh_photo_url = pu_val.url | strip
    else
      assign wdh_photo_url = pu_val | append: '' | strip
    endif
  endif

  if wdh_photo_url != blank
    assign wdh_drive_id = ''
    if wdh_photo_url contains 'drive.google.com/file/d/'
      assign wdh_drive_id = wdh_photo_url | split: '/file/d/' | last | split: '/' | first | split: '?' | first
    elsif wdh_photo_url contains 'drive.google.com/open?id='
      assign wdh_drive_id = wdh_photo_url | split: 'open?id=' | last | split: '&' | first | split: '#' | first
    elsif wdh_photo_url contains 'drive.google.com/uc?' and wdh_photo_url contains 'id='
      assign wdh_drive_id = wdh_photo_url | split: 'id=' | last | split: '&' | first | split: '#' | first
    elsif wdh_photo_url contains 'docs.google.com/uc?' and wdh_photo_url contains 'id='
      assign wdh_drive_id = wdh_photo_url | split: 'id=' | last | split: '&' | first | split: '#' | first
    endif
    if wdh_drive_id != blank
      assign wdh_photo_url = 'https://drive.google.com/thumbnail?id=' | append: wdh_drive_id | append: '&sz=w1600'
    endif
  endif

  assign wdh_img_src = ''
  if wdh_photo_url != blank
    assign raw = wdh_photo_url | strip
    if raw contains '://'
      assign wdh_img_src = raw
    else
      assign head2 = raw | slice: 0, 2
      assign head1 = raw | slice: 0, 1
      if head2 == '//'
        assign wdh_img_src = 'https:' | append: raw
      elsif head1 == '/'
        assign wdh_img_src = shop.secure_url | append: raw
      else
        assign wdh_img_src = raw
      endif
    endif
  endif
  if wdh_img_src == blank and wdh_photo_file_url != blank
    assign wdh_img_src = wdh_photo_file_url
  endif
  if wdh_img_src == blank and wdh_fb != blank
    assign wdh_img_src = wdh_fb
  endif

  assign wdh_day = variant.metafields.custom.day | metafield_text | strip
  assign wdh_time = variant.metafields.custom.time | metafield_text | strip
  assign wdh_kaijyo = variant.metafields.custom.kaijyo | metafield_text | strip
  assign wdh_jyusho = variant.metafields.custom.jyusho | metafield_text | strip
  assign wdh_mochimono = variant.metafields.custom.mochimono | metafield_text | strip
  assign wdh_biko = variant.metafields.custom.biko | metafield_text | strip
-%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  #shopify-section-{{ section.id }} .wdh-card {
    background-color: #ffffff;
    border-radius: var(--border-radius, 0.8rem);
    padding: 2rem 1.5rem;
    box-shadow: 0 0.1rem 0.4rem rgba(var(--color-foreground), 0.08);
    max-width: 72rem;
    margin: 0 auto;
  }
  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .wdh-card {
      padding: 2.5rem 2rem;
    }
  }
  #shopify-section-{{ section.id }} .wdh__layout {
    display: grid;
    gap: 1.75rem;
    align-items: start;
  }
  @media screen and (min-width: 990px) {
    #shopify-section-{{ section.id }} .wdh__layout {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.1fr);
      gap: 2.5rem;
    }
  }
  #shopify-section-{{ section.id }} .wdh__media {
    margin: 0;
    max-width: 100%;
    border-radius: calc(var(--border-radius, 0.8rem) - 0.2rem);
    overflow: hidden;
    background: rgba(var(--color-foreground), 0.04);
  }
  #shopify-section-{{ section.id }} .wdh__image {
    display: block;
    width: 100%;
    max-width: 100%;
    height: auto;
    vertical-align: middle;
    object-fit: contain;
  }
  #shopify-section-{{ section.id }} .wdh-course-block {
    border-radius: calc(var(--border-radius, 0.8rem) - 0.2rem);
    overflow: hidden;
    border: 0.1rem solid rgba(var(--color-foreground), 0.12);
  }
  #shopify-section-{{ section.id }} .wdh-table {
    width: 100%;
    border-collapse: collapse;
    margin: 0;
    background-color: rgb(var(--color-background));
  }
  #shopify-section-{{ section.id }} .wdh-table__title {
    margin: 0;
    padding: 1rem 1.25rem;
    font-size: 1.4rem;
    font-weight: 600;
    text-align: center;
    letter-spacing: 0.06rem;
    background-color: rgba(var(--color-link), 0.14);
    color: rgb(var(--color-foreground));
    border-bottom: 0.1rem solid rgba(var(--color-foreground), 0.1);
    box-shadow: inset 0 0.25rem 0 rgba(var(--color-background), 0.35);
  }
  #shopify-section-{{ section.id }} .wdh-table__label {
    width: 28%;
    margin: 0;
    padding: 1rem 1.1rem;
    font-size: 1.3rem;
    font-weight: 600;
    text-align: left;
    vertical-align: top;
    background-color: rgba(var(--color-foreground), 0.06);
    color: rgb(var(--color-foreground));
    border-bottom: 0.1rem solid rgba(var(--color-foreground), 0.12);
    border-right: 0.1rem solid rgba(var(--color-foreground), 0.12);
  }
  #shopify-section-{{ section.id }} .wdh-table__value {
    margin: 0;
    padding: 1rem 1.1rem;
    font-size: 1.4rem;
    line-height: calc(1 + 0.5 / var(--font-body-scale));
    vertical-align: top;
    color: rgba(var(--color-foreground), 0.92);
    background-color: rgb(var(--color-background));
    border-bottom: 0.1rem solid rgba(var(--color-foreground), 0.12);
    word-break: break-word;
    white-space: pre-wrap;
  }
  #shopify-section-{{ section.id }} .wdh-table__value--muted {
    font-size: 1.3rem;
    color: rgba(var(--color-foreground), 0.75);
  }
{%- endstyle -%}

{%- if product != blank -%}
  <script src="{{ 'workshop-dynamic-header.js' | asset_url }}" defer="defer"></script>

  <div
    class="workshop-dynamic-header"
    data-section-id="{{ section.id }}"
    data-initial-variant-id="{{ variant.id }}"
    data-initial-variant-title="{{ variant.title | escape }}"
    data-product-id="{{ product.id }}"
  >
    <script type="application/json" data-wdh-json>
      {
        "productId": {{ product.id | json }},
        "productTitle": {{ product.title | json }},
        "fallbackImage": {{ wdh_fb | json }},
        "b64List": [
          {%- for v in product.variants -%}
            {%- if forloop.index0 > 0 -%},{%- endif -%}
            {%- liquid
              assign v_photo_mf = v.metafields.custom.custom_photo
              if v_photo_mf == blank
                assign v_photo_mf = v.metafields.custom.photo
              endif
              assign v_photo_obj = v_photo_mf.value

              assign v_photo_file_url = ''
              if v_photo_mf != blank
                if v_photo_obj != blank
                  assign v_photo_file_url = v_photo_obj | image_url: width: 2000
                endif
                if v_photo_file_url == blank and v_photo_obj.preview_image != blank
                  assign v_photo_file_url = v_photo_obj.preview_image | image_url: width: 2000
                endif
                if v_photo_file_url == blank and v_photo_obj != blank
                  assign v_photo_file_url = v_photo_obj | file_url
                endif
                if v_photo_file_url == blank
                  assign v_photo_file_url = v_photo_mf | file_url
                endif
                if v_photo_file_url == blank and v_photo_obj.url != blank
                  assign v_photo_file_url = v_photo_obj.url
                endif
                if v_photo_file_url == blank
                  assign v_photo_file_url = v_photo_mf | metafield_text | strip
                endif
              endif

              assign v_photo_url = ''
              if v.metafields.custom.photo_url.value != blank
                assign v_pu = v.metafields.custom.photo_url.value
                if v_pu.url != blank
                  assign v_photo_url = v_pu.url | strip
                else
                  assign v_photo_url = v_pu | append: '' | strip
                endif
              endif
              if v_photo_url != blank
                assign v_drive_id = ''
                if v_photo_url contains 'drive.google.com/file/d/'
                  assign v_drive_id = v_photo_url | split: '/file/d/' | last | split: '/' | first | split: '?' | first
                elsif v_photo_url contains 'drive.google.com/open?id='
                  assign v_drive_id = v_photo_url | split: 'open?id=' | last | split: '&' | first | split: '#' | first
                elsif v_photo_url contains 'drive.google.com/uc?' and v_photo_url contains 'id='
                  assign v_drive_id = v_photo_url | split: 'id=' | last | split: '&' | first | split: '#' | first
                elsif v_photo_url contains 'docs.google.com/uc?' and v_photo_url contains 'id='
                  assign v_drive_id = v_photo_url | split: 'id=' | last | split: '&' | first | split: '#' | first
                endif
                if v_drive_id != blank
                  assign v_photo_url = 'https://drive.google.com/thumbnail?id=' | append: v_drive_id | append: '&sz=w1600'
                endif
              endif

              assign v_img = ''
              if v_photo_url != blank
                assign vr = v_photo_url | strip
                if vr contains '://'
                  assign v_img = vr
                else
                  assign v2 = vr | slice: 0, 2
                  assign v1 = vr | slice: 0, 1
                  if v2 == '//'
                    assign v_img = 'https:' | append: vr
                  elsif v1 == '/'
                    assign v_img = shop.secure_url | append: vr
                  else
                    assign v_img = vr
                  endif
                endif
              endif
              if v_img == blank and v_photo_file_url != blank
                assign v_img = v_photo_file_url
              endif
              if v_img == blank and wdh_fb != blank
                assign v_img = wdh_fb
              endif

              assign v_day = v.metafields.custom.day | metafield_text | strip
              assign v_time = v.metafields.custom.time | metafield_text | strip
              assign v_kaijyo = v.metafields.custom.kaijyo | metafield_text | strip
              assign v_jyusho = v.metafields.custom.jyusho | metafield_text | strip
              assign v_mochi = v.metafields.custom.mochimono | metafield_text | strip
              assign v_biko = v.metafields.custom.biko | metafield_text | strip
            -%}
            {
              "id": {{ v.id | json }},
              "imageUrl": {{ v_img | json }},
              "photoUrl": {{ v_photo_url | json }},
              "photoFileUrl": {{ v_photo_file_url | json }},
              "day_b64": {{ v_day | base64_encode | json }},
              "time_b64": {{ v_time | base64_encode | json }},
              "kaijyo_b64": {{ v_kaijyo | base64_encode | json }},
              "jyusho_b64": {{ v_jyusho | base64_encode | json }},
              "mochimono_b64": {{ v_mochi | base64_encode | json }},
              "biko_b64": {{ v_biko | base64_encode | json }}
            }
          {%- endfor -%}
        ]
      }
    </script>

    <div class="page-width section-{{ section.id }}-padding">
      <div class="wdh-card">
        <div class="wdh__layout">
          <figure class="wdh__media">
            {%- if wdh_img_src != blank -%}
              <img
                class="wdh__image"
                src="{{ wdh_img_src }}"
                alt="{{ product.title | escape }} — {{ variant.title | escape }}"
                loading="lazy"
                decoding="async"
              >
            {%- endif -%}
          </figure>

          <div class="wdh-course-block color-{{ section.settings.color_scheme }} gradient isolate">
            <table class="wdh-table" role="table">
              <thead>
                <tr>
                  <th class="wdh-table__title" scope="colgroup" colspan="2">講座詳細</th>
                </tr>
              </thead>
              <tbody>
                {%- if wdh_day != blank -%}
                  <tr data-wdh-row="day">
                    <th class="wdh-table__label" scope="row">日程</th>
                    <td class="wdh-table__value"><span data-wdh-field="day">{{ wdh_day }}</span></td>
                  </tr>
                {%- endif -%}
                {%- if wdh_time != blank -%}
                  <tr data-wdh-row="time">
                    <th class="wdh-table__label" scope="row">時間</th>
                    <td class="wdh-table__value"><span data-wdh-field="time">{{ wdh_time }}</span></td>
                  </tr>
                {%- endif -%}
                {%- if wdh_kaijyo != blank -%}
                  <tr data-wdh-row="kaijyo">
                    <th class="wdh-table__label" scope="row">会場</th>
                    <td class="wdh-table__value"><span data-wdh-field="kaijyo">{{ wdh_kaijyo }}</span></td>
                  </tr>
                {%- endif -%}
                {%- if wdh_jyusho != blank -%}
                  <tr data-wdh-row="jyusho">
                    <th class="wdh-table__label" scope="row">住所</th>
                    <td class="wdh-table__value"><span data-wdh-field="jyusho">{{ wdh_jyusho }}</span></td>
                  </tr>
                {%- endif -%}
                {%- if wdh_mochimono != blank -%}
                  <tr data-wdh-row="mochimono">
                    <th class="wdh-table__label" scope="row">持ち物</th>
                    <td class="wdh-table__value"><span data-wdh-field="mochimono">{{ wdh_mochimono }}</span></td>
                  </tr>
                {%- endif -%}
                {%- if wdh_biko != blank -%}
                  <tr data-wdh-row="biko">
                    <th class="wdh-table__label" scope="row">備考</th>
                    <td class="wdh-table__value wdh-table__value--muted"><span data-wdh-field="biko">{{ wdh_biko }}</span></td>
                  </tr>
                {%- endif -%}
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
{%- else -%}
  <div class="color-{{ section.settings.color_scheme }} gradient">
    <div class="page-width section-{{ section.id }}-padding">
      <div class="wdh-card">
        <p class="center">商品データがある商品ページテンプレートで表示されます。</p>
      </div>
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "ワークショップ動的ヘッダー",
  "tag": "section",
  "class": "section",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1",
      "info": "講座詳細テーブル（ヘッダー・罫線・背景）に反映されます。"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "ワークショップ動的ヘッダー"
    }
  ]
}
{% endschema %}
