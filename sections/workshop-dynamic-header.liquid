{%- liquid
  assign variant = product.selected_or_first_available_variant

  assign wdh_fb = ''
  if product.featured_image
    assign wdh_fb = product.featured_image | image_url: width: 2000
  elsif product.media.size > 0
    assign wdh_m0 = product.media.first
    if wdh_m0.media_type == 'image'
      assign wdh_fb = wdh_m0 | image_url: width: 2000
    elsif wdh_m0.preview_image
      assign wdh_fb = wdh_m0.preview_image | image_url: width: 2000
    endif
  endif

  assign wdh_img_src = ''
  if variant.metafields.custom.photo_url.value != blank
    assign pu_val = variant.metafields.custom.photo_url.value
    assign raw = ''
    if pu_val.url != blank
      assign raw = pu_val.url | strip
    else
      assign raw = pu_val | strip
    endif
    if raw != blank
      if raw contains '://'
        assign wdh_img_src = raw
      else
        assign head2 = raw | slice: 0, 2
        assign head1 = raw | slice: 0, 1
        if head2 == '//'
          assign wdh_img_src = 'https:' | append: raw
        elsif head1 == '/'
          assign wdh_img_src = shop.secure_url | append: raw
        else
          assign wdh_img_src = raw
        endif
      endif
    endif
  endif
  if wdh_img_src == blank and variant.metafields.custom.photo.value != blank
    assign wdh_img_src = variant.metafields.custom.photo | image_url: width: 2000
  endif
  if wdh_img_src == blank and wdh_fb != blank
    assign wdh_img_src = wdh_fb
  endif

  assign wdh_day = variant.metafields.custom.day.value | default: '' | strip
  assign wdh_time = variant.metafields.custom.time.value | default: '' | strip
  assign wdh_kaijyo = variant.metafields.custom.kaijyo.value | default: '' | strip
  assign wdh_jyusho = variant.metafields.custom.jyusho.value | default: '' | strip
  assign wdh_mochimono = variant.metafields.custom.mochimono.value | default: '' | strip
  assign wdh_biko = variant.metafields.custom.biko.value | default: '' | strip
-%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  #shopify-section-{{ section.id }} .wdh-card {
    background-color: #ffffff;
    border-radius: var(--border-radius, 0.8rem);
    padding: 2rem 1.5rem;
    box-shadow: 0 0.1rem 0.4rem rgba(var(--color-foreground), 0.08);
    max-width: 72rem;
    margin: 0 auto;
  }
  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .wdh-card {
      padding: 2.5rem 2rem;
    }
  }
  #shopify-section-{{ section.id }} .wdh__layout {
    display: grid;
    gap: 1.75rem;
    align-items: start;
  }
  @media screen and (min-width: 990px) {
    #shopify-section-{{ section.id }} .wdh__layout {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.1fr);
      gap: 2.5rem;
    }
  }
  #shopify-section-{{ section.id }} .wdh__media {
    margin: 0;
    max-width: 100%;
    border-radius: calc(var(--border-radius, 0.8rem) - 0.2rem);
    overflow: hidden;
    background: rgba(var(--color-foreground), 0.04);
  }
  #shopify-section-{{ section.id }} .wdh__image {
    display: block;
    width: 100%;
    max-width: 100%;
    height: auto;
    vertical-align: middle;
    object-fit: contain;
  }
  #shopify-section-{{ section.id }} .wdh-course-block {
    border-radius: calc(var(--border-radius, 0.8rem) - 0.2rem);
    overflow: hidden;
    border: 0.1rem solid rgba(var(--color-foreground), 0.12);
  }
  #shopify-section-{{ section.id }} .wdh-table {
    width: 100%;
    border-collapse: collapse;
    margin: 0;
    background-color: rgb(var(--color-background));
  }
  #shopify-section-{{ section.id }} .wdh-table__title {
    margin: 0;
    padding: 1rem 1.25rem;
    font-size: 1.4rem;
    font-weight: 600;
    text-align: center;
    letter-spacing: 0.06rem;
    background-color: rgba(var(--color-link), 0.14);
    color: rgb(var(--color-foreground));
    border-bottom: 0.1rem solid rgba(var(--color-foreground), 0.1);
    box-shadow: inset 0 0.25rem 0 rgba(var(--color-background), 0.35);
  }
  #shopify-section-{{ section.id }} .wdh-table__label {
    width: 28%;
    margin: 0;
    padding: 1rem 1.1rem;
    font-size: 1.3rem;
    font-weight: 600;
    text-align: left;
    vertical-align: top;
    background-color: rgba(var(--color-foreground), 0.06);
    color: rgb(var(--color-foreground));
    border-bottom: 0.1rem solid rgba(var(--color-foreground), 0.12);
    border-right: 0.1rem solid rgba(var(--color-foreground), 0.12);
  }
  #shopify-section-{{ section.id }} .wdh-table__value {
    margin: 0;
    padding: 1rem 1.1rem;
    font-size: 1.4rem;
    line-height: calc(1 + 0.5 / var(--font-body-scale));
    vertical-align: top;
    color: rgba(var(--color-foreground), 0.92);
    background-color: rgb(var(--color-background));
    border-bottom: 0.1rem solid rgba(var(--color-foreground), 0.12);
    word-break: break-word;
    white-space: pre-wrap;
  }
  #shopify-section-{{ section.id }} .wdh-table__value--muted {
    font-size: 1.3rem;
    color: rgba(var(--color-foreground), 0.75);
  }
{%- endstyle -%}

{%- if product != blank -%}
  <script src="{{ 'workshop-dynamic-header.js' | asset_url }}" defer="defer"></script>

  <div
    class="workshop-dynamic-header"
    data-section-id="{{ section.id }}"
    data-initial-variant-id="{{ variant.id }}"
    data-initial-variant-title="{{ variant.title | escape }}"
    data-product-id="{{ product.id }}"
  >
    <script type="application/json" data-wdh-json>
      {
        "productId": {{ product.id | json }},
        "productTitle": {{ product.title | json }},
        "fallbackImage": {{ wdh_fb | json }},
        "variants": {
          {%- for v in product.variants -%}
            {%- liquid
              assign v_img = ''
              assign v_purl = ''
              if v.metafields.custom.photo_url.value != blank
                assign v_pu = v.metafields.custom.photo_url.value
                assign v_raw = ''
                if v_pu.url != blank
                  assign v_raw = v_pu.url | strip
                else
                  assign v_raw = v_pu | strip
                endif
                assign v_purl = v_raw
                if v_raw != blank
                  if v_raw contains '://'
                    assign v_img = v_raw
                  else
                    assign vh2 = v_raw | slice: 0, 2
                    assign vh1 = v_raw | slice: 0, 1
                    if vh2 == '//'
                      assign v_img = 'https:' | append: v_raw
                    elsif vh1 == '/'
                      assign v_img = shop.secure_url | append: v_raw
                    else
                      assign v_img = v_raw
                    endif
                  endif
                endif
              endif
              if v_img == blank and v.metafields.custom.photo.value != blank
                assign v_img = v.metafields.custom.photo | image_url: width: 2000
              endif
              if v_img == blank and wdh_fb != blank
                assign v_img = wdh_fb
              endif
            -%}
            "{{ v.id }}": {
              "imageUrl": {{ v_img | json }},
              "photoUrl": {{ v_purl | json }},
              "photoFileUrl": {% if v.metafields.custom.photo.value != blank %}{{ v.metafields.custom.photo | image_url: width: 2000 | json }}{% else %}""{% endif %},
              "day": {{ v.metafields.custom.day.value | default: '' | strip | json }},
              "time": {{ v.metafields.custom.time.value | default: '' | strip | json }},
              "kaijyo": {{ v.metafields.custom.kaijyo.value | default: '' | strip | json }},
              "jyusho": {{ v.metafields.custom.jyusho.value | default: '' | strip | json }},
              "mochimono": {{ v.metafields.custom.mochimono.value | default: '' | strip | json }},
              "biko": {{ v.metafields.custom.biko.value | default: '' | strip | json }}
            }{%- unless forloop.last -%},{%- endunless -%}
          {%- endfor -%}
        }
      }
    </script>

    <div class="page-width section-{{ section.id }}-padding">
      <div class="wdh-card">
        <div class="wdh__layout">
          <figure class="wdh__media">
            {%- if wdh_img_src != blank -%}
              <img
                class="wdh__image"
                src="{{ wdh_img_src }}"
                alt="{{ product.title | escape }} — {{ variant.title | escape }}"
                loading="lazy"
                decoding="async"
              >
            {%- endif -%}
          </figure>

          <div class="wdh-course-block color-{{ section.settings.color_scheme }} gradient isolate">
            <table class="wdh-table" role="table">
              <thead>
                <tr>
                  <th class="wdh-table__title" scope="colgroup" colspan="2">講座詳細</th>
                </tr>
              </thead>
              <tbody>
                {%- if wdh_day != blank -%}
                  <tr data-wdh-row="day">
                    <th class="wdh-table__label" scope="row">日程</th>
                    <td class="wdh-table__value"><span data-wdh-field="day">{{ wdh_day }}</span></td>
                  </tr>
                {%- endif -%}
                {%- if wdh_time != blank -%}
                  <tr data-wdh-row="time">
                    <th class="wdh-table__label" scope="row">時間</th>
                    <td class="wdh-table__value"><span data-wdh-field="time">{{ wdh_time }}</span></td>
                  </tr>
                {%- endif -%}
                {%- if wdh_kaijyo != blank -%}
                  <tr data-wdh-row="kaijyo">
                    <th class="wdh-table__label" scope="row">会場</th>
                    <td class="wdh-table__value"><span data-wdh-field="kaijyo">{{ wdh_kaijyo }}</span></td>
                  </tr>
                {%- endif -%}
                {%- if wdh_jyusho != blank -%}
                  <tr data-wdh-row="jyusho">
                    <th class="wdh-table__label" scope="row">住所</th>
                    <td class="wdh-table__value"><span data-wdh-field="jyusho">{{ wdh_jyusho }}</span></td>
                  </tr>
                {%- endif -%}
                {%- if wdh_mochimono != blank -%}
                  <tr data-wdh-row="mochimono">
                    <th class="wdh-table__label" scope="row">持ち物</th>
                    <td class="wdh-table__value"><span data-wdh-field="mochimono">{{ wdh_mochimono }}</span></td>
                  </tr>
                {%- endif -%}
                {%- if wdh_biko != blank -%}
                  <tr data-wdh-row="biko">
                    <th class="wdh-table__label" scope="row">備考</th>
                    <td class="wdh-table__value wdh-table__value--muted"><span data-wdh-field="biko">{{ wdh_biko }}</span></td>
                  </tr>
                {%- endif -%}
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
{%- else -%}
  <div class="color-{{ section.settings.color_scheme }} gradient">
    <div class="page-width section-{{ section.id }}-padding">
      <div class="wdh-card">
        <p class="center">商品データがある商品ページテンプレートで表示されます。</p>
      </div>
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "ワークショップ動的ヘッダー",
  "tag": "section",
  "class": "section",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1",
      "info": "講座詳細テーブル（ヘッダー・罫線・背景）に反映されます。"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "ワークショップ動的ヘッダー"
    }
  ]
}
{% endschema %}
