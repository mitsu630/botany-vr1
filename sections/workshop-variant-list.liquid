{%- liquid
  assign product = section.settings.product
-%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  #shopify-section-{{ section.id }} .workshop-variant-list__card {
    background-color: #ffffff;
    border-radius: var(--border-radius, 0.8rem);
    padding: 2rem 1.5rem;
    height: 100%;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    box-shadow: 0 0.1rem 0.4rem rgba(var(--color-foreground), 0.08);
  }

  #shopify-section-{{ section.id }} .workshop-variant-list__title {
    margin: 0;
    font-size: calc(var(--font-heading-scale) * 1.4rem);
    line-height: calc(1 + 0.3 / var(--font-heading-scale));
    word-break: break-word;
  }

  #shopify-section-{{ section.id }} .workshop-variant-list__btn--soldout {
    opacity: 0.65;
    pointer-events: auto;
  }
{%- endstyle -%}

<div class="workshop-variant-list color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width section-{{ section.id }}-padding isolate">
    {%- if product != blank -%}
      <ul
        class="grid grid--1-col grid--2-col-tablet grid--3-col-desktop"
        role="list"
      >
        {%- for variant in product.variants -%}
          <li class="grid__item">
            <div class="workshop-variant-list__card">
              <h3 class="workshop-variant-list__title h4">
                {{ variant.title | escape }}
              </h3>
              <div class="workshop-variant-list__actions">
                {%- if variant.available -%}
                  <a
                    href="{{ variant.url }}"
                    class="button button--primary"
                  >
                    講座詳細はこちら
                  </a>
                {%- else -%}
                  <a
                    href="{{ variant.url }}"
                    class="button button--secondary workshop-variant-list__btn--soldout"
                  >
                    満席（会場詳細はこちら）
                  </a>
                {%- endif -%}
              </div>
            </div>
          </li>
        {%- endfor -%}
      </ul>
    {%- else -%}
      <div class="workshop-variant-list__empty">
        <p class="center">テーマエディターで商品を選択してください。</p>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "ワークショップ日程リスト",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "t:sections.featured-product.settings.product.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "ワークショップ日程リスト"
    }
  ]
}
{% endschema %}
