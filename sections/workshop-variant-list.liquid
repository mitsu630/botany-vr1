{%- liquid
  assign product = section.settings.product
  assign layout_grid = false
  if section.settings.layout == 'grid'
    assign layout_grid = true
  endif
-%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  #shopify-section-{{ section.id }} {
    --wvl-venue-fs: {{ section.settings.venue_font_size }}px;
    --wvl-datetime-fs: {{ section.settings.datetime_font_size }}px;
    --wvl-deadline-fs: {{ section.settings.deadline_font_size }}px;
    --wvl-datetime-opacity: {{ section.settings.datetime_text_opacity | times: 0.01 }};
    --wvl-card-pad: {{ section.settings.card_padding }}px;
    --wvl-card-gap: {{ section.settings.card_inner_gap }}px;
    --wvl-venue-datetime-gap: {{ section.settings.venue_datetime_gap }}px;
  }

  #shopify-section-{{ section.id }} .workshop-variant-list__card {
    background-color: #ffffff;
    border-radius: var(--border-radius, 0.8rem);
    padding: var(--wvl-card-pad);
    height: 100%;
    display: flex;
    flex-direction: column;
    gap: var(--wvl-card-gap);
    box-shadow: 0 0.1rem 0.4rem rgba(var(--color-foreground), 0.08);
  }

  #shopify-section-{{ section.id }} .workshop-variant-list__meta {
    display: flex;
    flex-direction: column;
    flex-wrap: nowrap;
    align-items: stretch;
    gap: var(--wvl-venue-datetime-gap);
    width: 100%;
  }

  #shopify-section-{{ section.id }} .workshop-variant-list__meta-row {
    display: block;
    width: 100%;
    flex: 0 0 auto;
    min-width: 0;
  }

  #shopify-section-{{ section.id }} .workshop-variant-list__venue {
    display: block;
    width: 100%;
    margin: 0;
    font-size: var(--wvl-venue-fs);
    line-height: calc(1 + 0.35 / var(--font-heading-scale));
    font-weight: 600;
    word-break: break-word;
    color: rgb(var(--color-foreground));
  }

  #shopify-section-{{ section.id }} .workshop-variant-list__datetime {
    display: block;
    width: 100%;
    margin: 0;
    font-size: var(--wvl-datetime-fs);
    line-height: calc(1 + 0.5 / var(--font-body-scale));
    word-break: break-word;
    color: rgba(var(--color-foreground), var(--wvl-datetime-opacity));
  }

  #shopify-section-{{ section.id }} .workshop-variant-list__deadline {
    margin: 0;
    font-size: var(--wvl-deadline-fs);
    line-height: calc(1 + 0.45 / var(--font-body-scale));
    font-weight: 600;
    word-break: break-word;
    color: rgb(var(--color-link));
  }

  #shopify-section-{{ section.id }} .workshop-variant-list__btn--soldout {
    opacity: 0.65;
    pointer-events: auto;
  }

  #shopify-section-{{ section.id }} .workshop-variant-list__actions {
    margin-top: auto;
  }

  #shopify-section-{{ section.id }} .workshop-variant-list--stack .workshop-variant-list__list {
    max-width: 72rem;
    margin: 0 auto;
  }
{%- endstyle -%}

<script src="{{ 'workshop-variant-list.js' | asset_url }}" defer="defer"></script>

<div
  class="workshop-variant-list color-{{ section.settings.color_scheme }} gradient"
  data-deadline-notice-days="{{ section.settings.deadline_notice_days_before }}"
>
  <div class="page-width section-{{ section.id }}-padding isolate{% unless layout_grid %} workshop-variant-list--stack{% endunless %}">
    {%- if product != blank -%}
      <ul
        class="workshop-variant-list__list grid{% if layout_grid %} grid--1-col grid--2-col-tablet grid--3-col-desktop{% else %} grid--1-col{% endif %}"
        role="list"
      >
        {%- for variant in product.variants -%}
          {%- liquid
            assign venue_m = variant.metafields.custom.workshop_venue.value
            assign datetime_m = variant.metafields.custom.workshop_datetime.value
            assign deadline_note = variant.metafields.custom.workshop_deadline_note.value

            assign venue = ''
            assign datetime_line = ''

            if venue_m != blank or datetime_m != blank
              assign venue = venue_m | default: ''
              assign datetime_line = datetime_m | default: ''
            else
              assign split_title = variant.title | split: ' || '
              if split_title.size >= 2
                assign venue = split_title[0] | strip
                assign datetime_line = split_title[1] | strip
              else
                assign split_title2 = variant.title | split: '||'
                if split_title2.size >= 2
                  assign venue = split_title2[0] | strip
                  assign datetime_line = split_title2[1] | strip
                else
                  assign venue = variant.title
                endif
              endif
            endif

            if datetime_line == blank and venue != blank
              assign wvl_raw = venue | strip | newline_to_br
              assign wvl_norm = wvl_raw | replace: '<br />', '||WVLBR||' | replace: '<br/>', '||WVLBR||' | replace: '<br>', '||WVLBR||'
              assign wvl_br = wvl_norm | split: '||WVLBR||'
              if wvl_br.size >= 2
                assign venue = wvl_br[0] | strip
                assign datetime_line = wvl_br[1] | strip
                for wvl_part in wvl_br
                  if forloop.index >= 3
                    assign datetime_line = datetime_line | append: ' ' | append: wvl_part | strip
                  endif
                endfor
              elsif venue contains ' / '
                assign wvl_sl = venue | split: ' / '
                if wvl_sl.size >= 2
                  assign venue = wvl_sl[0] | strip
                  assign datetime_line = wvl_sl[1] | strip
                endif
              elsif venue contains '／'
                assign wvl_sl = venue | split: '／'
                if wvl_sl.size >= 2
                  assign venue = wvl_sl[0] | strip
                  assign datetime_line = wvl_sl[1] | strip
                endif
              elsif venue contains ' | '
                assign wvl_sl = venue | split: ' | '
                if wvl_sl.size >= 2
                  assign venue = wvl_sl[0] | strip
                  assign datetime_line = wvl_sl[1] | strip
                endif
              endif

              if datetime_line == blank and venue != blank
                assign v_norm = venue | strip | replace: '　', ' ' | replace: '	', ' '
                assign v_norm = v_norm | replace: '０', '0' | replace: '１', '1' | replace: '２', '2' | replace: '３', '3' | replace: '４', '4' | replace: '５', '5' | replace: '６', '6' | replace: '７', '7' | replace: '８', '8' | replace: '９', '9'
                assign parts = v_norm | split: ' '
                assign venue_acc = ''
                assign date_acc = ''
                assign seen_date = false
                for part in parts
                  if part == blank
                  else
                    assign wvl_is_date_token = false
                    if part contains '月' and part contains '日'
                      if part contains '年'
                        assign wvl_is_date_token = true
                      else
                        assign wvl_hd = part | slice: 0, 1
                        if wvl_hd == '0' or wvl_hd == '1' or wvl_hd == '2' or wvl_hd == '3' or wvl_hd == '4' or wvl_hd == '5' or wvl_hd == '6' or wvl_hd == '7' or wvl_hd == '8' or wvl_hd == '9'
                          assign wvl_is_date_token = true
                        endif
                      endif
                    endif
                    if seen_date
                      assign date_acc = date_acc | append: ' ' | append: part
                    elsif wvl_is_date_token
                      assign seen_date = true
                      assign date_acc = part
                    else
                      if venue_acc == blank
                        assign venue_acc = part
                      else
                        assign venue_acc = venue_acc | append: ' ' | append: part
                      endif
                    endif
                  endif
                endfor
                if seen_date and venue_acc != blank
                  assign venue = venue_acc | strip
                  assign datetime_line = date_acc | strip
                endif
              endif
            endif
          -%}
          <li class="grid__item">
            <div
              class="workshop-variant-list__card"
              data-workshop-variant-card
              data-available="{% if variant.available %}true{% else %}false{% endif %}"
              data-manual-deadline="{% if deadline_note != blank %}true{% else %}false{% endif %}"
            >
              {%- if venue != blank or datetime_line != blank -%}
                <div class="workshop-variant-list__meta">
                  {%- if venue != blank -%}
                    <div class="workshop-variant-list__meta-row">
                      <h3 class="workshop-variant-list__venue">{{ venue | escape | newline_to_br }}</h3>
                    </div>
                  {%- endif -%}
                  {%- if datetime_line != blank -%}
                    <div class="workshop-variant-list__meta-row">
                      <p class="workshop-variant-list__datetime">
                        {{- datetime_line | escape | newline_to_br -}}
                      </p>
                    </div>
                  {%- endif -%}
                </div>
              {%- elsif venue == blank and datetime_line == blank -%}
                <div class="workshop-variant-list__meta">
                  <div class="workshop-variant-list__meta-row">
                    <h3 class="workshop-variant-list__venue">{{ variant.title | escape | newline_to_br }}</h3>
                  </div>
                </div>
              {%- endif -%}

              {%- if deadline_note != blank -%}
                <p class="workshop-variant-list__deadline">{{ deadline_note | escape | newline_to_br }}</p>
              {%- endif -%}

              <div class="workshop-variant-list__actions">
                {%- if variant.available -%}
                  <a
                    href="{{ variant.url }}"
                    class="button button--primary button--full-width"
                  >
                    講座詳細はこちら
                  </a>
                {%- else -%}
                  <a
                    href="{{ variant.url }}"
                    class="button button--secondary button--full-width workshop-variant-list__btn--soldout"
                  >
                    満席（会場詳細はこちら）
                  </a>
                {%- endif -%}
              </div>
            </div>
          </li>
        {%- endfor -%}
      </ul>
    {%- else -%}
      <div class="workshop-variant-list__empty">
        <p class="center">テーマエディターで商品を選択してください。</p>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "ワークショップ日程リスト",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "t:sections.featured-product.settings.product.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "レイアウト",
      "options": [
        {
          "value": "stack",
          "label": "縦並び（1列）"
        },
        {
          "value": "grid",
          "label": "レスポンシブグリッド（2〜3列）"
        }
      ],
      "default": "stack"
    },
    {
      "type": "header",
      "content": "タイポグラフィ"
    },
    {
      "type": "range",
      "id": "venue_font_size",
      "min": 14,
      "max": 28,
      "step": 1,
      "unit": "px",
      "label": "会場名の文字サイズ",
      "default": 18
    },
    {
      "type": "range",
      "id": "datetime_font_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "日時の文字サイズ",
      "default": 16
    },
    {
      "type": "range",
      "id": "datetime_text_opacity",
      "min": 45,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "日時の濃さ（カラースキームの文字色に対する透明度）",
      "default": 65
    },
    {
      "type": "range",
      "id": "deadline_font_size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "締切・注意文の文字サイズ",
      "default": 14
    },
    {
      "type": "range",
      "id": "venue_datetime_gap",
      "min": 0,
      "max": 32,
      "step": 2,
      "unit": "px",
      "label": "会場名と開催日の間の余白",
      "default": 10
    },
    {
      "type": "header",
      "content": "募集締切の自動表示"
    },
    {
      "type": "range",
      "id": "deadline_notice_days_before",
      "min": 0,
      "max": 30,
      "step": 1,
      "unit": "日",
      "label": "「募集締切間近」を表示する期間（締切の何日前から）",
      "info": "開催日の3日前の正午を締切として計算します。0 にすると、締切の正午までは常に表示します（満席・手動の締切メモありのカードは除く）。表示はお客様のブラウザの日時に基づきます。",
      "default": 7
    },
    {
      "type": "header",
      "content": "カード"
    },
    {
      "type": "range",
      "id": "card_padding",
      "min": 12,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "カード内の余白",
      "default": 24
    },
    {
      "type": "range",
      "id": "card_inner_gap",
      "min": 8,
      "max": 32,
      "step": 2,
      "unit": "px",
      "label": "カード内の要素間の間隔",
      "default": 16
    },
    {
      "type": "header",
      "content": "データの入れ方"
    },
    {
      "type": "paragraph",
      "content": "会場と開催日は別の行に表示されます。「東京都新宿区　4月29日（水）12:00〜」のように全角スペース区切りや「2026年4月29日…」のどちらでも対応します（年がない月日表記は当年・翌年を自動で判断）。半角スペース・改行・「 / 」「／」「 | 」「会場 || 日時」にも対応。スペースなしの「会場名4月29日…」は表示後に日付の直前で分割します。在庫あり・手動締切メモなしのときだけ「募集締切間近：…正午」を表示します。メタフィールド workshop_venue / workshop_datetime / workshop_deadline_note（任意）も利用できます。"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "ワークショップ日程リスト"
    }
  ]
}
{% endschema %}
