{% comment %}
  フッター「汎用カード」ブロック
  @param {object} block - footer section の generic_card ブロック
{% endcomment %}

{%- liquid
  assign radius = block.settings.border_radius
  assign pad = block.settings.padding
  assign ratio_class = block.settings.image_ratio | default: 'ratio-16-9'
  assign g_title_fs = block.settings.title_font_size_rem | default: 1.25
  assign g_excerpt_fs = block.settings.excerpt_font_size_rem | default: 1.6
  assign g_ff_setting = block.settings.card_text_font_family | default: 'inherit'
  if g_ff_setting == 'body'
    assign g_ff_css = 'var(--font-body-family)'
  elsif g_ff_setting == 'heading'
    assign g_ff_css = 'var(--font-heading-family)'
  else
    assign g_ff_css = ''
  endif
-%}
{%- capture footer_generic_card_style -%}
--footer-card-radius: {{ radius }}px; --footer-card-padding: {{ pad }}px; border-radius: {{ radius }}px; --fgc-title-fs: {{ g_title_fs }}rem; --fgc-excerpt-fs: {{ g_excerpt_fs }}rem;{% if g_ff_css != blank %} --fgc-font-family: {{ g_ff_css }};{% endif %}
{%- endcapture -%}

{%- if block.settings.card_link != blank -%}
  <a
    href="{{ block.settings.card_link }}"
    class="footer-generic-card footer-generic-card--is-link color-{{ block.settings.color_scheme }} gradient"
    style="{{ footer_generic_card_style }}"
    {{ block.shopify_attributes }}
  >
{%- else -%}
  <div
    class="footer-generic-card color-{{ block.settings.color_scheme }} gradient"
    style="{{ footer_generic_card_style }}"
    {{ block.shopify_attributes }}
  >
{%- endif -%}

{%- if block.settings.image != blank -%}
  <div class="footer-generic-card__media footer-generic-card__media--{{ ratio_class }}">
    {{
      block.settings.image
      | image_url: width: 1200
      | image_tag:
        loading: 'lazy',
        widths: '165, 360, 535, 750, 940, 1100, 1200',
        sizes: '(min-width: 990px) 400px, (min-width: 750px) 45vw, 100vw',
        class: 'footer-generic-card__image'
    }}
  </div>
{%- endif -%}

<div class="footer-generic-card__body">
  {%- if block.settings.title != blank -%}
    <h3 class="footer-generic-card__title inline-richtext h4">
      {{ block.settings.title }}
    </h3>
  {%- endif -%}
  {%- if block.settings.excerpt != blank -%}
    <div class="footer-generic-card__excerpt rte">
      {{ block.settings.excerpt }}
    </div>
  {%- endif -%}
</div>

{%- if block.settings.card_link != blank -%}
  </a>
{%- else -%}
  </div>
{%- endif -%}
