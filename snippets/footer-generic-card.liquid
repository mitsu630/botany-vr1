{% comment %}
  フッター「汎用カード」ブロック
  @param {object} block - footer section の generic_card ブロック
{% endcomment %}

{%- liquid
  assign radius = block.settings.border_radius
  assign pad = block.settings.padding
  assign ratio_class = block.settings.image_ratio | default: 'ratio-16-9'
  assign g_title_fs_raw = block.settings.title_font_size_rem_custom | default: block.settings.title_font_size_rem | default: 1.3
  assign g_excerpt_fs_raw = block.settings.excerpt_font_size_rem_custom | default: block.settings.excerpt_font_size_rem | default: 1.6
  assign g_title_fs = g_title_fs_raw | plus: 0.0
  assign g_excerpt_fs = g_excerpt_fs_raw | plus: 0.0
  assign g_ff_setting = block.settings.card_text_font_family | default: 'inherit'
  if g_ff_setting == 'body'
    assign g_ff_css = 'var(--font-body-family)'
  elsif g_ff_setting == 'heading'
    assign g_ff_css = 'var(--font-heading-family)'
  else
    assign g_ff_css = ''
  endif

  assign has_video = false
  assign ext_vid = block.settings.video_url | default: block.settings.video_link
  assign vid_id = ext_vid.id
  assign vid_type = ext_vid.type

  comment
    ブロックの `video_url` は通常 VideoUrlDrop（.id / .type / .preview_image）だが、
    テーマ/環境によっては文字列URLとして渡ることがあるためフォールバックでIDを抽出する。
  endcomment
  if vid_id == blank and ext_vid != blank
    assign ext_vid_str = ext_vid | append: ''
    if ext_vid_str contains 'youtu.be/'
      assign vid_type = 'youtube'
      assign after = ext_vid_str | split: 'youtu.be/' | last
      assign vid_id = after | split: '?' | first | split: '&' | first | split: '/' | first
    elsif ext_vid_str contains 'youtube.com'
      assign vid_type = 'youtube'
      assign after = ext_vid_str | split: 'v=' | last
      assign vid_id = after | split: '&' | first | split: '?' | first
    elsif ext_vid_str contains 'vimeo.com'
      assign vid_type = 'vimeo'
      assign path = ext_vid_str | split: '?' | first
      assign vid_id = path | split: '/' | last
    endif
  endif

  if vid_id != blank
    assign has_video = true
  endif

  assign card_wraps_with_link = false
  if block.settings.card_link != blank and has_video == false
    assign card_wraps_with_link = true
  endif

  if ratio_class == 'ratio-16-9'
    assign ratio_percent = 56.25
  elsif ratio_class == 'ratio-4-3'
    assign ratio_percent = 75.0
  elsif ratio_class == 'square'
    assign ratio_percent = 100.0
  else
    assign ratio_percent = nil
  endif
-%}
{%- capture footer_generic_card_style -%}
--footer-card-radius: {{ radius }}px; --footer-card-padding: {{ pad }}px; border-radius: {{ radius }}px; --fgc-title-fs: {{ g_title_fs }}rem; --fgc-excerpt-fs: {{ g_excerpt_fs }}rem;{% if g_ff_css != blank %} --fgc-font-family: {{ g_ff_css }};{% endif %}
{%- endcapture -%}

{%- if card_wraps_with_link -%}
  <a
    href="{{ block.settings.card_link }}"
    class="footer-generic-card footer-generic-card--is-link color-{{ block.settings.color_scheme }} gradient"
    style="{{ footer_generic_card_style }}"
    {{ block.shopify_attributes }}
  >
{%- else -%}
  <div
    class="footer-generic-card color-{{ block.settings.color_scheme }} gradient"
    style="{{ footer_generic_card_style }}"
    {{ block.shopify_attributes }}
  >
{%- endif -%}

{%- if has_video -%}
  {%- liquid
    assign vid_poster = block.settings.image | default: ext_vid.preview_image
    assign vid_aria = block.settings.title | default: 'Video' | strip_html | escape
    assign vid_alt = 'sections.video.load_video' | t: description: vid_aria
    if ratio_class == 'adapt' and vid_poster != blank
      assign ratio_percent = 1 | divided_by: vid_poster.aspect_ratio | times: 100
    elsif ratio_class == 'adapt'
      assign ratio_percent = 56.25
    endif
  -%}
  <div class="footer-generic-card__media footer-generic-card__media--video">
    <deferred-media
      class="footer-generic-card__video deferred-media"
      data-media-id="{{ vid_id }}"
      style="--ratio-percent: {{ ratio_percent }}%;"
    >
      <button
        id="Deferred-FooterCard-{{ block.id }}"
        type="button"
        class="footer-generic-card__video-poster deferred-media__poster media"
        aria-label="{{ vid_alt }}"
      >
        {%- if vid_poster != blank -%}
          {{
            vid_poster
            | image_url: width: 1200
            | image_tag:
              loading: 'lazy',
              widths: '165, 360, 535, 750, 940, 1100, 1200',
              sizes: '(min-width: 990px) 400px, (min-width: 750px) 45vw, 100vw',
              alt: vid_aria
          }}
        {%- elsif vid_type == 'youtube' -%}
          <img
            src="https://i.ytimg.com/vi/{{ vid_id }}/hqdefault.jpg"
            alt="{{ vid_aria }}"
            loading="lazy"
            width="480"
            height="360"
          >
        {%- else -%}
          {{ 'hero-apparel-3' | placeholder_svg_tag: 'placeholder-svg placeholder' }}
        {%- endif -%}
        <span class="deferred-media__poster-button motion-reduce">
          <span class="svg-wrapper">
            {{- 'icon-play.svg' | inline_asset_content -}}
          </span>
        </span>
      </button>
      <template>
        {%- if vid_type == 'youtube' -%}
          <iframe
            src="https://www.youtube.com/embed/{{ vid_id }}?enablejsapi=1&autoplay=1"
            class="js-youtube"
            allow="autoplay; encrypted-media"
            allowfullscreen
            title="{{ vid_aria }}"
          ></iframe>
        {%- else -%}
          <iframe
            src="https://player.vimeo.com/video/{{ vid_id }}?autoplay=1"
            class="js-vimeo"
            allow="autoplay; encrypted-media"
            allowfullscreen
            title="{{ vid_aria }}"
          ></iframe>
        {%- endif -%}
      </template>
    </deferred-media>
  </div>
{%- elsif block.settings.image != blank -%}
  <div class="footer-generic-card__media footer-generic-card__media--{{ ratio_class }}">
    {{
      block.settings.image
      | image_url: width: 1200
      | image_tag:
        loading: 'lazy',
        widths: '165, 360, 535, 750, 940, 1100, 1200',
        sizes: '(min-width: 990px) 400px, (min-width: 750px) 45vw, 100vw',
        class: 'footer-generic-card__image'
    }}
  </div>
{%- endif -%}

<div class="footer-generic-card__body">
  {%- if block.settings.card_link != blank and has_video -%}
    <a href="{{ block.settings.card_link }}" class="footer-generic-card__body-link">
  {%- endif -%}
  {%- if block.settings.title != blank -%}
    <h3 class="footer-generic-card__title inline-richtext h4">
      {{ block.settings.title }}
    </h3>
  {%- endif -%}
  {%- if block.settings.excerpt != blank -%}
    <div class="footer-generic-card__excerpt rte">
      {{ block.settings.excerpt }}
    </div>
  {%- endif -%}
  {%- if block.settings.card_link != blank and has_video -%}
    </a>
  {%- endif -%}
</div>

{%- if card_wraps_with_link -%}
  </a>
{%- else -%}
  </div>
{%- endif -%}
