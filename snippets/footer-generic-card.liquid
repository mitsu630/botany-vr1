{% comment %}
  フッター「汎用カード」ブロック
  @param {object} block - footer section の generic_card ブロック
{% endcomment %}

{%- liquid
  assign radius = block.settings.border_radius
  assign pad = block.settings.padding
  assign ratio_class = block.settings.image_ratio | default: 'ratio-16-9'
-%}

{%- if block.settings.card_link != blank -%}
  <a
    href="{{ block.settings.card_link }}"
    class="footer-generic-card footer-generic-card--is-link color-{{ block.settings.color_scheme }} gradient"
    style="--footer-card-radius: {{ radius }}px; --footer-card-padding: {{ pad }}px; border-radius: {{ radius }}px;"
    {{ block.shopify_attributes }}
  >
{%- else -%}
  <div
    class="footer-generic-card color-{{ block.settings.color_scheme }} gradient"
    style="--footer-card-radius: {{ radius }}px; --footer-card-padding: {{ pad }}px; border-radius: {{ radius }}px;"
    {{ block.shopify_attributes }}
  >
{%- endif -%}

{%- if block.settings.image != blank -%}
  <div class="footer-generic-card__media footer-generic-card__media--{{ ratio_class }}">
    {{
      block.settings.image
      | image_url: width: 1200
      | image_tag:
        loading: 'lazy',
        widths: '165, 360, 535, 750, 940, 1100, 1200',
        sizes: '(min-width: 990px) 400px, (min-width: 750px) 45vw, 100vw',
        class: 'footer-generic-card__image'
    }}
  </div>
{%- endif -%}

<div class="footer-generic-card__body">
  {%- if block.settings.title != blank -%}
    <h3 class="footer-generic-card__title inline-richtext h4">
      {{ block.settings.title }}
    </h3>
  {%- endif -%}
  {%- if block.settings.excerpt != blank -%}
    <div class="footer-generic-card__excerpt rte">
      {{ block.settings.excerpt }}
    </div>
  {%- endif -%}
</div>

{%- if block.settings.card_link != blank -%}
  </a>
{%- else -%}
  </div>
{%- endif -%}
