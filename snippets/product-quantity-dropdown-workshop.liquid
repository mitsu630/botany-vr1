{% comment %}
  ワークショップ用: 数量をネイティブ select で選択し、後ろに「人」を付与。
  product-info.js の .quantity__input は SELECT にも対応する。
{% endcomment %}
{%- liquid
  assign v = product.selected_or_first_available_variant
  assign qmin = v.quantity_rule.min
  assign qstep = v.quantity_rule.increment
  assign qmax = v.quantity_rule.max
  if qmax == blank
    assign cap = 5
  else
    assign cap = qmax
  endif
  if cap > 50
    assign cap = 50
  endif

  # 販売可能に寄せるため在庫追跡時は inventory_quantity で上限を絞る。負値は cap に使わない。
  assign inv_cap = blank
  if v.inventory_management == 'shopify' and v.inventory_quantity >= 0
    assign inv_cap = v.inventory_quantity
  endif

  assign is_sold_out = false
  if inv_cap != blank and inv_cap == 0
    assign is_sold_out = true
  endif

  if inv_cap != blank and inv_cap > 0
    assign cap = cap | at_most: inv_cap
  endif
-%}
<div class="jwb-quantity-dropdown-row">
  <div class="select jwb-unified-control">
    <select
      id="Quantity-{{ section.id }}"
      class="select__select quantity__input"
      name="quantity"
      data-jwb-quantity-select="true"
      data-jwb-form-id="{{ product_form_id }}"
      data-cart-quantity="{{ cart_qty }}"
      data-min="{{ qmin }}"
      {% if inv_cap != blank %}
        data-jwb-inv-cap="{{ inv_cap }}"
      {% endif %}
      {% unless is_sold_out %}
        {% unless qmax == blank %}
          data-max="{{ qmax }}"
        {% endunless %}
      {% endunless %}
      step="{{ qstep }}"
      data-cap-max="5"
      aria-labelledby="quantity-label-{{ section.id }}"
      {% if is_sold_out %}
        disabled
      {% endif %}
    >
      {%- assign n = qmin -%}
      {%- for i in (1..80) -%}
        {%- if is_sold_out -%}
          {%- break -%}
        {%- endif -%}
        {%- if n > cap -%}
          {%- break -%}
        {%- endif -%}
        <option
          value="{{ n }}"
          {% if n == qmin %}
            selected
          {% endif %}
        >
          {{- n -}}
        </option>
        {%- assign n = n | plus: qstep -%}
      {%- endfor -%}
    </select>
    <span class="svg-wrapper">
      {{- 'icon-caret.svg' | inline_asset_content -}}
    </span>
  </div>
  <span class="jwb-quantity-suffix" aria-hidden="true">人</span>
</div>
