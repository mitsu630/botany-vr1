{%- liquid
  assign out = ''

  assign pu_val = photo_url_mf.value
  assign raw = ''
  if pu_val != blank
    if pu_val.url != blank
      assign raw = pu_val.url | strip
    else
      assign raw = pu_val | strip
    endif
  endif

  if raw != blank
    if raw contains '://'
      assign out = raw
    else
      assign head2 = raw | slice: 0, 2
      assign head1 = raw | slice: 0, 1
      if head2 == '//'
        assign out = 'https:' | append: raw
      elsif head1 == '/'
        assign out = shop.secure_url | append: raw
      else
        assign out = raw
      endif
    endif
  endif

  if out == blank and photo_file_mf.value != blank
    assign out = photo_file_mf | image_url: width: 2000
    if out == blank
      assign out = photo_file_mf | file_url
    endif
  endif

  if out == blank and variant_obj.image
    assign out = variant_obj.image | image_url: width: 2000
  endif

  if out == blank and variant_obj.featured_image
    assign out = variant_obj.featured_image | image_url: width: 2000
  endif

  if out == blank and product_fallback != blank
    assign out = product_fallback
  endif

  if out == blank and variant_obj.product.images.size > 0
    assign out = variant_obj.product.images.first | image_url: width: 2000
  endif

  echo out
-%}
