{% doc %}
  @prompt
    <!DOCTYPE html>
    <html lang="zh-Hant">
    <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Information セクション プレビュー</title>
    <style>
      body { margin: 0; background: #fff; font-family: "Noto Sans TC", "Hiragino Sans", "Helvetica Neue", Arial, "Microsoft JhengHei", sans-serif; }
    
      .bp-info {
        background: #f7f4ee;
        padding: 80px 20px;
        color: #2d2a25;
        -webkit-font-smoothing: antialiased;
      }
      .bp-info__inner { max-width: 980px; margin: 0 auto; }
    
      .bp-info__head {
        text-align: center;
        border-top: 1px solid #2d2a25;
        border-bottom: 1px solid #2d2a25;
        padding: 28px 16px;
        margin-bottom: 56px;
      }
      .bp-info__title {
        font-size: clamp(32px, 5vw, 44px);
        font-weight: 800;
        letter-spacing: .02em;
        margin: 0 0 8px;
        color: #2d2a25;
        font-family: "Helvetica Neue", "Hiragino Sans", "Noto Sans TC", sans-serif;
      }
      .bp-info__subtitle {
        font-size: 14px; color: #5e5b53; margin: 0; letter-spacing: .05em;
      }
    
      .bp-info__list {
        list-style: none; margin: 0; padding: 0;
        display: flex; flex-direction: column; gap: 32px;
      }
      .bp-info__item {
        display: grid;
        grid-template-columns: 240px 1fr auto;
        align-items: center;
        gap: 32px;
        padding: 4px 12px;
      }
      .bp-info__thumb {
        width: 240px; height: 180px;
        overflow: hidden; border-radius: 4px;
        background: #ece6d8; display: block;
      }
      .bp-info__thumb img {
        width: 100%; height: 100%; object-fit: cover; display: block;
        transition: transform .4s ease;
      }
      .bp-info__item:hover .bp-info__thumb img { transform: scale(1.04); }
    
      .bp-info__body { display: flex; flex-direction: column; gap: 14px; }
      .bp-info__item-title {
        font-size: 18px; font-weight: 600; line-height: 1.6;
        color: #2d2a25; margin: 0; letter-spacing: .02em;
      }
      .bp-info__meta {
        display: flex; align-items: center; gap: 12px;
        color: #5e5b53; font-size: 14px; letter-spacing: .04em;
      }
      .bp-info__date { font-weight: 500; }
    
      .bp-info__new {
        display: inline-block;
        background: #c98a7a;
        color: #fff;
        font-size: 11px; font-weight: 600;
        letter-spacing: .12em;
        padding: 3px 10px;
        border-radius: 3px;
        text-transform: uppercase;
      }
    
      .bp-info__check {
        display: inline-block;
        background: #7a8b6f;
        color: #fff !important;
        text-decoration: none;
        font-size: 13px; letter-spacing: .15em;
        padding: 10px 32px;
        border-radius: 999px;
        transition: background .2s ease, transform .2s ease;
        white-space: nowrap;
      }
      .bp-info__check:hover { background: #65755b; transform: translateY(-1px); }
    
      @media (max-width: 720px) {
        .bp-info { padding: 56px 16px; }
        .bp-info__head { padding: 22px 12px; margin-bottom: 36px; }
        .bp-info__list { gap: 28px; }
        .bp-info__item { grid-template-columns: 130px 1fr; gap: 16px; padding: 0; }
        .bp-info__thumb { width: 130px; height: 100px; }
        .bp-info__item-title { font-size: 14.5px; }
        .bp-info__meta { font-size: 12.5px; gap: 8px; flex-wrap: wrap; }
        .bp-info__check {
          grid-column: 1 / -1; justify-self: end; margin-top: -4px;
          font-size: 12px; padding: 8px 24px;
        }
      }
    </style>
    </head>
    <body>
    
    <section class="bp-info" aria-label="最新消息">
      <div class="bp-info__inner">
    
        <header class="bp-info__head">
          <h2 class="bp-info__title">Information</h2>
          <p class="bp-info__subtitle">隨時掌握植物彩繪的最新消息</p>
        </header>
    
        <ul class="bp-info__list">
    
          <li class="bp-info__item">
            <a class="bp-info__thumb" href="#">
              <!-- プレビュー用：実際にはShopifyにアップした写真URLに差し替え -->
              <img src="https://images.unsplash.com/photo-1511795409834-ef04bbd61622?w=600&h=400&fit=crop" alt="台灣展覽會 開幕活動報導">
            </a>
            <div class="bp-info__body">
              <h3 class="bp-info__item-title">台灣展覽會・開幕活動圓滿落幕</h3>
              <div class="bp-info__meta">
                <span class="bp-info__date">2026.03.27 – 03.29</span>
                <span class="bp-info__new">New</span>
              </div>
            </div>
            <a class="bp-info__check" href="#">Check</a>
          </li>
    
        </ul>
    
      </div>
    </section>
    
    </body>
    </html>
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .bp-info-{{ ai_gen_id }} {
    display: block;
    background: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px;
    color: {{ block.settings.text_color }};
    -webkit-font-smoothing: antialiased;
    width: 100%;
  }

  .bp-info__inner-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .bp-info__head-{{ ai_gen_id }} {
    text-align: {{ block.settings.header_alignment }};
    border-top: {{ block.settings.header_border_thickness }}px solid {{ block.settings.border_color }};
    border-bottom: {{ block.settings.header_border_thickness }}px solid {{ block.settings.border_color }};
    padding: {{ block.settings.header_padding_vertical }}px {{ block.settings.header_padding_horizontal }}px;
    margin-bottom: {{ block.settings.header_margin_bottom }}px;
  }

  .bp-info__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: {{ block.settings.title_weight }};
    letter-spacing: {{ block.settings.title_letter_spacing }}em;
    margin: 0 0 {{ block.settings.title_margin_bottom }}px;
    color: {{ block.settings.text_color }};
  }

  .bp-info__subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0;
    letter-spacing: {{ block.settings.subtitle_letter_spacing }}em;
  }

  .bp-info__list-{{ ai_gen_id }} {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.item_gap }}px;
  }

  .bp-info__item-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: {{ block.settings.thumbnail_width }}px 1fr auto;
    align-items: center;
    gap: {{ block.settings.item_inner_gap }}px;
    padding: {{ block.settings.item_padding_vertical }}px {{ block.settings.item_padding_horizontal }}px;
  }

  .bp-info__thumb-{{ ai_gen_id }} {
    width: {{ block.settings.thumbnail_width }}px;
    height: {{ block.settings.thumbnail_height }}px;
    overflow: hidden;
    border-radius: {{ block.settings.thumbnail_radius }}px;
    background: {{ block.settings.thumbnail_bg }};
    display: block;
  }

  .bp-info__thumb-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }

  .bp-info__item-{{ ai_gen_id }}:hover .bp-info__thumb-{{ ai_gen_id }} img {
    transform: scale({{ block.settings.thumbnail_hover_scale }});
  }

  .bp-info__body-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.body_gap }}px;
  }

  .bp-info__item-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.item_title_size }}px;
    font-weight: {{ block.settings.item_title_weight }};
    line-height: {{ block.settings.item_title_line_height }};
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .bp-info__meta-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.meta_gap }}px;
    color: {{ block.settings.subtitle_color }};
    font-size: {{ block.settings.meta_size }}px;
  }

  .bp-info__date-{{ ai_gen_id }} {
    font-weight: {{ block.settings.date_weight }};
  }

  .bp-info__new-{{ ai_gen_id }} {
    display: inline-block;
    background: {{ block.settings.new_badge_bg }};
    color: {{ block.settings.new_badge_text_color }};
    font-size: {{ block.settings.new_badge_size }}px;
    font-weight: {{ block.settings.new_badge_weight }};
    letter-spacing: {{ block.settings.new_badge_letter_spacing }}em;
    padding: {{ block.settings.new_badge_padding_vertical }}px {{ block.settings.new_badge_padding_horizontal }}px;
    border-radius: {{ block.settings.new_badge_radius }}px;
    text-transform: uppercase;
  }

  .bp-info__check-{{ ai_gen_id }} {
    display: inline-block;
    background: {{ block.settings.button_bg }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    font-size: {{ block.settings.button_size }}px;
    letter-spacing: {{ block.settings.button_letter_spacing }}em;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    border-radius: {{ block.settings.button_radius }}px;
    transition: background 0.2s ease, transform 0.2s ease;
    white-space: nowrap;
  }

  .bp-info__check-{{ ai_gen_id }}:hover {
    background: {{ block.settings.button_hover_bg }};
    transform: translateY(-1px);
  }

  @media (max-width: 749px) {
    .bp-info-{{ ai_gen_id }} {
      padding: {{ block.settings.mobile_padding_top }}px {{ block.settings.mobile_padding_horizontal }}px {{ block.settings.mobile_padding_bottom }}px;
    }

    .bp-info__head-{{ ai_gen_id }} {
      padding: {{ block.settings.mobile_header_padding_vertical }}px {{ block.settings.mobile_header_padding_horizontal }}px;
      margin-bottom: {{ block.settings.mobile_header_margin_bottom }}px;
    }

    .bp-info__list-{{ ai_gen_id }} {
      gap: {{ block.settings.mobile_item_gap }}px;
    }

    .bp-info__item-{{ ai_gen_id }} {
      grid-template-columns: {{ block.settings.mobile_thumbnail_width }}px 1fr;
      gap: {{ block.settings.mobile_item_inner_gap }}px;
      padding: 0;
    }

    .bp-info__thumb-{{ ai_gen_id }} {
      width: {{ block.settings.mobile_thumbnail_width }}px;
      height: {{ block.settings.mobile_thumbnail_height }}px;
    }

    .bp-info__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_title_size }}px;
    }

    .bp-info__subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_subtitle_size }}px;
    }

    .bp-info__item-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_item_title_size }}px;
    }

    .bp-info__meta-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_meta_size }}px;
      gap: {{ block.settings.mobile_meta_gap }}px;
      flex-wrap: wrap;
    }

    .bp-info__check-{{ ai_gen_id }} {
      grid-column: 1 / -1;
      justify-self: end;
      margin-top: -4px;
      font-size: {{ block.settings.mobile_button_size }}px;
      padding: {{ block.settings.mobile_button_padding_vertical }}px {{ block.settings.mobile_button_padding_horizontal }}px;
    }
  }
{% endstyle %}

<bp-info-{{ ai_gen_id }} class="bp-info-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="bp-info__inner-{{ ai_gen_id }}">
    <header class="bp-info__head-{{ ai_gen_id }}">
      {% if block.settings.title != blank %}
        <h2 class="bp-info__title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
      {% endif %}
      {% if block.settings.subtitle != blank %}
        <p class="bp-info__subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</p>
      {% endif %}
    </header>

    <ul class="bp-info__list-{{ ai_gen_id }}">
      {% for i in (1..5) %}
        {% liquid
          assign item_enabled_key = 'item_' | append: i | append: '_enabled'
          assign item_image_key = 'item_' | append: i | append: '_image'
          assign item_title_key = 'item_' | append: i | append: '_title'
          assign item_date_key = 'item_' | append: i | append: '_date'
          assign item_show_new_key = 'item_' | append: i | append: '_show_new'
          assign item_link_key = 'item_' | append: i | append: '_link'

          assign item_enabled = block.settings[item_enabled_key]
          assign item_image = block.settings[item_image_key]
          assign item_title = block.settings[item_title_key]
          assign item_date = block.settings[item_date_key]
          assign item_show_new = block.settings[item_show_new_key]
          assign item_link = block.settings[item_link_key]
        %}

        {% if item_enabled %}
          <li class="bp-info__item-{{ ai_gen_id }}">
            <a class="bp-info__thumb-{{ ai_gen_id }}" href="{{ item_link }}">
              {% if item_image %}
                <img
                  src="{{ item_image | image_url: width: 600 }}"
                  alt="{{ item_image.alt | escape }}"
                  loading="lazy"
                  width="600"
                  height="400"
                >
              {% else %}
                {{ 'image' | placeholder_svg_tag }}
              {% endif %}
            </a>
            <div class="bp-info__body-{{ ai_gen_id }}">
              {% if item_title != blank %}
                <h3 class="bp-info__item-title-{{ ai_gen_id }}">{{ item_title }}</h3>
              {% endif %}
              <div class="bp-info__meta-{{ ai_gen_id }}">
                {% if item_date != blank %}
                  <span class="bp-info__date-{{ ai_gen_id }}">{{ item_date }}</span>
                {% endif %}
                {% if item_show_new %}
                  <span class="bp-info__new-{{ ai_gen_id }}">{{ block.settings.new_badge_text_label }}</span>
                {% endif %}
              </div>
            </div>
            <a class="bp-info__check-{{ ai_gen_id }}" href="{{ item_link }}">{{ block.settings.button_text_label }}</a>
          </li>
        {% endif %}
      {% endfor %}
    </ul>
  </div>
</bp-info-{{ ai_gen_id }}>

<script>
  (function() {
    class BpInfo{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('bp-info-{{ ai_gen_id }}', BpInfo{{ ai_gen_id }});
  })();
</script>

