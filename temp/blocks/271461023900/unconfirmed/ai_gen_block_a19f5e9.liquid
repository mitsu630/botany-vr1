{% doc %}
  @prompt
    お知らせ
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-announcement-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-announcement-container-{{ ai_gen_id }} {
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
    border-radius: {{ block.settings.border_radius }}px;
    text-align: {{ block.settings.text_alignment }};
    {% if block.settings.show_border %}
      border: {{ block.settings.border_thickness }}px solid {{ block.settings.border_color }};
    {% endif %}
  }

  .ai-announcement-icon-{{ ai_gen_id }} {
    display: inline-block;
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    margin-right: 8px;
    vertical-align: middle;
  }

  .ai-announcement-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    fill: {{ block.settings.icon_color }};
  }

  .ai-announcement-content-{{ ai_gen_id }} {
    display: inline-block;
    vertical-align: middle;
  }

  .ai-announcement-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 600;
    color: {{ block.settings.title_color }};
    margin: 0 0 4px 0;
  }

  .ai-announcement-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-announcement-link-{{ ai_gen_id }} {
    display: inline-block;
    margin-top: 12px;
    padding: 8px 16px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_text_size }}px;
    transition: background-color 0.3s ease;
  }

  .ai-announcement-link-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
  }

  @media screen and (max-width: 749px) {
    .ai-announcement-container-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_vertical | times: 0.8 }}px {{ block.settings.padding_horizontal | times: 0.8 }}px;
    }

    .ai-announcement-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.9 }}px;
    }

    .ai-announcement-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-announcement-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-announcement-container-{{ ai_gen_id }}">
    {% if block.settings.show_icon %}
      <span class="ai-announcement-icon-{{ ai_gen_id }}">
        {% if block.settings.icon_type == 'info' %}
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/>
          </svg>
        {% elsif block.settings.icon_type == 'bell' %}
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
            <path d="M12 22c1.1 0 2-.9 2-2h-4c0 1.1.89 2 2 2zm6-6v-5c0-3.07-1.64-5.64-4.5-6.32V4c0-.83-.67-1.5-1.5-1.5s-1.5.67-1.5 1.5v.68C7.63 5.36 6 7.92 6 11v5l-2 2v1h16v-1l-2-2z"/>
          </svg>
        {% elsif block.settings.icon_type == 'megaphone' %}
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
            <path d="M12 8c1.1 0 2-.9 2-2s-.9-2-2-2-2 .9-2 2 .9 2 2 2zm0 2c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm0 6c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2z"/>
            <path d="M20 2H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h14l4 4V4c0-1.1-.9-2-2-2z"/>
          </svg>
        {% elsif block.settings.icon_type == 'star' %}
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
            <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>
          </svg>
        {% endif %}
      </span>
    {% endif %}

    <div class="ai-announcement-content-{{ ai_gen_id }}">
      {% if block.settings.title != blank %}
        <div class="ai-announcement-title-{{ ai_gen_id }}">
          {{ block.settings.title }}
        </div>
      {% endif %}

      {% if block.settings.text != blank %}
        <div class="ai-announcement-text-{{ ai_gen_id }}">
          {{ block.settings.text }}
        </div>
      {% endif %}

      {% if block.settings.show_button and block.settings.button_text != blank %}
        <a href="{{ block.settings.button_link }}" class="ai-announcement-link-{{ ai_gen_id }}">
          {{ block.settings.button_text }}
        </a>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "お知らせ",
  "settings": [
    {
      "type": "header",
      "content": "コンテンツ"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "タイトル",
      "default": "重要なお知らせ"
    },
    {
      "type": "inline_richtext",
      "id": "text",
      "label": "テキスト",
      "default": "新しいワークショップの日程が公開されました。詳細をご確認ください。"
    },
    {
      "type": "header",
      "content": "アイコン"
    },
    {
      "type": "checkbox",
      "id": "show_icon",
      "label": "アイコンを表示",
      "default": true
    },
    {
      "type": "select",
      "id": "icon_type",
      "label": "アイコンタイプ",
      "options": [
        {
          "value": "info",
          "label": "情報"
        },
        {
          "value": "bell",
          "label": "ベル"
        },
        {
          "value": "megaphone",
          "label": "メガホン"
        },
        {
          "value": "star",
          "label": "スター"
        }
      ],
      "default": "bell"
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "アイコンサイズ",
      "min": 16,
      "max": 48,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "アイコンカラー",
      "default": "#36384c"
    },
    {
      "type": "header",
      "content": "ボタン"
    },
    {
      "type": "checkbox",
      "id": "show_button",
      "label": "ボタンを表示",
      "default": false
    },
    {
      "type": "inline_richtext",
      "id": "button_text",
      "label": "ボタンテキスト",
      "default": "詳細を見る"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "ボタンリンク"
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "ボタン背景色",
      "default": "#613a43"
    },
    {
      "type": "color",
      "id": "button_hover_background",
      "label": "ボタンホバー背景色",
      "default": "#36384c"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "ボタンテキストカラー",
      "default": "#e9dccd"
    },
    {
      "type": "range",
      "id": "button_text_size",
      "label": "ボタンテキストサイズ",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "ボタン角丸",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 4
    },
    {
      "type": "header",
      "content": "スタイル"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "背景色",
      "default": "#e3bab3"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "タイトルカラー",
      "default": "#36384c"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "テキストカラー",
      "default": "#36384c"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "タイトルサイズ",
      "min": 14,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "テキストサイズ",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "テキスト配置",
      "options": [
        {
          "value": "left",
          "label": "左"
        },
        {
          "value": "center",
          "label": "中央"
        },
        {
          "value": "right",
          "label": "右"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "padding_vertical",
      "label": "上下パディング",
      "min": 8,
      "max": 48,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "左右パディング",
      "min": 8,
      "max": 64,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "角丸",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "ボーダー"
    },
    {
      "type": "checkbox",
      "id": "show_border",
      "label": "ボーダーを表示",
      "default": false
    },
    {
      "type": "range",
      "id": "border_thickness",
      "label": "ボーダーの太さ",
      "min": 1,
      "max": 8,
      "step": 1,
      "unit": "px",
      "default": 1
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "ボーダーカラー",
      "default": "#36384c"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "デスクトップ幅",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "お知らせ"
    }
  ]
}
{% endschema %}
