{% doc %}
  @prompt
    インフォメーションセクション。写真付き
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-info-section-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-info-section-container-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.gap }}px;
    align-items: {{ block.settings.vertical_alignment }};
    {% if block.settings.layout == 'image_right' %}
      flex-direction: row-reverse;
    {% else %}
      flex-direction: row;
    {% endif %}
  }

  .ai-info-section-image-wrapper-{{ ai_gen_id }} {
    flex: 0 0 {{ block.settings.image_width }}%;
  }

  .ai-info-section-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-info-section-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 4 / 3;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.image_border_radius }}px;
    position: relative;
  }

  .ai-info-section-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-info-section-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-info-section-content-{{ ai_gen_id }} {
    flex: 1;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-info-section-heading-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    line-height: 1.3;
  }

  .ai-info-section-text-{{ ai_gen_id }} {
    margin: 0;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.6;
  }

  @media screen and (max-width: 749px) {
    .ai-info-section-container-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .ai-info-section-image-wrapper-{{ ai_gen_id }} {
      flex: 0 0 100%;
    }

    .ai-info-section-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
    }

    .ai-info-section-text-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.text_size }}px * 0.9);
    }
  }
{% endstyle %}

<info-section-{{ ai_gen_id }}
  class="ai-info-section-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-info-section-container-{{ ai_gen_id }}">
    <div class="ai-info-section-image-wrapper-{{ ai_gen_id }}">
      {% if block.settings.image %}
        <img
          src="{{ block.settings.image | image_url: width: 1200 }}"
          alt="{{ block.settings.image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.image.width }}"
          height="{{ block.settings.image.height }}"
          class="ai-info-section-image-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-info-section-image-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
          <div class="ai-info-section-empty-state-{{ ai_gen_id }}">
            画像を追加してください
          </div>
        </div>
      {% endif %}
    </div>

    <div class="ai-info-section-content-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-info-section-heading-{{ ai_gen_id }}">
          {{ block.settings.heading }}
        </h2>
      {% endif %}

      {% if block.settings.text != blank %}
        <div class="ai-info-section-text-{{ ai_gen_id }}">
          {{ block.settings.text }}
        </div>
      {% endif %}
    </div>
  </div>
</info-section-{{ ai_gen_id }}>

<script>
  (function() {
    class InfoSection{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }
    }

    customElements.define('info-section-{{ ai_gen_id }}', InfoSection{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "インフォメーション",
  "settings": [
    {
      "type": "header",
      "content": "画像"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "画像"
    },
    {
      "type": "range",
      "id": "image_width",
      "label": "画像の幅",
      "min": 30,
      "max": 60,
      "step": 5,
      "unit": "%",
      "default": 50
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "label": "画像の角丸",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "コンテンツ"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "見出し",
      "default": "<p>インフォメーション</p>"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "テキスト",
      "default": "<p>ここに説明文を入力してください。ボタニーペインティングのワークショップや講座に関する情報をお伝えします。</p>"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "レイアウト",
      "options": [
        {
          "value": "image_left",
          "label": "画像左"
        },
        {
          "value": "image_right",
          "label": "画像右"
        }
      ],
      "default": "image_left"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "テキスト配置",
      "options": [
        {
          "value": "left",
          "label": "左"
        },
        {
          "value": "center",
          "label": "中央"
        },
        {
          "value": "right",
          "label": "右"
        }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "vertical_alignment",
      "label": "垂直配置",
      "options": [
        {
          "value": "flex-start",
          "label": "上"
        },
        {
          "value": "center",
          "label": "中央"
        },
        {
          "value": "flex-end",
          "label": "下"
        }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "スタイル"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "デスクトップ幅",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "section_padding",
      "label": "パディング",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "gap",
      "label": "画像とテキストの間隔",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "背景色",
      "default": "#e9dccd"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "見出しサイズ",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "heading_spacing",
      "label": "見出し下の余白",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "見出し色",
      "default": "#36384c"
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "テキストサイズ",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "テキスト色",
      "default": "#36384c"
    }
  ],
  "presets": [
    {
      "name": "インフォメーション"
    }
  ]
}
{% endschema %}