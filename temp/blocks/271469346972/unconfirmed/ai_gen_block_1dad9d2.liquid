{% doc %}
  @prompt
    購入ボタン
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-purchase-button-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-purchase-button-container-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-purchase-button-btn-{{ ai_gen_id }} {
    width: 100%;
    padding: {{ block.settings.button_padding }}px {{ block.settings.button_padding | times: 1.5 }}px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    border: {{ block.settings.border_thickness }}px solid {{ block.settings.border_color }};
    border-radius: {{ block.settings.border_radius }}px;
    font-size: {{ block.settings.font_size }}px;
    font-weight: {{ block.settings.font_weight }};
    text-align: center;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.3s ease;
    display: inline-block;
  }

  .ai-purchase-button-btn-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.border_hover_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-purchase-button-container-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<purchase-button-{{ ai_gen_id }}
  class="ai-purchase-button-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-purchase-button-container-{{ ai_gen_id }}">
    <a
      href="{{ block.settings.button_link }}"
      class="ai-purchase-button-btn-{{ ai_gen_id }}"
    >
      {{ block.settings.button_text }}
    </a>
  </div>
</purchase-button-{{ ai_gen_id }}>

<script>
  (function() {
    class PurchaseButton{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }
    }

    customElements.define('purchase-button-{{ ai_gen_id }}', PurchaseButton{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "購入ボタン",
  "settings": [
    {
      "type": "header",
      "content": "ボタン"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "ボタンテキスト",
      "default": "今すぐ購入"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "ボタンリンク"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "デスクトップ幅",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "スタイル"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "背景色",
      "default": "#613a43"
    },
    {
      "type": "color",
      "id": "button_hover_color",
      "label": "ホバー背景色",
      "default": "#36384c"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "テキスト色",
      "default": "#e9dccd"
    },
    {
      "type": "color",
      "id": "button_hover_text_color",
      "label": "ホバーテキスト色",
      "default": "#e9dccd"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "フォントサイズ",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "フォントウェイト",
      "options": [
        {
          "value": "400",
          "label": "標準"
        },
        {
          "value": "500",
          "label": "ミディアム"
        },
        {
          "value": "600",
          "label": "セミボールド"
        },
        {
          "value": "700",
          "label": "ボールド"
        }
      ],
      "default": "600"
    },
    {
      "type": "range",
      "id": "button_padding",
      "label": "パディング",
      "min": 8,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "ボーダー"
    },
    {
      "type": "range",
      "id": "border_thickness",
      "label": "ボーダー太さ",
      "min": 0,
      "max": 4,
      "step": 1,
      "unit": "px",
      "default": 1
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "ボーダー色",
      "default": "#613a43"
    },
    {
      "type": "color",
      "id": "border_hover_color",
      "label": "ホバーボーダー色",
      "default": "#36384c"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "角丸",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "購入ボタン"
    }
  ]
}
{% endschema %}
