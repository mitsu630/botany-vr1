{% doc %}
  @prompt
    2つ横並びのボタンが欲しい
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-dual-buttons-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-dual-buttons__container-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.button_gap }}px;
    justify-content: {{ block.settings.alignment }};
    align-items: center;
    width: 100%;
  }

  .ai-dual-buttons__button-{{ ai_gen_id }} {
    flex: 1;
    max-width: {{ block.settings.button_max_width }}px;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    font-size: {{ block.settings.font_size }}px;
    text-align: center;
    text-decoration: none;
    border-radius: {{ block.settings.border_radius }}px;
    transition: all 0.3s ease;
    cursor: pointer;
    border: {{ block.settings.border_thickness }}px solid;
    display: inline-block;
  }

  .ai-dual-buttons__button--primary-{{ ai_gen_id }} {
    background-color: {{ block.settings.primary_bg_color }};
    color: {{ block.settings.primary_text_color }};
    border-color: {{ block.settings.primary_border_color }};
  }

  .ai-dual-buttons__button--primary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.primary_hover_bg_color }};
    color: {{ block.settings.primary_hover_text_color }};
    border-color: {{ block.settings.primary_hover_border_color }};
  }

  .ai-dual-buttons__button--secondary-{{ ai_gen_id }} {
    background-color: {{ block.settings.secondary_bg_color }};
    color: {{ block.settings.secondary_text_color }};
    border-color: {{ block.settings.secondary_border_color }};
  }

  .ai-dual-buttons__button--secondary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.secondary_hover_bg_color }};
    color: {{ block.settings.secondary_hover_text_color }};
    border-color: {{ block.settings.secondary_hover_border_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-dual-buttons__container-{{ ai_gen_id }} {
      {% if block.settings.mobile_stack %}
        flex-direction: column;
      {% endif %}
    }

    .ai-dual-buttons__button-{{ ai_gen_id }} {
      {% if block.settings.mobile_stack %}
        max-width: 100%;
      {% endif %}
    }
  }
{% endstyle %}

<dual-buttons-{{ ai_gen_id }}
  class="ai-dual-buttons-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-dual-buttons__container-{{ ai_gen_id }}">
    <a
      href="{{ block.settings.primary_button_link }}"
      class="ai-dual-buttons__button-{{ ai_gen_id }} ai-dual-buttons__button--primary-{{ ai_gen_id }}"
    >
      {{ block.settings.primary_button_text }}
    </a>
    <a
      href="{{ block.settings.secondary_button_link }}"
      class="ai-dual-buttons__button-{{ ai_gen_id }} ai-dual-buttons__button--secondary-{{ ai_gen_id }}"
    >
      {{ block.settings.secondary_button_text }}
    </a>
  </div>
</dual-buttons-{{ ai_gen_id }}>

<script>
  (function() {
    class DualButtons{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.style.display = 'block';
      }
    }

    customElements.define('dual-buttons-{{ ai_gen_id }}', DualButtons{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "横並びボタン",
  "settings": [
    {
      "type": "header",
      "content": "プライマリボタン"
    },
    {
      "type": "text",
      "id": "primary_button_text",
      "label": "ボタンテキスト",
      "default": "詳細を見る"
    },
    {
      "type": "url",
      "id": "primary_button_link",
      "label": "リンク"
    },
    {
      "type": "color",
      "id": "primary_bg_color",
      "label": "背景色",
      "default": "#613a43"
    },
    {
      "type": "color",
      "id": "primary_text_color",
      "label": "テキスト色",
      "default": "#e9dccd"
    },
    {
      "type": "color",
      "id": "primary_border_color",
      "label": "ボーダー色",
      "default": "#613a43"
    },
    {
      "type": "color",
      "id": "primary_hover_bg_color",
      "label": "ホバー背景色",
      "default": "#36384c"
    },
    {
      "type": "color",
      "id": "primary_hover_text_color",
      "label": "ホバーテキスト色",
      "default": "#e9dccd"
    },
    {
      "type": "color",
      "id": "primary_hover_border_color",
      "label": "ホバーボーダー色",
      "default": "#36384c"
    },
    {
      "type": "header",
      "content": "セカンダリボタン"
    },
    {
      "type": "text",
      "id": "secondary_button_text",
      "label": "ボタンテキスト",
      "default": "お問い合わせ"
    },
    {
      "type": "url",
      "id": "secondary_button_link",
      "label": "リンク"
    },
    {
      "type": "color",
      "id": "secondary_bg_color",
      "label": "背景色",
      "default": "#e9dccd"
    },
    {
      "type": "color",
      "id": "secondary_text_color",
      "label": "テキスト色",
      "default": "#36384c"
    },
    {
      "type": "color",
      "id": "secondary_border_color",
      "label": "ボーダー色",
      "default": "#36384c"
    },
    {
      "type": "color",
      "id": "secondary_hover_bg_color",
      "label": "ホバー背景色",
      "default": "#e3bab3"
    },
    {
      "type": "color",
      "id": "secondary_hover_text_color",
      "label": "ホバーテキスト色",
      "default": "#36384c"
    },
    {
      "type": "color",
      "id": "secondary_hover_border_color",
      "label": "ホバーボーダー色",
      "default": "#36384c"
    },
    {
      "type": "header",
      "content": "スタイル"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "配置",
      "options": [
        {
          "value": "flex-start",
          "label": "左"
        },
        {
          "value": "center",
          "label": "中央"
        },
        {
          "value": "flex-end",
          "label": "右"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "button_gap",
      "label": "ボタン間の間隔",
      "min": 8,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "button_max_width",
      "label": "ボタン最大幅",
      "min": 100,
      "max": 400,
      "step": 20,
      "unit": "px",
      "default": 300
    },
    {
      "type": "range",
      "id": "button_padding_vertical",
      "label": "縦方向パディング",
      "min": 8,
      "max": 32,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "button_padding_horizontal",
      "label": "横方向パディング",
      "min": 16,
      "max": 64,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "フォントサイズ",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "角丸",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "border_thickness",
      "label": "ボーダーの太さ",
      "min": 0,
      "max": 4,
      "step": 1,
      "unit": "px",
      "default": 1
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "デスクトップ幅",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "checkbox",
      "id": "mobile_stack",
      "label": "モバイルで縦並び",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "横並びボタン"
    }
  ]
}
{% endschema %}
