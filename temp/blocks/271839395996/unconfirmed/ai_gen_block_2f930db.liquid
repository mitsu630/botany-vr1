{% doc %}
  @prompt
    文章入れる
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-text-block-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px {{ block.settings.padding_horizontal }}px;
    background-color: {{ block.settings.background_color }};
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-text-block__content-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.font_size }}px;
    line-height: {{ block.settings.line_height }};
  }

  .ai-text-block__content-{{ ai_gen_id }} h1,
  .ai-text-block__content-{{ ai_gen_id }} h2,
  .ai-text-block__content-{{ ai_gen_id }} h3,
  .ai-text-block__content-{{ ai_gen_id }} h4,
  .ai-text-block__content-{{ ai_gen_id }} h5,
  .ai-text-block__content-{{ ai_gen_id }} h6 {
    margin-top: 0;
    margin-bottom: 0.5em;
  }

  .ai-text-block__content-{{ ai_gen_id }} p {
    margin-top: 0;
    margin-bottom: 1em;
  }

  .ai-text-block__content-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  .ai-text-block__content-{{ ai_gen_id }} a {
    color: {{ block.settings.link_color }};
    text-decoration: underline;
  }

  .ai-text-block__content-{{ ai_gen_id }} a:hover {
    opacity: 0.8;
  }

  @media screen and (max-width: 749px) {
    .ai-text-block-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top | times: 0.7 }}px {{ block.settings.padding_horizontal | times: 0.7 }}px {{ block.settings.padding_bottom | times: 0.7 }}px {{ block.settings.padding_horizontal | times: 0.7 }}px;
    }

    .ai-text-block__content-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-text-block-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-text-block__content-{{ ai_gen_id }}">
    {{ block.settings.text_content }}
  </div>
</div>

{% schema %}
{
  "name": "テキスト",
  "settings": [
    {
      "type": "richtext",
      "id": "text_content",
      "label": "テキスト",
      "default": "<p>ここにテキストを入力してください。</p>"
    },
    {
      "type": "header",
      "content": "レイアウト"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "配置",
      "options": [
        {
          "value": "left",
          "label": "左揃え"
        },
        {
          "value": "center",
          "label": "中央揃え"
        },
        {
          "value": "right",
          "label": "右揃え"
        }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "デスクトップ幅",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "スタイル"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "テキストカラー",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "リンクカラー",
      "default": "#0066cc"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "背景色",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "フォントサイズ",
      "min": 12,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "line_height",
      "label": "行の高さ",
      "min": 1,
      "max": 2,
      "step": 0.1,
      "default": 1.5
    },
    {
      "type": "header",
      "content": "余白"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "上部余白",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "下部余白",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "左右余白",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "テキスト"
    }
  ]
}
{% endschema %}