{% doc %}
  @prompt
    写真入りの簡単な２ステップ
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-two-step-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-two-step-container-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.gap }}px;
    align-items: stretch;
  }

  .ai-two-step-item-{{ ai_gen_id }} {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.item_gap }}px;
  }

  .ai-two-step-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    overflow: hidden;
    border-radius: {{ block.settings.image_radius }}px;
  }

  .ai-two-step-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-two-step-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1 / 1;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.image_radius }}px;
  }

  .ai-two-step-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-two-step-content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.text_gap }}px;
  }

  .ai-two-step-number-{{ ai_gen_id }} {
    font-size: {{ block.settings.number_size }}px;
    font-weight: 700;
    color: {{ block.settings.number_color }};
    line-height: 1;
  }

  .ai-two-step-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
    margin: 0;
    line-height: 1.3;
  }

  .ai-two-step-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
  }

  @media screen and (max-width: 749px) {
    .ai-two-step-container-{{ ai_gen_id }} {
      flex-direction: column;
    }
  }
{% endstyle %}

<two-step-guide-{{ ai_gen_id }}
  class="ai-two-step-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-two-step-container-{{ ai_gen_id }}">
    <div class="ai-two-step-item-{{ ai_gen_id }}">
      <div class="ai-two-step-image-wrapper-{{ ai_gen_id }}">
        {% if block.settings.image_1 %}
          <img
            src="{{ block.settings.image_1 | image_url: width: 800 }}"
            alt="{{ block.settings.image_1.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.image_1.width }}"
            height="{{ block.settings.image_1.height }}"
            class="ai-two-step-image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-two-step-image-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>
      <div class="ai-two-step-content-{{ ai_gen_id }}">
        <div class="ai-two-step-number-{{ ai_gen_id }}">{{ block.settings.number_1 }}</div>
        {% if block.settings.title_1 != blank %}
          <h3 class="ai-two-step-title-{{ ai_gen_id }}">{{ block.settings.title_1 }}</h3>
        {% endif %}
        {% if block.settings.description_1 != blank %}
          <div class="ai-two-step-description-{{ ai_gen_id }}">{{ block.settings.description_1 }}</div>
        {% endif %}
      </div>
    </div>

    <div class="ai-two-step-item-{{ ai_gen_id }}">
      <div class="ai-two-step-image-wrapper-{{ ai_gen_id }}">
        {% if block.settings.image_2 %}
          <img
            src="{{ block.settings.image_2 | image_url: width: 800 }}"
            alt="{{ block.settings.image_2.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.image_2.width }}"
            height="{{ block.settings.image_2.height }}"
            class="ai-two-step-image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-two-step-image-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>
      <div class="ai-two-step-content-{{ ai_gen_id }}">
        <div class="ai-two-step-number-{{ ai_gen_id }}">{{ block.settings.number_2 }}</div>
        {% if block.settings.title_2 != blank %}
          <h3 class="ai-two-step-title-{{ ai_gen_id }}">{{ block.settings.title_2 }}</h3>
        {% endif %}
        {% if block.settings.description_2 != blank %}
          <div class="ai-two-step-description-{{ ai_gen_id }}">{{ block.settings.description_2 }}</div>
        {% endif %}
      </div>
    </div>
  </div>
</two-step-guide-{{ ai_gen_id }}>

<script>
  (function() {
    class TwoStepGuide{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('two-step-guide-{{ ai_gen_id }}', TwoStepGuide{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "2ステップガイド",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "ステップ1"
    },
    {
      "type": "image_picker",
      "id": "image_1",
      "label": "画像"
    },
    {
      "type": "text",
      "id": "number_1",
      "label": "番号",
      "default": "1"
    },
    {
      "type": "text",
      "id": "title_1",
      "label": "タイトル",
      "default": "最初のステップ"
    },
    {
      "type": "textarea",
      "id": "description_1",
      "label": "説明",
      "default": "ここに最初のステップの説明を入力してください。"
    },
    {
      "type": "header",
      "content": "ステップ2"
    },
    {
      "type": "image_picker",
      "id": "image_2",
      "label": "画像"
    },
    {
      "type": "text",
      "id": "number_2",
      "label": "番号",
      "default": "2"
    },
    {
      "type": "text",
      "id": "title_2",
      "label": "タイトル",
      "default": "2番目のステップ"
    },
    {
      "type": "textarea",
      "id": "description_2",
      "label": "説明",
      "default": "ここに2番目のステップの説明を入力してください。"
    },
    {
      "type": "header",
      "content": "レイアウト"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "デスクトップ幅",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "section_padding",
      "label": "セクション余白",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "gap",
      "label": "ステップ間の間隔",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "item_gap",
      "label": "画像とテキストの間隔",
      "min": 10,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "text_gap",
      "label": "テキスト要素の間隔",
      "min": 5,
      "max": 30,
      "step": 5,
      "unit": "px",
      "default": 10
    },
    {
      "type": "header",
      "content": "スタイル"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "背景色",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "テキスト色",
      "default": "#36384c"
    },
    {
      "type": "color",
      "id": "number_color",
      "label": "番号の色",
      "default": "#613a43"
    },
    {
      "type": "range",
      "id": "number_size",
      "label": "番号のサイズ",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 36
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "タイトルのサイズ",
      "min": 14,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "description_size",
      "label": "説明のサイズ",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "image_radius",
      "label": "画像の角丸",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "2ステップガイド"
    }
  ]
}
{% endschema %}