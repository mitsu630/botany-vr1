{% doc %}
  @prompt
    ワークショップ詳細
    [ ボタニーペインティングとは ]
    天然の葉をパネルに貼り、彩るアートです。
    自然の葉脈と、あなたの選ぶ色が重なり合います。
    配置と色付けだけなので、初めての方も安心！
    誰が作っても、プロのような本格的な仕上がりになります。
    [ こんな方におすすめ ]
    絵は苦手だけど、何か作ることに憧れがある方。
    忙しい日常を忘れて、無心でリフレッシュしたい方。
    自分で作ったおしゃれなインテリアを部屋に飾りたい方。
    新しい趣味や、没頭できる時間を探している方。
    [ 作った作品の楽しみ方 ]
    玄関やリビングを彩る、世界に一つのインテリアに。
    非常に軽い素材なので、画鋲ひとつで壁に飾れます。
    大切な方への、心のこもった手作りギフトとしても人気です。
    季節ごとに色を変えて、いくつか並べて飾るのも素敵です。
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-workshop-details-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-workshop-details__section-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.section_spacing }}px;
  }

  .ai-workshop-details__section-{{ ai_gen_id }}:last-child {
    margin-bottom: 0;
  }

  .ai-workshop-details__heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    text-align: {{ block.settings.text_alignment }};
    font-weight: 600;
  }

  .ai-workshop-details__text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    line-height: {{ block.settings.line_height }};
    margin: 0;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-workshop-details__text-{{ ai_gen_id }} p {
    margin: 0 0 {{ block.settings.paragraph_spacing }}px;
  }

  .ai-workshop-details__text-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  .ai-workshop-details__divider-{{ ai_gen_id }} {
    height: {{ block.settings.divider_thickness }}px;
    background-color: {{ block.settings.divider_color }};
    border: none;
    margin: {{ block.settings.divider_spacing }}px 0;
  }

  @media screen and (max-width: 749px) {
    .ai-workshop-details-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding | times: 0.7 }}px;
    }

    .ai-workshop-details__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.85 }}px;
    }

    .ai-workshop-details__text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-workshop-details-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.section_1_enabled %}
    <div class="ai-workshop-details__section-{{ ai_gen_id }}">
      {% if block.settings.section_1_heading != blank %}
        <h2 class="ai-workshop-details__heading-{{ ai_gen_id }}">
          {{ block.settings.section_1_heading }}
        </h2>
      {% endif %}
      {% if block.settings.section_1_text != blank %}
        <div class="ai-workshop-details__text-{{ ai_gen_id }}">
          {{ block.settings.section_1_text }}
        </div>
      {% endif %}
    </div>
    {% if block.settings.show_dividers and block.settings.section_2_enabled %}
      <hr class="ai-workshop-details__divider-{{ ai_gen_id }}">
    {% endif %}
  {% endif %}

  {% if block.settings.section_2_enabled %}
    <div class="ai-workshop-details__section-{{ ai_gen_id }}">
      {% if block.settings.section_2_heading != blank %}
        <h2 class="ai-workshop-details__heading-{{ ai_gen_id }}">
          {{ block.settings.section_2_heading }}
        </h2>
      {% endif %}
      {% if block.settings.section_2_text != blank %}
        <div class="ai-workshop-details__text-{{ ai_gen_id }}">
          {{ block.settings.section_2_text }}
        </div>
      {% endif %}
    </div>
    {% if block.settings.show_dividers and block.settings.section_3_enabled %}
      <hr class="ai-workshop-details__divider-{{ ai_gen_id }}">
    {% endif %}
  {% endif %}

  {% if block.settings.section_3_enabled %}
    <div class="ai-workshop-details__section-{{ ai_gen_id }}">
      {% if block.settings.section_3_heading != blank %}
        <h2 class="ai-workshop-details__heading-{{ ai_gen_id }}">
          {{ block.settings.section_3_heading }}
        </h2>
      {% endif %}
      {% if block.settings.section_3_text != blank %}
        <div class="ai-workshop-details__text-{{ ai_gen_id }}">
          {{ block.settings.section_3_text }}
        </div>
      {% endif %}
    </div>
    {% if block.settings.show_dividers and block.settings.section_4_enabled %}
      <hr class="ai-workshop-details__divider-{{ ai_gen_id }}">
    {% endif %}
  {% endif %}

  {% if block.settings.section_4_enabled %}
    <div class="ai-workshop-details__section-{{ ai_gen_id }}">
      {% if block.settings.section_4_heading != blank %}
        <h2 class="ai-workshop-details__heading-{{ ai_gen_id }}">
          {{ block.settings.section_4_heading }}
        </h2>
      {% endif %}
      {% if block.settings.section_4_text != blank %}
        <div class="ai-workshop-details__text-{{ ai_gen_id }}">
          {{ block.settings.section_4_text }}
        </div>
      {% endif %}
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "ワークショップ詳細",
