      "step": 1,
      "unit": "px",
      "default": 1
    },
    {
      "type": "range",
      "id": "divider_spacing",
      "label": "区切り線の余白",
      "min": 8,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "区切り線の色",
      "default": "#e3bab3"
    },
    {
      "type": "header",
      "content": "タイポグラフィ"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "見出しサイズ",
      "min": 14,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "heading_spacing",
      "label": "見出し下余白",
      "min": 4,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "本文サイズ",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 15
    },
    {
      "type": "range",
      "id": "line_height",
