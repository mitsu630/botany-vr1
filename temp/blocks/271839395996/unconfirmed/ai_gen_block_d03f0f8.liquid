      "content": "カラー"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "背景色",
      "default": "#e9dccd"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "見出し色",
      "default": "#36384c"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "本文色",
      "default": "#36384c"
    }
  ],
  "presets": [
    {
      "name": "ワークショップ詳細"
    }
  ]
}
{% endschema %}