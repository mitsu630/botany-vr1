{% doc %}
  @prompt
    写真付きの２ステップ。
    １、２って感じで
    写真は真ん中に, ①②いらない, ステップっていう言葉を消して、左に数字、右側に文章みたいな
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-two-step-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-two-step-container-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.step_gap }}px;
  }

  .ai-two-step-item-{{ ai_gen_id }} {
    display: flex;
    align-items: flex-start;
    gap: {{ block.settings.content_gap }}px;
  }

  .ai-two-step-number-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.number_size }}px;
    height: {{ block.settings.number_size }}px;
    border-radius: 50%;
    background-color: {{ block.settings.number_bg_color }};
    color: {{ block.settings.number_text_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: {{ block.settings.number_font_size }}px;
    font-weight: 600;
  }

  .ai-two-step-content-{{ ai_gen_id }} {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .ai-two-step-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_font_size }}px;
    color: {{ block.settings.description_color }};
    line-height: 1.6;
  }

  @media screen and (max-width: 749px) {
    .ai-two-step-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<two-step-guide-{{ ai_gen_id }} class="ai-two-step-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-two-step-container-{{ ai_gen_id }}">
    {% for i in (1..2) %}
      {% liquid
        assign description_key = 'step_' | append: i | append: '_description'
        assign step_description = block.settings[description_key]
      %}
      
      <div class="ai-two-step-item-{{ ai_gen_id }}">
        <div class="ai-two-step-number-{{ ai_gen_id }}">{{ i }}</div>
        
        <div class="ai-two-step-content-{{ ai_gen_id }}">
          {% if step_description != blank %}
            <div class="ai-two-step-description-{{ ai_gen_id }}">{{ step_description }}</div>
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </div>
</two-step-guide-{{ ai_gen_id }}>

<script>
  (function() {
    class TwoStepGuide{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('two-step-guide-{{ ai_gen_id }}', TwoStepGuide{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "2ステップガイド",
  "settings": [
    {
      "type": "header",
      "content": "1"
    },
    {
      "type": "richtext",
      "id": "step_1_description",
      "label": "説明",
      "default": "<p>最初の説明をここに入力してください。</p>"
    },
    {
      "type": "header",
      "content": "2"
    },
    {
      "type": "richtext",
      "id": "step_2_description",
      "label": "説明",
      "default": "<p>2番目の説明をここに入力してください。</p>"
    },
    {
      "type": "header",
      "content": "レイアウト"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "デスクトップ幅",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "section_padding",
      "label": "セクション余白",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "step_gap",
      "label": "項目間の間隔",
      "min": 20,
      "max": 100,
      "step": 10,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "content_gap",
      "label": "数字と文章の間隔",
      "min": 10,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "数字スタイル"
    },
    {
      "type": "range",
      "id": "number_size",
      "label": "数字サイズ",
      "min": 30,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 50
    },
    {
      "type": "range",
      "id": "number_font_size",
      "label": "数字フォントサイズ",
      "min": 16,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "color",
      "id": "number_bg_color",
      "label": "数字背景色",
      "default": "#613a43"
    },
    {
      "type": "color",
      "id": "number_text_color",
      "label": "数字テキスト色",
      "default": "#e9dccd"
    },
    {
      "type": "header",
      "content": "テキストスタイル"
    },
    {
      "type": "range",
      "id": "description_font_size",
      "label": "説明フォントサイズ",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "説明色",
      "default": "#36384c"
    }
  ],
  "presets": [
    {
      "name": "2ステップガイド"
    }
  ]
}
{% endschema %}
