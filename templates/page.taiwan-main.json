    "custom_liquid_NMzFDg": {
      "type": "custom-liquid",
      "disabled": true,
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<style>\n  .bp-info {\n    background: #f7f4ee;\n    padding: 56px 20px;\n    color: #2d2a25;\n    font-family: \"Noto Sans TC\", \"Hiragino Sans\", \"Helvetica Neue\", Arial, \"Microsoft JhengHei\", sans-serif;\n    -webkit-font-smoothing: antialiased;\n  }\n  .bp-info__inner { max-width: 980px; margin: 0 auto; }\n  .bp-info__head {\n    text-align: center;\n    border-top: 1px solid #2d2a25;\n    border-bottom: 1px solid #2d2a25;\n    padding: 16px 16px 18px;\n    margin-bottom: 40px;\n  }\n  .bp-info__title {\n    font-size: clamp(26px, 4vw, 34px);\n    font-weight: 800;\n    letter-spacing: .02em;\n    margin: 0 0 4px;\n    color: #2d2a25;\n    line-height: 1.2;\n    font-family: \"Helvetica Neue\", \"Hiragino Sans\", \"Noto Sans TC\", sans-serif;\n  }\n  .bp-info__subtitle {\n    font-size: 13px; color: #5e5b53; margin: 0; letter-spacing: .05em;\n  }\n  .bp-info__list {\n    list-style: none; margin: 0; padding: 0;\n    display: flex; flex-direction: column; gap: 32px;\n  }\n  .bp-info__item {\n    display: grid;\n    grid-template-columns: 260px 1fr;\n    align-items: flex-start;\n    gap: 32px;\n    padding: 4px 12px;\n  }\n  .bp-info__thumb {\n    width: 260px; height: 195px;\n    overflow: hidden; border-radius: 4px;\n    background: #ece6d8; display: block;\n  }\n  .bp-info__thumb img {\n    width: 100%; height: 100%; object-fit: cover; display: block;\n    transition: transform .4s ease;\n  }\n  .bp-info__item:hover .bp-info__thumb img { transform: scale(1.04); }\n  .bp-info__body { display: flex; flex-direction: column; gap: 12px; padding-top: 4px; }\n\n  /* タイトル（英文 + 中文 2段） */\n  .bp-info__item-title {\n    margin: 0;\n    line-height: 1.4;\n    color: #2d2a25;\n  }\n  .bp-info__title-en {\n    display: block;\n    font-size: 13px;\n    letter-spacing: .18em;\n    color: #8a8676;\n    font-weight: 500;\n    margin-bottom: 6px;\n    font-family: \"Helvetica Neue\", \"Hiragino Sans\", Arial, sans-serif;\n    text-transform: uppercase;\n  }\n  .bp-info__title-tc {\n    display: block;\n    font-size: 20px;\n    font-weight: 600;\n    letter-spacing: .04em;\n    color: #2d2a25;\n  }\n\n  /* 詳細文 */\n  .bp-info__desc {\n    font-size: 14.5px;\n    line-height: 1.85;\n    color: #5e5b53;\n    margin: 4px 0 0;\n    letter-spacing: .02em;\n  }\n\n  /* メタ情報（日付 + NEW を必ず横並び） */\n  .bp-info__meta {\n    display: flex;\n    align-items: center;\n    gap: 12px;\n    color: #5e5b53;\n    font-size: 14px;\n    letter-spacing: .04em;\n    flex-wrap: nowrap;\n    margin-top: 4px;\n  }\n  .bp-info__date {\n    font-weight: 500;\n    white-space: nowrap;\n  }\n  .bp-info__new {\n    display: inline-block;\n    background: #c98a7a;\n    color: #fff;\n    font-size: 11px; font-weight: 600;\n    letter-spacing: .12em;\n    padding: 3px 10px;\n    border-radius: 3px;\n    text-transform: uppercase;\n    white-space: nowrap;\n  }\n\n  /* スマホ */\n  @media (max-width: 720px) {\n    .bp-info { padding: 44px 16px; }\n    .bp-info__head { padding: 12px 12px 14px; margin-bottom: 28px; }\n    .bp-info__list { gap: 28px; }\n    .bp-info__item {\n      grid-template-columns: 1fr;\n      gap: 16px;\n      padding: 0;\n    }\n    .bp-info__thumb { width: 100%; height: 220px; }\n    .bp-info__body { gap: 10px; padding-top: 0; }\n    .bp-info__title-en { font-size: 11px; letter-spacing: .15em; }\n    .bp-info__title-tc { font-size: 17px; }\n    .bp-info__desc { font-size: 13.5px; line-height: 1.8; }\n    .bp-info__meta { font-size: 13px; gap: 10px; }\n    .bp-info__new { font-size: 10px; padding: 2px 8px; }\n  }\n</style>\n\n<section class=\"bp-info\" aria-label=\"最新消息\">\n  <div class=\"bp-info__inner\">\n    <header class=\"bp-info__head\">\n      <h2 class=\"bp-info__title\">Information</h2>\n      <p class=\"bp-info__subtitle\">最新消息</p>\n    </header>\n    <ul class=\"bp-info__list\">\n      <li class=\"bp-info__item\">\n        <a class=\"bp-info__thumb\" href=\"#\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0402/9110/6972/files/line_oa_chat_260401_150845.jpg?v=1777336496\" alt=\"Lotus Lake Botanica 荷池植物藝術展\">\n        </a>\n        <div class=\"bp-info__body\">\n          <h3 class=\"bp-info__item-title\">\n            <span class=\"bp-info__title-en\">Lotus Lake Botanica</span>\n            <span class=\"bp-info__title-tc\">荷池植物藝術展</span>\n          </h3>\n          <p class=\"bp-info__desc\">\n            於台中舉辦了由完成師資培訓課程並取得講師資格的13位講師所舉辦的作品展覽。當日除本會代表杉本親自出席外，亦榮幸邀請到台中市文化局副局長蒞臨參觀。\n          </p>\n          <div class=\"bp-info__meta\">\n            <span class=\"bp-info__date\">2026.03.27 – 03.29</span>\n            <span class=\"bp-info__new\">New</span>\n          </div>\n        </div>\n      </li>\n    </ul>\n  </div>\n</section>",
        "color_scheme": "scheme-1",
        "padding_top": 40,
        "padding_bottom": 52
      }
    },
