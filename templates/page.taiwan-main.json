        "custom_liquid": "<style>\n  .bp-info {\n    background: #f7f4ee;\n    padding: 56px 20px;\n    color: #2d2a25;\n    font-family: \"Noto Sans TC\", \"Hiragino Sans\", \"Helvetica Neue\", Arial, \"Microsoft JhengHei\", sans-serif;\n    -webkit-font-smoothing: antialiased;\n  }\n  .bp-info__inner { max-width: 980px; margin: 0 auto; }\n  .bp-info__head {\n    text-align: center;\n    border-top: 1px solid #2d2a25;\n    border-bottom: 1px solid #2d2a25;\n    padding: 16px 16px 18px;\n    margin-bottom: 40px;\n  }\n  .bp-info__title {\n    font-size: clamp(26px, 4vw, 34px);\n    font-weight: 800;\n    letter-spacing: .02em;\n    margin: 0 0 4px;\n    color: #2d2a25;\n    line-height: 1.2;\n    font-family: \"Helvetica Neue\", \"Hiragino Sans\", \"Noto Sans TC\", sans-serif;\n  }\n  .bp-info__subtitle {\n    font-size: 13px; color: #5e5b53; margin: 0; letter-spacing: .05em;\n  }\n  .bp-info__list {\n    list-style: none; margin: 0; padding: 0;\n    display: flex; flex-direction: column; gap: 32px;\n  }\n  .bp-info__item {\n    display: grid;\n    grid-template-columns: 260px 1fr;\n    align-items: flex-start;\n    gap: 32px;\n    padding: 4px 12px;\n  }\n\n  /* ===== メディア部（メイン画像 + サムネイル） ===== */\n  .bp-info__media {\n    width: 260px;\n    display: flex;\n    flex-direction: column;\n    gap: 8px;\n  }\n  .bp-info__thumb {\n    width: 260px; height: 195px;\n    overflow: hidden; border-radius: 4px;\n    background: #ece6d8; display: block;\n    position: relative;\n  }\n  .bp-info__main-img {\n    width: 100%; height: 100%; object-fit: cover; display: block;\n    transition: opacity .3s ease;\n  }\n\n  /* サムネイル一覧 */\n  .bp-info__minis {\n    display: flex;\n    gap: 6px;\n    margin-top: 2px;\n  }\n  .bp-info__thumb-mini {\n    flex: 1 1 0;\n    min-width: 0;\n    aspect-ratio: 1 / 1;\n    padding: 0;\n    border: 1.5px solid transparent;\n    border-radius: 3px;\n    background: #ece6d8;\n    cursor: pointer;\n    overflow: hidden;\n    transition: border-color .2s ease, opacity .2s ease;\n    opacity: .65;\n  }\n  .bp-info__thumb-mini img {\n    width: 100%; height: 100%;\n    object-fit: cover; display: block;\n  }\n  .bp-info__thumb-mini:hover { opacity: 1; }\n  .bp-info__thumb-mini.is-active {\n    border-color: #b08d5a;\n    opacity: 1;\n  }\n\n  .bp-info__body { display: flex; flex-direction: column; gap: 12px; padding-top: 4px; }\n\n  /* タイトル（英文 + 中文 2段） */\n  .bp-info__item-title { margin: 0; line-height: 1.4; color: #2d2a25; }\n  .bp-info__title-en {\n    display: block;\n    font-size: 13px;\n    letter-spacing: .18em;\n    color: #8a8676;\n    font-weight: 500;\n    margin-bottom: 6px;\n    font-family: \"Helvetica Neue\", \"Hiragino Sans\", Arial, sans-serif;\n    text-transform: uppercase;\n  }\n  .bp-info__title-tc {\n    display: block;\n    font-size: 20px;\n    font-weight: 600;\n    letter-spacing: .04em;\n    color: #2d2a25;\n  }\n  .bp-info__desc {\n    font-size: 14.5px;\n    line-height: 1.85;\n    color: #5e5b53;\n    margin: 4px 0 0;\n    letter-spacing: .02em;\n  }\n  .bp-info__meta {\n    display: flex;\n    align-items: center;\n    gap: 12px;\n    color: #5e5b53;\n    font-size: 14px;\n    letter-spacing: .04em;\n    flex-wrap: nowrap;\n    margin-top: 4px;\n  }\n  .bp-info__date { font-weight: 500; white-space: nowrap; }\n  .bp-info__new {\n    display: inline-block;\n    background: #c98a7a;\n    color: #fff;\n    font-size: 11px; font-weight: 600;\n    letter-spacing: .12em;\n    padding: 3px 10px;\n    border-radius: 3px;\n    text-transform: uppercase;\n    white-space: nowrap;\n  }\n\n  /* スマホ */\n  @media (max-width: 720px) {\n    .bp-info { padding: 44px 16px; }\n    .bp-info__head { padding: 12px 12px 14px; margin-bottom: 28px; }\n    .bp-info__list { gap: 28px; }\n    .bp-info__item {\n      grid-template-columns: 1fr;\n      gap: 16px;\n      padding: 0;\n    }\n    .bp-info__media { width: 100%; gap: 6px; }\n    .bp-info__thumb { width: 100%; height: 220px; }\n    .bp-info__body { gap: 10px; padding-top: 0; }\n    .bp-info__title-en { font-size: 11px; letter-spacing: .15em; }\n    .bp-info__title-tc { font-size: 17px; }\n    .bp-info__desc { font-size: 13.5px; line-height: 1.8; }\n    .bp-info__meta { font-size: 13px; gap: 10px; }\n    .bp-info__new { font-size: 10px; padding: 2px 8px; }\n    .bp-info__minis { gap: 5px; }\n  }\n</style>\n\n<section class=\"bp-info\" aria-label=\"最新消息\">\n  <div class=\"bp-info__inner\">\n    <header class=\"bp-info__head\">\n      <h2 class=\"bp-info__title\">Information</h2>\n      <p class=\"bp-info__subtitle\">最新消息</p>\n    </header>\n    <ul class=\"bp-info__list\">\n      <li class=\"bp-info__item\">\n\n        <!-- ▼ 画像エリア（メイン + サムネイル5枚） -->\n        <div class=\"bp-info__media\">\n          <div class=\"bp-info__thumb\">\n            <img class=\"bp-info__main-img\"\n                 src=\"https://cdn.shopify.com/s/files/1/0402/9110/6972/files/line_oa_chat_260401_150845_1.jpg?v=1777343375\"\n                 alt=\"Lotus Lake Botanica 荷池植物藝術展\">\n          </div>\n          <div class=\"bp-info__minis\">\n            <button type=\"button\" class=\"bp-info__thumb-mini\"\n                    data-full=\"https://cdn.shopify.com/s/files/1/0402/9110/6972/files/line_oa_chat_260401_150905.jpg?v=1777343483\"\n                    aria-label=\"照片 1\">\n              <img src=\"https://cdn.shopify.com/s/files/1/0402/9110/6972/files/line_oa_chat_260401_150905.jpg?v=1777343483\" alt=\"\">\n            </button>\n            <button type=\"button\" class=\"bp-info__thumb-mini is-active\"\n                    data-full=\"https://cdn.shopify.com/s/files/1/0402/9110/6972/files/line_oa_chat_260401_150845_1.jpg?v=1777343375\"\n                    aria-label=\"照片 2\">\n              <img src=\"https://cdn.shopify.com/s/files/1/0402/9110/6972/files/line_oa_chat_260401_150845_1.jpg?v=1777343375\" alt=\"\">\n            </button>\n            <button type=\"button\" class=\"bp-info__thumb-mini\"\n                    data-full=\"https://cdn.shopify.com/s/files/1/0402/9110/6972/files/line_oa_chat_260401_150724.jpg?v=1777343375\"\n                    aria-label=\"照片 3\">\n              <img src=\"https://cdn.shopify.com/s/files/1/0402/9110/6972/files/line_oa_chat_260401_150724.jpg?v=1777343375\" alt=\"\">\n            </button>\n            <button type=\"button\" class=\"bp-info__thumb-mini\"\n                    data-full=\"https://cdn.shopify.com/s/files/1/0402/9110/6972/files/2_4x-100_0af2a312-529c-4da6-aa93-637e39e8c656.jpg?v=1777343374\"\n                    aria-label=\"照片 4\">\n              <img src=\"https://cdn.shopify.com/s/files/1/0402/9110/6972/files/2_4x-100_0af2a312-529c-4da6-aa93-637e39e8c656.jpg?v=1777343374\" alt=\"\">\n            </button>\n          </div>\n        </div>\n\n        <div class=\"bp-info__body\">\n          <h3 class=\"bp-info__item-title\">\n            <span class=\"bp-info__title-en\">Lotus Lake Botanica</span>\n            <span class=\"bp-info__title-tc\">荷池植物藝術展</span>\n          </h3>\n          <p class=\"bp-info__desc\">\n            於台中舉辦了由完成師資培訓課程並取得講師資格的13位講師所舉辦的作品展覽。當日除本會代表杉本親自出席外，亦榮幸邀請到台中市文化局副局長蒞臨參觀。\n          </p>\n          <div class=\"bp-info__meta\">\n            <span class=\"bp-info__date\">2026.03.27 – 03.29</span>\n            <span class=\"bp-info__new\">New</span>\n          </div>\n        </div>\n      </li>\n    </ul>\n  </div>\n</section>\n\n<script>\n  (function() {\n    var items = document.querySelectorAll('.bp-info__item');\n    items.forEach(function(item) {\n      var mainImg = item.querySelector('.bp-info__main-img');\n      var minis = item.querySelectorAll('.bp-info__thumb-mini');\n      if (!mainImg || !minis.length) return;\n      minis.forEach(function(mini) {\n        mini.addEventListener('click', function(e) {\n          e.preventDefault();\n          var url = mini.getAttribute('data-full');\n          if (!url) return;\n          // フェードして差し替え\n          mainImg.style.opacity = '0';\n          var pre = new Image();\n          pre.onload = function() {\n            mainImg.src = url;\n            mainImg.style.opacity = '1';\n          };\n          pre.src = url;\n          // アクティブ切替\n          minis.forEach(function(m) { m.classList.remove('is-active'); });\n          mini.classList.add('is-active');\n        });\n      });\n    });\n  })();\n</script>",
