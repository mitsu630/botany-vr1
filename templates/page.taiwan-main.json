      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<style>\n  .bp-compare {\n    background: #fbf9f4;\n    padding: 88px 20px;\n    color: #2d2a25;\n    font-family: \"Noto Sans TC\", \"Hiragino Sans\", \"Helvetica Neue\", Arial, \"Microsoft JhengHei\", sans-serif;\n    -webkit-font-smoothing: antialiased;\n  }\n  .bp-compare__inner {\n    max-width: 880px;\n    margin: 0 auto;\n  }\n\n  /* ===== テーブル ===== */\n  .bp-compare__table {\n    width: 100%;\n    border-collapse: collapse;\n    table-layout: fixed;\n  }\n  .bp-compare__table th,\n  .bp-compare__table td {\n    padding: 28px 18px;\n    text-align: center;\n    font-size: 16px;\n    line-height: 1.7;\n    border-bottom: 1px solid #ebe4d3;\n    vertical-align: middle;\n    color: #2d2a25;\n  }\n\n  /* 1列目（項目名）— 小さめ・トラッキング広めで上品に */\n  .bp-compare__table th:first-child,\n  .bp-compare__table td:first-child {\n    text-align: left;\n    color: #8a8270;\n    font-weight: 500;\n    font-size: 13px;\n    letter-spacing: .25em;\n    width: 24%;\n    padding-left: 4px;\n  }\n\n  /* ===== ヘッダー ===== */\n  .bp-compare__table thead th {\n    font-family: \"Noto Serif TC\", \"Source Han Serif TC\", \"Yu Mincho\", \"Hiragino Mincho ProN\", serif;\n    font-size: 19px;\n    font-weight: 500;\n    letter-spacing: .18em;\n    padding: 30px 18px 34px;\n    border-bottom: 1px solid #2d2a25;\n    position: relative;\n  }\n  .bp-compare__table thead th:first-child {\n    border-bottom: 1px solid transparent;\n  }\n\n  /* 推奨カラム — クリームのハイライト */\n  .bp-compare__table .is-pick {\n    background: #f5ede0;\n  }\n\n  /* 推奨カラム上部の細いゴールドライン */\n  .bp-compare__table thead th.is-pick::before {\n    content: \"\";\n    position: absolute;\n    top: 0;\n    left: 14%;\n    right: 14%;\n    height: 1.5px;\n    background: #b08d5a;\n  }\n\n  /* 推奨カラム下部のゴールドライン */\n  .bp-compare__table tbody tr:last-child td.is-pick {\n    border-bottom: 1.5px solid #b08d5a;\n  }\n  .bp-compare__table tbody tr:last-child td:not(.is-pick):not(:first-child) {\n    border-bottom: 1px solid #2d2a25;\n  }\n  .bp-compare__table tbody tr:last-child td:first-child {\n    border-bottom: 1px solid transparent;\n  }\n\n  /* ===== チェック・ダッシュ ===== */\n  .bp-compare__check {\n    display: inline-flex;\n    align-items: center;\n    justify-content: center;\n    width: 28px;\n    height: 28px;\n    border: 1px solid #c8c1ad;\n    border-radius: 50%;\n    font-size: 13px;\n    color: #6b6760;\n    font-weight: 500;\n  }\n  .is-pick .bp-compare__check {\n    border-color: #b08d5a;\n    color: #b08d5a;\n  }\n  .bp-compare__dash {\n    color: #c4bda9;\n    font-size: 20px;\n    letter-spacing: 0;\n  }\n\n  /* ===== 価格 ===== */\n  .bp-compare__price {\n    font-family: \"Helvetica Neue\", \"Hiragino Sans\", sans-serif;\n    font-size: 17px;\n    letter-spacing: .04em;\n    font-weight: 500;\n  }\n  .is-pick .bp-compare__price {\n    font-size: 19px;\n    font-weight: 600;\n    color: #2d2a25;\n  }\n  .bp-compare__price-unit {\n    font-size: 12px;\n    color: #8a8270;\n    letter-spacing: .15em;\n    margin-right: 4px;\n    font-weight: 400;\n  }\n\n  /* ===== スマホ ===== */\n  @media (max-width: 720px) {\n    .bp-compare { padding: 60px 14px; }\n    .bp-compare__table th,\n    .bp-compare__table td {\n      padding: 20px 6px;\n      font-size: 14px;\n    }\n    .bp-compare__table th:first-child,\n    .bp-compare__table td:first-child {\n      width: 28%;\n      font-size: 11px;\n      letter-spacing: .15em;\n      padding-left: 2px;\n    }\n    .bp-compare__table thead th {\n      font-size: 15px;\n      padding: 20px 6px 24px;\n      letter-spacing: .12em;\n    }\n    .bp-compare__table thead th.is-pick::before {\n      left: 8%;\n      right: 8%;\n    }\n    .bp-compare__check {\n      width: 24px;\n      height: 24px;\n      font-size: 11px;\n    }\n    .bp-compare__dash { font-size: 17px; }\n    .bp-compare__price { font-size: 14.5px; }\n    .is-pick .bp-compare__price { font-size: 15.5px; }\n    .bp-compare__price-unit { font-size: 10.5px; }\n  }\n</style>\n\n<section class=\"bp-compare\" aria-label=\"課程比較\">\n  <div class=\"bp-compare__inner\">\n    <table class=\"bp-compare__table\">\n      <thead>\n        <tr>\n          <th></th>\n          <th class=\"is-pick\">師資取得課程</th>\n          <th>體驗工作坊</th>\n        </tr>\n      </thead>\n      <tbody>\n        <tr>\n          <td>時間</td>\n          <td class=\"is-pick\">2 天</td>\n          <td>約 3 小時</td>\n        </tr>\n        <tr>\n          <td>費用</td>\n          <td class=\"is-pick\"><span class=\"bp-compare__price\"><span class=\"bp-compare__price-unit\">NT$</span>28,000</span></td>\n          <td><span class=\"bp-compare__price\"><span class=\"bp-compare__price-unit\">NT$</span>4,180〜</span></td>\n        </tr>\n        <tr>\n          <td>含畫材</td>\n          <td class=\"is-pick\"><span class=\"bp-compare__check\">✓</span></td>\n          <td><span class=\"bp-compare__check\">✓</span></td>\n        </tr>\n        <tr>\n          <td>認證證書</td>\n          <td class=\"is-pick\"><span class=\"bp-compare__check\">✓</span></td>\n          <td><span class=\"bp-compare__dash\">—</span></td>\n        </tr>\n        <tr>\n          <td>可開課販售作品</td>\n          <td class=\"is-pick\"><span class=\"bp-compare__check\">✓</span></td>\n          <td><span class=\"bp-compare__dash\">—</span></td>\n        </tr>\n      </tbody>\n    </table>\n  </div>\n</section>",
        "color_scheme": "scheme-1",
        "padding_top": 40,
        "padding_bottom": 52
      }
    },
    "custom_liquid_iXxthy": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<style>\n  .bp-cta-mini {\n    background: #fbf9f4;\n    padding: 36px 20px;\n    color: #2d2a25;\n    font-family: \"Noto Sans TC\", \"Hiragino Sans\", \"Helvetica Neue\", Arial, \"Microsoft JhengHei\", sans-serif;\n    -webkit-font-smoothing: antialiased;\n  }\n  .bp-cta-mini__inner {\n    max-width: 880px;\n    margin: 0 auto;\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 14px;\n  }\n\n  /* ===== ボタン ===== */\n  .bp-cta-mini__btn {\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    gap: 16px;\n    padding: 18px 24px;\n    background: #ffffff;\n    border: 1px solid #d8d2c2;\n    text-decoration: none;\n    color: #2d2a25;\n    transition: transform .3s ease, box-shadow .3s ease, border-color .3s ease, background .3s ease;\n  }\n  .bp-cta-mini__btn:hover {\n    transform: translateY(-2px);\n    box-shadow: 0 10px 24px rgba(80, 70, 50, .08);\n    border-color: #b08d5a;\n  }\n\n  /* 推奨ボタン */\n  .bp-cta-mini__btn--pick {\n    background: linear-gradient(180deg, #f5ede0 0%, #faf3e3 100%);\n    border-color: #c4a87a;\n  }\n  .bp-cta-mini__btn--pick:hover {\n    background: linear-gradient(180deg, #f0e5d0 0%, #f5ecd9 100%);\n    border-color: #a8865c;\n  }\n\n  /* 左側ラベル */\n  .bp-cta-mini__label {\n    display: flex;\n    flex-direction: column;\n    align-items: flex-start;\n    gap: 4px;\n    min-width: 0;\n  }\n  .bp-cta-mini__sub {\n    font-size: 10px;\n    letter-spacing: .35em;\n    color: #9c7a52;\n    text-transform: uppercase;\n    font-weight: 500;\n    font-family: \"Helvetica Neue\", \"Hiragino Sans\", sans-serif;\n  }\n  .bp-cta-mini__title {\n    font-family: \"Noto Serif TC\", \"Source Han Serif TC\", \"Yu Mincho\", \"Hiragino Mincho ProN\", serif;\n    font-size: 16.5px;\n    font-weight: 500;\n    letter-spacing: .15em;\n    color: #2d2a25;\n    line-height: 1.3;\n    white-space: nowrap;\n  }\n\n  /* 右側アクション */\n  .bp-cta-mini__action {\n    display: inline-flex;\n    align-items: center;\n    gap: 10px;\n    font-size: 12px;\n    letter-spacing: .25em;\n    color: #6b6760;\n    flex-shrink: 0;\n    font-weight: 500;\n    transition: color .3s ease, gap .3s ease;\n  }\n  .bp-cta-mini__btn--pick .bp-cta-mini__action { color: #8a6c3d; }\n  .bp-cta-mini__btn:hover .bp-cta-mini__action { color: #2d2a25; gap: 14px; }\n  .bp-cta-mini__btn--pick:hover .bp-cta-mini__action { color: #6b5025; }\n\n  /* 矢印 */\n  .bp-cta-mini__arrow {\n    position: relative;\n    display: inline-block;\n    width: 14px;\n    height: 1px;\n    background: currentColor;\n    transition: width .3s ease;\n  }\n  .bp-cta-mini__arrow::after {\n    content: \"\";\n    position: absolute;\n    right: 0;\n    top: 50%;\n    width: 5px;\n    height: 5px;\n    border-top: 1px solid currentColor;\n    border-right: 1px solid currentColor;\n    transform: translateY(-50%) rotate(45deg);\n  }\n  .bp-cta-mini__btn:hover .bp-cta-mini__arrow { width: 20px; }\n\n  /* スマホ */\n  @media (max-width: 720px) {\n    .bp-cta-mini { padding: 28px 16px; }\n    .bp-cta-mini__inner { grid-template-columns: 1fr; gap: 10px; }\n    .bp-cta-mini__btn { padding: 16px 20px; }\n    .bp-cta-mini__title { font-size: 15px; letter-spacing: .1em; }\n    .bp-cta-mini__sub { font-size: 9px; letter-spacing: .3em; }\n    .bp-cta-mini__action { font-size: 11px; letter-spacing: .2em; }\n  }\n</style>\n\n<section class=\"bp-cta-mini\" aria-label=\"課程報名\">\n  <div class=\"bp-cta-mini__inner\">\n\n    <!-- 師資取得課程（推奨） -->\n    <a class=\"bp-cta-mini__btn bp-cta-mini__btn--pick\" href=\"https://botanypainting.com/products/taiwan-special\">\n      <span class=\"bp-cta-mini__label\">\n        <span class=\"bp-cta-mini__sub\">Instructor License</span>\n        <span class=\"bp-cta-mini__title\">師資取得課程</span>\n      </span>\n      <span class=\"bp-cta-mini__action\">\n        立即報名\n        <span class=\"bp-cta-mini__arrow\"></span>\n      </span>\n    </a>\n\n    <!-- 單日體驗課程 -->\n    <a class=\"bp-cta-mini__btn\" href=\"https://botanypainting.com/products/taiwan-workshop-1\">\n      <span class=\"bp-cta-mini__label\">\n        <span class=\"bp-cta-mini__sub\">One-Day Workshop</span>\n        <span class=\"bp-cta-mini__title\">單日體驗課程</span>\n      </span>\n      <span class=\"bp-cta-mini__action\">\n        立即報名\n        <span class=\"bp-cta-mini__arrow\"></span>\n      </span>\n    </a>\n\n  </div>\n</section>",
        "color_scheme": "scheme-1",
        "padding_top": 40,
        "padding_bottom": 52
      }
    },
    "custom_liquid_pwfgAW": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<style>\n  .bp-faq {\n    background: #fbf9f4;\n    padding: 88px 20px;\n    color: #2d2a25;\n    font-family: \"Noto Sans TC\", \"Hiragino Sans\", \"Helvetica Neue\", Arial, \"Microsoft JhengHei\", sans-serif;\n    -webkit-font-smoothing: antialiased;\n  }\n  .bp-faq__inner {\n    max-width: 880px;\n    margin: 0 auto;\n  }\n\n  /* ===== ヘッダー ===== */\n  .bp-faq__head {\n    text-align: center;\n    margin-bottom: 56px;\n  }\n  .bp-faq__eyebrow {\n    display: inline-block;\n    letter-spacing: .45em;\n    font-size: 11px;\n    color: #9c7a52;\n    margin-bottom: 16px;\n    text-transform: uppercase;\n    font-weight: 500;\n    font-family: \"Helvetica Neue\", \"Hiragino Sans\", sans-serif;\n  }\n  .bp-faq__title {\n    font-family: \"Noto Serif TC\", \"Source Han Serif TC\", \"Yu Mincho\", \"Hiragino Mincho ProN\", \"MS Mincho\", serif;\n    font-size: clamp(26px, 3.4vw, 34px);\n    font-weight: 400;\n    letter-spacing: .35em;\n    margin: 0;\n    color: #2d2a25;\n    padding-left: .35em;\n  }\n  .bp-faq__rule {\n    display: block;\n    width: 36px;\n    height: 1px;\n    background: #a8957a;\n    margin: 22px auto 0;\n    border: none;\n  }\n\n  /* ===== リスト ===== */\n  .bp-faq__list {\n    border-top: 1px solid #d8d2c2;\n  }\n  .bp-faq__item {\n    border-bottom: 1px solid #d8d2c2;\n  }\n\n  /* 質問ボタン */\n  .bp-faq__q {\n    width: 100%;\n    display: flex;\n    align-items: flex-start;\n    gap: 18px;\n    padding: 26px 4px;\n    background: transparent;\n    border: none;\n    cursor: pointer;\n    text-align: left;\n    color: #2d2a25;\n    font: inherit;\n    transition: color .2s ease;\n  }\n  .bp-faq__q:hover { color: #6b5a3d; }\n\n  .bp-faq__q-mark {\n    font-family: \"Noto Serif TC\", \"Yu Mincho\", \"Hiragino Mincho ProN\", serif;\n    font-size: 19px;\n    color: #b08d5a;\n    letter-spacing: .04em;\n    flex-shrink: 0;\n    line-height: 1.5;\n  }\n  .bp-faq__q-text {\n    flex: 1;\n    font-size: 16px;\n    line-height: 1.6;\n    font-weight: 500;\n    letter-spacing: .03em;\n    padding-right: 8px;\n    padding-top: 1px;\n  }\n\n  /* 開閉アイコン（＋／−） */\n  .bp-faq__icon {\n    position: relative;\n    flex-shrink: 0;\n    width: 18px;\n    height: 18px;\n    margin-top: 4px;\n  }\n  .bp-faq__icon::before,\n  .bp-faq__icon::after {\n    content: \"\";\n    position: absolute;\n    background: #8a8270;\n    transition: transform .3s ease, opacity .3s ease;\n  }\n  .bp-faq__icon::before {\n    top: 50%; left: 0;\n    width: 100%; height: 1px;\n    transform: translateY(-50%);\n  }\n  .bp-faq__icon::after {\n    top: 0; left: 50%;\n    width: 1px; height: 100%;\n    transform: translateX(-50%);\n  }\n  .bp-faq__item.is-open .bp-faq__icon::after {\n    transform: translateX(-50%) scaleY(0);\n    opacity: 0;\n  }\n\n  /* 回答パネル（grid-template-rowsで滑らかに展開） */\n  .bp-faq__a {\n    display: grid;\n    grid-template-rows: 0fr;\n    transition: grid-template-rows .4s ease;\n  }\n  .bp-faq__a-inner {\n    overflow: hidden;\n  }\n  .bp-faq__a-content {\n    display: flex;\n    align-items: flex-start;\n    gap: 18px;\n    padding: 0 4px 28px;\n  }\n  .bp-faq__a-mark {\n    font-family: \"Noto Serif TC\", \"Yu Mincho\", \"Hiragino Mincho ProN\", serif;\n    font-size: 19px;\n    color: #8a8270;\n    flex-shrink: 0;\n    line-height: 1.7;\n  }\n  .bp-faq__a-text {\n    flex: 1;\n    font-size: 14.5px;\n    line-height: 2;\n    color: #5e5b53;\n    margin: 0;\n    letter-spacing: .04em;\n  }\n\n  /* 開いた状態 */\n  .bp-faq__item.is-open .bp-faq__a {\n    grid-template-rows: 1fr;\n  }\n\n  /* スマホ */\n  @media (max-width: 720px) {\n    .bp-faq { padding: 60px 16px; }\n    .bp-faq__head { margin-bottom: 36px; }\n    .bp-faq__title { letter-spacing: .2em; padding-left: .2em; }\n    .bp-faq__q { padding: 20px 2px; gap: 12px; }\n    .bp-faq__q-mark { font-size: 16px; }\n    .bp-faq__q-text { font-size: 14px; line-height: 1.65; padding-right: 4px; }\n    .bp-faq__icon { width: 14px; height: 14px; margin-top: 3px; }\n    .bp-faq__a-content { gap: 12px; padding: 0 2px 24px; }\n    .bp-faq__a-mark { font-size: 16px; }\n    .bp-faq__a-text { font-size: 13.5px; line-height: 1.9; letter-spacing: .02em; }\n  }\n</style>\n\n<section class=\"bp-faq\" aria-label=\"常見問題\">\n  <div class=\"bp-faq__inner\">\n\n    <div class=\"bp-faq__list\">\n\n      <!-- Q1 -->\n      <div class=\"bp-faq__item is-open\">\n        <button type=\"button\" class=\"bp-faq__q\" aria-expanded=\"true\">\n          <span class=\"bp-faq__q-mark\">Q.</span>\n          <span class=\"bp-faq__q-text\">我沒有美感，對繪畫也沒自信，也可以參加課程嗎？</span>\n          <span class=\"bp-faq__icon\" aria-hidden=\"true\"></span>\n        </button>\n        <div class=\"bp-faq__a\">\n          <div class=\"bp-faq__a-inner\">\n            <div class=\"bp-faq__a-content\">\n              <span class=\"bp-faq__a-mark\">A.</span>\n              <p class=\"bp-faq__a-text\">多數參加者都是繪畫初學者。植物彩繪的特點是葉脈自然突顯了色彩的美感，只要學習基本技術並反覆練習，就能逐漸提升技能。90% 的講師都是從初學者開始的，您可以安心參加課程。</p>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      <!-- Q2 -->\n      <div class=\"bp-faq__item\">\n        <button type=\"button\" class=\"bp-faq__q\" aria-expanded=\"false\">\n          <span class=\"bp-faq__q-mark\">Q.</span>\n          <span class=\"bp-faq__q-text\">如果未通過考試會怎麼處理？另外，有多少人未通過考試？</span>\n          <span class=\"bp-faq__icon\" aria-hidden=\"true\"></span>\n        </button>\n        <div class=\"bp-faq__a\">\n          <div class=\"bp-faq__a-inner\">\n            <div class=\"bp-faq__a-content\">\n              <span class=\"bp-faq__a-mark\">A.</span>\n              <p class=\"bp-faq__a-text\">技術測驗主要提供一個場地讓大家確認、詢問不清楚的地方，最重要的目的是解決有關植物彩繪的所有疑惑。在測驗中發現不明白的地方，請大膽詢問並確認。目前在台灣舉行的測驗中，所有參加者皆順利通過。</p>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      <!-- Q3 -->\n      <div class=\"bp-faq__item\">\n        <button type=\"button\" class=\"bp-faq__q\" aria-expanded=\"false\">\n          <span class=\"bp-faq__q-mark\">Q.</span>\n          <span class=\"bp-faq__q-text\">通過考試後，畫材要如何購買？</span>\n          <span class=\"bp-faq__icon\" aria-hidden=\"true\"></span>\n        </button>\n        <div class=\"bp-faq__a\">\n          <div class=\"bp-faq__a-inner\">\n            <div class=\"bp-faq__a-content\">\n              <span class=\"bp-faq__a-mark\">A.</span>\n              <p class=\"bp-faq__a-text\">總部有提供講師專用的畫材購買網站。除了蓮葉等天然植物之外，還備有畫筆、定著劑、顏料等各類畫材供您選購。不過，天然植物以外的畫材（如顏料、工具等）也可在台灣的畫材店購買，因此您不必完全依賴總部供應，請放心選擇最適合您的方式。</p>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      <!-- Q4 -->\n      <div class=\"bp-faq__item\">\n        <button type=\"button\" class=\"bp-faq__q\" aria-expanded=\"false\">\n          <span class=\"bp-faq__q-mark\">Q.</span>\n          <span class=\"bp-faq__q-text\">如果講座當天因故無法參加該怎麼辦？</span>\n          <span class=\"bp-faq__icon\" aria-hidden=\"true\"></span>\n        </button>\n        <div class=\"bp-faq__a\">\n          <div class=\"bp-faq__a-inner\">\n            <div class=\"bp-faq__a-content\">\n              <span class=\"bp-faq__a-mark\">A.</span>\n              <p class=\"bp-faq__a-text\">如果您臨時無法參加講座當天的課程，請提前與我們的營運事務局聯繫。我們將與您個別討論改期或其他應對方式。</p>\n            </div>\n          </div>\n        </div>\n      </div>\n\n    </div>\n  </div>\n</section>\n\n<script>\n  (function() {\n    var btns = document.querySelectorAll('.bp-faq__q');\n    btns.forEach(function(btn) {\n      btn.addEventListener('click', function() {\n        var item = btn.closest('.bp-faq__item');\n        var isOpen = item.classList.toggle('is-open');\n        btn.setAttribute('aria-expanded', isOpen ? 'true' : 'false');\n      });\n    });\n  })();\n</script>",
        "color_scheme": "",
        "padding_top": 40,
        "padding_bottom": 52
      }
    },
