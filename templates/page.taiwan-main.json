    "custom_liquid_YNKmfD": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<style>\n  .bp-video {\n    background: #fbf9f4;\n    padding: 60px 20px;\n    color: #2d2a25;\n    font-family: \"Noto Sans TC\", \"Hiragino Sans\", \"Helvetica Neue\", Arial, \"Microsoft JhengHei\", sans-serif;\n    -webkit-font-smoothing: antialiased;\n  }\n  .bp-video__inner {\n    max-width: 400px;\n    margin: 0 auto;\n  }\n\n  /* ===== サムネイル（トリガー） ===== */\n  .bp-video__trigger {\n    position: relative;\n    display: block;\n    width: 100%;\n    aspect-ratio: 3 / 4;\n    overflow: hidden;\n    border-radius: 4px;\n    cursor: pointer;\n    background: #ece6d8;\n    border: none;\n    padding: 0;\n    transition: transform .35s ease, box-shadow .35s ease;\n  }\n  .bp-video__trigger:hover {\n    transform: translateY(-3px);\n    box-shadow: 0 16px 40px rgba(80, 70, 50, .15);\n  }\n  .bp-video__thumb {\n    width: 100%;\n    height: 100%;\n    object-fit: cover;\n    display: block;\n    transition: transform .6s ease, filter .35s ease;\n  }\n  .bp-video__trigger:hover .bp-video__thumb {\n    transform: scale(1.04);\n    filter: brightness(0.92);\n  }\n\n  /* オーバーレイ＆プレイボタン */\n  .bp-video__overlay {\n    position: absolute;\n    inset: 0;\n    background: linear-gradient(180deg, rgba(0,0,0,0) 60%, rgba(0,0,0,.18) 100%);\n    pointer-events: none;\n  }\n  .bp-video__play {\n    position: absolute;\n    top: 50%; left: 50%;\n    transform: translate(-50%, -50%);\n    width: 76px; height: 76px;\n    background: rgba(255, 255, 255, .85);\n    border-radius: 50%;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    transition: transform .3s ease, background .3s ease;\n    backdrop-filter: blur(4px);\n    -webkit-backdrop-filter: blur(4px);\n    box-shadow: 0 6px 20px rgba(0, 0, 0, .12);\n  }\n  .bp-video__play::after {\n    content: \"\";\n    width: 0;\n    height: 0;\n    border-style: solid;\n    border-width: 12px 0 12px 20px;\n    border-color: transparent transparent transparent #2d2a25;\n    margin-left: 5px;\n  }\n  .bp-video__trigger:hover .bp-video__play {\n    transform: translate(-50%, -50%) scale(1.08);\n    background: #fff;\n  }\n\n  /* ラベル */\n  .bp-video__label {\n    position: absolute;\n    bottom: 18px;\n    left: 20px;\n    color: #fff;\n    font-size: 11px;\n    letter-spacing: .35em;\n    text-transform: uppercase;\n    font-weight: 500;\n    text-shadow: 0 1px 4px rgba(0, 0, 0, .4);\n    font-family: \"Helvetica Neue\", \"Hiragino Sans\", sans-serif;\n  }\n\n  /* ===== モーダル ===== */\n  .bp-video__modal {\n    position: fixed;\n    inset: 0;\n    background: rgba(20, 18, 14, 0.94);\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    z-index: 9999;\n    opacity: 0;\n    pointer-events: none;\n    transition: opacity .35s ease;\n    backdrop-filter: blur(6px);\n    -webkit-backdrop-filter: blur(6px);\n    padding: 24px;\n  }\n  .bp-video__modal.is-active {\n    opacity: 1;\n    pointer-events: auto;\n  }\n  .bp-video__modal-inner {\n    position: relative;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    background: transparent;\n    transform: scale(0.94);\n    transition: transform .35s ease;\n    max-width: 100%;\n    max-height: 100%;\n  }\n  .bp-video__modal.is-active .bp-video__modal-inner {\n    transform: scale(1);\n  }\n  /* 動画は本来の縦横比のままビューポートに収まるサイズで表示 */\n  .bp-video__modal video {\n    display: block;\n    width: auto;\n    height: auto;\n    max-width: 92vw;\n    max-height: 88vh;\n    background: #000;\n    border-radius: 4px;\n    box-shadow: 0 30px 80px rgba(0, 0, 0, .5);\n  }\n\n  /* 閉じるボタン */\n  .bp-video__close {\n    position: absolute;\n    top: 24px;\n    right: 24px;\n    width: 44px;\n    height: 44px;\n    background: transparent;\n    border: 1px solid rgba(255, 255, 255, 0.4);\n    border-radius: 50%;\n    cursor: pointer;\n    color: #fff;\n    transition: background .2s ease, border-color .2s ease, transform .2s ease;\n    z-index: 10000;\n    padding: 0;\n  }\n  .bp-video__close:hover {\n    background: rgba(255, 255, 255, .12);\n    border-color: rgba(255, 255, 255, .8);\n    transform: rotate(90deg);\n  }\n  .bp-video__close::before,\n  .bp-video__close::after {\n    content: \"\";\n    position: absolute;\n    top: 50%; left: 50%;\n    width: 18px; height: 1px;\n    background: currentColor;\n  }\n  .bp-video__close::before { transform: translate(-50%, -50%) rotate(45deg); }\n  .bp-video__close::after  { transform: translate(-50%, -50%) rotate(-45deg); }\n\n  /* スマホ */\n  @media (max-width: 720px) {\n    .bp-video { padding: 40px 16px; }\n    .bp-video__play { width: 60px; height: 60px; }\n    .bp-video__play::after {\n      border-width: 10px 0 10px 16px;\n      margin-left: 4px;\n    }\n    .bp-video__label { font-size: 10px; bottom: 14px; left: 14px; letter-spacing: .3em; }\n    .bp-video__close { top: 16px; right: 16px; width: 38px; height: 38px; }\n  }\n</style>\n\n<section class=\"bp-video\" aria-label=\"介紹影片\">\n  <div class=\"bp-video__inner\">\n\n    <button type=\"button\"\n            class=\"bp-video__trigger\"\n            id=\"bpVideoTrigger\"\n            aria-label=\"播放介紹影片\">\n      <img class=\"bp-video__thumb\"\n           src=\"https://botanypainting.com/cdn/shop/files/preview_images/4fa181e408c2430b9401f5a7e5b44239.thumbnail.0000000000_1100x.jpg?v=1777164328\"\n           alt=\"Botany Painting 介紹影片\">\n      <span class=\"bp-video__overlay\"></span>\n      <span class=\"bp-video__play\" aria-hidden=\"true\"></span>\n      <span class=\"bp-video__label\">Watch the Film</span>\n    </button>\n\n  </div>\n</section>\n\n<!-- モーダル -->\n<div class=\"bp-video__modal\" id=\"bpVideoModal\" aria-hidden=\"true\" role=\"dialog\">\n  <div class=\"bp-video__modal-inner\">\n    <video id=\"bpVideoElement\"\n           src=\"https://cdn.shopify.com/videos/c/o/v/4fa181e408c2430b9401f5a7e5b44239.mp4\"\n           controls\n           playsinline\n           preload=\"none\"\n           poster=\"https://botanypainting.com/cdn/shop/files/preview_images/4fa181e408c2430b9401f5a7e5b44239.thumbnail.0000000000_1100x.jpg?v=1777164328\"></video>\n  </div>\n  <button type=\"button\" class=\"bp-video__close\" id=\"bpVideoClose\" aria-label=\"關閉\"></button>\n</div>\n\n<script>\n  (function() {\n    var trigger = document.getElementById('bpVideoTrigger');\n    var modal   = document.getElementById('bpVideoModal');\n    var video   = document.getElementById('bpVideoElement');\n    var closeBtn = document.getElementById('bpVideoClose');\n    if (!trigger || !modal || !video) return;\n\n    function openModal() {\n      modal.classList.add('is-active');\n      modal.setAttribute('aria-hidden', 'false');\n      document.body.style.overflow = 'hidden';\n      // 少し遅延させてからプレイ（フェードイン中）\n      setTimeout(function() {\n        video.play().catch(function() {});\n      }, 120);\n    }\n    function closeModal() {\n      modal.classList.remove('is-active');\n      modal.setAttribute('aria-hidden', 'true');\n      document.body.style.overflow = '';\n      video.pause();\n      video.currentTime = 0;\n    }\n\n    trigger.addEventListener('click', openModal);\n    closeBtn.addEventListener('click', closeModal);\n    // 背景クリックで閉じる\n    modal.addEventListener('click', function(e) {\n      if (e.target === modal) closeModal();\n    });\n    // Escキーで閉じる\n    document.addEventListener('keydown', function(e) {\n      if (e.key === 'Escape' && modal.classList.contains('is-active')) closeModal();\n    });\n  })();\n</script>",
        "color_scheme": "scheme-1",
        "padding_top": 40,
        "padding_bottom": 52
      }
    },
