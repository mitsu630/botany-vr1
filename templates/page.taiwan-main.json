      "settings": {
        "custom_liquid": "<style>\n  .bp-cta-slim {\n    padding: 20px;\n    background: transparent;\n    color: #2d2a25;\n    font-family: \"Noto Sans TC\", \"Hiragino Sans\", \"Helvetica Neue\", Arial, \"Microsoft JhengHei\", sans-serif;\n    -webkit-font-smoothing: antialiased;\n  }\n  .bp-cta-slim__inner {\n    max-width: 760px;\n    margin: 0 auto;\n    display: flex;\n    gap: 10px;\n    justify-content: center;\n    flex-wrap: wrap;\n  }\n\n  .bp-cta-slim__btn {\n    flex: 1 1 0;\n    min-width: 200px;\n    display: inline-flex;\n    align-items: center;\n    justify-content: space-between;\n    gap: 14px;\n    padding: 14px 22px;\n    background: #ffffff;\n    border: 1px solid #d8d2c2;\n    text-decoration: none;\n    color: #2d2a25;\n    font-size: 14.5px;\n    letter-spacing: .1em;\n    font-family: \"Noto Serif TC\", \"Yu Mincho\", \"Hiragino Mincho ProN\", serif;\n    font-weight: 500;\n    transition: background .25s ease, border-color .25s ease, transform .25s ease;\n  }\n  .bp-cta-slim__btn:hover {\n    background: #f7f4ee;\n    border-color: #b08d5a;\n    transform: translateY(-1px);\n  }\n\n  .bp-cta-slim__btn--pick {\n    background: linear-gradient(180deg, #f5ede0 0%, #faf3e3 100%);\n    border-color: #c4a87a;\n  }\n  .bp-cta-slim__btn--pick:hover {\n    background: linear-gradient(180deg, #f0e5d0 0%, #f5ecd9 100%);\n    border-color: #a8865c;\n  }\n\n  /* 矢印 */\n  .bp-cta-slim__arrow {\n    position: relative;\n    display: inline-block;\n    width: 14px;\n    height: 1px;\n    background: currentColor;\n    flex-shrink: 0;\n    transition: width .25s ease;\n    color: #8a8270;\n  }\n  .bp-cta-slim__btn--pick .bp-cta-slim__arrow { color: #9c7a52; }\n  .bp-cta-slim__arrow::after {\n    content: \"\";\n    position: absolute;\n    right: 0;\n    top: 50%;\n    width: 5px;\n    height: 5px;\n    border-top: 1px solid currentColor;\n    border-right: 1px solid currentColor;\n    transform: translateY(-50%) rotate(45deg);\n  }\n  .bp-cta-slim__btn:hover .bp-cta-slim__arrow { width: 20px; }\n\n  @media (max-width: 480px) {\n    .bp-cta-slim__inner { gap: 8px; }\n    .bp-cta-slim__btn {\n      padding: 12px 16px;\n      font-size: 13.5px;\n      letter-spacing: .05em;\n      min-width: 0;\n    }\n  }\n</style>\n\n<section class=\"bp-cta-slim\" aria-label=\"課程報名\">\n  <div class=\"bp-cta-slim__inner\">\n\n    <a class=\"bp-cta-slim__btn bp-cta-slim__btn--pick\" href=\"https://botanypainting.com/products/taiwan-special\">\n      <span>師資取得課程</span>\n      <span class=\"bp-cta-slim__arrow\"></span>\n    </a>\n\n    <a class=\"bp-cta-slim__btn\" href=\"https://botanypainting.com/products/taiwan-workshop-1\">\n      <span>單日體驗課程</span>\n      <span class=\"bp-cta-slim__arrow\"></span>\n    </a>\n\n  </div>\n</section>",
        "color_scheme": "",
