            "margin_top": 24,
            "margin_bottom": 0
          }
        },
        "text_jtR8jw": {
          "type": "text",
          "settings": {
            "text": "<p>除了學習植物彩繪獨有的藝術特色課程外，還能了解有關畫材的基礎知識。接著，將實際體驗如何貼合印度菩提葉與蓮葉的基本技巧，並享受著色的樂趣。＜6個小時＞</p>",
            "font_size": 16,
            "color": "#ffffff",
