    "image_with_text_T8fxfw": {
      "type": "image-with-text",
      "blocks": {
        "heading_ydcamt": {
          "type": "heading",
          "settings": {
            "heading": "王唯真",
            "heading_size": "h2"
          }
        },
        "text_FrKN6j": {
          "type": "text",
          "settings": {
            "text": "<p>口譯員<br/><br/>出身於台灣台北的自由接案口譯員。活躍於日本酒、咖啡、藝術、鐵道、醫療、觀光等多個領域。全心全力支持在台日兩地努力奮鬥的人們，以深化日本與台灣的交流為使命。</p>",
            "text_style": "body"
          }
        }
      },
      "block_order": [
        "heading_ydcamt",
        "text_FrKN6j"
      ],
      "name": "t:sections.image-with-text.presets.name",
      "settings": {
