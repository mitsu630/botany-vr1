    "big_card_wadV4e": {
      "type": "big-card",
      "blocks": {
        "text_Ff6bbd": {
          "type": "text",
          "settings": {
            "text": "<p>A greeting from Mitsutoshi Sugimoto</p>",
            "text_font": "assistant_n4",
            "font_size": 15,
            "color": "#ffffff",
            "text_align": "left",
            "padding_top": 0,
            "padding_bottom": 0,
            "margin_top": 0,
            "margin_bottom": 0
          }
        },
        "title_TjVmjk": {
          "type": "title",
          "settings": {
            "title": "<p>來自植物彩繪代表 杉本光俊的問候</p>",
            "text_font": "assistant_n4",
            "font_size": 18,
            "color": "#ffffff",
            "text_align": "left",
            "padding_top": 0,
            "padding_bottom": 0,
            "margin_top": 0,
            "margin_bottom": 0
          }
        },
        "image_diz7fw": {
          "type": "image",
          "settings": {
            "image": "shopify://shop_images/IMG_2774.jpg",
            "aspect_ratio": "16 / 9",
            "image_fit": "cover",
            "image_width_mode": "box",
            "image_box_width": 1200,
            "image_box_height": 500,
            "image_align": "center",
            "image_background_transparent": true,
            "image_background_color": "#f2f2f2",
            "padding_top": 0,
            "padding_bottom": 0,
            "margin_top": 0,
            "margin_bottom": 0
          }
        },
        "text_NYAEKN": {
          "type": "text",
          "settings": {
            "text": "<p>在日本，許多人在參與植物彩繪的課程中，與我們共同度過了許多愉快的藝術時光。即使是從未學習過繪畫的人，也可以學習如何教授植物彩繪，並在教學中找到自己的生活意義。有些人甚至表示，植物彩繪改變了他們的人生！這讓我深刻體會到，植物彩繪不僅僅是一門藝術，它還包含著更深層次的價值。 希望能讓台灣的朋友們也認識這門「非藝術的藝術課程」——植物彩繪。</p>",
            "text_font": "assistant_n4",
            "font_size": 15,
            "color": "#ffffff",
            "text_align": "left",
            "padding_top": 0,
            "padding_bottom": 0,
            "margin_top": 0,
            "margin_bottom": 0
          }
        }
      },
      "block_order": [
        "text_Ff6bbd",
        "title_TjVmjk",
        "image_diz7fw",
        "text_NYAEKN"
      ],
      "name": "ビックカード",
      "settings": {
        "background_color": "#36384c",
